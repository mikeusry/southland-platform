---
/**
 * BlogCard - Displays a blog post card with image, title, and excerpt
 * Used in blog grids and listings
 */

interface Props {
  title: string;
  slug: string;
  description: string;
  publishDate: Date;
  featuredImage?: string;
  author?: string;
  segment?: string;
  tags?: string[];
  variant?: 'card' | 'compact' | 'featured';
  class?: string;
}

const {
  title,
  slug,
  description,
  publishDate,
  featuredImage,
  author,
  segment = 'general',
  tags = [],
  variant = 'card',
  class: className = '',
} = Astro.props;

// ── Segment fallback images ─────────────────────────────────────────────────
// When a post uses a generic/mismatched hero, pick a segment-appropriate image.
const GENERIC_HEROES = ['DSC_0137', 'Farm_Athens_GA_4', 'Farm_Athens_GA_7', 'Farm_Athens_GA_11']
const isGenericImage = !featuredImage || GENERIC_HEROES.some((h) => featuredImage.includes(h))

const SEGMENT_FALLBACKS: Record<string, string[]> = {
  poultry: [
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/poultry/poultry_house_w1zen3_iecnpo',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/poultry/Poultry_Industry_dcsedd_wyrhru',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/poultry/broilers/broiler_farm_sxnkd0',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/poultry/backyard/BY_Chicken_kdbbxr',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/poultry/backyard/BY-Eggs_lwlnnx',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/poultry/backyard/Healthy_chickens',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/poultry/Pasture-raised_hens_gkeodz_uz3ogv',
  ],
  turf: [
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/turf/home-and-yard-2026-03-25-01-32-34-utc_result_kwqnjn',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/turf/house-with-a-green-lawn-under-blue-sky-2026-03-18-16-04-37-utc_result_vxsjpl',
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/turf/mowed-green-frontyard-grass-before-residential-sub-2026-03-19-09-25-06-utc_result_isfebr',
  ],
  agriculture: [
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/heroes/DSC_0137_dco2wk',
  ],
  general: [
    'https://res.cloudinary.com/southland-organics/image/upload/w_600,h_340,c_fill,g_auto,q_auto,f_auto/Southland%20Website/heroes/Farm_Athens_GA_7_jbdjik',
  ],
}

// Pick a deterministic-but-varied fallback based on slug hash
function pickFallback(seg: string, postSlug: string): string {
  const pool = SEGMENT_FALLBACKS[seg] || SEGMENT_FALLBACKS.general
  const hash = postSlug.split('').reduce((a, c) => a + c.charCodeAt(0), 0)
  return pool[hash % pool.length]
}

const resolvedImage = isGenericImage ? pickFallback(segment, slug) : featuredImage

// Format date
const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Segment config — colors + labels
const segmentConfig: Record<string, { color: string; label: string }> = {
  poultry: { color: 'bg-[#2C5234]/10 text-[#2C5234]', label: 'Poultry' },
  turf: { color: 'bg-emerald-50 text-emerald-700', label: 'Turf & Lawn' },
  agriculture: { color: 'bg-amber-50 text-amber-700', label: 'Agriculture' },
  general: { color: 'bg-gray-100 text-gray-600', label: 'News' },
};
const segmentInfo = segmentConfig[segment] || segmentConfig.general;

const variantClasses = {
  card: 'bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow',
  compact: 'flex gap-4 p-4 bg-white rounded-lg border border-gray-100',
  featured: 'bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden',
};
---

<article class={`blog-card ${variantClasses[variant]} ${className}`}>
  {variant === 'compact' ? (
    <!-- Compact layout: horizontal -->
    <Fragment>
      {resolvedImage && (
        <img
          src={resolvedImage}
          alt={title}
          class="w-24 h-24 rounded-lg object-cover flex-shrink-0"
          loading="lazy"
        />
      )}
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${segmentInfo.color}`}>
            {segmentInfo.label}
          </span>
          <time class="text-xs text-gray-500">{formattedDate}</time>
        </div>
        <h3 class="font-bold text-shopify-title truncate">
          <a href={`/blog/${slug}/`} class="hover:text-southland-green">
            {title}
          </a>
        </h3>
        <p class="text-sm text-gray-600 line-clamp-2">{description}</p>
      </div>
    </Fragment>
  ) : (
    <!-- Card/Featured layout: vertical -->
    <Fragment>
      {resolvedImage && (
        <a href={`/blog/${slug}/`} class="block aspect-video overflow-hidden">
          <img
            src={resolvedImage}
            alt={title}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
        </a>
      )}
      <div class={`p-${variant === 'featured' ? '8' : '6'}`}>
        <div class="flex items-center gap-2 mb-3">
          <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${segmentInfo.color}`}>
            {segmentInfo.label}
          </span>
          <time class="text-xs text-gray-500">{formattedDate}</time>
        </div>

        <h3 class={`font-bold text-shopify-title mb-2 ${variant === 'featured' ? 'text-2xl' : 'text-lg'}`}>
          <a href={`/blog/${slug}/`} class="hover:text-southland-green transition-colors">
            {title}
          </a>
        </h3>

        <p class={`text-shopify-secondary-text mb-4 ${variant === 'featured' ? 'text-base' : 'text-sm'} line-clamp-3`}>
          {description}
        </p>

        {author && (
          <p class="text-sm text-gray-500 mb-3">By {author}</p>
        )}

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-4">
            {tags.filter(t => t !== 'Biosecurity' && t !== 'Case Study' && t !== 'Humate Hub').slice(0, variant === 'featured' ? 4 : 2).map((tag) => (
              <span class="text-[11px] bg-gray-50 text-gray-400 px-2 py-0.5 rounded border border-gray-100">
                {tag}
              </span>
            ))}
          </div>
        )}

        <a
          href={`/blog/${slug}/`}
          class={`inline-flex items-center gap-2 ${variant === 'featured' ? 'btn-primary' : 'text-southland-green hover:underline font-medium text-sm'}`}
        >
          Read more
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </Fragment>
  )}
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
