---
/**
 * CollectionProductCard — Persona-aware product card for collection grids.
 *
 * Displays a Shopify product with subtle persona adaptation:
 * - Badge text changes by persona
 * - Price display format adapts (simple vs per-unit)
 * - Universal "View Product" CTA (no persona-specific CTAs on cards)
 */
import type { Product } from '@southland/shopify-storefront'
import { optimizeShopifyImage } from '../../lib/cloudinary'
import type { ReviewAggregate } from '../../lib/klaviyo-reviews'
import StarRating from '../product/StarRating.astro'

interface Props {
  product: Product
  persona?: import('../../lib/persona').PersonaId
  class?: string
  reviewAggregate?: ReviewAggregate | null
}

const { product, persona, class: className, reviewAggregate } = Astro.props

// Get the first available image
const image = product.images[0] ?? null

// Get the lowest price for display
const price = product.priceRange.minVariantPrice
const priceFormatted = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: price.currencyCode || 'USD',
}).format(Number(price.amount))

// Persona-aware badge
function getPersonaBadge(): string | null {
  if (!persona || persona === 'general') return null

  // Check product tags for persona-specific badges
  const tags = product.tags.map((t) => t.toLowerCase())

  // Poultry — backyard
  if (persona === 'betty') {
    if (tags.includes('bundle')) return 'Starter Bundle'
    if (tags.includes('bestseller') || tags.includes('best-seller')) return 'Flock Favorite'
    return null
  }

  // Poultry — commercial (bill, bob, tom, greg)
  if (persona === 'bill' || persona === 'bob' || persona === 'tom' || persona === 'greg') {
    if (tags.includes('bundle')) return 'Value Pack'
    if (tags.includes('bestseller') || tags.includes('best-seller')) return 'Commercial Favorite'
    return null
  }

  // Turf & Soil (taylor, gary, hannah, maggie)
  if (persona === 'taylor' || persona === 'gary' || persona === 'hannah' || persona === 'maggie') {
    if (tags.includes('bundle')) return 'Program Bundle'
    if (tags.includes('bestseller') || tags.includes('best-seller')) return "Pro's Choice"
    return null
  }

  return null
}

const badge = getPersonaBadge()

// Check if product has a gallon/bulk variant for per-unit pricing (Bill)
function getPerUnitPrice(): string | null {
  if (persona !== 'bill' && persona !== 'bob' && persona !== 'tom' && persona !== 'greg')
    return null
  const gallonVariant = product.variants.find((v) =>
    v.selectedOptions.some(
      (opt) => opt.name === 'Size' && (opt.value.includes('Gallon') || opt.value.includes('gallon'))
    )
  )
  if (!gallonVariant) return null
  const amount = Number(gallonVariant.price.amount)
  // 1 gallon = 128 oz
  const perOz = amount / 128
  return `$${perOz.toFixed(2)}/oz`
}

const perUnit = getPerUnitPrice()

// "Best for:" line based on product tags/type
function getBestFor(): string | null {
  const tags = product.tags.map((t) => t.toLowerCase())
  const title = product.title.toLowerCase()

  if (
    tags.includes('poultry') ||
    title.includes('poultry') ||
    title.includes('bird') ||
    title.includes('litter') ||
    title.includes('hen')
  ) {
    if (tags.includes('backyard') || title.includes('backyard')) return 'Backyard flock health'
    return 'Poultry gut health & litter management'
  }
  if (
    tags.includes('lawn') ||
    tags.includes('turf') ||
    title.includes('lawn') ||
    title.includes('turf') ||
    title.includes('soil')
  ) {
    return 'Lawn & turf soil biology'
  }
  if (tags.includes('sanitizer') || title.includes('sanitizer') || title.includes('sanitize')) {
    return 'Farm & food safety sanitation'
  }
  if (
    tags.includes('septic') ||
    tags.includes('waste') ||
    title.includes('septic') ||
    title.includes('waste')
  ) {
    return 'Septic & waste treatment'
  }
  return null
}

const bestFor = getBestFor()

// Display-friendly name: strip "| SEO keyword stuff" from Shopify titles
// Full title preserved on PDP for SEO; cards show just the brand name
const displayName = product.title.includes('|') ? product.title.split('|')[0].trim() : product.title
---

<a
  href={`/products/${product.handle}/`}
  class:list={[
    'group block overflow-hidden rounded-lg border border-gray-200 bg-white transition-shadow hover:shadow-md',
    className,
  ]}
>
  {/* Product Image */}
  <div class="relative aspect-square overflow-hidden bg-gray-50">
    {
      image ? (
        <img
          src={optimizeShopifyImage(image.url, product.handle, 400, 400)}
          alt={image.altText || product.title}
          width="400"
          height="400"
          loading="lazy"
          class="h-full w-full object-contain transition-transform group-hover:scale-105"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-gray-300">
          <svg class="h-16 w-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
            />
          </svg>
        </div>
      )
    }

    {/* Persona Badge */}
    {
      badge && (
        <span
          class:list={[
            'absolute left-3 top-3 rounded-full px-2.5 py-0.5 text-xs font-semibold',
            persona === 'betty' && 'bg-amber-100 text-amber-800',
            (persona === 'bill' || persona === 'bob' || persona === 'tom' || persona === 'greg') &&
              'bg-green-100 text-green-800',
            (persona === 'taylor' ||
              persona === 'gary' ||
              persona === 'hannah' ||
              persona === 'maggie') &&
              'bg-emerald-100 text-emerald-800',
            persona === 'sam' && 'bg-purple-100 text-purple-800',
          ]}
        >
          {badge}
        </span>
      )
    }
  </div>

  {/* Product Info */}
  <div class="p-4">
    <h3 class="text-sm font-semibold text-gray-900 group-hover:text-brand-green-dark">
      {displayName}
    </h3>

    {
      reviewAggregate && reviewAggregate.reviewCount > 0 && (
        <div class="mt-1">
          <StarRating
            rating={reviewAggregate.averageRating}
            count={reviewAggregate.reviewCount}
            size="sm"
          />
        </div>
      )
    }

    {
      product.description && (
        <p class="mt-1 line-clamp-2 text-xs text-gray-500">{product.description}</p>
      )
    }

    {bestFor && <p class="mt-1.5 text-xs font-medium text-[#44883E]">Best for: {bestFor}</p>}

    <div class="mt-3 flex items-baseline gap-2">
      <span class="text-base font-bold text-gray-900">{priceFormatted}</span>
      {perUnit && <span class="text-xs text-gray-500">{perUnit}</span>}
    </div>

    <span
      class="mt-3 inline-block text-sm font-medium text-brand-green-light group-hover:underline"
    >
      View Product &rarr;
    </span>
  </div>
</a>
