---
/**
 * StarRating — pure Astro component for star display.
 * Renders 1-5 filled/partial/empty stars with optional review count link.
 * Zero JavaScript — SVG + CSS only.
 */
interface Props {
  rating: number
  count?: number
  size?: 'sm' | 'md' | 'lg'
  anchorTo?: string
  showCount?: boolean
}

const { rating, count, size = 'md', anchorTo, showCount = true } = Astro.props

const sizes = {
  sm: { star: 'w-4 h-4', text: 'text-xs', gap: 'gap-0.5' },
  md: { star: 'w-5 h-5', text: 'text-sm', gap: 'gap-0.5' },
  lg: { star: 'w-6 h-6', text: 'text-base', gap: 'gap-1' },
}
const s = sizes[size]

// Generate star fill percentages (0, 50, or 100 for simplicity)
const stars = Array.from({ length: 5 }, (_, i) => {
  const diff = rating - i
  if (diff >= 0.75) return 100
  if (diff >= 0.25) return 50
  return 0
})

const countText = count === 1 ? '1 review' : `${count} reviews`
---

<div class={`inline-flex items-center ${s.gap}`}>
  <div class={`flex items-center ${s.gap}`} aria-label={`${rating} out of 5 stars`}>
    {
      stars.map((fill) => (
        <span class={`relative inline-block ${s.star} flex-shrink-0`}>
          {/* Empty star (background) */}
          <svg
            class="absolute inset-0 h-full w-full text-gray-300"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          {/* Filled star (overlay with clip) */}
          {fill > 0 && (
            <svg
              class="absolute inset-0 h-full w-full text-yellow-400"
              fill="currentColor"
              viewBox="0 0 20 20"
              style={fill < 100 ? `clip-path: inset(0 ${100 - fill}% 0 0)` : undefined}
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          )}
        </span>
      ))
    }
  </div>
  {
    showCount &&
      count != null &&
      count > 0 &&
      (anchorTo ? (
        <a href={anchorTo} class={`${s.text} ml-1 text-brand-green-light hover:underline`}>
          {countText}
        </a>
      ) : (
        <span class={`${s.text} ml-1 text-gray-600`}>{countText}</span>
      ))
  }
</div>
