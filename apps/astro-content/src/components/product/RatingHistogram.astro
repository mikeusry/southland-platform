---
/**
 * RatingHistogram — 5-star distribution bar chart.
 * Shows count per star level with proportional green bars.
 */
interface Props {
  distribution: Record<1 | 2 | 3 | 4 | 5, number>
  totalCount: number
}

const { distribution, totalCount } = Astro.props
const rows = [5, 4, 3, 2, 1] as const
---

<div class="space-y-1.5">
  {
    rows.map((star) => {
      const count = distribution[star] ?? 0
      const pct = totalCount > 0 ? (count / totalCount) * 100 : 0
      return (
        <div class="flex items-center gap-2 text-sm">
          <span class="w-6 text-right text-gray-600">{star}</span>
          <svg
            class="h-3.5 w-3.5 flex-shrink-0 text-yellow-400"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <div class="flex-1">
            <div class="h-2.5 w-full rounded-full bg-gray-200">
              <div
                class="h-2.5 rounded-full bg-brand-green-light transition-all"
                style={`width: ${pct}%`}
              />
            </div>
          </div>
          <span class="w-6 text-right text-xs text-gray-500">{count}</span>
        </div>
      )
    })
  }
</div>
