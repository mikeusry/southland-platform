---
/**
 * ReviewCard — single customer review card.
 * SSR-rendered for SEO. Includes star rating, title, body, author, verified badge, date.
 */
import StarRating from './StarRating.astro'
import type { KlaviyoReview } from '../../lib/klaviyo-reviews'

interface Props {
  review: KlaviyoReview
}

const { review } = Astro.props

// Relative date formatting
function relativeDate(iso: string): string {
  const now = Date.now()
  const then = new Date(iso).getTime()
  const diffMs = now - then
  const days = Math.floor(diffMs / (1000 * 60 * 60 * 24))

  if (days === 0) return 'Today'
  if (days === 1) return 'Yesterday'
  if (days < 30) return `${days} days ago`
  const months = Math.floor(days / 30)
  if (months === 1) return '1 month ago'
  if (months < 12) return `${months} months ago`
  const years = Math.floor(months / 12)
  return years === 1 ? '1 year ago' : `${years} years ago`
}

const dateStr = relativeDate(review.createdAt)
const isLong = review.content.length > 300
---

<div class="rounded-lg border border-gray-200 bg-white p-5" data-review-id={review.id}>
  <div class="flex items-start justify-between gap-3">
    <StarRating rating={review.rating} size="sm" showCount={false} />
    <span class="flex-shrink-0 text-xs text-gray-400">{dateStr}</span>
  </div>

  {review.title && <h3 class="mt-2 text-sm font-bold text-gray-900">{review.title}</h3>}

  {
    isLong ? (
      <details class="group mt-2">
        <summary class="cursor-pointer text-sm leading-relaxed text-gray-700 [&::-webkit-details-marker]:hidden">
          <span class="line-clamp-4">{review.content}</span>
          <span class="mt-1 block text-xs font-medium text-brand-green-light group-open:hidden">
            Read more
          </span>
        </summary>
        <p class="text-sm leading-relaxed text-gray-700">{review.content}</p>
      </details>
    ) : (
      <p class="mt-2 text-sm leading-relaxed text-gray-700">{review.content}</p>
    )
  }

  {/* Customer photos */}
  {
    review.images.length > 0 && (
      <div class="mt-3 flex gap-2">
        {review.images.slice(0, 4).map((img) => (
          <img
            src={img.url}
            alt="Customer photo"
            class="h-16 w-16 rounded-md border border-gray-200 object-cover"
            loading="lazy"
            width="64"
            height="64"
          />
        ))}
      </div>
    )
  }

  <div class="mt-3 flex items-center gap-2">
    <span class="text-sm font-medium text-gray-900">{review.author}</span>
    {
      review.verified && (
        <span class="inline-flex items-center gap-1 rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"
            />
          </svg>
          Verified Buyer
        </span>
      )
    }
  </div>

  {/* Public reply (for Q&A) */}
  {
    review.publicReply && review.publicReply.content && (
      <div class="mt-3 rounded-md bg-gray-50 p-3">
        <p class="text-xs font-semibold uppercase text-gray-500">Southland Organics replied</p>
        <p class="mt-1 text-sm text-gray-700">{review.publicReply.content}</p>
      </div>
    )
  }
</div>
