---
/**
 * Decision Engine Component — Segment Selector
 *
 * Homepage 3-way branch routing visitors into segment lanes.
 * Sets segment (not persona) — persona refinement happens on hub pages.
 *
 * Flow: Homepage → select segment → scroll to products → visit hub page → select persona
 *
 * Features:
 * - 3 clickable segment cards (Poultry, Turf & Soil, Waste)
 * - Persists segment in localStorage + cookie (via shared persona lib)
 * - Fires `segment_path_selected` event to point.dog pixel + GTM
 * - Smooth-scrolls to scroll target (default: #featured-products)
 * - Highlights active segment card for returning visitors
 * - Frictionless default: preselects if visitor arrived from a segment-leaning URL
 */

interface Props {
  headline?: string
  subheadline?: string
  scrollTarget?: string
  source?: 'decision_engine' | 'hero'
  class?: string
}

const {
  headline = 'What are you working on?',
  subheadline = 'Choose your focus and we\'ll show you the right solutions',
  scrollTarget = 'featured-products',
  source = 'decision_engine',
  class: className = '',
} = Astro.props

// Segment paths — maps to the 3 segments in persona-profiles.ts
const segmentPaths = [
  {
    id: 'poultry',
    label: 'Poultry',
    description: 'Commercial broilers, backyard flocks, turkeys, breeders, and game birds',
    microcopy: 'Start here if you raise poultry — commercial or backyard.',
    icon: 'barn',
    color: 'bg-green-50 hover:bg-green-100 border-green-200',
    iconColor: 'text-green-700',
    hubPage: '/poultry/',
  },
  {
    id: 'turf',
    label: 'Turf & Soil',
    description: 'Lawn care pros, golf courses, homeowners, and market gardeners',
    microcopy: 'Organic programs for professional turf and residential lawns.',
    icon: 'grass',
    color: 'bg-emerald-50 hover:bg-emerald-100 border-emerald-200',
    iconColor: 'text-emerald-600',
    hubPage: '/lawn/',
  },
  {
    id: 'waste',
    label: 'Septic & Waste',
    description: 'Septic systems, holding tanks, grease traps, and odor control',
    microcopy: 'Biological treatments for homes, campgrounds, and facilities.',
    icon: 'droplet',
    color: 'bg-purple-50 hover:bg-purple-100 border-purple-200',
    iconColor: 'text-purple-600',
    hubPage: '/waste/',
  },
]
---

<section
  class={`decision-engine py-12 ${className}`}
  data-scroll-target={scrollTarget}
  data-source={source}
>
  <div class="mx-auto max-w-4xl px-4">
    <!-- Header -->
    <div class="mb-10 text-center">
      <h2 class="mb-3 text-3xl font-bold md:text-4xl" style="color: var(--color-title);">
        {headline}
      </h2>
      <p class="text-lg text-gray-600">
        {subheadline}
      </p>
    </div>

    <!-- Segment Cards -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {segmentPaths.map((segment) => (
        <button
          class={`segment-card group relative cursor-pointer rounded-xl border-2 p-6 text-left transition-all duration-300 ${segment.color}`}
          data-segment-id={segment.id}
          data-segment-select={segment.id}
          data-hub-page={segment.hubPage}
          aria-label={`Select ${segment.label}`}
        >
          <!-- Icon -->
          <div class={`mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-white shadow-sm ${segment.iconColor}`}>
            {segment.icon === 'barn' && (
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21h18M4 21V10l8-6 8 6v11M9 21v-6h6v6"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4l-8 6h16l-8-6z"/>
              </svg>
            )}
            {segment.icon === 'grass' && (
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21V8c0-3 3-5 5-5M12 21V8c0-3 3-5 5-5M17 21v-8c0-2-2-4-4-4"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 21c0-3 2-5 4-6M19 21c0-3-2-5-4-6"/>
              </svg>
            )}
            {segment.icon === 'droplet' && (
              <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21c-4.418 0-8-3.134-8-7 0-4.418 8-11 8-11s8 6.582 8 11c0 3.866-3.582 7-8 7z"/>
              </svg>
            )}
          </div>

          <!-- Content -->
          <h3 class="mb-2 text-xl font-bold" style="color: var(--color-title);">
            {segment.label}
          </h3>
          <p class="mb-2 text-sm leading-relaxed text-gray-600">
            {segment.description}
          </p>
          <p class="text-xs italic text-gray-400">
            {segment.microcopy}
          </p>

          <!-- Arrow indicator -->
          <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 transition-opacity group-hover:opacity-100">
            <svg class={`h-6 w-6 ${segment.iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </button>
      ))}
    </div>

    <!-- Skip link -->
    <div class="mt-8 text-center">
      <button
        class="skip-personalization text-sm text-gray-500 underline underline-offset-2 hover:text-gray-700"
        aria-label="Skip personalization and continue browsing"
      >
        Just browsing? Skip this step
      </button>
    </div>
  </div>
</section>

<script>
  import { setSegment } from '../../lib/persona'
  import { attachSegmentHandlers } from '../../lib/personaDom'

  function initDecisionEngine() {
    document.querySelectorAll<HTMLElement>('.decision-engine').forEach((container) => {
      const scrollTarget = container.dataset.scrollTarget || 'featured-products'
      const source = (container.dataset.source as 'decision_engine' | 'hero') || 'decision_engine'

      // Attach segment card handlers (click + highlight)
      attachSegmentHandlers(container, source, scrollTarget)

      // Handle skip button
      const skipBtn = container.querySelector('.skip-personalization')
      skipBtn?.addEventListener('click', () => {
        // Track skip event
        if ((window as any).pdPixel) {
          ;(window as any).pdPixel.track('segment_path_skipped', {
            source,
            page: window.location.pathname,
          })
        }

        setSegment('general', source)

        document.getElementById(scrollTarget)?.scrollIntoView({
          behavior: 'smooth',
          block: 'start',
        })
      })
    })
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDecisionEngine)
  } else {
    initDecisionEngine()
  }

  // Run on Astro page transitions
  document.addEventListener('astro:page-load', initDecisionEngine as any)
</script>

<style>
  .segment-card:focus {
    outline: none;
    ring: 4px;
    ring-color: var(--color-accent);
    ring-opacity: 0.5;
  }

  .segment-card:active {
    transform: scale(0.98);
  }

  /* Animation for cards */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .segment-card {
    animation: fadeInUp 0.5s ease-out forwards;
  }

  .segment-card:nth-child(1) { animation-delay: 0.1s; }
  .segment-card:nth-child(2) { animation-delay: 0.2s; }
  .segment-card:nth-child(3) { animation-delay: 0.3s; }
</style>
