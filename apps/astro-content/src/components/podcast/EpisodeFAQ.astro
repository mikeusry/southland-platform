---
export interface FAQItem {
  question: string
  answer: string
}

export interface Props {
  items: FAQItem[]
}

const { items } = Astro.props
---

{
  items.length > 0 && (
    <section class="rounded-xl border border-gray-100 bg-white p-6" aria-labelledby="episode-faq">
      <h2 id="episode-faq" class="mb-4 text-xl font-semibold text-gray-900">
        Frequently Asked Questions
      </h2>
      <div class="divide-y divide-gray-100">
        {items.map((item) => (
          <details class="group py-4 first:pt-0 last:pb-0">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-base font-medium text-gray-900">
              <span>{item.question}</span>
              <span
                aria-hidden="true"
                class="mt-1 flex-shrink-0 text-southland-green transition-transform group-open:rotate-45"
              >
                +
              </span>
            </summary>
            <div class="prose-southland prose mt-3 max-w-none text-gray-600">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  )
}
