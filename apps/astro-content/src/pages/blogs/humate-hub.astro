---
/**
 * /blogs/humate-hub — Humate Hub: Soil Science Education
 *
 * Mike Usry's authority page for soil biology, humic/fulvic acid
 * education, and lawn care science. Targets Taylor (Turf Pro),
 * Hannah (Homeowner), Gary (Golf), and Maggie (Market Garden).
 *
 * CRO structure:
 *   1. Hero — soil background image + Mike overlay + dual CTA
 *   2. "What is the Humate Hub?" — educational intro (from Shopify)
 *   3. Learning path — Beginner → Intermediate → Advanced
 *   4. Video section — 3 Mux video thumbnails
 *   5. Product band — JTBD-framed lawn care products
 *   6. All articles — full grid
 *   7. Final CTA — Mike + dual CTA + Klaviyo
 */

export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogGrid from '../../components/blog/BlogGrid.astro'
import EmailCapture from '../../components/shared/EmailCapture.astro'
import { getCollection } from 'astro:content'
import { buildSouthlandUrl, getLogoUrl } from '../../lib/cloudinary'
import { createClient, getProductByHandle } from '@southland/shopify-storefront'

// ── Images ──────────────────────────────────────────────────────────────────
const mikePhoto = buildSouthlandUrl('team/MIKE_Usry', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

const heroBackground = buildSouthlandUrl('heroes/Farm_Athens_GA_4_qaishv', {
  width: 1600,
  height: 600,
  crop: 'fill',
  gravity: 'center',
  quality: 'auto',
  format: 'auto',
})

// ── All humate hub posts ────────────────────────────────────────────────────
const allPosts = await getCollection('blog', ({ data }) => {
  if (data.draft) return false
  return (data.tags || []).some((t) => t.toLowerCase() === 'humate hub')
})

const posts = allPosts.sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
)

const videoPosts = posts.filter((p) => p.data.muxPlaybackIds && p.data.muxPlaybackIds.length > 0)

// Learning path
const beginnerSlugs = ['understanding-humate-a-beginners-guide', 'humate-for-lawns', 'the-benefits-of-humic-acid-for-lawns']
const intermediateSlugs = ['humic-acid-for-lawns-3-simple-steps', 'how-do-plants-get-nutrients-cation-exchange-capacity-cec-explained', 'why-humate-soil-conditioner']
const advancedSlugs = ['humic-acid-vs-fulvic-acid-key-differences-and-benefits-explained', 'fulvic-acid-for-plants-the-missing-ingredient-in-your-diy-lawn-and-garden-care-program']

function findPost(slug: string) {
  return posts.find((p) => p.id.replace(/\.mdx?$/, '') === slug)
}

// ── Products with JTBD ──────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const PRODUCT_JTBD = [
  { handle: 'natural-lawn-care-products', bestFor: 'Complete humate-based lawn program — soil biology, root development, and nutrient uptake' },
  { handle: 'torched-all-natural-weed-killer', bestFor: 'Organic weed control that works with your soil biology, not against it' },
]

const productResults = await Promise.all(PRODUCT_JTBD.map((p) => getProductByHandle(client, p.handle)))
const products = PRODUCT_JTBD.map((p, i) => ({ ...p, product: productResults[i] })).filter((p) => p.product)

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── SEO ─────────────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const title = 'Humate Hub: How to Heal Your Soil from the Ground Up'
const description =
  'Learn the science behind humic acid, fulvic acid, and soil biology. Practical guides for lawn care professionals, homeowners, and anyone who wants healthier soil.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${siteUrl}/blogs/humate-hub`,
  publisher: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: siteUrl,
    foundingDate: '2009',
  },
  author: {
    '@type': 'Person',
    name: 'Mike Usry',
    jobTitle: 'Founder & CEO',
    worksFor: { '@type': 'Organization', name: 'Southland Organics' },
  },
}

// Learning path level config
const LEVELS = [
  {
    step: 1,
    level: 'Beginner',
    title: 'What is Humate?',
    subtitle: 'The basics of soil biology and why it matters.',
    bestFor: 'Homeowners and lawn pros new to humic acid',
    slugs: beginnerSlugs,
    borderColor: 'border-[#2C5234]/20',
    bgColor: 'bg-[#2C5234]/5',
    badgeColor: 'bg-[#2C5234]/10 text-[#2C5234]',
  },
  {
    step: 2,
    level: 'Intermediate',
    title: 'How to Apply',
    subtitle: 'Application guides and soil chemistry.',
    bestFor: 'Contractors looking for application rates and tank mix tips',
    slugs: intermediateSlugs,
    borderColor: 'border-[#44883E]/20',
    bgColor: 'bg-[#44883E]/5',
    badgeColor: 'bg-[#44883E]/10 text-[#44883E]',
  },
  {
    step: 3,
    level: 'Advanced',
    title: 'Deep Soil Science',
    subtitle: 'Humic vs fulvic acid, CEC, and formulation.',
    bestFor: 'Agronomists and turf managers wanting deeper soil biology',
    slugs: advancedSlugs,
    borderColor: 'border-[#2C5234]/30',
    bgColor: 'bg-[#2C5234]/5',
    badgeColor: 'bg-[#2C5234] text-white',
  },
]
---

<BaseLayout
  title={title}
  description={description}
  ogImage={mikePhoto}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — soil background + Mike overlay                      -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden py-20 md:py-24">
    <!-- Background image -->
    <img
      src={heroBackground}
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#2C5234]/95 via-[#2C5234]/85 to-[#2C5234]/60"></div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-10 md:grid-cols-[1fr_280px] lg:grid-cols-[1fr_320px]">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-green-300">
            Soil Science Education
          </p>
          <h1 class="mb-6 font-heading text-3xl uppercase text-white md:text-4xl lg:text-5xl">
            Humate Hub
          </h1>
          <p class="mb-4 text-lg leading-relaxed text-white/85">
            Heal your soil from the ground up. Humic acid, fulvic acid, and living biology aren't buzzwords — they're the foundation of every healthy lawn, field, and garden.
          </p>
          <p class="mb-4 text-sm text-white/50">
            <strong class="text-white">{posts.length} curated guides</strong> covering soil science, application rates, and the biology that makes everything else work.
          </p>
          <p class="mb-8 text-xs font-medium uppercase tracking-wider text-green-400/60">
            For lawn pros, golf courses, farmers, and homeowners who want soil that actually works
          </p>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            {['15+ years in soil biology', 'Humate deposit expertise', 'Host of Ag & Culture Podcast'].map((cred) => (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-sm font-medium text-white/90">
                <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                </svg>
                {cred}
              </span>
            ))}
          </div>

          <!-- Dual CTAs -->
          <div class="flex flex-wrap items-center gap-3">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3 text-base font-semibold text-white shadow-lg transition-all hover:bg-[#3a7534] hover:shadow-xl"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Talk Soil: 800-608-3755
            </a>
            <a
              href="/contact/?dept=lawn"
              class="inline-flex items-center gap-2 rounded-lg border border-white/20 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white/10"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
              Ask a Question
            </a>
          </div>
        </div>

        <!-- Mike's photo -->
        <div class="hidden md:block">
          <div class="relative">
            <img
              src={mikePhoto}
              alt="Mike Usry, Founder & CEO of Southland Organics — 15+ years in soil biology and humate science"
              width="320"
              height="400"
              class="rounded-2xl object-cover shadow-2xl ring-2 ring-white/20"
              loading="eager"
            />
            <div class="absolute -bottom-3 -right-3 rounded-xl bg-white px-4 py-2 shadow-lg">
              <p class="text-xs font-semibold text-gray-500">Founder & CEO</p>
              <p class="font-heading text-sm uppercase text-southland-green-dark">Mike Usry</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: WHAT IS THE HUMATE HUB? — educational intro                -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-12 md:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center font-heading text-2xl uppercase md:text-3xl" style="color: var(--color-title);">What is the Humate Hub?</h2>
      <div class="grid gap-8 md:grid-cols-[1.2fr_1fr]">
        <div>
          <p class="mb-4 text-base leading-relaxed text-gray-600">
            The Humate Hub is a curated collection of guides designed to teach you about humic substances and their impact on lawn and garden care. These naturally occurring organic compounds are derived from the decomposition of ancient plant matter — a treasure trove of nutrients essential for soil health and plant growth.
          </p>
          <p class="text-base leading-relaxed text-gray-600">
            From the basic science behind humic acids to advanced application techniques, this hub ensures your soil receives the rejuvenation it deserves — without synthetic chemicals.
          </p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-gray-50 p-6">
          <p class="mb-4 text-sm font-bold text-gray-900">Who is this for?</p>
          <ul class="space-y-3">
            {[
              { icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z', label: 'Lawn care professionals', detail: 'Application rates, tank mixes, program design' },
              { icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Golf & turf managers', detail: 'Soil biology for fairways, greens, and sports turf' },
              { icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', label: 'Homeowners', detail: 'Safe, organic lawn care for families and pets' },
              { icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', label: 'Farmers & market gardeners', detail: 'Soil amendments for row crops, produce, and specialty growers' },
            ].map(({ icon, label, detail }) => (
              <li class="flex items-start gap-3">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
                  <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-gray-900">{label}</p>
                  <p class="text-xs text-gray-500">{detail}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: LEARNING PATH — Beginner → Advanced (green hex icons)      -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-brand-gray py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="mb-3 font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
          Start Learning
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-600">
          Whether you're new to humates or ready to go deep on soil chemistry, start here.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {LEVELS.map((lvl, i) => {
          const levelPosts = lvl.slugs.map(findPost).filter(Boolean)
          const stepIcons = [
            'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', // book
            'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', // lightbulb
            'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', // beaker
          ]
          return (
            <div class={`rounded-xl border ${lvl.borderColor} ${lvl.bgColor} p-6`}>
              <div class="mb-3 flex items-center gap-3">
                <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
                  <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={stepIcons[i]} />
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Step {lvl.step}</p>
                  <span class={`inline-block rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider ${lvl.badgeColor}`}>{lvl.level}</span>
                  <h3 class="text-xl font-bold text-gray-900">{lvl.title}</h3>
                </div>
              </div>
              <p class="mb-1 text-sm text-gray-500">{lvl.subtitle}</p>
              <p class="mb-4 text-xs font-medium text-[#44883E]">Best for: {lvl.bestFor}</p>
              <ul class="space-y-2.5">
                {levelPosts.map((post) => {
                  const slug = post!.id.replace(/\.mdx?$/, '')
                  return (
                    <li>
                      <a href={`/blog/${slug}/`} class="flex items-start gap-2 text-sm">
                        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-[#44883E]/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                        <span class="text-gray-500 hover:text-southland-green">{post!.data.title}</span>
                      </a>
                    </li>
                  )
                })}
              </ul>
            </div>
          )
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: INLINE LEAD CAPTURE                                        -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-southland-green-dark py-14">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-8 md:grid-cols-[1fr_1fr]">
        <div>
          <h2 class="mb-3 font-heading text-2xl uppercase text-white md:text-3xl">
            Get soil science tips in your inbox
          </h2>
          <p class="text-white/70">
            Practical humate and lawn care guidance from Mike. Application rates, seasonal timing, and soil biology — no fluff.
          </p>
        </div>
        <div>
          <EmailCapture
            headline=""
            description=""
            listId="TckeZK"
            source="lawn"
            buttonText="Subscribe"
            variant="banner"
          />
          <p class="mt-3 text-center text-xs text-white/40">
            Or call directly: <a href="tel:800-608-3755" class="underline">800-608-3755</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 5: VIDEO — Mux-hosted soil science videos                     -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  {videoPosts.length > 0 && (
    <section class="bg-white py-16 md:py-20">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 text-center">
          <span class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-southland-green">
            Watch & Learn
          </span>
          <h2 class="mb-3 font-heading text-2xl uppercase md:text-3xl" style="color: var(--color-title);">
            Soil Science on Video
          </h2>
          <p class="mx-auto max-w-xl text-gray-600">
            Short videos covering humate application, soil chemistry, and the science behind healthier turf.
          </p>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
          {videoPosts.map((post) => {
            const pid = post.data.muxPlaybackIds![0]
            const slug = post.id.replace(/\.mdx?$/, '')
            return (
              <a href={`/blog/${slug}/`} class="group">
                <div class="aspect-video overflow-hidden rounded-xl shadow-md transition-shadow group-hover:shadow-lg">
                  <img
                    src={`https://image.mux.com/${pid}/thumbnail.jpg?time=10&width=640`}
                    alt={post.data.title}
                    width="640"
                    height="360"
                    class="h-full w-full object-cover transition-transform group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <p class="mt-3 text-sm font-semibold text-gray-900 group-hover:text-southland-green">{post.data.title}</p>
              </a>
            )
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 6: PRODUCTS — JTBD-framed                                     -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  {products.length > 0 && (
    <section class="border-y border-gray-100 bg-gray-50 py-14">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 text-center">
          <p class="mb-1 text-sm font-semibold uppercase tracking-wider text-gray-400">
            Put the science to work
          </p>
          <h2 class="font-heading text-2xl uppercase md:text-3xl" style="color: var(--color-title);">
            Humate-Powered Products
          </h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          {products.map(({ product, bestFor }) => {
            const image = product!.images?.[0]
            const price = product!.priceRange?.minVariantPrice
            return (
              <a
                href={`/products/${product!.handle}/`}
                class="group flex items-center gap-6 rounded-xl border border-gray-200 bg-white p-6 transition-all hover:border-southland-green/20 hover:shadow-md"
              >
                {image && (
                  <img
                    src={image.url}
                    alt={image.altText || product!.title}
                    width="120"
                    height="120"
                    class="h-24 w-24 flex-shrink-0 object-contain transition-transform group-hover:scale-105"
                    loading="lazy"
                  />
                )}
                <div>
                  <h3 class="text-base font-bold text-gray-900 group-hover:text-southland-green">
                    {product!.title}
                  </h3>
                  {price && (
                    <p class="text-sm font-semibold text-southland-green">
                      From {formatPrice(price.amount)}
                    </p>
                  )}
                  <p class="mt-1 text-xs text-gray-500">{bestFor}</p>
                </div>
              </a>
            )
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 7: ALL ARTICLES                                               -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-brand-gray py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="font-heading text-2xl uppercase md:text-3xl" style="color: var(--color-title);">
          All Articles
        </h2>
        <p class="mt-2 text-gray-500">{posts.length} curated guides and deep dives</p>
      </div>
      <BlogGrid posts={posts} showFeatured={true} columns={3} />
    </div>
  </section>

