---
/**
 * /blogs/poultry-biosecurity — Poultry Biosecurity Lead Capture Hub
 *
 * Allen Reynolds' authority page. Not a blog listing — a conversion engine.
 * Organizes 50+ posts by JTBD, captures leads via phone, form, and Klaviyo.
 *
 * CRO structure (Perplexity-audited 2026-03-24):
 *   1. Hero — Allen + dual CTA (Call + Send a Question)
 *   2. "Start Here" — 3 highest-impact articles for Bill
 *   3. Topic grid — 6 JTBD cards with "Best for" lines, mobile accordion
 *   4. Inline lead capture — Klaviyo → Rv67aH (PBS Newsletter)
 *   5. Video — Mux-hosted biosecurity videos
 *   6. Product band — JTBD-framed products + program CTA
 *   7. Latest articles — full archive with topic tags
 *   8. Final CTA — mirrors hero (Call + Send a Question + subscribe)
 */

export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogGrid from '../../components/blog/BlogGrid.astro'
import EmailCapture from '../../components/shared/EmailCapture.astro'
import { getCollection } from 'astro:content'
import { buildSouthlandUrl } from '../../lib/cloudinary'
import { createClient, getProductByHandle } from '@southland/shopify-storefront'

// ── Allen's photo ───────────────────────────────────────────────────────────
const allenPhoto = buildSouthlandUrl('team/ALLEN_Reynolds', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

// ── All biosecurity posts ───────────────────────────────────────────────────
const allPosts = await getCollection('blog', ({ data }) => {
  if (data.draft) return false
  return (data.tags || []).some((t) => t.toLowerCase() === 'biosecurity')
})

const posts = allPosts.sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
)

// ── JTBD topic categories ───────────────────────────────────────────────────
// SVG icon paths for each topic (white on green hex)
const TOPIC_ICONS: Record<string, string> = {
  mortality: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z', // alert triangle
  litter: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', // house
  environment: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', // monitor/environment
  'bird-health': 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', // heart
  operations: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z', // cog
  business: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', // document
}

const TOPICS = [
  {
    id: 'mortality',
    label: 'Mortality & Disease',
    bestFor: 'High mortality, disease pressure, or post-flock investigation',
    slugs: [
      'early-disease-detection-in-poultry',
      'dealing-with-mass-mortality-the-emotional-side-of-poultry-farming',
      'poultry-farmers-options-for-managing-mortality',
      'poultry-gut-health',
    ],
  },
  {
    id: 'litter',
    label: 'Litter & Ammonia',
    bestFor: 'Wet litter, ammonia spikes, paw quality issues, or pre-clean-out planning',
    slugs: [
      'all-about-litter-what-s-really-happening-on-the-poultry-house-floor',
      'poultry-litter-treatment-for-healthy-floors-and-healthy-birds',
      'how-to-manage-poultry-litter-piles-in-your-parking-lot',
      'clean-out-checklist',
    ],
  },
  {
    id: 'environment',
    label: 'House Environment',
    bestFor: 'Ventilation prep, water line issues, lighting, or heater selection',
    slugs: [
      'how-smart-lighting-systems-help-create-calmer-more-productive-flocks',
      'poultry-ventilation-tune-up-prep-for-the-warm-months',
      'how-to-clean-water-lines-in-poultry-houses',
      'poultry-house-heater-comparison',
    ],
  },
  {
    id: 'bird-health',
    label: 'Bird Health & Nutrition',
    bestFor: 'Gut health, vitamin programs, FCR improvement, or heat stress',
    slugs: [
      'chicken-gut-microbiome-management',
      'how-to-boost-bird-health-through-poultry-vitamins',
      'water-consumption-what-it-indicates-about-bird-health',
      'the-impact-of-chicken-body-temperature-on-feed-conversion-ratio-and-weight-gain',
    ],
  },
  {
    id: 'operations',
    label: 'Farm Operations',
    bestFor: 'Equipment maintenance, electrical safety, or placement prep',
    slugs: [
      '7-electrical-best-practices-for-poultry-growers',
      'safeguarding-your-structures-lighting-and-surge-protection-on-poultry-farms',
      'normalization-of-deviance-why-details-matter-in-poultry-farming',
      'the-first-three-days-of-a-chickens-life-the-most-important-stage',
    ],
  },
  {
    id: 'business',
    label: 'Business & Regulations',
    bestFor: 'USDA rules, tax strategy, NAE/NAIHM compliance, or right-to-repair',
    slugs: [
      'new-usda-rules-and-their-impact-on-poultry-growers',
      'how-to-keep-your-money-earned-on-the-farm-tax-credits-vs-farm-credits',
      'nae-chicken-vs-naihm-chicken',
      'ftc-v-john-deere-why-this-lawsuit-hits-home-for-poultry-farmers',
    ],
  },
]

function findPost(slug: string) {
  return posts.find((p) => p.id.replace(/\.mdx?$/, '') === slug)
}

// "Start Here" — 3 highest-impact articles for Bill
const START_HERE = [
  { slug: 'early-disease-detection-in-poultry', problem: 'Mortality spike' },
  { slug: 'all-about-litter-what-s-really-happening-on-the-poultry-house-floor', problem: 'Wet litter / ammonia' },
  { slug: 'the-first-three-days-of-a-chickens-life-the-most-important-stage', problem: 'Placement prep' },
]

// Topic→slug lookup for article card tags
const slugToTopic = new Map<string, string>()
TOPICS.forEach((t) => t.slugs.forEach((s) => slugToTopic.set(s, t.label)))

// ── Products with JTBD framing ──────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const PRODUCT_JTBD = [
  { handle: 'poultry-probiotic', bestFor: 'Gut health, FCR, and mortality reduction in ABF and conventional flocks' },
  { handle: 'poultry-litter-amendment', bestFor: 'Ammonia control, litter moisture, and paw quality between flocks' },
  { handle: 'natural-mite-control-livestock-poultry', bestFor: 'Darkling beetle and mite control without harsh chemicals' },
]

const productResults = await Promise.all(PRODUCT_JTBD.map((p) => getProductByHandle(client, p.handle)))
const products = PRODUCT_JTBD.map((p, i) => ({ ...p, product: productResults[i] })).filter((p) => p.product)

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── SEO ─────────────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const title = 'Poultry Biosecurity Resources | Southland Organics'
const description =
  'Expert poultry biosecurity resources from Allen Reynolds — 10+ years in houses, hundreds of farm visits. Mortality, litter, ventilation, disease prevention, and more.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${siteUrl}/blogs/poultry-biosecurity`,
  publisher: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: siteUrl,
    foundingDate: '2009',
  },
  author: {
    '@type': 'Person',
    name: 'Allen Reynolds',
    jobTitle: 'VP & Director of Operations',
    worksFor: { '@type': 'Organization', name: 'Southland Organics' },
  },
}
---

<BaseLayout
  title={title}
  description={description}
  ogImage={allenPhoto}
  schema={schema}
>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — Allen + dual CTA                                   -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gradient-to-br from-southland-green-dark via-[#1f3d24] to-[#162b1b] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-10 md:grid-cols-[1fr_280px] lg:grid-cols-[1fr_320px]">

        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-green-400">
            Poultry Biosecurity Resources
          </p>
          <h1 class="mb-6 font-heading text-3xl uppercase text-white md:text-4xl lg:text-5xl">
            We've been in the houses.
          </h1>
          <p class="mb-4 text-lg leading-relaxed text-white/80">
            <strong class="text-white">{posts.length} field-tested articles</strong> on mortality, litter, ventilation, and disease prevention — written by Allen Reynolds for growers who don't have time for white papers.
          </p>
          <p class="mb-8 text-sm text-white/50">
            10+ years on poultry farms. Hundreds of farm visits. ABF specialist since 2017.
          </p>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            {['10+ years on farms', 'Hundreds of farm visits', 'ABF specialist since 2017', 'Actually answers the phone'].map((cred) => (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/10 px-3 py-1.5 text-sm font-medium text-white/90">
                <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                </svg>
                {cred}
              </span>
            ))}
          </div>

          <!-- Dual CTAs -->
          <div class="flex flex-wrap items-center gap-3">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3 text-base font-semibold text-white shadow-lg transition-all hover:bg-[#3a7534] hover:shadow-xl"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Allen: 800-608-3755
            </a>
            <a
              href="/contact/?dept=poultry"
              class="inline-flex items-center gap-2 rounded-lg border border-white/20 px-6 py-3 text-base font-medium text-white transition-colors hover:bg-white/10"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
              Send a Question
            </a>
          </div>
        </div>

        <!-- Allen's photo -->
        <div class="hidden md:block">
          <div class="relative">
            <img
              src={allenPhoto}
              alt="Allen Reynolds, VP & Director of Operations at Southland Organics — 10+ years helping commercial poultry growers"
              width="320"
              height="400"
              class="rounded-2xl object-cover shadow-2xl"
              loading="eager"
            />
            <div class="absolute -bottom-3 -right-3 rounded-xl bg-white px-4 py-2 shadow-lg">
              <p class="text-xs font-semibold text-gray-500">VP & Director of Operations</p>
              <p class="font-heading text-sm uppercase text-southland-green-dark">Allen Reynolds</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: START HERE — 3 highest-impact articles                     -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="border-b border-gray-100 bg-white py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        <h2 class="text-lg font-bold text-gray-900">Start here if you're dealing with...</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        {START_HERE.map(({ slug, problem }) => {
          const post = findPost(slug)
          if (!post) return null
          const postSlug = post.id.replace(/\.mdx?$/, '')
          return (
            <a
              href={`/blog/${postSlug}/`}
              class="group flex items-center gap-4 rounded-xl border border-gray-100 bg-gray-50 p-4 transition-all hover:border-southland-green/20 hover:shadow-md"
            >
              {post.data.featuredImage && (
                <img
                  src={post.data.featuredImage}
                  alt={post.data.title}
                  width="80"
                  height="80"
                  class="h-16 w-16 flex-shrink-0 rounded-lg object-cover"
                  loading="lazy"
                />
              )}
              <div class="min-w-0">
                <p class="mb-0.5 text-xs font-semibold uppercase tracking-wider text-southland-green">{problem}</p>
                <p class="text-sm font-medium text-gray-900 group-hover:text-southland-green line-clamp-2">{post.data.title}</p>
              </div>
            </a>
          )
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: TOPIC GRID — desktop cards, mobile accordion               -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="mb-3 font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
          Browse by Topic
        </h2>
        <p class="mx-auto max-w-2xl text-lg text-gray-600">
          Real-world biosecurity knowledge organized by what you're dealing with right now.
        </p>
      </div>

      <!-- Desktop: grid -->
      <div class="hidden gap-8 md:grid md:grid-cols-2 lg:grid-cols-3">
        {TOPICS.map((topic) => {
          const topicPosts = topic.slugs.map(findPost).filter(Boolean)
          const iconPath = TOPIC_ICONS[topic.id]
          return (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-6 transition-shadow hover:shadow-md" id={`topic-${topic.id}`}>
              <div class="mb-2 flex items-center gap-3">
                <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
                  <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                  </svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900">{topic.label}</h3>
              </div>
              <p class="mb-4 text-xs font-medium uppercase tracking-wider text-southland-green">
                Best for: {topic.bestFor}
              </p>
              <ul class="space-y-3">
                {topicPosts.map((post) => {
                  const slug = post!.id.replace(/\.mdx?$/, '')
                  return (
                    <li>
                      <a href={`/blog/${slug}/`} class="group flex items-start gap-2 text-sm">
                        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-southland-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                        <span class="font-medium text-gray-700 group-hover:text-southland-green">{post!.data.title}</span>
                      </a>
                    </li>
                  )
                })}
              </ul>
            </div>
          )
        })}
      </div>

      <!-- Mobile: accordion -->
      <div class="space-y-3 md:hidden">
        {TOPICS.map((topic) => {
          const topicPosts = topic.slugs.map(findPost).filter(Boolean)
          const iconPath = TOPIC_ICONS[topic.id]
          return (
            <details class="group rounded-xl border border-gray-100 bg-gray-50">
              <summary class="flex cursor-pointer items-center gap-3 p-4">
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
                  <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="font-bold text-gray-900">{topic.label}</p>
                  <p class="text-xs text-southland-green">{topic.bestFor}</p>
                </div>
                <svg class="h-5 w-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <ul class="space-y-3 px-4 pb-4">
                {topicPosts.map((post) => {
                  const slug = post!.id.replace(/\.mdx?$/, '')
                  return (
                    <li>
                      <a href={`/blog/${slug}/`} class="group flex items-start gap-2 text-sm">
                        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-southland-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                        <span class="font-medium text-gray-700 group-hover:text-southland-green">{post!.data.title}</span>
                      </a>
                    </li>
                  )
                })}
              </ul>
            </details>
          )
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: INLINE LEAD CAPTURE                                        -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-southland-green-dark py-14">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-8 md:grid-cols-[1fr_1fr]">
        <div>
          <h2 class="mb-3 font-heading text-2xl uppercase text-white md:text-3xl">
            Get new biosecurity articles and field tips in your inbox
          </h2>
          <p class="text-white/70">
            Practical poultry advice from Allen. No spam, no sales pitches — just what's working on farms right now.
          </p>
        </div>
        <div>
          <EmailCapture
            headline=""
            description=""
            listId="Rv67aH"
            source="biosecurity"
            buttonText="Subscribe"
            variant="banner"
          />
          <p class="mt-3 text-center text-xs text-white/40">
            Or call directly: <a href="tel:800-608-3755" class="underline">800-608-3755</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 5: VIDEO — Mux-hosted biosecurity videos                      -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <span class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-southland-green">
          Watch & Learn
        </span>
        <h2 class="mb-3 font-heading text-2xl uppercase md:text-3xl" style="color: var(--color-title);">
          See It in Action
        </h2>
        <p class="mx-auto max-w-2xl text-gray-600">
          Short videos from real complexes — biosecurity fundamentals and performance data you can apply on your next flock.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <div>
          <div class="aspect-video overflow-hidden rounded-xl shadow-lg">
            <mux-player
              playback-id="z6tTWiAx3b02CnfkX600WeJhQ2rqA268q6i5S9QqiRvmg"
              accent-color="#44883e"
              metadata-video-title="Poultry Farm Biosecurity Basics"
              default-hidden-captions
              poster="https://image.mux.com/z6tTWiAx3b02CnfkX600WeJhQ2rqA268q6i5S9QqiRvmg/thumbnail.jpg?time=10"
              style="width:100%;height:100%;--media-object-fit:cover;"
            ></mux-player>
          </div>
          <p class="mt-3 text-sm font-semibold text-gray-900">Poultry Farm Biosecurity Basics</p>
          <p class="text-xs text-gray-500">5 min — The fundamentals every grower needs to know</p>
        </div>

        <div>
          <div class="aspect-video overflow-hidden rounded-xl shadow-lg">
            <mux-player
              playback-id="kisHZ3H00cgwwtbYpNFTuJvpX3aQjYktRPognZMCkl8A"
              accent-color="#44883e"
              metadata-video-title="Big Ole Bird Performance Study Results"
              default-hidden-captions
              poster="https://image.mux.com/kisHZ3H00cgwwtbYpNFTuJvpX3aQjYktRPognZMCkl8A/thumbnail.jpg?time=10"
              style="width:100%;height:100%;--media-object-fit:cover;"
            ></mux-player>
          </div>
          <p class="mt-3 text-sm font-semibold text-gray-900">Big Ole Bird | Performance Study Results</p>
