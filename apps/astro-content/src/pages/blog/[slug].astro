---
/**
 * Individual Blog Post Page - /blog/[slug]/
 * Shows full article content with E-E-A-T author/reviewer attribution and SEO schema
 */

import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogCard from '../../components/blog/BlogCard.astro'
import AuthorCard from '../../components/blog/AuthorCard.astro'
import { getCollection, getEntry, render } from 'astro:content'
import { buildPersonSchema, buildOrganizationSchema } from '../../lib/schema'
import { resolveEpisodeCover, buildSouthlandUrl } from '../../lib/cloudinary'

export const prerender = true

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.draft !== true
  })

  return posts.map((post) => {
    const slug = post.id.replace(/\.mdx?$/, '')
    return {
      params: { slug },
      props: { post, slug },
    }
  })
}

const { post, slug: postSlug } = Astro.props
const { Content, headings } = await render(post)

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'

// Reading time estimate (~238 words per minute)
const wordCount = post.body?.split(/\s+/).length || 0
const readingTime = Math.max(1, Math.ceil(wordCount / 238))

// TOC: filter to H2 and H3 only
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3)

// Fetch author from team collection (if it's a slug reference)
let author = null
let authorEntry = null
if (post.data.author) {
  try {
    const teamMember = await getEntry('team', post.data.author)
    if (teamMember) {
      authorEntry = teamMember
      const photoUrl = teamMember.data.photo
        ? buildSouthlandUrl(teamMember.data.photo, {
            width: 80,
            height: 80,
            crop: 'fill',
            gravity: 'face',
            quality: 'auto',
            format: 'auto',
          })
        : null
      author = {
        ...teamMember.data,
        photo: photoUrl,
        slug: post.data.author,
      }
    }
  } catch {
    // Fallback: author is just a name string (legacy data)
    author = { name: post.data.author, slug: null }
  }
}

// Fetch reviewer from team collection
let reviewer = null
let reviewerEntry = null
if (post.data.reviewer) {
  try {
    const teamMember = await getEntry('team', post.data.reviewer)
    if (teamMember) {
      reviewerEntry = teamMember
      const reviewerPhotoUrl = teamMember.data.photo
        ? buildSouthlandUrl(teamMember.data.photo, {
            width: 80,
            height: 80,
            crop: 'fill',
            gravity: 'face',
            quality: 'auto',
            format: 'auto',
          })
        : null
      reviewer = {
        ...teamMember.data,
        photo: reviewerPhotoUrl,
        slug: post.data.reviewer,
      }
    }
  } catch {
    // Reviewer not found
  }
}

// Format dates
const formattedDate = new Date(post.data.publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const formattedUpdatedDate = post.data.updatedDate
  ? new Date(post.data.updatedDate).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null

// Get related posts (same segment)
const allPosts = await getCollection('blog', ({ data }) => data.draft !== true)
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.segment === post.data.segment)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3)

// Resolve related episodes (cross-promotion)
const relatedEpisodeEntries = post.data.relatedEpisodes?.length
  ? await Promise.all(
      post.data.relatedEpisodes.map(async (slug) => {
        try {
          return await getEntry('episodes', slug)
        } catch {
          return null
        }
      })
    ).then((eps) => eps.filter((ep): ep is NonNullable<typeof ep> => ep != null))
  : []

// Segment labels
const segmentLabels: Record<string, string> = {
  poultry: 'Poultry',
  turf: 'Turf & Lawn',
  agriculture: 'Agriculture',
  general: 'General',
}

// Build E-E-A-T optimized schema markup using shared utility
const authorSchema = authorEntry
  ? buildPersonSchema(authorEntry)
  : {
      '@type': 'Organization',
      name: author?.name || 'Southland Organics',
      url: siteUrl,
    }

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: new Date(post.data.publishDate).toISOString(),
  dateModified: post.data.updatedDate
    ? new Date(post.data.updatedDate).toISOString()
    : new Date(post.data.publishDate).toISOString(),
  url: `${siteUrl}/blog/${postSlug}/`,
  image: post.data.featuredImage || `${siteUrl}/og-image.jpg`,
  author: authorSchema,
  ...(reviewerEntry && { reviewedBy: buildPersonSchema(reviewerEntry) }),
  publisher: buildOrganizationSchema(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/blog/${postSlug}/`,
  },
  keywords: post.data.tags?.join(', '),
  wordCount,
}

// BreadcrumbList schema
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${siteUrl}/blog/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: `${siteUrl}/blog/${postSlug}/`,
    },
  ],
}

// FAQPage schema — extract from H2/H3 headings that are questions
const faqItems = tocHeadings
  .filter((h) => h.text.includes('?'))
  .map((h) => ({
    '@type': 'Question',
    name: h.text,
  }))

const faqSchema =
  faqItems.length >= 2
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems.map((q) => ({
          ...q,
          acceptedAnswer: {
            '@type': 'Answer',
            name: 'See full answer in article',
            text: `Read the full explanation in our article: ${post.data.title}`,
          },
        })),
      }
    : null

// Persona-aware CTA copy
type SegmentCta = {
  heading: string
  description: string
  promise: string
  primaryHref: string
  primaryLabel: string
  heroLink: string
  heroLinkLabel: string
}
const segmentCtas: Record<string, SegmentCta> = {
  poultry: {
    heading: "Ready to Improve Your Flock's Performance?",
    description:
      'Our team of poultry specialists can help you find the right organic solutions for healthier birds and better results.',
    promise:
      'Field-tested probiotics and supplements trusted by commercial growers and backyard flocks alike.',
    primaryHref: '/contact/',
    primaryLabel: 'Talk to a Poultry Specialist',
    heroLink: '/collections/poultry-broilers/',
    heroLinkLabel: 'See poultry products',
  },
  turf: {
    heading: 'Ready to Build Better Soil?',
    description:
      'Our turf and soil health experts can help you choose the right organic products for a healthier lawn and garden.',
    promise:
      'Field-tested biology and fertilizers that pair perfectly with the practices in this article.',
    primaryHref: '/collections/turf/',
    primaryLabel: 'Shop Lawn & Garden Products',
    heroLink: '/collections/turf/',
    heroLinkLabel: 'See lawn & garden products',
  },
  agriculture: {
    heading: 'Ready to Grow Healthier Crops?',
    description:
      'Our agriculture team can help you find organic solutions to improve soil biology and crop performance.',
    promise:
      'Liquid biologicals and soil conditioners built for real field conditions, not just lab results.',
    primaryHref: '/contact/',
    primaryLabel: 'Talk to an Ag Specialist',
    heroLink: '/collections/crops/',
    heroLinkLabel: 'See agriculture products',
  },
  general: {
    heading: 'Need Help With Your Operation?',
    description:
      'Our team of experts is here to help you find the right organic solutions for your needs.',
    promise:
      'Biology-first products backed by university trials, trusted by growers across the Southeast.',
    primaryHref: '/contact/',
    primaryLabel: 'Contact Us',
    heroLink: '/products/',
    heroLinkLabel: 'Browse all products',
  },
}
const cta = segmentCtas[post.data.segment || 'general']
---

<BaseLayout
  title={post.data.title}
  description={post.data.description.length > 160
    ? post.data.description.slice(0, 157) + '...'
    : post.data.description}
  ogImage={post.data.featuredImage}
  ogType="article"
  schema={articleSchema}
  articlePublishedTime={new Date(post.data.publishDate).toISOString()}
  articleModifiedTime={post.data.updatedDate
    ? new Date(post.data.updatedDate).toISOString()
    : new Date(post.data.publishDate).toISOString()}
  articleAuthor={author?.name}
  articleSection={segmentLabels[post.data.segment || 'general']}
>
  <!-- Article Header — split layout: text left, media right -->
  <header
    class="bg-gradient-to-br from-southland-green-dark via-southland-green-dark to-[#1f3d24] py-10 md:py-14"
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-white/60">
          <li>
            <a href="/" class="transition-colors hover:text-white">Home</a>
          </li>
          <li>
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </li>
          <li>
            <a href="/blog/" class="transition-colors hover:text-white">Blog</a>
          </li>
          <li>
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </li>
          <li class="max-w-[250px] truncate text-white/80">{post.data.title}</li>
        </ol>
      </nav>

      <div class="lg:grid lg:grid-cols-[1fr_420px] lg:items-center lg:gap-10">
        <!-- Left: text -->
        <div>
          <!-- Segment badge -->
          <a
            href={`/blog/category/${post.data.segment}/`}
            class="mb-4 inline-block rounded-full bg-southland-green px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white transition-colors hover:bg-southland-green/80"
          >
            {segmentLabels[post.data.segment || 'general']}
          </a>

          <!-- Title -->
          <h1
            class="mb-3 font-heading text-2xl uppercase leading-tight text-white md:text-3xl lg:text-4xl"
          >
            {post.data.title}
          </h1>

          <!-- Description -->
          <p class="mb-5 text-base leading-relaxed text-white/80 lg:text-lg">
            {post.data.description}
          </p>

          <!-- Author mini-bio + meta -->
          <div class="flex items-start gap-3">
            {
              author?.photo && (
                <a href={author.slug ? `/team/${author.slug}/` : '#'} class="flex-shrink-0">
                  <img
                    src={author.photo}
                    alt={author.name}
                    width="40"
                    height="40"
                    class="h-10 w-10 rounded-full object-cover ring-2 ring-white/20"
                    loading="eager"
                  />
                </a>
              )
            }
            <div>
              <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-sm text-white/80">
                {
                  author &&
                    (author.slug ? (
                      <a
                        href={`/team/${author.slug}/`}
                        class="font-medium text-white transition-colors hover:text-southland-green"
                      >
                        {author.name}
                      </a>
                    ) : (
                      <span class="font-medium text-white">{author.name}</span>
                    ))
                }
                {author?.role && <span class="text-white/50">— {author.role}</span>}
              </div>
              <div
                class="mt-0.5 flex flex-wrap items-center gap-x-2 gap-y-0.5 text-xs text-white/50"
              >
                <time datetime={new Date(post.data.publishDate).toISOString()}>
                  {formattedDate}
                </time>
                {
                  formattedUpdatedDate && formattedUpdatedDate !== formattedDate && (
                    <>
                      <span>•</span>
                      <span>Updated {formattedUpdatedDate}</span>
                    </>
                  )
                }
                <span>•</span>
                <span>{readingTime} min read</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: media (image or video) -->
        <div class="mt-8 lg:mt-0">
          {
            post.data.muxPlaybackIds && post.data.muxPlaybackIds.length > 0 ? (
              <div class="aspect-video overflow-hidden rounded-xl shadow-2xl ring-1 ring-white/10">
                <mux-player
                  playback-id={post.data.muxPlaybackIds[0]}
                  accent-color="#44883e"
                  metadata-video-title={post.data.title}
                  default-hidden-captions
                  poster={`https://image.mux.com/${post.data.muxPlaybackIds[0]}/thumbnail.jpg?time=10`}
                  style="width:100%;height:100%;--media-object-fit:cover;"
                />
              </div>
            ) : post.data.featuredImage ? (
              <img
                src={post.data.featuredImage}
                alt={post.data.title}
                width="800"
                height="450"
                class="aspect-video w-full rounded-xl object-cover shadow-2xl ring-1 ring-white/10"
                loading="eager"
                fetchpriority="high"
              />
            ) : null
          }
          <a
            href={cta.heroLink}
            class="mt-3 inline-flex items-center gap-1.5 text-sm text-white/60 transition-colors hover:text-white"
          >
            {cta.heroLinkLabel}
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </header>
  {
    post.data.muxPlaybackIds && post.data.muxPlaybackIds.length > 0 && (
      <script>import('@mux/mux-player').catch(function () {})</script>
    )
  }

  <!-- Extra structured data -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {
    faqSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )
  }

  <!-- Additional video embeds (if multiple) -->
  {
    post.data.muxPlaybackIds && post.data.muxPlaybackIds.length > 1 && (
      <div class="border-b border-gray-100 bg-gray-50 py-8">
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
          <div class="grid gap-6 md:grid-cols-2">
            {post.data.muxPlaybackIds.slice(1).map((pid: string, i: number) => (
              <div class="aspect-video overflow-hidden rounded-xl shadow-lg">
                <mux-player
                  playback-id={pid}
                  accent-color="#44883e"
                  metadata-video-title={`${post.data.title} (Part ${i + 2})`}
                  default-hidden-captions
                  poster={`https://image.mux.com/${pid}/thumbnail.jpg?time=10`}
                  style="width:100%;height:100%;--media-object-fit:cover;"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    )
  }

  <!-- Article Content -->
  <article class="bg-white py-12 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-[1fr_260px] lg:gap-12">
        <!-- Main content -->
        <div class="mx-auto max-w-4xl lg:mx-0">
          <div
            class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-shopify-title prose-h2:mb-6 prose-h2:mt-12 prose-h2:font-heading prose-h2:text-2xl prose-h3:mb-4 prose-h3:mt-8 prose-h3:text-xl prose-p:leading-relaxed prose-p:text-shopify-secondary-text prose-a:text-southland-green prose-a:no-underline hover:prose-a:underline prose-blockquote:rounded-r-lg prose-blockquote:border-l-4 prose-blockquote:border-southland-green prose-blockquote:bg-gray-50 prose-blockquote:px-6 prose-blockquote:py-2 prose-strong:text-shopify-title prose-ul:my-6 prose-li:text-shopify-secondary-text prose-img:rounded-lg prose-img:shadow-md"
          >
            <Content />
          </div>
        </div>

        <!-- Table of Contents (desktop sidebar) -->
        {
          tocHeadings.length >= 3 && (
            <aside class="hidden lg:block">
              <nav class="sticky top-24" aria-label="Table of contents">
                <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-gray-400">
                  On this page
                </h4>
                <ul class="space-y-2 border-l border-gray-200 text-sm">
                  {tocHeadings.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class:list={[
                          'block border-l-2 transition-colors hover:border-southland-green hover:text-southland-green',
                          h.depth === 2
                            ? 'border-transparent py-1 pl-4 text-gray-600'
                            : 'border-transparent py-0.5 pl-7 text-xs text-gray-400',
                        ]}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }
      </div>

      <!-- Mobile TOC (collapsible, above content on small screens) -->
      {
        tocHeadings.length >= 3 && (
          <details class="mx-auto mb-8 max-w-4xl rounded-lg border border-gray-200 bg-gray-50 p-4 lg:hidden">
            <summary class="cursor-pointer text-sm font-semibold text-gray-600">
              Table of Contents
            </summary>
            <ul class="mt-3 space-y-2 text-sm">
              {tocHeadings.map((h) => (
                <li>
                  <a
                    href={`#${h.slug}`}
                    class:list={[
                      'block text-gray-600 hover:text-southland-green',
                      h.depth === 3 && 'pl-4 text-xs text-gray-400',
                    ]}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </details>
        )
      }
    </div>

    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Author & Reviewer Cards (E-E-A-T) -->
      {
        (author?.slug || reviewer?.slug) && (
          <div class="mt-12 space-y-6 border-t border-gray-200 pt-8">
            {author?.slug && (
              <AuthorCard
                name={author.name}
                slug={author.slug}
                role={author.role}
                bio={author.bio}
                photo={author.photo ?? undefined}
                credentials={author.credentials}
                yearsExperience={author.yearsExperience}
                links={author.links}
                variant="full"
                label="Written by"
              />
            )}
            {reviewer?.slug && (
              <AuthorCard
                name={reviewer.name}
                slug={reviewer.slug}
                role={reviewer.role}
                bio={reviewer.bio}
                photo={reviewer.photo ?? undefined}
                credentials={reviewer.credentials}
                yearsExperience={reviewer.yearsExperience}
                links={reviewer.links}
                variant="full"
                label="Reviewed by"
              />
            )}
          </div>
        )
      }

      <!-- Tags -->
      {
        post.data.tags && post.data.tags.length > 0 && (
          <div class="mt-12 border-t border-gray-200 pt-8">
            <h4 class="mb-3 text-sm font-medium text-gray-500">Topics</h4>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <a
                  href={`/blog/?tag=${encodeURIComponent(tag)}`}
                  class="rounded-full bg-gray-100 px-3 py-1 text-sm text-gray-700 transition-colors hover:bg-southland-green hover:text-white"
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>
        )
      }

      <!-- Related Episodes (cross-promotion) -->
      {
        relatedEpisodeEntries.length > 0 && (
          <div class="mt-12 border-t border-gray-200 pt-8">
            <h4 class="mb-4 text-lg font-bold text-shopify-title">Related Podcast Episodes</h4>
            <div class="space-y-4">
              {relatedEpisodeEntries.map((ep) => (
                <a
                  href={`/podcast/${ep.id.replace(/\.mdx?$/, '')}/`}
                  class="group flex items-start gap-4 rounded-xl border border-gray-100 bg-brand-gray p-4 transition-shadow hover:shadow-md"
                >
                  {(ep.data.coverImage || ep.data.thumbnail) && (
                    <img
                      src={resolveEpisodeCover(ep.data, 256)}
                      alt={ep.data.title}
                      width="128"
                      height="80"
                      class="h-20 w-32 flex-shrink-0 rounded-lg object-cover"
                      loading="lazy"
                    />
                  )}
                  <div>
                    <div class="mb-1 flex items-center gap-2 text-xs text-gray-500">
                      <span class="font-medium text-southland-green">
                        Episode {ep.data.episodeNumber}
                      </span>
                      <span>&bull;</span>
                      <span>{ep.data.duration}</span>
                    </div>
                    <h5 class="font-bold text-shopify-title transition-colors group-hover:text-southland-green">
                      {ep.data.title}
                    </h5>
                    <p class="mt-1 line-clamp-2 text-sm text-shopify-secondary-text">
                      {ep.data.description}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }

      <!-- Share -->
      <div class="mt-8 border-t border-gray-200 pt-8">
        <h4 class="mb-3 text-sm font-medium text-gray-500">Share this article</h4>
        <div class="flex gap-3">
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`${siteUrl}/blog/${postSlug}/`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg bg-gray-100 p-2 text-gray-600 transition-colors hover:bg-gray-200"
            title="Share on X"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`${siteUrl}/blog/${postSlug}/`)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg bg-gray-100 p-2 text-gray-600 transition-colors hover:bg-gray-200"
            title="Share on Facebook"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path>
            </svg>
          </a>
          <a
            href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(`${siteUrl}/blog/${postSlug}/`)}&title=${encodeURIComponent(post.data.title)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg bg-gray-100 p-2 text-gray-600 transition-colors hover:bg-gray-200"
            title="Share on LinkedIn"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </article>

  <!-- Related Posts -->
  {
    relatedPosts.length > 0 && (
      <section class="bg-brand-gray py-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <h2 class="mb-8 font-heading text-2xl uppercase text-shopify-title">Related Articles</h2>
          <div class="grid gap-6 md:grid-cols-3">
            {relatedPosts.map((relatedPost) => (
              <BlogCard
                title={relatedPost.data.title}
                slug={relatedPost.id.replace(/\.mdx?$/, '')}
                description={relatedPost.data.description}
                publishDate={relatedPost.data.publishDate}
                featuredImage={relatedPost.data.featuredImage}
                segment={relatedPost.data.segment}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA (persona-aware) -->
  <section class="border-t border-gray-100 bg-gradient-to-b from-white to-gray-50 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-3 font-heading text-2xl uppercase text-shopify-title md:text-3xl">
        {cta.heading}
      </h2>
      <p class="mx-auto mb-2 max-w-xl text-base text-shopify-secondary-text">
        {cta.description}
      </p>
      <p class="mx-auto mb-8 max-w-xl text-sm italic text-gray-400">
        {cta.promise}
      </p>
      <a href={cta.primaryHref} class="btn-primary inline-flex items-center gap-2">
        {cta.primaryLabel}
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </a>
      {/* Tool links — segment-aware */}
      <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
        {
          (post.data.segment === 'turf' || post.data.segment === 'agriculture') && (
            <a
              href="/tools/lawn-quiz/"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-[#44883E] hover:text-green-700"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
                />
              </svg>
              Take the Lawn Quiz
            </a>
          )
        }
        <a
          href="/application-rate-calculator/"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-[#44883E] hover:text-green-700"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
            ></path></svg
          >
          Calculate Application Rate
        </a>
        <a
          href="/tools/compare/"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-[#44883E] hover:text-green-700"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"
            ></path></svg
          >
          Compare Biological vs. Conventional
        </a>
      </div>

      <div class="mt-4">
        <a href="/blog/" class="text-sm text-gray-500 transition-colors hover:text-southland-green">
          More articles &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
