---
/**
 * /livestock/swine/ — Pig & Swine StoryBrand Landing Page
 *
 * StoryBrand framework: Hero (Hog Operator) → Problem (the challenges) → Guide (Southland)
 * → JTBD (2 jobs with real products) → Proof → Plan → Objections → CTA
 *
 * Products fetched dynamically from Shopify Storefront API.
 * Copy hardcoded — will extract to TinaCMS after pattern stabilizes.
 */
import { getCollection } from 'astro:content'
import { createClient, getProductByHandle, getCollectionProducts } from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../../components/CloudinaryHero.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro'
import { buildSouthlandUrl } from '../../../lib/cloudinary'

// ── Allen Reynolds photo ────────────────────────────────────────────────────
const allenPhoto = buildSouthlandUrl('team/ALLEN_Reynolds', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

const HANDLE = 'pig-and-swine-supplements'

// ── TinaCMS lookup ──────────────────────────────────────────────────────────
const allCollections = await getCollection('shopCollections')
const tinaDoc =
  allCollections.find(
    (c) => c.data.handle === HANDLE || c.id.replace(/\.mdx?$/, '') === HANDLE,
  ) ?? null

const title = tinaDoc?.data.title || 'Pig and Swine Supplements'
const seoTitle = 'Swine Probiotics & Supplements | Southland Organics'
const seoDescription =
  tinaDoc?.data.seoDescription ||
  'Natural swine supplements for gut health, feed efficiency, growth, and pest control. USDA Organic, no antibiotics, family-owned since 2009.'
const faq = tinaDoc?.data.faq ?? []

// ── Fetch products ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

// Fetch JTBD-featured products individually (need full detail)
const jtbdHandles = [
  'apple-cider-vinegar-for-pigs',
  'desecticide-natural-mite-control',
  'zeropoint-industrial',
] as const

const jtbdProducts = await Promise.all(
  jtbdHandles.map((h) => getProductByHandle(client, h))
)
const productMap = new Map(
  jtbdProducts.filter(Boolean).map((p) => [p!.handle, p!])
)

// Fetch ALL products in the swine collection for the shop grid
const swineCollection = await getCollectionProducts(client, HANDLE)
const allSwineProducts: Product[] = swineCollection?.products ?? []

/** Helper: get product or null */
function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

/** Helper: format price from Shopify Money */
function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── JTBD data (2 jobs for swine) ────────────────────────────────────────────
const jobs = [
  {
    title: 'Support gut health and feed efficiency.',
    struggle:
      'Scouring, inconsistent growth, and feed waste eat into margins before you can catch it.',
    bestFor: 'Operations focused on gut health, growth rates, and feed conversion',
    products: [getProduct('apple-cider-vinegar-for-pigs')].filter(Boolean),
    proof: 'Supports healthy gut flora naturally',
    proofSource: 'ACV research, organic acid benefits',
    recommended: true,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  },
  {
    title: 'Control pests and maintain biosecurity.',
    struggle:
      'Mites stress animals, spread disease, and conventional treatments leave residues you have to manage around.',
    bestFor: 'Barns with mite pressure, biosecurity concerns, or multi-species operations',
    products: [getProduct('desecticide-natural-mite-control'), getProduct('zeropoint-industrial')].filter(Boolean),
    proof: 'Effective pest control without residues',
    proofSource: 'Natural mite and pathogen management',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
]

// ── Objections (FAQ) ────────────────────────────────────────────────────────
const objections = [
  {
    question: 'Does apple cider vinegar really help pigs?',
    answer:
      "It does — and there's real science behind it. Apple cider vinegar is an organic acid that lowers gut pH, creating an environment where beneficial bacteria thrive and pathogens struggle. It supports digestion, nutrient absorption, and overall gut health. Our ACV is raw, unfiltered, and formulated specifically for livestock — not the diluted grocery store stuff. Growers consistently report better stool consistency, improved appetite, and healthier-looking animals within the first few weeks.",
  },
  {
    question: "My pigs are already on a feed program. Why add supplements?",
    answer:
      "Feed programs are designed around nutrition — calories, protein, minerals. But nutrition is only half the equation. If your pigs can't efficiently absorb what they're eating because of poor gut biology, you're paying for feed that's passing right through. ACV supports the gut environment so your existing feed program actually delivers what it's supposed to. Think of it as getting more value from what you're already spending.",
  },
  {
    question: "How is Desecticide different from chemical pest treatments?",
    answer:
      "Conventional mite treatments work by poisoning insects — which means residues, withdrawal periods, and the risk of building resistance over time. Desecticide uses a completely different mechanism: natural ingredients that physically eliminate pests without leaving chemical residues. No withdrawal period, no resistance buildup, safe to use around animals. And because it's not a neurotoxin, you don't have to worry about the unintended effects on your animals or your workers.",
  },
  {
    question: "I've never heard of Southland Organics. Why should I trust you?",
    answer:
      "Fair question. We've been in business since 2009 — family-owned, A+ BBB rated, and we built our reputation in commercial poultry before expanding into swine. Thousands of livestock producers trust our products. We don't ask you to overhaul your operation. Try one product, see if it makes a difference. If it doesn't, don't reorder. That's the whole pitch.",
  },
  {
    question: 'Are these products safe for all ages and breeds?',
    answer:
      "Yes. Our products are natural, USDA Organic compatible, and contain no antibiotics or synthetic chemicals. ACV can be used for pigs at any stage — from weanlings to finishing hogs to breeding stock. Desecticide and ZeroPoint are applied to the environment, not the animals directly, so breed and age aren't a factor. We're happy to walk you through dosing and application for your specific setup.",
  },
]

// ── Schema.org ──────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/livestock/swine/`

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: seoDescription,
  url: canonicalUrl,
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [...objections, ...faq].map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}
---

<BaseLayout title={seoTitle} description={seoDescription} schema={[pageSchema, faqSchema]} canonicalUrl={canonicalUrl}>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — "Healthier pigs start in the gut"                   -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/heroes/mangalista_result_azucxe"
    alt="Mangalitsa pigs — natural swine supplements from Southland Organics"
    height={600}
    minHeight="500px"
    overlay="gradient"
    overlayOpacity={90}
    gravity="center"
    contentAlign="center"
    contentJustify="start"
    priority={true}
  >
    <div class="mx-auto w-full max-w-6xl pb-12 pt-12 md:pt-20">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Livestock', href: '/livestock/' },
          { label: 'Swine' },
        ]}
        class="mb-4 [&_a]:text-white/80 [&_span]:text-white/60 [&_*]:text-sm"
      />
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-block rounded-full bg-white/15 px-4 py-1 text-sm font-medium text-green-300">
            For Hog Operations
          </span>
          <span class="inline-block rounded-full bg-green-400/20 px-3 py-1 text-sm font-semibold text-green-300">
            Natural Supplements
          </span>
        </div>
        <h1 class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl lg:text-6xl">
          Healthier pigs start in the gut, not the feed bin.
        </h1>
        <p class="mb-5 text-lg text-white/70 md:text-xl">
          You can't control genetics or market prices. But you can control:
        </p>
        <!-- Two levers — scannable -->
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-2">
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Gut Health
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Pest Control
          </span>
        </div>
        <!-- CTAs + trust badges as one unified block -->
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3.5 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Allen
          </a>
          <a
            href="#swine-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Shop Products
          </a>
          <a
            href="#proof"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/5"
          >
            See the Proof
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
        <p class="mt-2 text-sm text-white/50">No sales script — just a conversation about your operation</p>
        <!-- Trust bar — tight, single baseline -->
        <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/80">
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            No Antibiotics
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Natural Ingredients
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Family-Owned
          </span>
        </div>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM — "Nobody talks about the real cost"               -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
        Nobody talks about the real cost.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        Feed bills are just the beginning. The hidden costs are what kill margins.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What the operation demands</h3>
          <p class="leading-relaxed text-gray-600">
            Consistent growth rates, feed efficiency, healthy pigs that finish on schedule. Every day an animal is off-feed or underperforming, you're losing money.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#44883E]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What keeps you up</h3>
          <p class="leading-relaxed text-gray-600">
            Gut issues cascade fast. One sick pen spreads. Antibiotics mask the problem but create resistance. You know the cycle, and you know it's not sustainable.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What shouldn't be true</h3>
          <p class="leading-relaxed text-gray-600">
            Raising healthy animals shouldn't require practices you wouldn't want your customers to know about. There's a better way — and it starts with biology, not chemistry.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: GUIDE — "We started in the barn, not the boardroom"        -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
        <div class="order-2 md:order-1">
          <span class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-green-700">
            Your guide
          </span>
          <h2 class="mb-6 font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
            We started in the barn, not the boardroom.
          </h2>
          <p class="mb-4 text-lg leading-relaxed text-gray-700">
            Allen Reynolds has spent over a decade inside livestock operations — not behind a desk. He built his reputation helping commercial poultry growers solve gut health and litter problems, and the same biology that works for birds works for pigs.
          </p>
          <p class="mb-4 text-lg leading-relaxed text-gray-600">
            Organic acids support gut flora. Natural pest control eliminates mites without chemical residues. These aren't theories — they're the same principles livestock producers have trusted for years, validated by real results on real farms.
          </p>
          <p class="mb-8 leading-relaxed text-gray-600">
            When you call, Allen answers. He'll listen to your situation, recommend what makes sense, and never push a product you don't need. That's not a tagline — it's how we've done business since 2009.
          </p>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              10+ years on farms
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Hundreds of farm visits
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Poultry & livestock specialist
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Actually answers the phone
            </span>
          </div>

          <!-- Quick contact -->
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[#44883E]/85"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Allen
            </a>
            <a
              href="mailto:allen@southlandorganics.com"
              class="text-sm font-medium text-green-700 underline decoration-green-300 underline-offset-2 hover:text-green-600"
            >
              allen@southlandorganics.com
            </a>
          </div>
        </div>

        <!-- Allen's photo -->
        <div class="order-1 md:order-2">
          <div class="relative mx-auto w-64 md:w-72 lg:w-80">
            <img
              src={allenPhoto}
              alt="Allen Reynolds, VP & Director of Operations at Southland Organics"
              width="600"
              height="750"
              class="rounded-2xl object-cover shadow-lg"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 right-0 rounded-b-2xl bg-gradient-to-t from-black/70 to-transparent px-5 pb-4 pt-10">
              <p class="text-lg font-bold text-white">Allen Reynolds</p>
              <p class="text-sm text-green-300">VP & Director of Operations</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: JTBD GRID — "Two jobs. Real solutions."                    -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-4xl uppercase md:text-5xl" style="color: var(--color-title);">
        Two jobs. Real solutions.
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-gray-600">
        Every product here exists to do one of two jobs in your barn. Pick the job you need help with — we'll show you the right tools.
      </p>
      <p class="mb-12 text-center">
        <a href="#swine-products" class="inline-flex items-center gap-1 text-sm font-medium text-green-700 hover:text-green-600 hover:underline">
          Skip to all swine products
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </p>
      <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-2">
        {jobs.map((job) => (
          <div class:list={[
            'relative flex flex-col rounded-xl border bg-white p-8 shadow-sm',
            job.recommended ? 'border-green-300 ring-1 ring-green-200' : 'border-gray-200',
          ]}>
            {job.recommended && (
              <span class="absolute -top-3 left-6 rounded-full bg-green-600 px-3 py-0.5 text-xs font-bold uppercase tracking-wide text-white">
                Recommended starting point
              </span>
            )}

            <!-- Job icon (hex) -->
