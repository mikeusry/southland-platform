---
/**
 * Persona Command Center — Detail Page
 * /admin/personas/[slug]/
 *
 * War room for a single persona: profile, JTBD coverage, page inventory,
 * plays, copy sandbox, and CDP placeholders.
 */

import AdminLayout from '../../../layouts/AdminLayout.astro'
import {
  getPersona,
  getJTBDCoverage,
  getNextBestMove,
  PERSONAS,
} from '../../../lib/persona-profiles'
import { PAGE_GROUPS } from '../../../lib/site-audit-pages'
import { getCollection } from 'astro:content'

export const prerender = true

export function getStaticPaths() {
  return PERSONAS.map((p) => ({ params: { slug: p.slug } }))
}

const { slug } = Astro.params
const persona = getPersona(slug!)

if (!persona) {
  return Astro.redirect('/admin/personas/')
}

const coverage = getJTBDCoverage(persona)
const nextMove = getNextBestMove(persona)

// CDP metrics — populated when persona-metrics.json exists
// Generate with: cd mothership && node scripts/cdp/persona-metrics.js --json > ../southland-platform/apps/astro-content/src/data/persona-metrics.json
const cdpMetrics: any = null
const cdpPlay: any = null
const hasCDPData = false

// Relative date helper
function relativeDate(dateStr: string): string {
  const now = new Date('2026-03-22')
  const then = new Date(dateStr)
  const diffMs = now.getTime() - then.getTime()
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24))
  if (diffDays === 0) return 'today'
  if (diffDays === 1) return '1 day ago'
  if (diffDays < 30) return `${diffDays} days ago`
  if (diffDays < 60) return '1 month ago'
  return `${Math.floor(diffDays / 30)} months ago`
}

// Page inventory — static pages + blog posts via centralized inference
import { inferPersonaFromBlog, isUntagged } from '../../../lib/persona-inference'

const staticPersonaPages = PAGE_GROUPS.flatMap((g) => g.pages)
  .filter((p) => p.persona === slug)
  .map((p) => ({ ...p, source: 'page', confidence: 'high' }))

let blogEntries: any[] = []
try {
  blogEntries = await getCollection('blog', ({ data }: any) => data.draft !== true)
} catch (e) {
  console.warn('[personas] Failed to fetch blog collection:', e)
}

const filteredBlog = blogEntries.filter((e: any) => {
  const match = inferPersonaFromBlog(e.data.tags || [], e.data.segment || 'general')
  return match ? match.persona === slug : false
})
filteredBlog.sort((a: any, b: any) => {
  return new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
})
const allPersonaBlogPosts = filteredBlog.map((e: any) => {
  const s = e.id.replace(/\.mdx?$/, '')
  return {
    name: e.data.title,
    route: '/blog/' + s + '/',
    pageType: 'content',
    funnelStage: e.data.funnelStage || 'awareness',
    pipeline: 'shipped',
    persona: slug,
    source: 'blog',
    confidence: 'medium',
  }
})

// Cap blog display at 25, show count of remaining
const LINEUP_CAP = 25
const cappedBlogPosts = allPersonaBlogPosts.slice(0, LINEUP_CAP)
const hiddenBlogCount = allPersonaBlogPosts.length - cappedBlogPosts.length
const totalBlogCount = allPersonaBlogPosts.length
const hasBlogPosts = totalBlogCount > 0

// Untagged posts backlog
const untaggedCount = blogEntries.filter((e: any) => isUntagged(e.data.tags || [])).length

const allPersonaPages = [...staticPersonaPages, ...cappedBlogPosts]

const awarenessPages = allPersonaPages.filter((p) => p.funnelStage === 'awareness')
const considerationPages = allPersonaPages.filter((p) => p.funnelStage === 'consideration')
const purchasePages = allPersonaPages.filter((p) => p.funnelStage === 'purchase')
const postPurchasePages = allPersonaPages.filter((p) => p.funnelStage === 'post-purchase')

// JTBD gaps for page inventory
const jtbdGaps = persona.jtbd.filter((j) => j.status === 'gap')

// Funnel stage groups for iteration
const funnelGroups = [
  { label: 'Awareness', pages: awarenessPages },
  { label: 'Consideration', pages: considerationPages },
  { label: 'Purchase', pages: purchasePages },
  { label: 'Post-purchase', pages: postPurchasePages },
]

// Mission progress
const missionProgress =
  persona.mission.target > 0 ? Math.round((persona.mission.done / persona.mission.target) * 100) : 0

// Coverage percentages for the segmented bar
const coveredPct = coverage.total > 0 ? (coverage.covered / coverage.total) * 100 : 0
const partialPct = coverage.total > 0 ? (coverage.partial / coverage.total) * 100 : 0
const gapPct = coverage.total > 0 ? (coverage.gap / coverage.total) * 100 : 0

// Pipeline label helper
function pipelineLabel(pipeline?: string): string {
  const map: Record<string, string> = {
    'no-copy': 'No Copy',
    'copy-draft': 'Copy Draft',
    'copy-approved': 'Copy Approved',
    built: 'Built',
    'design-review': 'Design Review',
    shipped: 'Shipped',
  }
  return pipeline ? map[pipeline] || pipeline : 'Not started'
}

function pipelineClass(pipeline?: string): string {
  if (!pipeline) return 'badge-neutral'
  if (pipeline === 'shipped') return 'badge-success'
  if (pipeline === 'built' || pipeline === 'design-review') return 'badge-warning'
  return 'badge-neutral'
}
---

<AdminLayout title={`${persona.name} Command Center`} activeNav="/admin/personas">
  <!-- ================================================================== -->
  <!-- SECTION 1: Mission Banner                                          -->
  <!-- ================================================================== -->
  <div
    class="mission-banner"
    style={`background: ${persona.bgColor}; border-left: 4px solid ${persona.color};`}
  >
    <div class="mission-content">
      <div class="mission-label" style={`color: ${persona.color};`}>MISSION (next 30 days)</div>
      <div class="mission-text">{persona.mission.text}</div>
      <div class="mission-meta">
        <span class="mission-deadline">Deadline: {persona.mission.deadline}</span>
      </div>
    </div>
    <div class="mission-progress">
      <div class="mission-progress-label">
        {persona.mission.done}/{persona.mission.target} assets shipped
      </div>
      <div class="mission-progress-bar">
        <div
          class="mission-progress-fill"
          style={`width: ${missionProgress}%; background: ${persona.color};`}
        >
        </div>
      </div>
    </div>
  </div>

  <!-- ================================================================== -->
  <!-- SECTION 2: Narrative + JTBD Meter                                  -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Narrative + JTBD Coverage</div>

    <div class="narrative-callout" style={`border-left: 3px solid ${persona.color};`}>
      {persona.narrative}
    </div>

    <div class="jtbd-meter">
      <div class="jtbd-meter-header">
        <span class="jtbd-meter-title">Jobs covered: {coverage.covered} / {coverage.total}</span>
        <span class="jtbd-meter-breakdown">
          <span class="jtbd-legend-dot" style="background: #16a34a;"></span>
          {coverage.covered} covered
          <span class="jtbd-legend-dot" style="background: #f59e0b;"></span>
          {coverage.partial} partial
          <span class="jtbd-legend-dot" style="background: #ef4444;"></span>
          {coverage.gap} gap
        </span>
      </div>
      <div class="jtbd-bar">
        {
          coveredPct > 0 && (
            <div class="jtbd-bar-segment jtbd-bar-covered" style={`flex: ${coveredPct};`} />
          )
        }
        {
          partialPct > 0 && (
            <div class="jtbd-bar-segment jtbd-bar-partial" style={`flex: ${partialPct};`} />
          )
        }
        {gapPct > 0 && <div class="jtbd-bar-segment jtbd-bar-gap" style={`flex: ${gapPct};`} />}
      </div>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 3: Last Touched Activity Strip                             -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Last Touched</div>

    {
      persona.lastActivity.length > 0 ? (
        <div class="activity-strip">
          {persona.lastActivity.map((act) => (
            <div class="activity-item">
              <span class="activity-label">{act.label}</span>
              <span class="activity-date">({relativeDate(act.date)})</span>
            </div>
          ))}
        </div>
      ) : (
        <div class="activity-strip">
          <div class="activity-item activity-empty">
            No activity recorded yet for {persona.name}.
          </div>
        </div>
      )
    }
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 4: Stats Row                                               -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Key Stats</div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-value">{Math.round(persona.weight * 100)}%</div>
        <div class="stat-label">Weight</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{persona.customerCount.toLocaleString()}</div>
        <div class="stat-label">Customer Count</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">
          ${
            persona.avgLTV.toLocaleString(undefined, {
              minimumFractionDigits: 2,
              maximumFractionDigits: 2,
            })
          }
        </div>
        <div class="stat-label">Avg LTV</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{persona.revenueGoalPct}%</div>
        <div class="stat-label">Revenue Goal Share</div>
      </div>
    </div>

    <div class="stat-lander-link">
      <a href={persona.landerUrl} class="btn btn-secondary">View {persona.name} Lander &rarr;</a>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 5: Funnel Snapshot                                          -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Funnel Snapshot</div>

    {
      hasCDPData ? (
        <div class="cdp-metrics-grid">
          <div class="cdp-metric">
            <div class="cdp-metric-value">{cdpMetrics.customerCount}</div>
            <div class="cdp-metric-label">Customers</div>
          </div>
          <div class="cdp-metric">
            <div class="cdp-metric-value">{cdpMetrics.active90d}</div>
            <div class="cdp-metric-label">Active (90d)</div>
          </div>
          <div class="cdp-metric">
            <div class="cdp-metric-value">{cdpMetrics.repeatBuyers}</div>
            <div class="cdp-metric-label">Repeat Buyers</div>
          </div>
          <div class="cdp-metric">
            <div class="cdp-metric-value">{cdpMetrics.repeatRatePct}%</div>
            <div class="cdp-metric-label">Repeat Rate</div>
          </div>
          <div class="cdp-metric">
            <div class="cdp-metric-value">{cdpMetrics.dormant60_180d}</div>
            <div class="cdp-metric-label">Dormant (60-180d)</div>
          </div>
          <div class="cdp-metric">
            <div class="cdp-metric-value">{cdpMetrics.dormant180Plus}</div>
            <div class="cdp-metric-label">Dormant (180d+)</div>
          </div>
          <div class="cdp-metric">
            <div class="cdp-metric-value">${cdpMetrics.totalRevenue?.toLocaleString()}</div>
            <div class="cdp-metric-label">Total Revenue</div>
          </div>
          <div class="cdp-metric">
            <div class="cdp-metric-value">{cdpMetrics.avgDaysSinceOrder}d</div>
            <div class="cdp-metric-label">Avg Days Since Order</div>
          </div>
        </div>
      ) : (
        <div class="placeholder-card">
          <div class="placeholder-icon">&#x1F50C;</div>
          <div class="placeholder-text">
            Run <code>node scripts/cdp/persona-metrics.js --json</code> in mothership to populate.
          </div>
          <details class="placeholder-details">
            <summary>What this will unlock</summary>
            <ul>
              <li>Customer count, active/dormant split, repeat rate</li>
              <li>Total revenue, avg days since order</li>
              <li>Play target sizing with real numbers</li>
            </ul>
          </details>
        </div>
      )
    }
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 6: Radar Chart (PLACEHOLDER)                               -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Coverage Radar</div>

    <div class="placeholder-card">
      <div class="placeholder-icon">&#x1F50C;</div>
      <div class="placeholder-text">Radar chart: Are we serving {persona.name} evenly?</div>
      <p class="placeholder-note">
        6 spokes: Awareness, Consideration, Purchase, Post-purchase, E-E-A-T/Trust, Technical
        Quality. Derived from site audit badges on persona-tagged pages.
      </p>
      <details class="placeholder-details">
        <summary>What this will unlock</summary>
        <ul>
          <li>Visual balance check across funnel stages</li>
          <li>Spot overweight awareness vs underweight post-purchase</li>
          <li>Weighted by traffic and revenue when CDP data available</li>
        </ul>
      </details>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 7: Demographics                                            -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Demographics</div>

    <div class="demo-grid">
      <div class="demo-item">
        <div class="demo-label">Age</div>
        <div class="demo-value">{persona.demographics.age}</div>
      </div>
      <div class="demo-item">
        <div class="demo-label">Income</div>
        <div class="demo-value">{persona.demographics.income}</div>
      </div>
      <div class="demo-item">
        <div class="demo-label">Location</div>
        <div class="demo-value">{persona.demographics.location}</div>
      </div>
      <div class="demo-item">
        <div class="demo-label">Operation</div>
        <div class="demo-value">{persona.demographics.operation}</div>
      </div>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 8: Values & Fears                                          -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Values &amp; Fears</div>

    <div class="two-col">
      <div class="col-card">
        <div class="col-card-title">Values</div>
        <ul class="col-list">
          {persona.values.map((v) => <li>{v}</li>)}
        </ul>
      </div>
      <div class="col-card">
        <div class="col-card-title">Fears</div>
        <ul class="col-list">
          {persona.fears.map((f) => <li>{f}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 9: Pain Points + JTBD Detail                               -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Pain Points + Jobs to Be Done</div>

    {
      nextMove && (
        <div class="next-move-callout" style={`border-left: 3px solid ${persona.color};`}>
          <div class="next-move-label">Next Best Move</div>
          <div class="next-move-text">
            For {persona.name} this week: Fill JTBD{' '}
            {nextMove.status === 'gap' ? 'gap' : 'partial gap'} &ldquo;{nextMove.statement}&rdquo;
            with a mid-funnel article.
          </div>
        </div>
      )
    }

    <div class="pain-points-box">
      <div class="col-card-title">Pain Points</div>
      <ul class="col-list">
        {persona.painPoints.map((pp) => <li>{pp}</li>)}
      </ul>
    </div>

    <div class="jtbd-detail">
      <div class="col-card-title">JTBD Checklist</div>
      <div class="jtbd-list">
        {
          persona.jtbd.map((job) => (
            <div class="jtbd-item">
              <span class={`jtbd-status-icon jtbd-status-${job.status}`}>
                {job.status === 'covered'
                  ? '\u2713'
                  : job.status === 'partial'
                    ? '\u25CB'
                    : '\u2717'}
              </span>
              <span class="jtbd-statement">{job.statement}</span>
              <span
                class={`badge ${job.status === 'covered' ? 'badge-success' : job.status === 'partial' ? 'badge-warning' : 'badge-error'}`}
              >
                {job.status}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 10: Buying Triggers & Objections                           -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Buying Triggers &amp; Objections</div>

    <div class="two-col">
      <div class="col-card">
        <div class="col-card-title">Buying Triggers</div>
        <ul class="col-list">
          {persona.buyingTriggers.map((bt) => <li>{bt}</li>)}
        </ul>
      </div>
      <div class="col-card">
        <div class="col-card-title">Objections</div>
        <ul class="col-list">
          {persona.objections.map((obj) => <li>{obj}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 11: Trust Hierarchy                                        -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Trust Hierarchy</div>

    <div class="trust-list-card">
      <ol class="trust-list">
        {persona.trustHierarchy.map((item) => <li>{item}</li>)}
      </ol>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 12: Communication, Language & Copy Sandbox                  -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Communication, Language &amp; Copy Sandbox</div>

    <div class="two-col">
      <div class="col-card">
        <div class="col-card-title">Preferred Channels</div>
        <ul class="col-list">
          {persona.preferredChannels.map((ch) => <li>{ch}</li>)}
        </ul>
      </div>
      <div class="col-card">
        <div class="col-card-title">Content Preferences</div>
        <ul class="col-list">
          {persona.contentPreferences.map((cp) => <li>{cp}</li>)}
        </ul>
      </div>
    </div>

    <div class="language-section">
      <div class="col-card-title">Language Rules</div>
      <table class="language-table">
        <thead>
          <tr>
            <th class="lang-use-header">Use</th>
            <th class="lang-avoid-header">Avoid</th>
          </tr>
        </thead>
        <tbody>
          {
            Array.from({
              length: Math.max(
                persona.languageRules.use.length,
                persona.languageRules.avoid.length
              ),
            }).map((_, i) => (
              <tr>
                <td class="lang-use-cell">{persona.languageRules.use[i] || ''}</td>
                <td class="lang-avoid-cell">{persona.languageRules.avoid[i] || ''}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="skepticism-section">
      <div class="col-card-title">Skepticism Triggers</div>
      <ul class="col-list">
        {persona.skepticismTriggers.map((st) => <li>{st}</li>)}
      </ul>
    </div>

    <div class="copy-sandbox-section">
      <div class="col-card-title">Copy Sandbox</div>
      <p class="sandbox-description">
        Paste a draft headline or intro below. The checklist will light up based on {
          persona.name
        }&apos;s language rules.
      </p>
      <textarea
        id="copy-sandbox-input"
        class="sandbox-textarea"
        placeholder={`Paste draft copy for ${persona.name} here...`}
        rows="4"></textarea>
      <div class="sandbox-rules-grid">
        <div class="sandbox-rules-col">
          <div class="sandbox-rules-title sandbox-use-title">Use words found</div>
          <div id="sandbox-use-results" class="sandbox-results">
            {
              persona.languageRules.use.map((word) => (
                <div class="sandbox-rule-item" data-sandbox-use={word.toLowerCase()}>
                  <span class="sandbox-rule-icon sandbox-rule-inactive">&mdash;</span>
                  <span class="sandbox-rule-word">{word}</span>
                </div>
              ))
            }
          </div>
        </div>
        <div class="sandbox-rules-col">
          <div class="sandbox-rules-title sandbox-avoid-title">Avoid words found</div>
          <div id="sandbox-avoid-results" class="sandbox-results">
            {
              persona.languageRules.avoid.map((word) => (
                <div class="sandbox-rule-item" data-sandbox-avoid={word.toLowerCase()}>
                  <span class="sandbox-rule-icon sandbox-rule-inactive">&mdash;</span>
                  <span class="sandbox-rule-word">{word}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 13: Top Products + Persona x Product Matrix                 -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Top Products</div>

    <div class="product-cards">
      {
        persona.topProducts.map((prod) => (
          <div class="product-card">
            <span class="product-name">{prod.name}</span>
            <span class="product-handle">{prod.handle}</span>
            {prod.roas && <span class="product-roas">{prod.roas}x ROAS</span>}
          </div>
        ))
      }
    </div>

    <div class="placeholder-card" style="margin-top: 16px;">
      <div class="placeholder-icon">&#x1F50C;</div>
      <div class="placeholder-text">Persona x Product Matrix</div>
      <p class="placeholder-note">
        Cross-persona view showing which products are heroes for whom. Surfaces white space where a
        persona&apos;s JTBD has no strong product match.
      </p>
      <details class="placeholder-details">
        <summary>What this will unlock</summary>
        <ul>
          <li>Matrix of all 3 personas vs all products with revenue data</li>
          <li>Identify products with no persona champion</li>
          <li>Surface JTBD-product gaps for new content</li>
        </ul>
      </details>
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 14: Page Inventory ("The Lineup")                           -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">The Lineup &mdash; Page Inventory</div>
    <p class="section-description">
      {staticPersonaPages.length + totalBlogCount} pages serving {persona.name}
      {hasBlogPosts ? ` (${totalBlogCount} blog, ${staticPersonaPages.length} site)` : ''}.
      {hiddenBlogCount > 0 ? ` Showing top ${LINEUP_CAP} blog posts by date.` : ''}
    </p>

    {
      !hasBlogPosts && slug === 'betty' && (
        <div class="lineup-notice">
          No blog posts explicitly targeting Backyard Betty yet. Add a <code>Backyard Poultry</code>{' '}
          tag to blog posts written for small flock owners.
        </div>
      )
    }

    {
      !hasBlogPosts && !allPersonaBlogPosts.length && slug !== 'betty' && (
        <div class="lineup-notice">
          No blog posts matched for {persona.name}. Posts are matched by tags (
          {slug === 'taylor' ? 'Turf' : 'Poultry'}).
        </div>
      )
    }

    <table class="lineup-table">
      <thead>
        <tr>
          <th class="lt-page">Page</th>
          <th class="lt-route">Route</th>
          <th class="lt-source">Source</th>
          <th class="lt-type">Type</th>
          <th class="lt-pipeline">Pipeline</th>
          <th class="lt-health">Health</th>
        </tr>
      </thead>
      <tbody>
        {
          funnelGroups.map((group) => (
            <>
              <tr class="lt-stage-row">
                <td colspan="6">
                  <span class="lt-stage-label">{group.label}</span>
                  <span class="lt-stage-count">{group.pages.length}</span>
                </td>
              </tr>
              {group.pages.length > 0 ? (
                group.pages.map((page) => (
                  <tr class="lt-page-row">
                    <td class="lt-page">
                      <a href={page.route} target="_blank">
                        {page.name}
                      </a>
                    </td>
                    <td class="lt-route">
                      <code>{page.route}</code>
                    </td>
                    <td class="lt-source">
                      <span class={`source-label source-${page.source}`}>{page.source}</span>
                    </td>
                    <td class="lt-type">{page.pageType}</td>
                    <td class="lt-pipeline">
                      <span class={`pipeline-text ${pipelineClass(page.pipeline)}`}>
                        {pipelineLabel(page.pipeline)}
                      </span>
                    </td>
                    <td class="lt-health">&mdash;</td>
                  </tr>
                ))
              ) : (
                <tr class="lt-empty-row">
                  <td colspan="6">No pages at this stage yet.</td>
                </tr>
              )}
              {jtbdGaps.map((gap) => (
                <tr class="lt-gap-row">
                  <td colspan="6">No content for: &ldquo;{gap.statement}&rdquo;</td>
                </tr>
              ))}
            </>
          ))
        }
      </tbody>
    </table>

    {
      hiddenBlogCount > 0 && (
        <div class="lineup-more">
          + {hiddenBlogCount} more blog posts not shown.{' '}
          <a href="/admin/site-audit">View all in Site Audit</a>
        </div>
      )
    }

    {
      untaggedCount > 0 && (
        <div class="lineup-untagged">
          {untaggedCount} blog posts have no tags and can't be assigned to any persona.
        </div>
      )
    }
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 15: Plays                                                   -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Plays</div>

    <div class="plays-grid">
      {
        persona.plays.map((play) => (
          <div class="play-card">
            <div class="play-title">{play.title}</div>
            <div class="play-description">{play.description}</div>
            <div class="play-estimates">
              {play.targetEstimate && (
                <span class="play-estimate-item">
                  <span class="play-estimate-label">Target:</span> {play.targetEstimate}
                </span>
              )}
              {play.expectedLift && (
                <span class="play-estimate-item">
                  <span class="play-estimate-label">Expected lift:</span> {play.expectedLift}
                </span>
              )}
            </div>
            <div class="play-actions">
              <button class="btn btn-secondary" disabled>
                Export Audience
              </button>
              <button class="btn btn-secondary" disabled>
                Generate Brief
              </button>
              <button class="btn btn-secondary" disabled>
                Create UTM Bundle
              </button>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ================================================================== -->
  <!-- SECTION 16: Persona Drift + Message Winners (PLACEHOLDERS)          -->
  <!-- ================================================================== -->
  <section class="section">
    <div class="section-header">Persona Drift &amp; Message Winners</div>

    <div class="two-col">
      <div class="placeholder-card">
        <div class="placeholder-icon">&#x1F50C;</div>
        <div class="placeholder-text">Persona Drift</div>
        <p class="placeholder-note">
          X% of {persona.name} sessions in last 90d browsed other persona content.
        </p>
        <details class="placeholder-details">
          <summary>What this will unlock</summary>
          <ul>
            <li>Drift percentage showing cross-persona browsing</li>
            <li>Which other persona content {persona.name} visitors consume</li>
            <li>Signals for persona misclassification or multi-persona customers</li>
          </ul>
        </details>
      </div>
      <div class="placeholder-card">
        <div class="placeholder-icon">&#x1F50C;</div>
        <div class="placeholder-text">Message Winners</div>
        <p class="placeholder-note">Top-performing phrases and angles for {persona.name}.</p>
        <details class="placeholder-details">
          <summary>What this will unlock</summary>
          <ul>
            <li>Best-performing ad headlines by CTR and conversion</li>
            <li>Email subject lines with highest open rates</li>
            <li>Blog titles driving the most organic traffic</li>
            <li>Copy patterns to replicate across channels</li>
          </ul>
        </details>
      </div>
    </div>
  </section>

  <!-- Copy Sandbox Script -->
  <script is:inline>
    ;(function () {
      var textarea = document.getElementById('copy-sandbox-input')
      if (!textarea) return

      var useItems = document.querySelectorAll('[data-sandbox-use]')
      var avoidItems = document.querySelectorAll('[data-sandbox-avoid]')

      textarea.addEventListener('input', function () {
        var text = textarea.value.toLowerCase()

        useItems.forEach(function (el) {
          var word = el.getAttribute('data-sandbox-use')
          var icon = el.querySelector('.sandbox-rule-icon')
          if (text.indexOf(word) !== -1) {
            icon.textContent = '\u2713'
            icon.className = 'sandbox-rule-icon sandbox-rule-found-use'
          } else {
            icon.textContent = '\u2014'
            icon.className = 'sandbox-rule-icon sandbox-rule-inactive'
          }
        })

        avoidItems.forEach(function (el) {
          var word = el.getAttribute('data-sandbox-avoid')
          var icon = el.querySelector('.sandbox-rule-icon')
          if (text.indexOf(word) !== -1) {
            icon.textContent = '\u2717'
            icon.className = 'sandbox-rule-icon sandbox-rule-found-avoid'
          } else {
            icon.textContent = '\u2014'
            icon.className = 'sandbox-rule-icon sandbox-rule-inactive'
          }
        })
      })
    })()
  </script>
</AdminLayout>

