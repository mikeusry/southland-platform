---
/**
 * Persona Pipeline — Table-based pipeline view
 *
 * Design pattern: Underline tabs from southland-inventory quotes page.
 * Pipeline table with left-border accent, JTBD bar, status token, next move.
 * Click row → navigate to /admin/personas/[slug]/
 */
import AdminLayout from '../../../layouts/AdminLayout.astro'
import {
  PERSONAS,
  getJTBDCoverage,
  getNextBestMove,
} from '../../../lib/persona-profiles'
import { PAGE_GROUPS } from '../../../lib/site-audit-pages'
import type { PersonaProfile } from '../../../lib/persona-profiles'

export const prerender = true

// ── Segment definitions ─────────────────────────────────────────────────────
const SEGMENTS = [
  { key: 'all', label: 'All' },
  { key: 'poultry', label: 'Poultry', slugs: ['bill', 'betty', 'bob', 'tom', 'greg'] },
  { key: 'turf', label: 'Turf & Soil', slugs: ['taylor', 'gary', 'hannah', 'maggie'] },
  { key: 'waste', label: 'Waste', slugs: ['sam'] },
]

// ── Lander status derivation ────────────────────────────────────────────────
type LanderStatus = 'live' | 'building' | 'greenfield'

function getLanderStatus(p: PersonaProfile): LanderStatus {
  const hasShipped = p.lastActivity.some((a) => a.label.toLowerCase().includes('shipped') || a.label.toLowerCase().includes('lander page built'))
  if (hasShipped) return 'live'
  if (p.mission.done > 0) return 'building'
  return 'greenfield'
}

const STATUS_TOKEN: Record<LanderStatus, { label: string; bg: string; text: string; border: string }> = {
  live:       { label: 'Live',       bg: '#ecfdf5', text: '#065f46', border: '#a7f3d0' },
  building:   { label: 'Building',   bg: '#fffbeb', text: '#92400e', border: '#fde68a' },
  greenfield: { label: 'Greenfield', bg: '#fef2f2', text: '#991b1b', border: '#fecaca' },
}

// ── JTBD health color for left border ───────────────────────────────────────
function getHealthColor(p: PersonaProfile): string {
  const c = getJTBDCoverage(p)
  const coveredRatio = c.covered / c.total
  if (coveredRatio >= 0.5) return '#10b981'
  if (coveredRatio >= 0.2) return '#f59e0b'
  return '#ef4444'
}

// ── Compute page counts ─────────────────────────────────────────────────────
const personaPageCounts: Record<string, number> = {}
for (const persona of PERSONAS) {
  let count = 0
  for (const group of PAGE_GROUPS) {
    for (const page of group.pages) {
      if (page.persona === persona.slug) count++
    }
  }
  personaPageCounts[persona.slug] = count
}

// ── Build row data ──────────────────────────────────────────────────────────
const rows = PERSONAS.map((p) => {
  const coverage = getJTBDCoverage(p)
  const coveredPct = (coverage.covered / coverage.total) * 100
  const partialPct = (coverage.partial / coverage.total) * 100
  const gapPct = (coverage.gap / coverage.total) * 100
  const status = getLanderStatus(p)
  const nextMove = getNextBestMove(p)
  const healthColor = getHealthColor(p)
  const segment = SEGMENTS.find((s) => s.slugs?.includes(p.slug))?.key ?? 'all'

  return {
    ...p,
    coverage,
    coveredPct,
    partialPct,
    gapPct,
    status,
    nextMove,
    healthColor,
    segment,
    pageCount: personaPageCounts[p.slug] ?? 0,
  }
})

// ── Summary metrics ─────────────────────────────────────────────────────────
const liveCount = rows.filter((r) => r.status === 'live').length
const buildingCount = rows.filter((r) => r.status === 'building').length
const greenfieldCount = rows.filter((r) => r.status === 'greenfield').length
const totalCustomers = rows.reduce((sum, r) => sum + r.customerCount, 0)
const totalJobs = rows.reduce((sum, r) => sum + r.coverage.total, 0)
const coveredJobs = rows.reduce((sum, r) => sum + r.coverage.covered, 0)
---

<AdminLayout title="Personas">
  <div class="pipeline-page">

    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <header class="page-header">
      <h1>Persona Pipeline</h1>
      <p class="subtitle">{rows.length} personas &middot; {liveCount} live &middot; {buildingCount} building &middot; {greenfieldCount} greenfield &middot; {totalCustomers.toLocaleString()} customers &middot; {coveredJobs}/{totalJobs} jobs covered</p>
    </header>

    <!-- ── Underline tabs ──────────────────────────────────────────────── -->
    <nav class="tab-bar">
      <div class="tab-group" data-group="segment">
        {SEGMENTS.map((seg) => {
          const count = seg.key === 'all' ? rows.length : rows.filter((r) => r.segment === seg.key).length
          return (
            <button
              class="tab"
              data-filter={seg.key}
              aria-selected={seg.key === 'all' ? 'true' : 'false'}
            >
              {seg.label} ({count})
            </button>
          )
        })}
      </div>
      <div class="tab-group" data-group="status">
        <button class="tab" data-status="all" aria-selected="true">All</button>
        <button class="tab" data-status="live">Live ({liveCount})</button>
        <button class="tab" data-status="building">Building ({buildingCount})</button>
        <button class="tab" data-status="greenfield">Greenfield ({greenfieldCount})</button>
      </div>
    </nav>

    <!-- ── Pipeline table ──────────────────────────────────────────────── -->
    <div class="table-wrap">
      <table class="pipeline-table">
        <thead>
          <tr>
            <th class="col-persona">Persona</th>
            <th class="col-num">Weight</th>
            <th class="col-num">Customers</th>
            <th class="col-num">Avg LTV</th>
            <th class="col-jtbd">JTBD Coverage</th>
            <th class="col-num hide-mobile">Pages</th>
            <th class="col-status">Status</th>
            <th class="col-next">Next Move</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => {
            const tok = STATUS_TOKEN[r.status]
            return (
              <tr
                class="pipeline-row"
                data-segment={r.segment}
                data-status={r.status}
                data-href={`/admin/personas/${r.slug}/`}
                style={`border-left: 4px solid ${r.healthColor}`}
              >
                <td class="col-persona">
                  <a href={`/admin/personas/${r.slug}/`} class="persona-name">{r.name}</a>
                  <span class="persona-tagline">{r.tagline}</span>
                </td>
                <td class="col-num">
                  <span class="num-primary">{(r.weight * 100).toFixed(0)}%</span>
                </td>
                <td class="col-num">
                  <span class="num-primary">{r.customerCount.toLocaleString()}</span>
                </td>
                <td class="col-num">
                  <span class="num-primary">${r.avgLTV.toFixed(0)}</span>
                </td>
                <td class="col-jtbd">
                  <div class="jtbd-bar">
                    <div class="jtbd-seg seg-covered" style={`width: ${r.coveredPct}%`} />
                    <div class="jtbd-seg seg-partial" style={`width: ${r.partialPct}%`} />
                    <div class="jtbd-seg seg-gap" style={`width: ${r.gapPct}%`} />
                  </div>
                  <span class="jtbd-label">{r.coverage.covered}/{r.coverage.total}</span>
                </td>
                <td class="col-num hide-mobile">
                  <span class="num-secondary">{r.pageCount}</span>
                </td>
                <td class="col-status">
                  <span
                    class="status-token"
                    style={`background: ${tok.bg}; color: ${tok.text}; border-color: ${tok.border}`}
                  >
                    {tok.label}
                  </span>
                </td>
                <td class="col-next">
                  {r.nextMove ? (
                    <span class="next-text">{r.nextMove.statement}</span>
                  ) : (
                    <span class="next-none">All covered</span>
                  )}
                </td>
              </tr>
            )
          })}
        </tbody>
      </table>
    </div>

  </div>
</AdminLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    let activeSegment = 'all'
    let activeStatus = 'all'

    const rows = document.querySelectorAll<HTMLTableRowElement>('.pipeline-row')
    const segTabs = document.querySelectorAll<HTMLButtonElement>('[data-group="segment"] .tab')
    const statusTabs = document.querySelectorAll<HTMLButtonElement>('[data-group="status"] .tab')

    function applyFilters() {
      rows.forEach((row) => {
        const seg = row.dataset.segment
        const status = row.dataset.status
        const segMatch = activeSegment === 'all' || seg === activeSegment
        const statusMatch = activeStatus === 'all' || status === activeStatus
        row.style.display = segMatch && statusMatch ? '' : 'none'
      })
    }

    segTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeSegment = tab.dataset.filter!
        segTabs.forEach((t) => t.setAttribute('aria-selected', 'false'))
        tab.setAttribute('aria-selected', 'true')
        applyFilters()
      })
    })

    statusTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activeStatus = tab.dataset.status!
        statusTabs.forEach((t) => t.setAttribute('aria-selected', 'false'))
        tab.setAttribute('aria-selected', 'true')
        applyFilters()
      })
    })

    rows.forEach((row) => {
      row.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) return
        const href = row.dataset.href
        if (href) window.location.href = href
      })
    })
  })
</script>

<style>
  .pipeline-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .page-header {
    margin-bottom: 1rem;
  }

  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.25rem;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 0.82rem;
    margin: 0;
  }

  /* ── Underline tabs ──────────────────────────────────────────────────────── */
  .tab-bar {
    display: flex;
    gap: 2rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
    flex-wrap: wrap;
  }

  .tab-group {
    display: flex;
    gap: 0.125rem;
  }

  .tab {
    padding: 0.5rem 0.75rem;
    margin-bottom: -1px;
    border: none;
    border-bottom: 2px solid transparent;
    background: none;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .tab:hover {
    color: var(--text);
  }

  .tab[aria-selected="true"] {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  /* ── Pipeline table ──────────────────────────────────────────────────────── */
  .table-wrap {
    overflow-x: auto;
    background: #fff;
  }

  .pipeline-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .pipeline-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
  }

  .pipeline-table th {
    background: var(--surface, #f9fafb);
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 0.75rem;
    text-align: left;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .pipeline-table th.col-num {
    text-align: right;
  }

  .pipeline-table td {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .pipeline-row {
    cursor: pointer;
    transition: background 0.1s ease;
  }

  .pipeline-row:hover {
    background: var(--surface, #f9fafb);
  }

  .pipeline-row:last-child td {
    border-bottom: none;
  }

  /* ── Persona cell ────────────────────────────────────────────────────────── */
  .persona-name {
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    display: block;
    line-height: 1.3;
  }

  .persona-name:hover {
    text-decoration: underline;
  }

  .persona-tagline {
    display: block;
    font-size: 0.72rem;
    color: var(--text-tertiary);
    line-height: 1.3;
    max-width: 280px;
  }

  /* ── Number cells ────────────────────────────────────────────────────────── */
  .col-num {
    text-align: right;
    white-space: nowrap;
  }

  .num-primary {
    font-weight: 600;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .num-secondary {
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }

  /* ── JTBD coverage column ────────────────────────────────────────────────── */
  .col-jtbd {
    min-width: 110px;
  }

  .jtbd-bar {
    display: flex;
    height: 6px;
    border-radius: 3px;
    overflow: hidden;
    background: var(--border);
    margin-bottom: 0.2rem;
  }

  .jtbd-seg { height: 100%; }
  .seg-covered { background: #16a34a; }
  .seg-partial { background: #d97706; }
  .seg-gap { background: #dc2626; }

  .jtbd-label {
    font-size: 0.68rem;
    color: var(--text-tertiary);
  }

  /* ── Status TOKEN ────────────────────────────────────────────────────────── */
  .status-token {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid;
    white-space: nowrap;
  }

  /* ── Next move column ────────────────────────────────────────────────────── */
  .col-next {
    max-width: 240px;
  }

  .next-text {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .next-none {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    font-style: italic;
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .hide-mobile { display: none; }
    .persona-tagline { display: none; }
    .col-next { display: none; }
  }
</style>
