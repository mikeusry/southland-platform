<script is:inline>
  // =========================================================================
  // CONFIG
  // =========================================================================

  var STORAGE_KEY = 'southland_site_audit'
  var CURRENT_SCAN_VERSION = 2

  // =========================================================================
  // STATE
  // =========================================================================

  var scanCancelled = false
  var sessionScanCount = 0
  var scanResults = {}

  function loadState() {
    try {
      var saved = localStorage.getItem(STORAGE_KEY)
      return saved ? JSON.parse(saved) : {}
    } catch (e) {
      return {}
    }
  }

  function saveState(state) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state))
  }

  // =========================================================================
  // ROW STATUS — now includes blocked state
  // =========================================================================

  function getRowStatus(pipeline, blocker) {
    if (blocker) return 'blocked'
    if (pipeline === 'shipped') return 'approved'
    if (pipeline && pipeline !== 'no-copy') return 'in-review'
    return 'not-started'
  }

  function updateProgress() {
    var state = loadState()
    var rows = document.querySelectorAll('.table-row')
    var shipped = 0, inPipeline = 0, blocked = 0, notStarted = 0

    rows.forEach(function(row) {
      var route = row.dataset.route
      var data = state[route] || {}
      var blocker = data.blocker || row.dataset.blocker || ''
      var pipelineEl = row.querySelector('[data-field="pipeline"]')
      var pipeline = data.pipeline || (pipelineEl && pipelineEl.value) || 'no-copy'
      var status = getRowStatus(pipeline, blocker)
      var dot = row.querySelector('[data-status-dot]')
      if (dot) dot.className = 'status-dot ' + status

      if (status === 'approved') shipped++
      else if (status === 'blocked') blocked++
      else if (status === 'in-review') inPipeline++
      else notStarted++

      // Pipeline select styling
      var pipelineSelect = row.querySelector('.pipeline-select')
      if (pipelineSelect) {
        pipelineSelect.className = 'pipeline-select'
        if (pipeline !== 'no-copy') pipelineSelect.classList.add('stage-' + pipeline)
      }

      // Blocker select styling
      var blockerSelect = row.querySelector('.blocker-select')
      if (blockerSelect) {
        blockerSelect.className = 'blocker-select'
        if (blocker) blockerSelect.classList.add('has-blocker')
      }

      updateChecks(row, data)
      updateCRO(row, data)
      updateReviewed(row, data)
    })

    var total = rows.length
    var percent = total > 0 ? Math.round((shipped / total) * 100) : 0
    document.getElementById('shipped-count').textContent = shipped
    document.getElementById('pipeline-count').textContent = inPipeline
    document.getElementById('blocked-count').textContent = blocked
    document.getElementById('pending-count').textContent = notStarted
    document.getElementById('progress-bar').style.width = percent + '%'
    document.getElementById('progress-percent').textContent = percent + '%'

    updateIntegrationStats()
  }

  // =========================================================================
  // CHECKS — expanded checklist with named items
  // =========================================================================

  function updateChecks(row, data) {
    var checksEl = row.querySelector('.checks-detail')
    if (!checksEl) return

    var pageType = row.dataset.pageType
    var pipeline = data.pipeline || 'no-copy'

    if (pipeline === 'no-copy' || pipeline === 'copy-draft' || pipeline === 'copy-approved') {
      checksEl.innerHTML = '<span style="color:var(--text-tertiary)">--</span>'
      return
    }

    var checks = data.checks || {}
    var parts = []

    if (pageType === 'lander') {
      parts.push(checkItem('CTA', checks.ctaPersonaTrue))
      parts.push(checkItem('Proof', checks.proofPresent))
      parts.push(checkItem('Rhythm', checks.rhythmCorrect))
      parts.push(checkItem('Eveleth', checks.evelethUppercase))
      parts.push(checkItem('DualCTA', checks.dualCta))
      parts.push(checkItem('Funnel', checks.noOrphan))
    } else if (pageType === 'collection') {
      parts.push(checkItem('Trust', checks.trustStrip))
      parts.push(checkItem('Qualify', checks.qualificationBullets))
      parts.push(checkItem('Funnel', checks.noOrphan))
    } else if (pageType === 'pdp') {
      parts.push(checkItem('Proof', checks.proofPresent))
      parts.push(checkItem('Guarantee', checks.guaranteeNearCta))
      parts.push(checkItem('Funnel', checks.noOrphan))
    } else {
      checksEl.innerHTML = '<span style="color:var(--text-tertiary)">--</span>'
      return
    }

    checksEl.innerHTML = parts.join(' ')
  }

  function checkItem(label, value) {
    if (value === undefined) return '<span class="check-warn">' + label + '?</span>'
    if (value) return '<span class="check-pass">' + label + '\u2713</span>'
    return '<span class="check-fail">' + label + '\u2717</span>'
  }

  // =========================================================================
  // CRO SCORE — A/B/C grade based on completeness signals
  // =========================================================================

  function updateCRO(row, data) {
    var croEl = row.querySelector('.cro-score')
    if (!croEl) return

    var pageType = row.dataset.pageType
    var pipeline = data.pipeline || 'no-copy'
    var checks = data.checks || {}

    if (pipeline === 'no-copy' || pipeline === 'copy-draft') {
      croEl.textContent = '--'
      croEl.className = 'cro-score'
      return
    }

    var score = 0
    var total = 0

    if (pageType === 'lander') {
      total = 6
      if (checks.ctaPersonaTrue) score++
      if (checks.proofPresent) score++
      if (checks.rhythmCorrect) score++
      if (checks.evelethUppercase) score++
      if (checks.dualCta) score++
      if (checks.noOrphan) score++
    } else if (pageType === 'collection') {
      total = 3
      if (checks.trustStrip) score++
      if (checks.qualificationBullets) score++
      if (checks.noOrphan) score++
    } else if (pageType === 'pdp') {
      total = 3
      if (checks.proofPresent) score++
      if (checks.guaranteeNearCta) score++
      if (checks.noOrphan) score++
    } else {
      croEl.textContent = '--'
      croEl.className = 'cro-score'
      return
    }

    if (total === 0) {
      croEl.textContent = '--'
      croEl.className = 'cro-score'
      return
    }

    var pct = Math.round((score / total) * 100)
    var grade, cls
    if (pct >= 80) { grade = 'A'; cls = 'cro-a' }
    else if (pct >= 50) { grade = 'B'; cls = 'cro-b' }
    else { grade = 'C'; cls = 'cro-c' }

    croEl.textContent = grade
    croEl.className = 'cro-score ' + cls
    croEl.title = score + '/' + total + ' checks (' + pct + '%)'
  }

  // =========================================================================
  // REVIEWED DATE
  // =========================================================================

  function updateReviewed(row, data) {
    var el = row.querySelector('.reviewed-date')
    if (!el) return

    if (data.reviewedAt) {
      var d = new Date(data.reviewedAt)
      var label = (d.getMonth() + 1) + '/' + d.getDate()
      if (data.reviewer) label += ' ' + data.reviewer
      el.textContent = label
      el.className = 'reviewed-date has-date'
      el.title = 'Reviewed ' + d.toLocaleDateString() + (data.reviewer ? ' by ' + data.reviewer : '') + '. Click to update.'
    } else {
      el.textContent = '--'
      el.className = 'reviewed-date'
      el.title = 'Click to mark as reviewed'
    }
  }

  // =========================================================================
  // FILTERING
  // =========================================================================

  function applyFilters() {
    var persona = document.getElementById('filter-persona').value
    var funnel = document.getElementById('filter-funnel').value
    var blocker = document.getElementById('filter-blocker').value
    var priority = document.getElementById('filter-priority').value
    var state = loadState()

    document.querySelectorAll('.table-row').forEach(function(row) {
      var show = true
      if (persona && row.dataset.persona !== persona) show = false
      if (funnel && row.dataset.funnelStage !== funnel) show = false
      if (priority && row.dataset.priority !== priority) show = false
      if (blocker) {
        var data = state[row.dataset.route] || {}
        var rowBlocker = data.blocker || row.dataset.blocker || ''
        if (rowBlocker !== blocker) show = false
      }
      row.classList.toggle('filtered-out', !show)
    })

    // Update group visibility — hide groups with all rows filtered out
    document.querySelectorAll('.audit-group').forEach(function(group) {
      var visibleRows = group.querySelectorAll('.table-row:not(.filtered-out)')
      group.classList.toggle('hidden', visibleRows.length === 0)
    })
  }

  // =========================================================================
  // INTEGRATION STATS
  // =========================================================================

  function updateIntegrationStats() {
    var state = loadState()
    var scanned = 0, totalAlignment = 0, totalEntries = 0

    Object.values(state).forEach(function(data) {
      if (data.scan && data.scan.avgAlignment !== undefined) {
        scanned++
        totalAlignment += data.scan.avgAlignment
        totalEntries += data.scan.scoredCount || 0
      }
    })

    document.getElementById('scanned-count').textContent = scanned
    document.getElementById('avg-alignment').textContent = scanned > 0 ? Math.round(totalAlignment / scanned) + '%' : '--'
    document.getElementById('total-entries').textContent = totalEntries
  }

  // =========================================================================
  // SCAN ROUTE
  // =========================================================================

  function scanRoute(route) {
    return fetch('/api/site-audit/scan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ route: route }),
    })
    .then(function(res) { return res.json() })
    .then(function(result) {
      sessionScanCount++
      if (result && result.entries) scanResults[route] = result
      return result
    })
  }

  // =========================================================================
  // HELPERS
  // =========================================================================

  function getBarClass(pct) {
    if (pct >= 60) return 'high'
    if (pct >= 40) return 'mid'
    return 'low'
  }

  function personaInitial(name) {
    if (!name) return '?'
    return name.split(' ').pop().charAt(0).toUpperCase()
  }

  function badgeColor(alignment) {
    if (alignment >= 60) return 'score-high'
    if (alignment >= 40) return 'score-mid'
    return 'score-low'
  }

  // =========================================================================
  // RENDER SCORE BADGE
  // =========================================================================

  function renderScoreBadge(row, result) {
    var scoreCol = row.querySelector('.col-score')
    if (!result || result.scannable === false) return

    var agg = result.aggregate
    var p = agg.persona
    var label, cls

    if (!p) {
      label = '--'
      cls = 'score-low'
    } else if (p.unclearCount === result.scoredCount) {
      label = '?'
      cls = 'score-confused'
    } else {
      var initial = personaInitial(p.primaryAudience)
      label = initial + ' ' + p.avgAlignment + '%'
      cls = badgeColor(p.avgAlignment)
    }

    scoreCol.innerHTML = '<button class="score-badge ' + cls + '" data-action="toggle-details" title="Click to expand">' + label + '</button>'
  }

  // =========================================================================
  // RENDER DETAIL PANEL
  // =========================================================================

  function renderDetailPanel(route, result) {
    var panel = document.querySelector('[data-details-for="' + route + '"]')
    if (!panel || result.scannable === false) return

    var entries = result.entries || []
    var agg = result.aggregate
    var p = agg.persona
    var q = agg.quality
    var html = ''

    var summary = result.scoredCount + ' entries scanned.'
    if (p) {
      if (p.unclearCount === result.scoredCount) {
        summary += ' No clear audience — content is too generic.'
      } else {
        summary += ' Speaks to <strong>' + p.primaryAudience + '</strong> at ' + p.avgAlignment + '% avg fit.'
        if (q.noInternalLinks > 0) summary += ' ' + q.noInternalLinks + ' have zero internal links.'
        else if (q.stubbedCount > 0) summary += ' ' + q.stubbedCount + ' are stubs.'
        else if (q.missingMeta > 0) summary += ' ' + q.missingMeta + ' missing meta.'
      }
    }
    html += '<div class="detail-summary">' + summary + '</div>'

    var fixes = generateFixes(entries, result.scoredCount)
    if (fixes.length > 0) {
      html += '<div class="detail-fixes"><div class="detail-fixes-title">Top Fixes</div><ol>'
      fixes.forEach(function(fix) { html += '<li>' + fix + '</li>' })
      html += '</ol></div>'
    }

    if (entries.length > 0) {
      var sorted = entries.slice().sort(function(a, b) { return issueCount(b) - issueCount(a) })
      html += '<table class="entry-table"><thead><tr>' +
        '<th>Entry</th><th>Audience</th><th>Align</th><th>Words</th><th>Read.</th><th>Links</th><th>H2s</th><th>Gap</th>' +
        '</tr></thead><tbody>'

      sorted.forEach(function(entry) {
        var ep = entry.persona
        var eq = entry.quality
        var eg = entry.gap

        var audienceCell, alignCell
        if (!ep) {
          audienceCell = '<span class="cell-muted">--</span>'
          alignCell = '<span class="cell-muted">--</span>'
        } else if (ep.unclear) {
          audienceCell = '<span class="cell-amber">unclear</span>'
          alignCell = '<span class="cell-muted">--</span>'
        } else {
          audienceCell = ep.audience
          var alignCls = ep.alignment >= 60 ? 'cell-green' : (ep.alignment >= 40 ? 'cell-amber' : 'cell-red')
          alignCell = '<span class="' + alignCls + '">' + ep.alignment + '%</span>'
        }

        var wordsCls = eq.stubbed ? 'cell-red' : (eq.wordCount < 300 ? 'cell-amber' : '')
        var wordsCell = '<span class="' + wordsCls + '">' + eq.wordCount + '</span>'
        var readCell = eq.readability.gradeLevel !== 'unknown' ? eq.readability.gradeLevel : '<span class="cell-muted">--</span>'
        var linkTotal = eq.internalLinks + eq.externalLinks
        var linksCell = '<span class="' + (linkTotal === 0 ? 'cell-red' : '') + '">' + linkTotal + '</span>'
        var h2Cell = eq.headings.h2 > 0 ? eq.headings.h2 + ' H2' : '<span class="cell-muted">--</span>'
        if (!eq.headings.properStructure && eq.headings.h2 > 0) h2Cell = '<span class="cell-amber">' + h2Cell + '</span>'
        var gapCell = '<span class="cell-muted">--</span>'
        if (eg) gapCell = '<span class="gap-badge gap-' + eg.status.toLowerCase() + '">' + eg.status + '</span>'

        html += '<tr>' +
          '<td class="entry-title"><a href="' + entry.url + '" target="_blank">' + entry.title + '</a></td>' +
          '<td>' + audienceCell + '</td><td>' + alignCell + '</td><td>' + wordsCell + '</td>' +
          '<td>' + readCell + '</td><td>' + linksCell + '</td><td>' + h2Cell + '</td><td>' + gapCell + '</td></tr>'
      })
      html += '</tbody></table>'
    }

    if (p && p.unclearCount < result.scoredCount) {
      var billTotal = 0, bettyTotal = 0, taylorTotal = 0, personaCount = 0
      entries.forEach(function(e) {
        if (e.persona) {
          billTotal += e.persona.scores.bill
          bettyTotal += e.persona.scores.betty
          taylorTotal += e.persona.scores.taylor
          personaCount++
        }
      })
      if (personaCount > 0) {
        var avgBill = Math.round(billTotal / personaCount)
        var avgBetty = Math.round(bettyTotal / personaCount)
        var avgTaylor = Math.round(taylorTotal / personaCount)
        html += '<div class="persona-chart"><div class="persona-chart-title">Persona Fit (avg across ' + personaCount + ' entries)</div><div class="persona-bar-group">'
        html += renderPersonaBar('Bill', avgBill) + renderPersonaBar('Betty', avgBetty) + renderPersonaBar('Taylor', avgTaylor)
        html += '</div>'
        var unclearEntries = entries.filter(function(e) { return e.persona && e.persona.unclear })
        if (unclearEntries.length > 0) {
          html += '<div style="margin-top:8px;font-size:12px;color:var(--text-secondary);"><strong>Unclear:</strong> '
          html += unclearEntries.map(function(e) { return e.title }).join(', ') + '</div>'
        }
        html += '</div>'
      }
    }

    panel.innerHTML = html
  }

  function renderPersonaBar(label, pct) {
    return '<div class="persona-bar-row"><span class="persona-bar-label">' + label + '</span>' +
      '<div class="persona-bar-track"><div class="persona-bar-fill ' + getBarClass(pct) + '" style="width:' + pct + '%"></div></div>' +
      '<span class="persona-bar-pct">' + pct + '%</span></div>'
  }

  // =========================================================================
  // ISSUE COUNTING
  // =========================================================================

  function issueCount(entry) {
    var count = 0
    var q = entry.quality
    if (q.stubbed) count += 2
    if (q.internalLinks + q.externalLinks === 0) count += 2
    if (!q.hasMetaDescription) count++
    if (!q.headings.properStructure) count++
    if (entry.persona && entry.persona.unclear) count += 2
    if (!entry.persona) count++
    if (entry.gap && entry.gap.status === 'ORPHAN') count++
    return count
  }

  // =========================================================================
  // FIX GENERATION
  // =========================================================================

  function generateFixes(entries, scoredCount) {
    var fixes = []
    var noLinks = entries.filter(function(e) { return e.quality.internalLinks + e.quality.externalLinks === 0 })
    if (noLinks.length > 0) {
      var names = noLinks.slice(0, 4).map(function(e) { return e.title })
      fixes.push('Add internal links to <strong>' + names.join('</strong>, <strong>') + '</strong>' + (noLinks.length > 4 ? ' + ' + (noLinks.length - 4) + ' more' : ''))
    }
    var stubs = entries.filter(function(e) { return e.quality.stubbed })
    if (stubs.length > 0) {
      var names2 = stubs.slice(0, 3).map(function(e) { return e.title + ' (' + e.quality.wordCount + 'w)' })
      fixes.push('Expand <strong>' + names2.join('</strong>, <strong>') + '</strong> — stubs')
    }
    var noMeta = entries.filter(function(e) { return !e.quality.hasMetaDescription })
    if (noMeta.length > 0) {
      var names3 = noMeta.slice(0, 4).map(function(e) { return e.title })
      fixes.push('Add meta descriptions: <strong>' + names3.join('</strong>, <strong>') + '</strong>')
    }
    var unclear = entries.filter(function(e) { return e.persona && e.persona.unclear })
    if (unclear.length > 0 && fixes.length < 4) {
      var names5 = unclear.slice(0, 3).map(function(e) { return e.title })
      fixes.push('<strong>' + names5.join('</strong>, <strong>') + '</strong> — no clear audience')
    }
    return fixes.slice(0, 4)
  }

  // =========================================================================
  // AUTO-SET PIPELINE FROM SCAN
  // =========================================================================

  function autoSetPipelineFromScan(route, result) {
    if (!result || result.scannable === false) return
    var row = document.querySelector('.table-row[data-route="' + route + '"]')
    if (!row) return
    var st = loadState()
    var data = st[route] || {}
    if (data.pipeline && data.pipeline !== 'no-copy') return

    var agg = result.aggregate
    var p = agg.persona
    var q = agg.quality
    var qualityPassed = 0
    if (q.avgWordCount >= 300) qualityPassed++
    if (q.missingMeta === 0) qualityPassed++
    if (q.noInternalLinks === 0) qualityPassed++
    if (q.badHeadingsCount === 0) qualityPassed++
    if (q.avgReadability >= 50) qualityPassed++
    if (q.stubbedCount === 0) qualityPassed++

    var inferredStage = 'no-copy'
    if (p && p.avgAlignment >= 60 && qualityPassed >= 4) inferredStage = 'built'
    else if (p && p.avgAlignment >= 40) inferredStage = 'copy-draft'

    if (inferredStage !== 'no-copy') {
      var pipelineSelect = row.querySelector('[data-field="pipeline"]')
      if (pipelineSelect) {
        pipelineSelect.value = inferredStage
        pipelineSelect.dispatchEvent(new Event('change'))
      }
    }
  }

  // =========================================================================
  // CACHE SCAN RESULT
  // =========================================================================

  function cacheScanResult(route, result) {
    if (result.scannable === false) return
    var state = loadState()
    if (!state[route]) state[route] = {}
    var p = result.aggregate.persona
    var q = result.aggregate.quality
    var g = result.aggregate.gap
    state[route].scan = {
      scannedAt: result.scannedAt,
      scanVersion: result.scanVersion,
      scoredCount: result.scoredCount,
      totalEntries: result.entryCount,
      primaryAudience: p ? p.primaryAudience : null,
      avgAlignment: p ? p.avgAlignment : null,
      unclearCount: p ? p.unclearCount : null,
      avgWordCount: q.avgWordCount,
      missingMeta: q.missingMeta,
      noInternalLinks: q.noInternalLinks,
      stubbedCount: q.stubbedCount,
      gap: g,
      entries: result.entries,
    }
    saveState(state)
  }

  // =========================================================================
  // RESTORE CACHED SCANS
  // =========================================================================

  function restoreCachedScans() {
    var state = loadState()
    Object.keys(state).forEach(function(route) {
      var data = state[route]
      if (!data.scan) return
      var row = document.querySelector('.table-row[data-route="' + route + '"]')
      if (!row) return
      var scoreCol = row.querySelector('.col-score')
      if (!scoreCol) return
      var scan = data.scan
      var stale = scan.scanVersion < CURRENT_SCAN_VERSION
      var label, cls
      if (!scan.primaryAudience) { label = '--'; cls = 'score-low' }
      else if (scan.unclearCount === scan.scoredCount) { label = '?'; cls = 'score-confused' }
      else {
        label = personaInitial(scan.primaryAudience) + ' ' + scan.avgAlignment + '%'
        cls = badgeColor(scan.avgAlignment)
      }
      if (stale) label += '*'
      scoreCol.innerHTML = '<button class="score-badge ' + cls + '" data-action="toggle-details" title="' +
        (stale ? 'Stale — re-scan' : 'Click to expand') + '">' + label + '</button>'
      if (scan.entries) {
        scanResults[route] = {
          scannable: true, scoredCount: scan.scoredCount, entryCount: scan.totalEntries, entries: scan.entries,
          aggregate: {
            persona: scan.primaryAudience ? { primaryAudience: scan.primaryAudience, avgAlignment: scan.avgAlignment, unclearCount: scan.unclearCount } : null,
            quality: { avgWordCount: scan.avgWordCount, missingMeta: scan.missingMeta, noInternalLinks: scan.noInternalLinks, stubbedCount: scan.stubbedCount, avgReadability: 0, badHeadingsCount: 0 },
            gap: scan.gap,
          },
        }
      }
    })
  }

  // =========================================================================
  // SCAN ALL
  // =========================================================================

  function scanAll() {
    var rows = document.querySelectorAll('.table-row[data-content-type="dynamic"]')
    var routes = []
    rows.forEach(function(row) { routes.push(row.dataset.route) })
    if (routes.length === 0) return

    scanCancelled = false
    var progressEl = document.getElementById('scan-progress')
    var progressBar = document.getElementById('scan-progress-bar')
    var progressCount = document.getElementById('scan-progress-count')
    var progressLabel = document.getElementById('scan-progress-label')
    var scanAllBtn = document.getElementById('scan-all-btn')
    progressEl.style.display = ''
    scanAllBtn.disabled = true
    var completed = 0

    function next() {
      if (scanCancelled || completed >= routes.length) {
        progressEl.style.display = 'none'
        scanAllBtn.disabled = false
        updateProgress()
        return
      }
      progressLabel.textContent = 'Scanning ' + routes[completed] + '...'
      var route = routes[completed]
      var row = document.querySelector('.table-row[data-route="' + route + '"]')
      var scanBtn = row ? row.querySelector('.scan-btn, .score-badge') : null
      if (scanBtn) scanBtn.classList.add('scanning')

      scanRoute(route)
        .then(function(result) {
          if (result && result.scannable !== false && result.entries) {
            renderScoreBadge(row, result)
            renderDetailPanel(route, result)
            autoSetPipelineFromScan(route, result)
            cacheScanResult(route, result)
          }
        })
        .catch(function(err) { console.error('Scan failed for ' + route + ':', err) })
        .finally(function() {
          if (scanBtn) scanBtn.classList.remove('scanning')
          completed++
          progressBar.style.width = Math.round((completed / routes.length) * 100) + '%'
          progressCount.textContent = completed + '/' + routes.length
          setTimeout(next, 500)
        })
    }
    progressCount.textContent = '0/' + routes.length
    next()
  }

  // =========================================================================
  // INIT
  // =========================================================================

  function init() {
    var state = loadState()

    // Populate fields from saved state
    document.querySelectorAll('.table-row').forEach(function(row) {
      var route = row.dataset.route
      var data = state[route] || {}
      var pipelineSelect = row.querySelector('[data-field="pipeline"]')
      if (data.pipeline && pipelineSelect) pipelineSelect.value = data.pipeline
      var blockerSelect = row.querySelector('[data-field="blocker"]')
      if (data.blocker && blockerSelect) blockerSelect.value = data.blocker
    })

    // Change listeners for pipeline/blocker
    document.querySelectorAll('.pipeline-select').forEach(function(el) {
      el.addEventListener('change', function() {
        var row = this.closest('.table-row')
        var route = row.dataset.route
        var st = loadState()
        if (!st[route]) st[route] = {}
        st[route].pipeline = this.value
        saveState(st)
        updateProgress()
      })
    })
    document.querySelectorAll('.blocker-select').forEach(function(el) {
      el.addEventListener('change', function() {
        var row = this.closest('.table-row')
        var route = row.dataset.route
        var st = loadState()
        if (!st[route]) st[route] = {}
        st[route].blocker = this.value
        saveState(st)
        updateProgress()
      })
    })
    // Reviewed date — click to mark
    document.querySelectorAll('.reviewed-date').forEach(function(el) {
      el.addEventListener('click', function() {
        var route = this.dataset.reviewedFor
        var st = loadState()
        if (!st[route]) st[route] = {}
        st[route].reviewedAt = new Date().toISOString()
        st[route].reviewer = prompt('Reviewer initials:', st[route].reviewer || '')
        saveState(st)
        updateProgress()
      })
    })

    // Filter listeners
    ;['filter-persona', 'filter-funnel', 'filter-blocker', 'filter-priority'].forEach(function(id) {
      document.getElementById(id).addEventListener('change', applyFilters)
    })

    // Scan button + toggle — delegated
    document.addEventListener('click', function(e) {
      var scanBtn = e.target.closest('[data-action="scan"]')
      if (scanBtn) {
        var row = scanBtn.closest('.table-row')
        var route = row.dataset.route
        scanBtn.disabled = true
        scanBtn.classList.add('scanning')
        scanBtn.textContent = '...'
        scanRoute(route)
          .then(function(result) {
            if (result && result.scannable !== false && result.entries) {
              renderScoreBadge(row, result)
              renderDetailPanel(route, result)
              autoSetPipelineFromScan(route, result)
              cacheScanResult(route, result)
              var panel = document.querySelector('[data-details-for="' + route + '"]')
              if (panel) panel.classList.add('open')
            }
          })
          .catch(function(err) {
            console.error('Scan error:', err)
            scanBtn.textContent = 'Err'
            scanBtn.disabled = false
            scanBtn.classList.remove('scanning')
          })
          .finally(function() { updateProgress() })
      }

      var toggleBtn = e.target.closest('[data-action="toggle-details"]')
      if (toggleBtn) {
        var row2 = toggleBtn.closest('.table-row')
        var route2 = row2.dataset.route
        var panel = document.querySelector('[data-details-for="' + route2 + '"]')
        if (panel) {
          if (!panel.innerHTML && scanResults[route2]) renderDetailPanel(route2, scanResults[route2])
          panel.classList.toggle('open')
        }
      }
    })

    // Scan All
    document.getElementById('scan-all-btn').addEventListener('click', scanAll)
    document.getElementById('scan-cancel-btn').addEventListener('click', function() { scanCancelled = true })

    // Export
    document.getElementById('export-btn').addEventListener('click', function() {
      var st = loadState()
      var blob = new Blob([JSON.stringify(st, null, 2)], { type: 'application/json' })
      var url = URL.createObjectURL(blob)
      var a = document.createElement('a')
      a.href = url
      a.download = 'site-audit-' + new Date().toISOString().split('T')[0] + '.json'
      a.click()
      URL.revokeObjectURL(url)
    })

    // Reset
    document.getElementById('reset-btn').addEventListener('click', function() {
      if (confirm('Reset all audit progress? This cannot be undone.')) {
        localStorage.removeItem(STORAGE_KEY)
        scanResults = {}
        location.reload()
      }
    })

    restoreCachedScans()
    updateProgress()
  }

  init()
</script>
