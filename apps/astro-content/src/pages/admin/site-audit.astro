---
/**
 * Site Audit — Page Operations Console
 * Prioritization + funnel coverage + quality signals + copy/design pipeline
 */
import AdminLayout from '../../layouts/AdminLayout.astro'

type ContentType = 'dynamic' | 'index' | 'non-content'
type PageType = 'lander' | 'collection' | 'pdp' | 'content' | 'hub' | 'utility'
type Persona = 'bill' | 'betty' | 'taylor' | 'general' | null
type FunnelStage = 'awareness' | 'consideration' | 'purchase' | 'post-purchase'
type Blocker = 'copy' | 'dev' | 'design' | 'data' | null
type PipelineStage = 'no-copy' | 'copy-draft' | 'copy-approved' | 'built' | 'design-review' | 'shipped'
interface AuditPage {
  route: string
  name: string
  template: string
  priority: 'high' | 'medium' | 'low'
  contentType: ContentType
  pageType: PageType
  persona: Persona
  funnelStage: FunnelStage
  primaryGoal: string
  blocker: Blocker
  pipeline?: PipelineStage
  funnelNext?: string
  copyDoc?: string
}

const PIPELINE_STAGES = [
  { value: 'no-copy', label: 'No Copy' },
  { value: 'copy-draft', label: 'Copy Draft' },
  { value: 'copy-approved', label: 'Copy Approved' },
  { value: 'built', label: 'Built' },
  { value: 'design-review', label: 'Design Review' },
  { value: 'shipped', label: 'Shipped' },
] as const

const BLOCKERS = [
  { value: '', label: '--' },
  { value: 'copy', label: 'Copy' },
  { value: 'dev', label: 'Dev' },
  { value: 'design', label: 'Design' },
  { value: 'data', label: 'Data' },
] as const

const pageGroups: { name: string; id: string; pages: AuditPage[] }[] = [
  {
    name: 'Homepage',
    id: 'homepage',
    pages: [
      { route: '/', name: 'Homepage', template: 'index.astro', priority: 'high', contentType: 'non-content', pageType: 'lander', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Route to persona', blocker: 'copy', funnelNext: '/collections/' },
    ],
  },
  {
    name: 'Persona Landings',
    id: 'persona',
    pages: [
      { route: '/poultry/', name: 'Poultry Hub', template: 'poultry/index.astro', priority: 'high', contentType: 'non-content', pageType: 'hub', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Route to persona', blocker: null, pipeline: 'design-review', funnelNext: '/poultry/commercial/', copyDoc: 'BB-Persona/poultry-hub-copy.md' },
      { route: '/poultry/commercial/', name: 'Broiler Bill Landing', template: 'poultry/commercial/index.astro', priority: 'high', contentType: 'non-content', pageType: 'lander', persona: 'bill', funnelStage: 'consideration', primaryGoal: 'Call sales', blocker: null, pipeline: 'design-review', funnelNext: '/collections/poultry-broilers/', copyDoc: 'BB-Persona/Broilers Landing Page 276cee770ea480b5a085e898802e7e22.md' },
      { route: '/poultry/backyard/', name: 'Backyard Betty Landing', template: 'poultry/backyard/index.astro', priority: 'high', contentType: 'non-content', pageType: 'lander', persona: 'betty', funnelStage: 'consideration', primaryGoal: 'Add to cart', blocker: 'copy', funnelNext: '/collections/backyard-poultry/', copyDoc: 'BB-Persona/betty-storybrand.md' },
      { route: '/lawn/', name: 'Turf Pro Taylor Landing', template: 'lawn/index.astro', priority: 'high', contentType: 'non-content', pageType: 'lander', persona: 'taylor', funnelStage: 'consideration', primaryGoal: 'Build program', blocker: 'copy', funnelNext: '/collections/turf/', copyDoc: 'BB-Persona/taylor-storybrand.md' },
    ],
  },
  {
    name: 'Shop Collections',
    id: 'collections',
    pages: [
      { route: '/collections/', name: 'Collections Index', template: 'collections/index.astro', priority: 'high', contentType: 'index', pageType: 'hub', persona: 'general', funnelStage: 'consideration', primaryGoal: 'Browse products', blocker: null, pipeline: 'built' },
      { route: '/collections/[slug]', name: 'Collection Detail', template: 'collections/[slug].astro', priority: 'high', contentType: 'dynamic', pageType: 'collection', persona: null, funnelStage: 'consideration', primaryGoal: 'Add to cart', blocker: 'copy', pipeline: 'built' },
    ],
  },
  {
    name: 'Podcast',
    id: 'podcast',
    pages: [
      { route: '/podcast/', name: 'Podcast Hub', template: 'podcast/index.astro', priority: 'high', contentType: 'index', pageType: 'hub', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Educate', blocker: null, pipeline: 'shipped' },
      { route: '/podcast/[slug]', name: 'Episode Detail', template: 'podcast/[...slug].astro', priority: 'high', contentType: 'dynamic', pageType: 'content', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Educate', blocker: null, pipeline: 'shipped' },
      { route: '/podcast/search', name: 'Podcast Search', template: 'podcast/search.astro', priority: 'medium', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Search', blocker: null, pipeline: 'shipped' },
      { route: '/podcast/topics/', name: 'Topics Index', template: 'podcast/topics/index.astro', priority: 'medium', contentType: 'index', pageType: 'hub', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Browse topics', blocker: null, pipeline: 'shipped' },
      { route: '/podcast/topics/[slug]', name: 'Topic Detail', template: 'podcast/topics/[slug].astro', priority: 'medium', contentType: 'dynamic', pageType: 'content', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Educate', blocker: null, pipeline: 'shipped' },
      { route: '/podcast/guests/', name: 'Guests Index', template: 'podcast/guests/index.astro', priority: 'low', contentType: 'index', pageType: 'hub', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Browse guests', blocker: null, pipeline: 'shipped' },
    ],
  },
  {
    name: 'Blog',
    id: 'blog',
    pages: [
      { route: '/blog/', name: 'Blog Index', template: 'blog/index.astro', priority: 'high', contentType: 'index', pageType: 'hub', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Educate', blocker: null, pipeline: 'shipped' },
      { route: '/blog/[slug]', name: 'Blog Post', template: 'blog/[slug].astro', priority: 'high', contentType: 'dynamic', pageType: 'content', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Educate', blocker: null, pipeline: 'shipped' },
      { route: '/blog/category/[segment]', name: 'Category Archive', template: 'blog/category/[segment].astro', priority: 'medium', contentType: 'non-content', pageType: 'hub', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Browse category', blocker: null, pipeline: 'shipped' },
    ],
  },
  {
    name: 'Team',
    id: 'team',
    pages: [
      { route: '/team/', name: 'Team Index', template: 'team/index.astro', priority: 'medium', contentType: 'index', pageType: 'hub', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Build trust', blocker: null, pipeline: 'shipped' },
      { route: '/team/[slug]', name: 'Team Member', template: 'team/[slug].astro', priority: 'medium', contentType: 'dynamic', pageType: 'content', persona: 'general', funnelStage: 'awareness', primaryGoal: 'Build trust', blocker: null, pipeline: 'shipped' },
    ],
  },
  {
    name: 'Surveys (CDP)',
    id: 'surveys',
    pages: [
      { route: '/survey/backyard', name: 'Betty Outcome Survey', template: 'survey/backyard.astro', priority: 'medium', contentType: 'non-content', pageType: 'utility', persona: 'betty', funnelStage: 'post-purchase', primaryGoal: 'Collect outcomes', blocker: 'data' },
      { route: '/survey/commercial', name: 'Bill Outcome Survey', template: 'survey/commercial.astro', priority: 'medium', contentType: 'non-content', pageType: 'utility', persona: 'bill', funnelStage: 'post-purchase', primaryGoal: 'Collect outcomes', blocker: 'data' },
    ],
  },
  {
    name: 'Utility',
    id: 'utility',
    pages: [
      { route: '/search', name: 'Global Search', template: 'search.astro', priority: 'low', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Search', blocker: null },
    ],
  },
  {
    name: 'Admin',
    id: 'admin',
    pages: [
      { route: '/admin/', name: 'Admin Dashboard', template: 'admin/index.astro', priority: 'medium', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
      { route: '/admin/branding', name: 'Brand Guidelines', template: 'admin/branding.astro', priority: 'low', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
      { route: '/admin/images', name: 'Image Docs', template: 'admin/images.astro', priority: 'low', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
      { route: '/admin/cdp/', name: 'CDP Analytics', template: 'admin/cdp/index.astro', priority: 'medium', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
      { route: '/admin/cdp-guide', name: 'CDP Guide', template: 'admin/cdp-guide.astro', priority: 'low', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
      { route: '/admin/sales-log', name: 'Sales Log', template: 'admin/sales-log.astro', priority: 'medium', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
      { route: '/admin/content-quality', name: 'Content Quality', template: 'admin/content-quality.astro', priority: 'medium', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
      { route: '/admin/site-audit', name: 'Site Audit (this page)', template: 'admin/site-audit.astro', priority: 'low', contentType: 'non-content', pageType: 'utility', persona: null, funnelStage: 'awareness', primaryGoal: 'Internal', blocker: null, pipeline: 'shipped' },
    ],
  },
]

const totalPages = pageGroups.reduce((sum, g) => sum + g.pages.length, 0)

// Funnel coverage summary
const funnelCoverage = {
  awareness: 0,
  consideration: 0,
  purchase: 0,
  'post-purchase': 0,
}
const personaCoverage = { bill: 0, betty: 0, taylor: 0, general: 0, none: 0 }
pageGroups.forEach(g => g.pages.forEach(p => {
  funnelCoverage[p.funnelStage]++
  if (p.persona) personaCoverage[p.persona]++
  else personaCoverage.none++
}))
---

<AdminLayout title="Site Audit" activeNav="/admin/site-audit">
  <header class="page-header">
    <h1 class="page-title">Site Audit</h1>
    <p class="page-subtitle">Page operations console for Southland Organics — prioritize work, close funnel gaps, and enforce copy/design standards.</p>
  </header>

  <!-- Progress + Coverage Overview -->
  <div class="overview-grid">
    <div class="progress-card">
      <div class="card-label">Pipeline Progress</div>
      <div class="progress-stats">
        <div class="stat">
          <span class="stat-value" id="shipped-count">0</span>
          <span class="stat-label">Shipped</span>
        </div>
        <div class="stat">
          <span class="stat-value" id="pipeline-count">0</span>
          <span class="stat-label">In Pipeline</span>
        </div>
        <div class="stat">
          <span class="stat-value" id="blocked-count">0</span>
          <span class="stat-label">Blocked</span>
        </div>
        <div class="stat">
          <span class="stat-value" id="pending-count">{totalPages}</span>
          <span class="stat-label">Not Started</span>
        </div>
      </div>
      <div class="progress-bar-container">
        <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
      </div>
      <div class="progress-label">
        <span id="progress-percent">0%</span> shipped
      </div>
      <div class="tile-hint">Sort by impact, persona, or funnel stage to see where to work next.</div>
    </div>

    <div class="coverage-card">
      <div class="card-label">Funnel Coverage</div>
      <div class="coverage-bars">
        <div class="coverage-row">
          <span class="coverage-label">Awareness</span>
          <div class="coverage-track"><div class="coverage-fill fill-awareness" style={`width: ${Math.round(funnelCoverage.awareness / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{funnelCoverage.awareness}</span>
        </div>
        <div class="coverage-row">
          <span class="coverage-label">Consider</span>
          <div class="coverage-track"><div class="coverage-fill fill-consideration" style={`width: ${Math.round(funnelCoverage.consideration / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{funnelCoverage.consideration}</span>
        </div>
        <div class="coverage-row">
          <span class="coverage-label">Purchase</span>
          <div class="coverage-track"><div class="coverage-fill fill-purchase" style={`width: ${Math.round(funnelCoverage.purchase / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{funnelCoverage.purchase}</span>
        </div>
        <div class="coverage-row">
          <span class="coverage-label">Post-purch</span>
          <div class="coverage-track"><div class="coverage-fill fill-post" style={`width: ${Math.round(funnelCoverage['post-purchase'] / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{funnelCoverage['post-purchase']}</span>
        </div>
      </div>
    </div>

    <div class="coverage-card">
      <div class="card-label">Persona Coverage</div>
      <div class="coverage-bars">
        <div class="coverage-row">
          <span class="coverage-label persona-chip persona-bill">Bill</span>
          <div class="coverage-track"><div class="coverage-fill fill-bill" style={`width: ${Math.round(personaCoverage.bill / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{personaCoverage.bill}</span>
        </div>
        <div class="coverage-row">
          <span class="coverage-label persona-chip persona-betty">Betty</span>
          <div class="coverage-track"><div class="coverage-fill fill-betty" style={`width: ${Math.round(personaCoverage.betty / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{personaCoverage.betty}</span>
        </div>
        <div class="coverage-row">
          <span class="coverage-label persona-chip persona-taylor">Taylor</span>
          <div class="coverage-track"><div class="coverage-fill fill-taylor" style={`width: ${Math.round(personaCoverage.taylor / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{personaCoverage.taylor}</span>
        </div>
        <div class="coverage-row muted-row">
          <span class="coverage-label">General</span>
          <div class="coverage-track"><div class="coverage-fill fill-general" style={`width: ${Math.round(personaCoverage.general / totalPages * 100)}%`}></div></div>
          <span class="coverage-count">{personaCoverage.general}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Actions Bar -->
  <div class="actions-bar">
    <div class="filter-group">
      <select class="filter-select" id="filter-persona">
        <option value="">All Personas</option>
        <option value="bill">Bill</option>
        <option value="betty">Betty</option>
        <option value="taylor">Taylor</option>
        <option value="general">General</option>
      </select>
      <select class="filter-select" id="filter-funnel">
        <option value="">All Funnel</option>
        <option value="awareness">Awareness</option>
        <option value="consideration">Consideration</option>
        <option value="purchase">Purchase</option>
        <option value="post-purchase">Post-purchase</option>
      </select>
      <select class="filter-select" id="filter-blocker">
        <option value="">All Blockers</option>
        <option value="copy">Blocked: Copy</option>
        <option value="dev">Blocked: Dev</option>
        <option value="design">Blocked: Design</option>
        <option value="data">Blocked: Data</option>
      </select>
      <select class="filter-select" id="filter-priority">
        <option value="">All Priority</option>
        <option value="high">High</option>
        <option value="medium">Medium</option>
        <option value="low">Low</option>
      </select>
    </div>
    <div class="action-buttons">
      <button class="btn btn-primary" id="scan-all-btn" title="Score all scannable pages via Mothership">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22" /></svg>
        Scan All
      </button>
      <button class="btn btn-secondary" id="export-btn">Export</button>
      <button class="btn btn-secondary" id="reset-btn">Reset</button>
    </div>
  </div>

  <!-- Legend -->
  <div class="legend">
    <div class="legend-group">
      <span class="legend-label">Type:</span>
      <span class="type-badge type-lander">lander</span>
      <span class="type-badge type-collection">collection</span>
      <span class="type-badge type-pdp">pdp</span>
      <span class="type-badge type-content">content</span>
      <span class="type-badge type-hub">hub</span>
    </div>
    <div class="legend-group">
      <span class="legend-label">Blocker:</span>
      <span class="blocker-badge blocker-copy">Copy</span>
      <span class="blocker-badge blocker-dev">Dev</span>
      <span class="blocker-badge blocker-design">Design</span>
      <span class="blocker-badge blocker-data">Data</span>
    </div>
  </div>

  <!-- Page Groups -->
  {
    pageGroups.map((group) => (
      <div class="audit-group" data-group={group.id}>
        <div class="group-header">
          <h2 class="group-title">{group.name}</h2>
          <span class="group-count">{group.pages.length} pages</span>
        </div>
        <div class="audit-table">
          <div class="table-header">
            <div class="col-status muted-header"></div>
            <div class="col-page">Page</div>
            <div class="col-type muted-header">Type</div>
            <div class="col-persona">Persona</div>
            <div class="col-funnel muted-header">Funnel</div>
            <div class="col-goal muted-header">Goal</div>
            <div class="col-pipeline strong-header">Pipeline</div>
            <div class="col-blocker strong-header">Blocker</div>
            <div class="col-score">Persona Fit</div>
            <div class="col-cro">CRO</div>
            <div class="col-checks">Checks</div>
            <div class="col-reviewed muted-header">Reviewed</div>
            <div class="col-actions"></div>
          </div>
          {group.pages.map((page) => (
            <div>
              <div class="table-row"
                data-route={page.route}
                data-content-type={page.contentType}
                data-page-type={page.pageType}
                data-persona={page.persona || ''}
                data-funnel-stage={page.funnelStage}
                data-priority={page.priority}
                data-blocker={page.blocker || ''}
                data-funnel-next={page.funnelNext || ''}
                data-copy-doc={page.copyDoc || ''}
                data-primary-goal={page.primaryGoal}
              >
                <div class="col-status">
                  <span class="status-dot not-started" data-status-dot />
                </div>
                <div class="col-page">
                  <div class="page-name-row">
                    <span class="page-name">{page.name}</span>
                    <span class={`priority-badge ${page.priority}`}>{page.priority}</span>
                  </div>
                  <div class="page-route-row">
                    <code>{page.route}</code>
                    <a
                      href={page.route.replace('[slug]', 'example').replace('[segment]', 'poultry').replace('[...slug]', 'episode-1')}
                      target="_blank"
                      class="view-link"
                      title="Open page"
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                  </div>
                </div>
                <div class="col-type">
                  <span class={`type-badge type-${page.pageType}`}>{page.pageType}</span>
                </div>
                <div class="col-persona">
                  {page.persona ? (
                    <span class={`persona-chip persona-${page.persona}`}>{page.persona}</span>
                  ) : (
                    <span class="persona-chip persona-none">--</span>
                  )}
                </div>
                <div class="col-funnel">
                  <span class={`funnel-badge funnel-${page.funnelStage}`} title={page.funnelStage}>{
                    page.funnelStage === 'awareness' ? 'A' :
                    page.funnelStage === 'consideration' ? 'C' :
                    page.funnelStage === 'purchase' ? 'P' : 'Post'
                  }</span>
                </div>
                <div class="col-goal">
                  <span class="goal-text" title={page.primaryGoal}>{page.primaryGoal}</span>
                </div>
                <div class="col-pipeline">
                  <select class="pipeline-select" data-field="pipeline">
                    {PIPELINE_STAGES.map((stage) => (
                      <option value={stage.value} selected={stage.value === (page.pipeline || 'no-copy')}>{stage.label}</option>
                    ))}
                  </select>
                </div>
                <div class="col-blocker">
                  <select class="blocker-select" data-field="blocker">
                    {BLOCKERS.map((b) => (
                      <option value={b.value} selected={b.value === (page.blocker || '')}>{b.label}</option>
                    ))}
                  </select>
                </div>
                <div class="col-score">
                  {page.contentType === 'dynamic' ? (
                    <button class="scan-btn" data-action="scan" title="Score via Mothership">Scan</button>
                  ) : (
                    <span class="score-na">--</span>
                  )}
                </div>
                <div class="col-cro">
                  <span class="cro-score" data-cro-for={page.route}>--</span>
                </div>
                <div class="col-checks">
                  <span class="checks-detail" data-checks-for={page.route}>--</span>
                </div>
                <div class="col-reviewed">
                  <span class="reviewed-date" data-reviewed-for={page.route} title="Click to mark reviewed">--</span>
                </div>
                <div class="col-actions">
                  <a
                    href={page.route.replace('[slug]', 'example').replace('[segment]', 'poultry').replace('[...slug]', 'episode-1')}
                    target="_blank"
                    class="open-btn"
                    title="Open page"
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                </div>
              </div>
              <div class="scan-details" data-details-for={page.route}></div>
            </div>
          ))}
        </div>
      </div>
    ))
  }

  <!-- Mothership Integration -->
  <div class="integration-footer">
    <div class="integration-header-row">
      <div class="integration-title">
        <h2 class="card-title">Mothership Integration</h2>
        <span class="badge badge-success">Live</span>
      </div>
      <div class="integration-tiles">
        <div class="int-tile">
          <span class="int-tile-value" id="scanned-count">0</span>
          <span class="int-tile-label">Routes Scanned</span>
        </div>
        <div class="int-tile">
          <span class="int-tile-value" id="avg-alignment">--</span>
          <span class="int-tile-label">Avg Persona Fit</span>
        </div>
        <div class="int-tile">
          <span class="int-tile-value" id="total-entries">0</span>
          <span class="int-tile-label">Entries Scored</span>
        </div>
      </div>
    </div>
