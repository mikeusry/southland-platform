---
/**
 * Site Audit v2 — Workflow-Aligned Operations Console
 *
 * Simplified: dynamic inventory from content collections,
 * pipeline stages match real workflow (brief → writing → built → design → shipped),
 * no manual CRO checks, auto-expanding scan results.
 */
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getCollection } from 'astro:content'

// ---------------------------------------------------------------------------
// Pipeline stages — match the real workflow
// ---------------------------------------------------------------------------
type PipelineStage = 'brief' | 'writing' | 'built' | 'design' | 'shipped'

const PIPELINE_STAGES: { value: PipelineStage | ''; label: string }[] = [
  { value: '', label: 'Not started' },
  { value: 'brief', label: 'Brief' },
  { value: 'writing', label: 'Writing' },
  { value: 'built', label: 'Built' },
  { value: 'design', label: 'Design Review' },
  { value: 'shipped', label: 'Shipped' },
]

// ---------------------------------------------------------------------------
// Build dynamic inventory from actual content collections + routes
// ---------------------------------------------------------------------------
interface PageEntry {
  route: string
  name: string
  scanRoute?: string // route pattern for scan API
  count?: number
  type: 'collection' | 'static' | 'index'
  backingCollection?: string // collection slug that 301s here (content lives in shopCollections MDX)
}

interface PageGroup {
  name: string
  id: string
  pages: PageEntry[]
}

// ---------------------------------------------------------------------------
// Redirect map — collection slugs that 301 to persona landings
// Must stay in sync with middleware.ts REDIRECTS + collections/[slug].astro
// ---------------------------------------------------------------------------
const COLLECTION_REDIRECTS: Record<string, { landing: string; name: string }> = {
  'backyard-birds':    { landing: '/poultry/backyard/',    name: 'Backyard Betty Landing' },
  'poultry-broilers':  { landing: '/poultry/commercial/',  name: 'Broiler Bill Landing' },
  'poultry':           { landing: '/poultry/',             name: 'Poultry Hub' },
  'poultry-breeders':  { landing: '/poultry/breeders/',    name: 'Breeders Landing' },
  'turkey':            { landing: '/poultry/turkey/',      name: 'Turkey Landing' },
  'game-birds':        { landing: '/poultry/game-birds/',  name: 'Game Birds Landing' },
  'hydroseeders':      { landing: '/hydroseeders/',        name: 'Hydroseeders Landing' },
}

// ---------------------------------------------------------------------------
// Fetch collection counts + split live vs redirected at build time
// ---------------------------------------------------------------------------
let episodeCount = 0
let blogCount = 0
let teamCount = 0
let topicCount = 0

let allCollectionSlugs: string[] = []
try {
  const collections = await getCollection('shopCollections')
  allCollectionSlugs = collections.map((c) => c.data.handle || c.id.replace(/\.mdx?$/, ''))
} catch { /* */ }

const redirectedSlugs = allCollectionSlugs.filter((s) => s in COLLECTION_REDIRECTS)
const liveSlugs = allCollectionSlugs.filter((s) => !(s in COLLECTION_REDIRECTS))

try {
  const episodes = await getCollection('episodes')
  episodeCount = episodes.length
} catch { /* */ }

try {
  const blogs = await getCollection('blog')
  blogCount = blogs.length
} catch { /* */ }

try {
  const team = await getCollection('team')
  teamCount = team.length
} catch { /* */ }

try {
  const topics = await getCollection('topics')
  topicCount = topics.length
} catch { /* */ }

// ---------------------------------------------------------------------------
// Build persona landings with their backing collection slug (for scanning)
// ---------------------------------------------------------------------------
const personaPages: PageEntry[] = [
  { route: '/', name: 'Homepage', type: 'static' },
]

// Persona landings backed by redirected collections
for (const slug of redirectedSlugs) {
  const redir = COLLECTION_REDIRECTS[slug]!
  personaPages.push({
    route: redir.landing,
    name: redir.name,
    type: 'static',
    backingCollection: slug,
  })
}

// ---------------------------------------------------------------------------
// Page groups
// ---------------------------------------------------------------------------
const pageGroups: PageGroup[] = [
  {
    name: `Persona Landings (${personaPages.length})`,
    id: 'persona',
    pages: personaPages,
  },
  {
    name: `Shop Collections (${liveSlugs.length} live, ${redirectedSlugs.length} redirect)`,
    id: 'collections',
    pages: [
      { route: '/collections/', name: 'Collections Index', type: 'index' },
      { route: '/collections/[slug]', name: 'Live Collection Pages', type: 'collection', scanRoute: '/collections/[slug]', count: liveSlugs.length },
    ],
  },
  {
    name: `Podcast (${episodeCount} episodes)`,
    id: 'podcast',
    pages: [
      { route: '/podcast/', name: 'Podcast Hub', type: 'index' },
      { route: '/podcast/[...slug]', name: 'Episodes', type: 'collection', scanRoute: '/podcast/[slug]', count: episodeCount },
      { route: '/podcast/search', name: 'Podcast Search', type: 'static' },
      { route: '/podcast/topics/[slug]', name: 'Topics', type: 'collection', scanRoute: '/podcast/topics/[slug]', count: topicCount },
    ],
  },
  {
    name: `Blog (${blogCount} posts)`,
    id: 'blog',
    pages: [
      { route: '/blog/', name: 'Blog Index', type: 'index' },
      { route: '/blog/[slug]', name: 'Blog Posts', type: 'collection', scanRoute: '/blog/[slug]', count: blogCount },
    ],
  },
  {
    name: `Team (${teamCount})`,
    id: 'team',
    pages: [
      { route: '/team/', name: 'Team Index', type: 'index' },
      { route: '/team/[slug]', name: 'Team Members', type: 'collection', scanRoute: '/team/[slug]', count: teamCount },
    ],
  },
  {
    name: 'Products',
    id: 'products',
    pages: [
      { route: '/products/[handle]', name: 'Product Pages', type: 'static' },
      { route: '/build-a-case/', name: 'Build a Case', type: 'static' },
      { route: '/cart', name: 'Cart', type: 'static' },
      { route: '/account', name: 'Account', type: 'static' },
    ],
  },
  {
    name: 'Utility & Info',
    id: 'utility',
    pages: [
      { route: '/about/', name: 'About', type: 'static' },
      { route: '/contact/', name: 'Contact', type: 'static' },
      { route: '/distribution/', name: 'Distribution', type: 'static' },
      { route: '/store-locator/', name: 'Store Locator', type: 'static' },
    ],
  },
]

const totalPages = pageGroups.reduce((sum, g) => sum + g.pages.length, 0)
const scannableRoutes = pageGroups
  .flatMap((g) => g.pages)
  .filter((p) => p.scanRoute)
  .map((p) => p.scanRoute!)
---

<AdminLayout title="Site Audit" activeNav="/admin/site-audit">
  <header class="page-header">
    <h1 class="page-title">Site Audit</h1>
    <p class="page-subtitle">Workflow pipeline + persona scoring for every page on the site.</p>
  </header>

  <!-- Pipeline Progress -->
  <div class="overview-grid">
    <div class="progress-card">
      <div class="card-label">Pipeline Progress</div>
      <div class="progress-stats">
        <div class="stat">
          <span class="stat-value" id="shipped-count">0</span>
          <span class="stat-label">Shipped</span>
        </div>
        <div class="stat">
          <span class="stat-value" id="pipeline-count">0</span>
          <span class="stat-label">In Pipeline</span>
        </div>
        <div class="stat">
          <span class="stat-value" id="not-started-count">{totalPages}</span>
          <span class="stat-label">Not Started</span>
        </div>
      </div>
      <div class="progress-bar-container">
        <div class="progress-bar" id="progress-bar" style="width: 0%"></div>
      </div>
      <div class="progress-label">
        <span id="progress-percent">0%</span> shipped
      </div>
    </div>

    <div class="progress-card">
      <div class="card-label">Mothership Scan</div>
      <div class="progress-stats">
        <div class="stat">
          <span class="stat-value" id="scanned-count">0</span>
          <span class="stat-label">Routes Scanned</span>
        </div>
        <div class="stat">
          <span class="stat-value" id="avg-alignment">--</span>
          <span class="stat-label">Avg Persona Fit</span>
        </div>
        <div class="stat">
          <span class="stat-value" id="total-entries">0</span>
          <span class="stat-label">Entries Scored</span>
        </div>
      </div>
      <div class="scan-actions">
        <button class="btn btn-primary btn-sm" id="scan-all-btn">
          Scan All Collections
        </button>
        <button class="btn btn-secondary btn-sm" id="reset-btn" title="Clear all saved pipeline state">Reset</button>
      </div>
    </div>

    <div class="progress-card">
      <div class="card-label">Workflow</div>
      <div class="workflow-stages">
        <div class="wf-stage">
          <span class="wf-dot wf-brief"></span>
          <span class="wf-label">Brief</span>
          <span class="wf-desc">research-brief.mjs</span>
        </div>
        <div class="wf-arrow">&rarr;</div>
        <div class="wf-stage">
          <span class="wf-dot wf-writing"></span>
          <span class="wf-label">Writing</span>
          <span class="wf-desc">/southland-copy</span>
        </div>
        <div class="wf-arrow">&rarr;</div>
        <div class="wf-stage">
          <span class="wf-dot wf-built"></span>
          <span class="wf-label">Built</span>
          <span class="wf-desc">Astro page</span>
        </div>
        <div class="wf-arrow">&rarr;</div>
        <div class="wf-stage">
          <span class="wf-dot wf-design"></span>
          <span class="wf-label">Design</span>
          <span class="wf-desc">/design review</span>
        </div>
        <div class="wf-arrow">&rarr;</div>
        <div class="wf-stage">
          <span class="wf-dot wf-shipped"></span>
          <span class="wf-label">Shipped</span>
          <span class="wf-desc">Live on site</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Page Groups -->
  {
    pageGroups.map((group) => (
      <div class="audit-group" data-group={group.id}>
        <div class="group-header">
          <h2 class="group-title">{group.name}</h2>
          <span class="group-count">{group.pages.length} routes</span>
        </div>
        <div class="audit-table">
          <div class="table-header">
            <div class="col-status"></div>
            <div class="col-page">Page</div>
            <div class="col-type">Type</div>
            <div class="col-pipeline">Pipeline</div>
            <div class="col-score">Persona Fit</div>
            <div class="col-quality">Quality</div>
            <div class="col-actions"></div>
          </div>
          {group.pages.map((page) => (
            <div>
              <div
                class="table-row"
                data-route={page.route}
                data-scan-route={page.scanRoute || ''}
                data-type={page.type}
                data-count={page.count || 0}
              >
                <div class="col-status">
                  <span class="status-dot not-started" data-status-dot />
                </div>
                <div class="col-page">
                  <div class="page-name-row">
                    <span class="page-name">{page.name}</span>
                    {page.count ? <span class="entry-count">{page.count}</span> : null}
                  </div>
                  <code class="page-route">{page.route}</code>
                  {page.backingCollection ? (
                    <span class="redirect-tag" title={`/collections/${page.backingCollection} → ${page.route} (301)`}>
                      &larr; /collections/{page.backingCollection}
                    </span>
                  ) : null}
                </div>
                <div class="col-type">
                  <span class={`type-badge type-${page.type}`}>{page.type}</span>
                </div>
                <div class="col-pipeline">
                  <select class="pipeline-select" data-field="pipeline">
                    {PIPELINE_STAGES.map((stage) => (
                      <option value={stage.value}>{stage.label}</option>
                    ))}
                  </select>
                </div>
                <div class="col-score">
                  {page.scanRoute ? (
                    <button class="scan-btn" data-action="scan" title="Score via Mothership persona vectors">Scan</button>
                  ) : (
                    <span class="score-na">--</span>
                  )}
                </div>
                <div class="col-quality">
                  <span class="quality-summary" data-quality-for={page.route}>--</span>
                </div>
                <div class="col-actions">
                  {page.route.includes('[') ? null : (
                    <a
                      href={page.route}
                      target="_blank"
                      class="open-btn"
                      title="Open page"
                    >
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                  )}
                </div>
              </div>
              <div class="scan-details" data-details-for={page.route}></div>
            </div>
          ))}
        </div>
      </div>
    ))
  }

  <!-- Scan progress (sticky bottom) -->
  <div class="scan-progress" id="scan-progress" style="display: none;">
    <div class="scan-progress-inner">
      <span class="scan-progress-label" id="scan-progress-label">Scanning...</span>
      <div class="scan-progress-bar-container">
        <div class="scan-progress-bar" id="scan-progress-bar" style="width: 0%"></div>
      </div>
      <span class="scan-progress-count" id="scan-progress-count">0/0</span>
      <button class="btn btn-secondary btn-sm" id="scan-cancel-btn">Cancel</button>
    </div>
  </div>

  <!-- Scannable routes for JS -->
  <script is:inline define:vars={{ scannableRoutes }}>
    window.__SCANNABLE_ROUTES = scannableRoutes
  </script>
</AdminLayout>

<style>
  :global(.admin-main) { max-width: none !important; }

  /* ========== Overview Grid ========== */
  .overview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }
  .progress-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
  }
  .card-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    margin-bottom: 12px;
  }
  .progress-stats { display: flex; gap: 20px; margin-bottom: 12px; }
  .stat { text-align: center; }
  .stat-value {
    display: block;
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
    line-height: 1;
  }
  .stat-label {
    font-size: 10px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .progress-bar-container {
    height: 6px;
    background: var(--surface-alt);
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-bar {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.3s ease;
  }
  .progress-label {
    margin-top: 6px;
    font-size: 12px;
    color: var(--text-secondary);
  }
  #progress-percent { font-weight: 600; color: var(--accent); }
  .scan-actions { display: flex; gap: 8px; margin-top: 12px; }

  /* Workflow stages */
  .workflow-stages {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .wf-stage { text-align: center; }
  .wf-dot {
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin: 0 auto 4px;
  }
  .wf-brief { background: #94a3b8; }
  .wf-writing { background: #f59e0b; }
  .wf-built { background: #3b82f6; }
  .wf-design { background: #8b5cf6; }
  .wf-shipped { background: #22c55e; }
  .wf-label { display: block; font-size: 11px; font-weight: 600; color: var(--text); }
  .wf-desc { display: block; font-size: 9px; color: var(--text-tertiary); font-family: var(--font-mono); }
  .wf-arrow { color: var(--text-tertiary); font-size: 14px; margin: 0 2px; }

  /* ========== Audit Table ========== */
  .audit-group {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 16px;
    overflow: hidden;
  }
  .group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: var(--surface-alt);
    border-bottom: 1px solid var(--border);
  }
  .group-title { font-size: 14px; font-weight: 600; color: var(--text); }
  .group-count { font-size: 12px; color: var(--text-secondary); }
  .audit-table { font-size: 12px; overflow-x: auto; }

  .table-header,
  .table-row {
    display: grid;
    grid-template-columns: 28px minmax(200px, 1.5fr) 80px 120px 90px 120px 32px;
    gap: 8px;
    padding: 8px 16px;
    align-items: center;
  }
  .table-header {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    font-size: 10px;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    position: sticky;
    top: 0;
    z-index: 2;
  }
  .table-row {
    border-bottom: 1px solid var(--border-subtle);
  }
  .table-row:hover { background: var(--bg); }

  .col-status { display: flex; justify-content: center; }
  .col-page { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .page-name-row { display: flex; align-items: center; gap: 6px; }
  .page-name { font-weight: 500; color: var(--text); font-size: 13px; }
  .entry-count {
    font-size: 10px;
    font-weight: 600;
    color: var(--text-tertiary);
    background: var(--surface-alt);
    padding: 1px 5px;
    border-radius: 3px;
  }
  .page-route {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-tertiary);
  }
  .redirect-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 9px;
    color: #7c3aed;
    background: #ede9fe;
    padding: 1px 6px;
    border-radius: 3px;
    cursor: help;
  }

  /* Status dots */
  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-dot.not-started { background: var(--border); }
  .status-dot.in-progress { background: #f59e0b; }
  .status-dot.shipped { background: #22c55e; }

  /* Type badges */
  .type-badge {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .type-collection { background: #dbeafe; color: #1e40af; }
  .type-static { background: #f3f4f6; color: #6b7280; }
  .type-index { background: #f3f4f6; color: #9ca3af; }

  /* Pipeline select */
  .pipeline-select {
    width: 100%;
    padding: 4px 6px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 11px;
    background: var(--surface);
    cursor: pointer;
  }
  .pipeline-select:focus { outline: none; border-color: var(--accent); }
  .pipeline-select.stage-shipped { border-color: #22c55e; color: #166534; font-weight: 600; }
  .pipeline-select.stage-design { border-color: #8b5cf6; color: #5b21b6; }
  .pipeline-select.stage-built { border-color: #3b82f6; color: #1e40af; }
  .pipeline-select.stage-writing { border-color: #f59e0b; color: #92400e; }
  .pipeline-select.stage-brief { border-color: #94a3b8; color: #475569; }

  /* Scan button */
  .scan-btn {
    padding: 3px 10px;
    font-size: 10px;
    font-weight: 600;
    background: var(--surface);
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.15s;
  }
  .scan-btn:hover { background: var(--accent); color: white; }
  .scan-btn:disabled { opacity: 0.5; cursor: wait; }
  .scan-btn.scanning { animation: pulse 1.5s infinite; }
  .score-na { font-size: 11px; color: var(--text-tertiary); }

  /* Score badge (replaces scan button after scan) */
  .score-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 24px;
    padding: 0 8px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: transform 0.15s;
  }
  .score-badge:hover { transform: scale(1.05); }
  .score-high { background: #dcfce7; color: #166534; }
  .score-mid { background: #fef3c7; color: #92400e; }
  .score-low { background: #fee2e2; color: #991b1b; }
  .score-confused { background: #f3f4f6; color: #9ca3af; }

  .quality-summary { font-size: 10px; color: var(--text-tertiary); }

  .open-btn {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
    border-radius: var(--radius-sm);
    transition: all 0.15s;
    text-decoration: none;
  }
  .open-btn:hover { background: var(--surface-alt); color: var(--accent); }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* ========== Scan Detail Panel ========== */
  .scan-details {
    display: none;
    padding: 16px 20px;
    background: var(--surface-alt);
    border-bottom: 1px solid var(--border-subtle);
  }
  .scan-details.open { display: block; }

  .detail-summary {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 16px;
    line-height: 1.5;
  }
  .detail-fixes {
    margin-bottom: 16px;
    padding: 12px 16px;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: var(--radius-sm);
  }
  .detail-fixes-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #92400e;
    margin-bottom: 8px;
  }
  .detail-fixes ol { margin: 0; padding-left: 20px; font-size: 13px; color: #78350f; line-height: 1.6; }

  .entry-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-bottom: 16px; }
  .entry-table th {
    text-align: left;
    padding: 8px 10px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }
  .entry-table td {
    padding: 8px 10px;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--text);
    vertical-align: middle;
  }
  .entry-table tr:hover td { background: var(--bg); }
  .entry-table .entry-title a { color: var(--accent); text-decoration: none; font-weight: 500; }
  .entry-table .entry-title a:hover { text-decoration: underline; }
  .entry-table .cell-red { color: #dc2626; font-weight: 600; }
  .entry-table .cell-amber { color: #d97706; font-weight: 600; }
  .entry-table .cell-green { color: #16a34a; }
  .entry-table .cell-muted { color: var(--text-tertiary); }
  .entry-table .gap-badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 10px; font-weight: 600; }
  .entry-table .gap-orphan { background: #fee2e2; color: #991b1b; }
  .entry-table .gap-weak { background: #fef3c7; color: #92400e; }
  .entry-table .gap-confused { background: #ede9fe; color: #5b21b6; }
  .entry-table .gap-ok { background: #dcfce7; color: #166534; }

  .persona-chart {
    margin-top: 12px;
    padding: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }
  .persona-chart-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    margin-bottom: 10px;
  }
  .persona-bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  .persona-bar-label { font-size: 10px; font-weight: 600; width: 50px; flex-shrink: 0; color: var(--text-secondary); }
  .persona-bar-track { flex: 1; height: 8px; background: var(--surface-alt); border-radius: 4px; overflow: hidden; }
  .persona-bar-fill { height: 100%; border-radius: 4px; transition: width 0.3s ease; }
  .persona-bar-fill.high { background: #16a34a; }
  .persona-bar-fill.mid { background: #eab308; }
  .persona-bar-fill.low { background: #dc2626; }
  .persona-bar-pct { font-size: 10px; font-weight: 600; width: 30px; text-align: right; color: var(--text-secondary); }

  /* ========== Scan Progress (Sticky Bottom) ========== */
  .scan-progress {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--surface);
    border-top: 2px solid var(--accent);
    box-shadow: 0 -2px 8px rgba(0,0,0,0.1);
  }
  .scan-progress-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .scan-progress-label { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; }
  .scan-progress-bar-container { flex: 1; height: 8px; background: var(--surface-alt); border-radius: 4px; overflow: hidden; }
  .scan-progress-bar { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.3s ease; }
  .scan-progress-count { font-size: 12px; font-weight: 600; color: var(--text-secondary); white-space: nowrap; }
  .btn-sm { padding: 4px 12px; font-size: 12px; }

  /* ========== Responsive ========== */
  @media (max-width: 1200px) {
    .overview-grid { grid-template-columns: 1fr; }
    .table-header, .table-row {
      grid-template-columns: 28px minmax(160px, 1.5fr) 70px 110px 80px 100px 28px;
    }
  }
  @media (max-width: 900px) {
    .table-header, .table-row {
      grid-template-columns: 28px 1fr 100px 80px 28px;
    }
    .col-type, .col-quality { display: none; }
    .workflow-stages { flex-direction: column; align-items: flex-start; }
    .wf-arrow { display: none; }
  }
</style>

<script is:inline>
  // =========================================================================
  // CONFIG + STATE
  // =========================================================================
  var STORAGE_KEY = 'southland_site_audit_v2'
  var scanCancelled = false
  var scanResults = {}

  function loadState() {
    try {
      var saved = localStorage.getItem(STORAGE_KEY)
      return saved ? JSON.parse(saved) : {}
    } catch (e) { return {} }
  }

  function saveState(state) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state))
  }

  // =========================================================================
  // STATUS + PROGRESS
  // =========================================================================

  function getRowStatus(pipeline) {
    if (pipeline === 'shipped') return 'shipped'
    if (pipeline) return 'in-progress'
    return 'not-started'
  }

  function updateProgress() {
    var state = loadState()
    var rows = document.querySelectorAll('.table-row')
    var shipped = 0, inPipeline = 0, notStarted = 0

    rows.forEach(function(row) {
      var route = row.dataset.route
      var data = state[route] || {}
      var pipeline = data.pipeline || ''
      var pipelineSelect = row.querySelector('[data-field="pipeline"]')
      if (pipelineSelect && !data.pipeline) pipeline = pipelineSelect.value

      var status = getRowStatus(pipeline)
      var dot = row.querySelector('[data-status-dot]')
      if (dot) dot.className = 'status-dot ' + status

      if (status === 'shipped') shipped++
      else if (status === 'in-progress') inPipeline++
      else notStarted++

      // Pipeline select styling
      if (pipelineSelect) {
        pipelineSelect.className = 'pipeline-select'
        if (pipeline) pipelineSelect.classList.add('stage-' + pipeline)
        if (data.pipeline) pipelineSelect.value = data.pipeline
      }

      // Quality summary
      updateQualitySummary(row, data)
    })

    var total = rows.length
    var percent = total > 0 ? Math.round((shipped / total) * 100) : 0
    document.getElementById('shipped-count').textContent = shipped
    document.getElementById('pipeline-count').textContent = inPipeline
    document.getElementById('not-started-count').textContent = notStarted
    document.getElementById('progress-bar').style.width = percent + '%'
    document.getElementById('progress-percent').textContent = percent + '%'

    updateScanStats()
  }

  function updateQualitySummary(row, data) {
    var el = row.querySelector('.quality-summary')
    if (!el || !data.scan) return

    var q = data.scan
    var parts = []
    if (q.avgWordCount) parts.push(q.avgWordCount + 'w avg')
    if (q.stubbedCount > 0) parts.push(q.stubbedCount + ' stubs')
    if (q.missingMeta > 0) parts.push(q.missingMeta + ' no meta')
    if (q.noInternalLinks > 0) parts.push(q.noInternalLinks + ' no links')

    if (parts.length > 0) {
      el.textContent = parts.join(' · ')
      el.style.color = (q.stubbedCount > 0 || q.noInternalLinks > 0) ? '#dc2626' : 'var(--text-secondary)'
    }
  }

  function updateScanStats() {
    var state = loadState()
    var scanned = 0, totalAlignment = 0, totalEntries = 0

    Object.values(state).forEach(function(data) {
      if (data.scan && data.scan.avgAlignment !== undefined) {
        scanned++
        totalAlignment += data.scan.avgAlignment
        totalEntries += data.scan.scoredCount || 0
      }
    })

    document.getElementById('scanned-count').textContent = scanned
    document.getElementById('avg-alignment').textContent = scanned > 0 ? Math.round(totalAlignment / scanned) + '%' : '--'
    document.getElementById('total-entries').textContent = totalEntries
  }

  // =========================================================================
  // SCAN
  // =========================================================================

  function scanRoute(route) {
    return fetch('/api/site-audit/scan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ route: route }),
    })
    .then(function(res) { return res.json() })
    .then(function(result) {
      if (result && result.entries) scanResults[route] = result
      return result
    })
  }

  function handleScanResult(route, result) {
    if (!result || result.scannable === false) return

    // Find the row that has this scan route
    var row = document.querySelector('.table-row[data-scan-route="' + route + '"]')
    if (!row) return

    // Render score badge
    renderScoreBadge(row, result)

    // Render detail panel
    renderDetailPanel(row.dataset.route, result)

    // Auto-expand detail panel
    var panel = document.querySelector('[data-details-for="' + row.dataset.route + '"]')
    if (panel) panel.classList.add('open')

    // Cache result
    cacheScanResult(row.dataset.route, result)

    // Auto-set pipeline if not already set
    autoSetPipeline(row, result)

    updateProgress()
  }

  // =========================================================================
  // SCORE BADGE
  // =========================================================================

  function renderScoreBadge(row, result) {
    var scoreCol = row.querySelector('.col-score')
    if (!scoreCol) return

    var p = result.aggregate.persona
    var label, cls

    if (!p) {
      label = '--'
      cls = 'score-low'
    } else if (p.unclearCount === result.scoredCount) {
      label = '?'
      cls = 'score-confused'
    } else {
      var initial = p.primaryAudience ? p.primaryAudience.split(' ').pop().charAt(0).toUpperCase() : '?'
      label = initial + ' ' + p.avgAlignment + '%'
      cls = p.avgAlignment >= 60 ? 'score-high' : (p.avgAlignment >= 40 ? 'score-mid' : 'score-low')
    }

    scoreCol.innerHTML = '<button class="score-badge ' + cls + '" data-action="toggle-details" title="Click to expand/collapse">' + label + '</button>'
  }

  // =========================================================================
  // DETAIL PANEL
  // =========================================================================

  function renderDetailPanel(route, result) {
    var panel = document.querySelector('[data-details-for="' + route + '"]')
    if (!panel) return

    var entries = result.entries || []
    var agg = result.aggregate
    var p = agg.persona
    var q = agg.quality
    var html = ''

    // Summary line
    var summary = '<strong>' + result.scoredCount + '</strong> entries scanned.'
    if (p) {
      if (p.unclearCount === result.scoredCount) {
        summary += ' No clear audience — content is too generic.'
      } else {
        summary += ' Speaks to <strong>' + p.primaryAudience + '</strong> at ' + p.avgAlignment + '% avg fit.'
        if (q.noInternalLinks > 0) summary += ' <span style="color:#dc2626">' + q.noInternalLinks + ' have zero internal links.</span>'
        if (q.stubbedCount > 0) summary += ' <span style="color:#dc2626">' + q.stubbedCount + ' are stubs.</span>'
        if (q.missingMeta > 0) summary += ' ' + q.missingMeta + ' missing meta.'
      }
    }
    html += '<div class="detail-summary">' + summary + '</div>'

    // Top fixes
    var fixes = generateFixes(entries)
    if (fixes.length > 0) {
      html += '<div class="detail-fixes"><div class="detail-fixes-title">Top Fixes</div><ol>'
      fixes.forEach(function(f) { html += '<li>' + f + '</li>' })
      html += '</ol></div>'
    }

    // Entry table
    if (entries.length > 0) {
      var sorted = entries.slice().sort(function(a, b) { return issueCount(b) - issueCount(a) })
      html += '<table class="entry-table"><thead><tr>'
      html += '<th>Entry</th><th>Audience</th><th>Align</th><th>Words</th><th>Read.</th><th>Links</th><th>H2s</th><th>Gap</th>'
      html += '</tr></thead><tbody>'

      sorted.forEach(function(entry) {
        var ep = entry.persona
        var eq = entry.quality
        var eg = entry.gap

        var audienceCell, alignCell
        if (!ep) {
          audienceCell = '<span class="cell-muted">--</span>'
          alignCell = '<span class="cell-muted">--</span>'
        } else if (ep.unclear) {
          audienceCell = '<span class="cell-amber">unclear</span>'
          alignCell = '<span class="cell-muted">--</span>'
        } else {
          audienceCell = ep.audience
          var alignCls = ep.alignment >= 60 ? 'cell-green' : (ep.alignment >= 40 ? 'cell-amber' : 'cell-red')
          alignCell = '<span class="' + alignCls + '">' + ep.alignment + '%</span>'
        }

        var wordsCls = eq.stubbed ? 'cell-red' : (eq.wordCount < 300 ? 'cell-amber' : '')
        var wordsCell = '<span class="' + wordsCls + '">' + eq.wordCount + '</span>'
        var readCell = eq.readability.gradeLevel !== 'unknown' ? eq.readability.gradeLevel : '<span class="cell-muted">--</span>'
        var linkTotal = eq.internalLinks + eq.externalLinks
        var linksCell = '<span class="' + (linkTotal === 0 ? 'cell-red' : '') + '">' + linkTotal + '</span>'
        var h2Cell = eq.headings.h2 > 0 ? eq.headings.h2 + ' H2' : '<span class="cell-muted">--</span>'
        if (!eq.headings.properStructure && eq.headings.h2 > 0) h2Cell = '<span class="cell-amber">' + h2Cell + '</span>'
        var gapCell = '<span class="cell-muted">--</span>'
        if (eg) gapCell = '<span class="gap-badge gap-' + eg.status.toLowerCase() + '">' + eg.status + '</span>'

        html += '<tr>'
        html += '<td class="entry-title"><a href="' + entry.url + '" target="_blank">' + entry.title + '</a></td>'
        html += '<td>' + audienceCell + '</td><td>' + alignCell + '</td><td>' + wordsCell + '</td>'
        html += '<td>' + readCell + '</td><td>' + linksCell + '</td><td>' + h2Cell + '</td><td>' + gapCell + '</td></tr>'
      })
      html += '</tbody></table>'
    }

    // Persona distribution chart
    if (p && p.unclearCount < result.scoredCount) {
      var billTotal = 0, bettyTotal = 0, taylorTotal = 0, personaCount = 0
      entries.forEach(function(e) {
        if (e.persona) {
          billTotal += e.persona.scores.bill
          bettyTotal += e.persona.scores.betty
          taylorTotal += e.persona.scores.taylor
          personaCount++
        }
      })
      if (personaCount > 0) {
        var avgBill = Math.round(billTotal / personaCount)
        var avgBetty = Math.round(bettyTotal / personaCount)
        var avgTaylor = Math.round(taylorTotal / personaCount)
        html += '<div class="persona-chart"><div class="persona-chart-title">Persona Fit (avg across ' + personaCount + ' entries)</div>'
        html += renderPersonaBar('Bill', avgBill) + renderPersonaBar('Betty', avgBetty) + renderPersonaBar('Taylor', avgTaylor)
        html += '</div>'
      }
    }

    panel.innerHTML = html
  }

  function renderPersonaBar(label, pct) {
    var cls = pct >= 60 ? 'high' : (pct >= 40 ? 'mid' : 'low')
    return '<div class="persona-bar-row"><span class="persona-bar-label">' + label + '</span>' +
      '<div class="persona-bar-track"><div class="persona-bar-fill ' + cls + '" style="width:' + pct + '%"></div></div>' +
      '<span class="persona-bar-pct">' + pct + '%</span></div>'
  }

  // =========================================================================
  // FIXES + ISSUE COUNT
  // =========================================================================

  function issueCount(entry) {
    var count = 0
    var q = entry.quality
    if (q.stubbed) count += 2
    if (q.internalLinks + q.externalLinks === 0) count += 2
    if (!q.hasMetaDescription) count++
    if (!q.headings.properStructure) count++
    if (entry.persona && entry.persona.unclear) count += 2
    if (!entry.persona) count++
    if (entry.gap && entry.gap.status === 'ORPHAN') count++
    return count
  }

  function generateFixes(entries) {
    var fixes = []
    var noLinks = entries.filter(function(e) { return e.quality.internalLinks + e.quality.externalLinks === 0 })
    if (noLinks.length > 0) {
      var names = noLinks.slice(0, 4).map(function(e) { return e.title })
      fixes.push('Add internal links to <strong>' + names.join('</strong>, <strong>') + '</strong>' + (noLinks.length > 4 ? ' + ' + (noLinks.length - 4) + ' more' : ''))
    }
    var stubs = entries.filter(function(e) { return e.quality.stubbed })
    if (stubs.length > 0) {
      var names2 = stubs.slice(0, 3).map(function(e) { return e.title + ' (' + e.quality.wordCount + 'w)' })
      fixes.push('Expand stubs: <strong>' + names2.join('</strong>, <strong>') + '</strong>')
    }
    var noMeta = entries.filter(function(e) { return !e.quality.hasMetaDescription })
    if (noMeta.length > 0) {
      var names3 = noMeta.slice(0, 4).map(function(e) { return e.title })
      fixes.push('Add meta descriptions: <strong>' + names3.join('</strong>, <strong>') + '</strong>')
    }
    var unclear = entries.filter(function(e) { return e.persona && e.persona.unclear })
    if (unclear.length > 0 && fixes.length < 4) {
      var names4 = unclear.slice(0, 3).map(function(e) { return e.title })
      fixes.push('Unclear audience: <strong>' + names4.join('</strong>, <strong>') + '</strong>')
    }
    return fixes.slice(0, 4)
  }

  // =========================================================================
  // AUTO-SET PIPELINE
  // =========================================================================

  function autoSetPipeline(row, result) {
    var state = loadState()
    var route = row.dataset.route
    var data = state[route] || {}
    if (data.pipeline) return // already manually set

    var p = result.aggregate.persona
    var q = result.aggregate.quality
    var qualityPassed = 0
    if (q.avgWordCount >= 300) qualityPassed++
    if (q.missingMeta === 0) qualityPassed++
    if (q.noInternalLinks === 0) qualityPassed++
    if (q.badHeadingsCount === 0) qualityPassed++
    if (q.stubbedCount === 0) qualityPassed++

    var inferred = ''
    if (p && p.avgAlignment >= 60 && qualityPassed >= 4) inferred = 'built'
    else if (p && p.avgAlignment >= 40) inferred = 'writing'

    if (inferred) {
      var sel = row.querySelector('[data-field="pipeline"]')
      if (sel) {
        sel.value = inferred
        state[route] = data
        state[route].pipeline = inferred
        saveState(state)
      }
    }
  }

  // =========================================================================
  // CACHE SCAN
  // =========================================================================

  function cacheScanResult(route, result) {
    if (result.scannable === false) return
    var state = loadState()
    if (!state[route]) state[route] = {}
    var p = result.aggregate.persona
    var q = result.aggregate.quality
    state[route].scan = {
      scannedAt: result.scannedAt,
      scoredCount: result.scoredCount,
      totalEntries: result.entryCount,
      primaryAudience: p ? p.primaryAudience : null,
      avgAlignment: p ? p.avgAlignment : null,
      unclearCount: p ? p.unclearCount : null,
      avgWordCount: q.avgWordCount,
      missingMeta: q.missingMeta,
      noInternalLinks: q.noInternalLinks,
      stubbedCount: q.stubbedCount,
    }
    saveState(state)
  }

  // =========================================================================
  // EVENT HANDLERS
  // =========================================================================

  document.addEventListener('DOMContentLoaded', function() {
    updateProgress()

    // Pipeline change
    document.querySelectorAll('.pipeline-select').forEach(function(sel) {
      sel.addEventListener('change', function() {
        var row = sel.closest('.table-row')
        var route = row.dataset.route
        var state = loadState()
        if (!state[route]) state[route] = {}
        state[route].pipeline = sel.value
        saveState(state)
        updateProgress()
      })
    })

    // Individual scan buttons
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-action="scan"]')
      if (btn) {
        var row = btn.closest('.table-row')
        var scanRoute = row.dataset.scanRoute
        if (!scanRoute) return

        btn.disabled = true
        btn.classList.add('scanning')
        btn.textContent = '...'

        window.scanRoute(scanRoute).then(function(result) {
          handleScanResult(scanRoute, result)
        }).catch(function(err) {
          btn.disabled = false
          btn.classList.remove('scanning')
          btn.textContent = 'Error'
          console.error('Scan failed:', err)
        })
      }

      // Toggle detail panel
      var toggle = e.target.closest('[data-action="toggle-details"]')
      if (toggle) {
        var row2 = toggle.closest('.table-row')
        var panel = document.querySelector('[data-details-for="' + row2.dataset.route + '"]')
        if (panel) panel.classList.toggle('open')
      }
    })

    // Scan All
    document.getElementById('scan-all-btn').addEventListener('click', function() {
      var routes = window.__SCANNABLE_ROUTES || []
      if (routes.length === 0) return

      scanCancelled = false
      var progressEl = document.getElementById('scan-progress')
      var barEl = document.getElementById('scan-progress-bar')
      var labelEl = document.getElementById('scan-progress-label')
      var countEl = document.getElementById('scan-progress-count')
      progressEl.style.display = 'block'

      var done = 0
      var total = routes.length

      function next(i) {
        if (i >= total || scanCancelled) {
          progressEl.style.display = 'none'
          return
        }

        var route = routes[i]
        labelEl.textContent = 'Scanning ' + route + '...'
        countEl.textContent = (i + 1) + '/' + total

        scanRoute(route).then(function(result) {
          done++
          barEl.style.width = Math.round((done / total) * 100) + '%'
          handleScanResult(route, result)
          next(i + 1)
        }).catch(function() {
          done++
          barEl.style.width = Math.round((done / total) * 100) + '%'
          next(i + 1)
        })
      }

      next(0)
    })

    // Cancel scan
    document.getElementById('scan-cancel-btn').addEventListener('click', function() {
      scanCancelled = true
    })

    // Reset
    document.getElementById('reset-btn').addEventListener('click', function() {
      if (confirm('Reset all pipeline state and scan results?')) {
        localStorage.removeItem(STORAGE_KEY)
        scanResults = {}
        document.querySelectorAll('.scan-details').forEach(function(p) {
          p.classList.remove('open')
          p.innerHTML = ''
        })
        document.querySelectorAll('.pipeline-select').forEach(function(s) { s.value = '' })
        document.querySelectorAll('.col-score').forEach(function(col) {
          var row = col.closest('.table-row')
          if (row && row.dataset.scanRoute) {
            col.innerHTML = '<button class="scan-btn" data-action="scan">Scan</button>'
          }
        })
        document.querySelectorAll('.quality-summary').forEach(function(el) {
          el.textContent = '--'
          el.style.color = ''
        })
        updateProgress()
      }
    })
  })

  // Make scanRoute global so inline handlers work
  window.scanRoute = scanRoute
</script>
