---
/**
 * Go-Live Readiness — Page Audit Pipeline
 *
 * Pipeline-style audit console for DNS cutover readiness.
 * Leads Pipeline pattern: summary cards → compact table → side drawer.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro'

// ---------------------------------------------------------------------------
// Pages with classification data
// ---------------------------------------------------------------------------
const pages = [
  { path: '/poultry/commercial/', label: 'Broiler Bill Landing', archetype: 'storybrand-landing', persona: 'bill', referencePage: null, priority: 'critical', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/poultry/backyard/', label: 'Backyard Betty Landing', archetype: 'storybrand-landing', persona: 'betty', referencePage: '/poultry/commercial/', priority: 'critical', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/poultry/breeders/', label: 'Breeders Landing', archetype: 'storybrand-landing', persona: 'bill', referencePage: '/poultry/commercial/', priority: 'critical', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/poultry/turkey/', label: 'Turkey Landing', archetype: 'storybrand-landing', persona: 'bill', referencePage: '/poultry/commercial/', priority: 'critical', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/poultry/game-birds/', label: 'Game Birds Landing', archetype: 'storybrand-landing', persona: 'bill', referencePage: '/poultry/commercial/', priority: 'critical', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/lawn/turf-pros/', label: 'Turf Pro Landing', archetype: 'storybrand-landing', persona: 'taylor', referencePage: '/poultry/commercial/', priority: 'critical', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/lawn/golf-courses/', label: 'Golf Courses Landing', archetype: 'storybrand-landing', persona: 'taylor', referencePage: '/poultry/commercial/', priority: 'high', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/lawn/homeowners/', label: 'Homeowners Landing', archetype: 'storybrand-landing', persona: 'general', referencePage: '/poultry/commercial/', priority: 'high', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/lawn/landscapers/', label: 'Landscapers Landing', archetype: 'storybrand-landing', persona: 'taylor', referencePage: '/poultry/commercial/', priority: 'high', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/agriculture/crops/', label: 'Crops Landing', archetype: 'storybrand-landing', persona: 'general', referencePage: '/poultry/commercial/', priority: 'high', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/agriculture/produce/', label: 'Produce Landing', archetype: 'storybrand-landing', persona: 'general', referencePage: '/poultry/commercial/', priority: 'high', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/livestock/swine/', label: 'Swine Landing', archetype: 'storybrand-landing', persona: 'general', referencePage: '/poultry/commercial/', priority: 'high', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/hydroseeders/', label: 'Hydroseeders Landing', archetype: 'storybrand-landing', persona: 'taylor', referencePage: '/poultry/commercial/', priority: 'high', group: 'StoryBrand Landings', type: 'audit' },
  { path: '/poultry/', label: 'Poultry Hub', archetype: 'hub', persona: 'general', referencePage: null, priority: 'critical', group: 'Hub Pages', type: 'audit' },
  { path: '/lawn/', label: 'Lawn Hub', archetype: 'hub', persona: 'general', referencePage: '/poultry/', priority: 'high', group: 'Hub Pages', type: 'audit' },
  { path: '/blog/', label: 'Blog Index', archetype: 'hub', persona: 'general', referencePage: null, priority: 'high', group: 'Hub Pages', type: 'audit' },
  { path: '/podcast/', label: 'Podcast Hub', archetype: 'hub', persona: 'general', referencePage: null, priority: 'high', group: 'Hub Pages', type: 'audit' },
  { path: '/about/', label: 'About', archetype: 'utility', persona: 'general', referencePage: '/contact/', priority: 'high', group: 'Utility Pages', type: 'audit' },
  { path: '/contact/', label: 'Contact', archetype: 'utility', persona: 'general', referencePage: null, priority: 'high', group: 'Utility Pages', type: 'audit' },
  { path: '/distribution/', label: 'Distribution', archetype: 'utility', persona: 'general', referencePage: '/contact/', priority: 'medium', group: 'Utility Pages', type: 'audit' },
  { path: '/store-locator/', label: 'Store Locator', archetype: 'utility', persona: 'general', referencePage: '/contact/', priority: 'medium', group: 'Utility Pages', type: 'audit' },
  { path: '/team/', label: 'Team', archetype: 'utility', persona: 'general', referencePage: '/contact/', priority: 'medium', group: 'Utility Pages', type: 'audit' },
  { path: '/podcast/guests/', label: 'Podcast Guests', archetype: 'utility', persona: 'general', referencePage: '/podcast/', priority: 'medium', group: 'Utility Pages', type: 'audit' },
  { path: '/podcast/topics/', label: 'Podcast Topics', archetype: 'utility', persona: 'general', referencePage: '/podcast/', priority: 'medium', group: 'Utility Pages', type: 'audit' },
  { path: '/build-a-case/', label: 'Build a Case', archetype: 'shop', persona: 'general', referencePage: null, priority: 'high', group: 'Shop Pages', type: 'audit' },
  { path: '/products/', label: 'Products Index', archetype: 'shop', persona: 'general', referencePage: null, priority: 'high', group: 'Shop Pages', type: 'audit' },
  { path: '/products/sanitizers/', label: 'Sanitizers', archetype: 'shop', persona: 'general', referencePage: null, priority: 'medium', group: 'Shop Pages', type: 'audit' },
  { path: '/products/waste-treatment/', label: 'Waste Treatment', archetype: 'shop', persona: 'general', referencePage: null, priority: 'medium', group: 'Shop Pages', type: 'audit' },
  { path: '/blog/how-do-plants-get-nutrients-cation-exchange-capacity-cec-explained/', label: 'Sample Blog (CEC)', archetype: 'content', persona: 'general', referencePage: null, priority: 'medium', group: 'Content Samples', type: 'audit' },
  { path: '/', label: 'Homepage', archetype: 'proxy', persona: 'general', referencePage: null, priority: 'critical', group: 'Proxy Pass-through', type: 'check' },
  { path: '/products/big-ole-bird', label: 'Sample PDP', archetype: 'proxy', persona: 'general', referencePage: null, priority: 'medium', group: 'Proxy Pass-through', type: 'check' },
  { path: '/cart/', label: 'Cart', archetype: 'proxy', persona: 'general', referencePage: null, priority: 'medium', group: 'Proxy Pass-through', type: 'check' },
  { path: '/collections/all', label: 'All Products', archetype: 'proxy', persona: 'general', referencePage: null, priority: 'medium', group: 'Proxy Pass-through', type: 'check' },
]

const pageGroupOrder = ['StoryBrand Landings', 'Hub Pages', 'Utility Pages', 'Shop Pages', 'Content Samples', 'Proxy Pass-through']
const groupShortNames: Record<string, string> = { 'StoryBrand Landings': 'STORYBRAND', 'Hub Pages': 'HUB', 'Utility Pages': 'UTILITY', 'Shop Pages': 'SHOP', 'Content Samples': 'CONTENT', 'Proxy Pass-through': 'PROXY' }

function groupBy<T extends { group: string }>(items: T[]): Map<string, T[]> {
  const map = new Map<string, T[]>()
  for (const item of items) {
    if (!map.has(item.group)) map.set(item.group, [])
    map.get(item.group)!.push(item)
  }
  return map
}

const pageGroups = groupBy(pages)
const totalPages = pages.length
const auditableCount = pages.filter(p => p.type === 'audit').length
---

<AdminLayout title="Go Live" activeNav="/admin/go-live">

  <!-- Summary Cards -->
  <div class="summary-cards">
    <button class="scard scard--ship" data-filter="ship">
      <div class="scard__num" id="count-ship">0</div>
      <div class="scard__label" id="label-ship">Ship</div>
    </button>
    <button class="scard scard--fix" data-filter="fix">
      <div class="scard__num" id="count-fix">0</div>
      <div class="scard__label" id="label-fix">Fix</div>
    </button>
    <button class="scard scard--rewrite" data-filter="rewrite">
      <div class="scard__num" id="count-rewrite">0</div>
      <div class="scard__label" id="label-rewrite">Rewrite</div>
    </button>
    <button class="scard scard--unaudited" data-filter="unaudited">
      <div class="scard__num" id="count-unaudited">{totalPages}</div>
      <div class="scard__label" id="label-unaudited">Not Audited</div>
    </button>
  </div>

  <!-- Progress + controls -->
  <div class="controls-row">
    <span class="progress-text" id="progress-text">0/{totalPages} approved</span>
    <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
    <label class="critical-toggle">
      <input type="checkbox" id="critical-only" /> <span id="critical-label">Critical only</span>
    </label>
    <button class="btn btn-sm btn-primary" id="audit-all-btn">Audit All ({auditableCount})</button>
    <button class="btn btn-sm btn-secondary" id="reset-btn">Reset</button>
  </div>

  <!-- Compact Table -->
  <div class="table-wrap">
    <table class="audit-table">
      <thead>
        <tr>
          <th class="th-page">Page</th>
          <th class="th-group">Group</th>
          <th class="th-grade">Grade</th>
          <th class="th-grade">Orig</th>
          <th class="th-grade">Voice</th>
          <th class="th-verdict">Verdict</th>
          <th class="th-actions"></th>
        </tr>
      </thead>
      <tbody>
        {pageGroupOrder.map(groupName => {
          const groupPages = pageGroups.get(groupName) || []
          return (
            <>
              <tr class="group-row"><td colspan="7">{groupName} <span class="group-count">{groupPages.length}</span></td></tr>
              {groupPages.map(page => (
                <tr
                  class="page-row"
                  data-path={page.path}
                  data-archetype={page.archetype}
                  data-persona={page.persona}
                  data-reference={page.referencePage || ''}
                  data-page-type={page.type}
                  data-priority={page.priority}
                  data-status="pending"
                  data-verdict=""
                  data-group={groupShortNames[page.group] || page.group}
                >
                  <td class="td-page">
                    <div class="page-info">
                      <div class="page-name">{page.label}</div>
                      <div class="page-path">{page.path}</div>
                    </div>
                  </td>
                  <td class="td-group">{groupShortNames[page.group]}</td>
                  <td class="td-grade"><span class="grade-slot" id={`g-${page.path}`}>—</span></td>
                  <td class="td-grade"><span class="grade-slot" id={`o-${page.path}`}>—</span></td>
                  <td class="td-grade"><span class="grade-slot" id={`vd-${page.path}`}>—</span></td>
                  <td class="td-verdict"><span class="verdict-slot" id={`v-${page.path}`}>—</span></td>
                  <td class="td-actions">
                    <a class="icon-link" href={page.path} target="_blank" rel="noopener" title="Open page">&#x2197;</a>
                    <button class="btn btn-sm btn-secondary action-btn" data-action="audit">{page.type === 'audit' ? 'Audit' : 'Check'}</button>
                  </td>
                </tr>
              ))}
            </>
          )
        })}
      </tbody>
    </table>
  </div>

  <!-- Drawer backdrop -->
  <div class="drawer-backdrop" id="drawer-backdrop" style="display:none"></div>

  <!-- Side Drawer -->
  <div class="drawer" id="audit-drawer">
    <div class="drawer-header">
      <div>
        <div class="drawer-title" id="drawer-title"></div>
        <div class="drawer-path" id="drawer-path"></div>
        <div class="drawer-meta" id="drawer-meta"></div>
      </div>
      <button class="drawer-close" id="drawer-close">&times;</button>
    </div>
    <div class="drawer-body" id="drawer-body"></div>
    <div class="drawer-footer" id="drawer-footer"></div>
  </div>

<style is:global>
  /* ── Summary Cards ─────────────────────────────────────────── */
  .summary-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 12px;
  }
  .scard {
    padding: 14px 16px;
    border-radius: var(--radius);
    border: 2px solid transparent;
    text-align: left;
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s;
    font-family: var(--font);
  }
  .scard:hover { box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
  .scard.active { border-color: currentColor; }
  .scard__num { font-size: 26px; font-weight: 700; font-family: var(--font-mono); line-height: 1; }
  .scard__label { font-size: 11px; color: var(--text-secondary); margin-top: 4px; }
  .scard--ship { background: #dcfce7; }
  .scard--ship .scard__num { color: #166534; }
  .scard--fix { background: #fef3c7; }
  .scard--fix .scard__num { color: #92400e; }
  .scard--rewrite { background: #fee2e2; }
  .scard--rewrite .scard__num { color: #991b1b; }
  .scard--unaudited { background: #e5e7eb; }
  .scard--unaudited .scard__num { color: #6b7280; }

  /* ── Controls Row ──────────────────────────────────────────── */
  .controls-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    font-size: 13px;
    color: var(--text-secondary);
  }
  .progress-text { white-space: nowrap; font-weight: 500; }
  .progress-track {
    flex: 1;
    height: 4px;
    background: var(--surface-alt);
    border-radius: 2px;
    overflow: hidden;
    min-width: 80px;
  }
  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.3s ease;
  }
  .critical-toggle {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    cursor: pointer;
    white-space: nowrap;
    color: var(--text-secondary);
  }
  .critical-toggle input { accent-color: var(--accent); }
  .btn-sm { padding: 4px 10px; font-size: 12px; }
  .btn-primary { background: var(--accent); color: white; border: 1px solid var(--accent); }
  .btn-primary:hover { opacity: 0.9; }

  /* ── Table ──────────────────────────────────────────────────── */
  .table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .audit-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .audit-table thead th {
    padding: 6px 12px;
    text-align: left;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    background: var(--surface-alt);
    border-bottom: 1px solid var(--border);
  }
  .th-grade, .th-verdict { text-align: center; width: 60px; }
  .th-group { width: 100px; }
  .th-actions { width: 100px; }

  .group-row td {
    padding: 5px 12px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    background: var(--surface-alt);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }
  .group-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 16px;
    padding: 0 5px;
    border-radius: 8px;
    background: var(--surface);
    font-size: 10px;
    font-weight: 500;
    color: var(--text-secondary);
    margin-left: 4px;
  }

  .page-row {
    border-bottom: 1px solid var(--border-subtle);
    border-left: 3px solid var(--border);
    cursor: pointer;
    transition: background 0.1s;
  }
  .page-row:hover { background: var(--surface-alt); }
  .page-row.selected { background: rgba(68,136,62,0.06); }
  .page-row[data-verdict="ship"] { border-left-color: #22c55e; }
  .page-row[data-verdict="fix"] { border-left-color: #f59e0b; }
  .page-row[data-verdict="rewrite"] { border-left-color: #ef4444; }
  .page-row[data-status="flagged"] { border-left-color: #ef4444; }
  .page-row[data-status="approved"] { opacity: 0.6; }
  .page-row[data-status="approved"]:hover { opacity: 0.85; }

  .td-page {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
  }
  .page-info { min-width: 0; }
  .page-name { font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .page-path { font-size: 11px; color: var(--text-tertiary); font-family: var(--font-mono); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 260px; }

  .td-group {
    padding: 7px 8px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    color: var(--text-tertiary);
  }
  .td-grade, .td-verdict { text-align: center; padding: 7px 8px; }
  .grade-slot { font-size: 12px; font-weight: 700; font-family: var(--font-mono); color: var(--text-tertiary); }
  .verdict-slot { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; color: var(--text-tertiary); }

  .grade-A { color: #166534; }
  .grade-B { color: #1e40af; }
  .grade-C { color: #92400e; }
  .grade-D { color: #991b1b; }
  .grade-F { color: #fff; background: #991b1b; padding: 1px 5px; border-radius: 3px; }
  .verdict-ship { color: #166534; }
  .verdict-fix { color: #92400e; }
  .verdict-rewrite { color: #991b1b; }

  .td-actions {
    padding: 7px 12px;
    text-align: right;
    white-space: nowrap;
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    padding: 3px 5px;
    font-size: 13px;
    color: var(--text-tertiary);
    text-decoration: none;
    border-radius: 3px;
  }
  .icon-link:hover { background: var(--surface-alt); color: var(--text); }
  .action-btn { margin-left: 4px; }

  /* ── Drawer ─────────────────────────────────────────────────── */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: rgba(0,0,0,0.12);
  }
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    width: 520px;
    max-width: 100vw;
    background: var(--surface);
    border-left: 1px solid var(--border);
    box-shadow: -4px 0 20px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.2s ease;
  }
  .drawer.open { transform: translateX(0); }
  .drawer-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .drawer-title { font-size: 15px; font-weight: 600; color: var(--text); }
  .drawer-path { font-size: 11px; color: var(--text-tertiary); font-family: var(--font-mono); margin-top: 2px; }
  .drawer-meta { font-size: 11px; color: var(--text-tertiary); margin-top: 4px; }
  .drawer-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: var(--text-tertiary);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    line-height: 1;
  }
  .drawer-close:hover { background: var(--surface-alt); color: var(--text); }
  .drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }
  .drawer-footer {
    flex-shrink: 0;
    padding: 12px 20px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  /* Drawer sections */
  .dsection { margin-bottom: 14px; }
  .dsection-title {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-tertiary);
    margin-bottom: 6px;
  }
  .dclass-row {
    display: flex;
    gap: 12px;
    font-size: 12px;
    color: var(--text-secondary);
    flex-wrap: wrap;
  }
  .dclass-row strong { color: var(--text); }

  .dgrades {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
    font-size: 12px;
    color: var(--text-secondary);
  }
  .dgrades strong { font-family: var(--font-mono); font-weight: 700; }

  .dcat {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    margin-bottom: 4px;
    overflow: hidden;
  }
  .dcat-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
    user-select: none;
  }
  .dcat-header:hover { background: var(--surface-alt); }
  .dcat-toggle { font-size: 9px; color: var(--text-tertiary); transition: transform 0.15s; }
  .dcat.open .dcat-toggle { transform: rotate(90deg); }
  .dcat-grade { margin-left: auto; font-family: var(--font-mono); font-weight: 700; font-size: 11px; }
  .dcat-body { display: none; padding: 0 10px 6px; font-size: 12px; }
  .dcat.open .dcat-body { display: block; }

  .dcheck {
    display: flex;
    align-items: flex-start;
    gap: 5px;
    padding: 3px 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .dcheck:last-child { border-bottom: none; }
  .dcheck-icon { flex-shrink: 0; width: 14px; text-align: center; font-size: 11px; }
  .dcheck-label { color: var(--text); }
  .dcheck-detail { color: var(--text-tertiary); font-size: 11px; }
  .chk-pass { color: #166534; }
  .chk-fail { color: #991b1b; }
  .chk-warn { color: #92400e; }

  /* Deep scan */
  .deep-section {
    padding: 10px 12px;
    border: 1px dashed var(--border);
    border-radius: var(--radius-sm);
    margin-bottom: 14px;
  }
  .deep-btn {
    padding: 5px 12px;
    font-size: 12px;
    cursor: pointer;
  }
  .deep-hint { font-size: 11px; color: var(--text-tertiary); margin-top: 4px; }

  /* Actions list */
  .dactions { margin-bottom: 14px; }
  .daction-row {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    font-size: 12px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .daction-row:last-child { border-bottom: none; }
  .daction-num { font-weight: 600; color: var(--text-tertiary); min-width: 18px; }
  .daction-type {
    font-size: 10px;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 3px;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .dtype-fix { background: #fef3c7; color: #92400e; }
  .dtype-rewrite { background: #fee2e2; color: #991b1b; }
  .dtype-add { background: #dbeafe; color: #1e40af; }
  .daction-text { flex: 1; color: var(--text); }

  /* Footer review actions */
  .review-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
  }
  .btn-approve { background: #dcfce7; color: #166534; border: 1px solid transparent; }
  .btn-approve:hover, .btn-approve.active { background: #22c55e; color: white; }
  .btn-flag { background: #fee2e2; color: #991b1b; border: 1px solid transparent; }
  .btn-flag:hover, .btn-flag.active { background: #ef4444; color: white; }
  .btn-skip { background: var(--surface-alt); color: var(--text-secondary); border: 1px solid transparent; }
  .btn-skip:hover, .btn-skip.active { background: var(--text-tertiary); color: white; }
  .note-input {
    width: 100%;
    padding: 6px 8px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--font);
    font-size: 12px;
    resize: vertical;
    min-height: 32px;
  }

  @media (max-width: 900px) {
    .summary-cards { grid-template-columns: repeat(2, 1fr); }
    .controls-row { flex-wrap: wrap; }
    .drawer { width: 100vw; }
  }
</style>

<script is:inline>
  // ═══════════════════════════════════════════════════════════════════════════
  // STATE
  // ═══════════════════════════════════════════════════════════════════════════
  var STORAGE_KEY = 'southland_go_live_v3'
  var FILTER_KEY = 'southland_go_live_filter'
  var TOTAL_PAGES = document.querySelectorAll('.page-row').length

  function emptyState() { return { _version: 3, _infra: {}, pages: {} } }

  function loadStateLocal() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY)
      if (!raw) return null
      var s = JSON.parse(raw)
      return s._version === 3 ? s : null
    } catch (e) { return null }
  }

  async function loadStateFromFile() {
    try {
      var res = await fetch('/api/go-live/state')
      if (!res.ok) return null
      var data = await res.json()
      if (!data || data._version !== 3) return null
      return data
    } catch (e) { return null }
  }

  function mergeStates(fileState, localState) {
    if (!fileState) return localState || emptyState()
    if (!localState) return fileState
    var merged = JSON.parse(JSON.stringify(fileState))
    for (var path in localState.pages) {
      var lp = localState.pages[path]
      var fp = merged.pages[path]
      if (!fp) { merged.pages[path] = lp; continue }
      if (lp.reviewedAt && (!fp.reviewedAt || lp.reviewedAt > fp.reviewedAt)) {
        fp.status = lp.status; fp.reviewedAt = lp.reviewedAt; fp.note = lp.note
      }
      if (lp.cached && lp.cached.fetchedAt && (!fp.cached || !fp.cached.fetchedAt || lp.cached.fetchedAt > fp.cached.fetchedAt)) {
        fp.cached = lp.cached; fp.audit = lp.audit
      }
      // Deep scan: keep whichever exists or is newer; tie goes to local
      if (lp.deepScan && !fp.deepScan) {
        fp.deepScan = lp.deepScan
      } else if (lp.deepScan && fp.deepScan && lp.deepScan.scannedAt && (!fp.deepScan.scannedAt || lp.deepScan.scannedAt >= fp.deepScan.scannedAt)) {
        fp.deepScan = lp.deepScan
      }
    }
    for (var k in localState._infra) { if (localState._infra[k]) merged._infra[k] = true }
    return merged
  }

  var _saveTimer = null
  function saveState(s) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(s))
    clearTimeout(_saveTimer)
    _saveTimer = setTimeout(function() {
      fetch('/api/go-live/state', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(s) }).catch(function() {})
    }, 500)
  }

  function getPage(state, path) {
    if (!state.pages[path]) state.pages[path] = { status: null, reviewedAt: null, note: '', cached: null, audit: null, deepScan: null }
    return state.pages[path]
  }

  function esc(str) { return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') }

  function timeAgo(iso) {
    if (!iso) return 'never'
    var ms = Date.now() - new Date(iso).getTime()
    var mins = Math.round(ms / 60000)
    if (mins < 1) return 'just now'
    if (mins < 60) return mins + 'm ago'
    var hrs = Math.round(mins / 60)
    if (hrs < 24) return hrs + 'h ago'
    return Math.round(hrs / 24) + 'd ago'
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // SUMMARY + FILTERS
  // ═══════════════════════════════════════════════════════════════════════════
  var activeFilter = localStorage.getItem(FILTER_KEY) || null

  function updateSummary(state) {
    var approved = 0, flagged = 0, skipped = 0
    var ship = 0, fix = 0, rewrite = 0, audited = 0
    for (var key in state.pages) {
      var p = state.pages[key]
      if (p.status === 'approved') approved++
      else if (p.status === 'flagged') flagged++
      else if (p.status === 'skipped') skipped++
      if (p.audit && p.audit.verdict) {
        audited++
        if (p.audit.verdict === 'ship') ship++
        else if (p.audit.verdict === 'fix') fix++
        else if (p.audit.verdict === 'rewrite') rewrite++
      }
    }
    var unaudited = TOTAL_PAGES - audited

    document.getElementById('count-ship').textContent = ship
    document.getElementById('label-ship').textContent = ship + ' page' + (ship !== 1 ? 's' : '') + ' \u00B7 ' + (TOTAL_PAGES > 0 ? Math.round(ship / TOTAL_PAGES * 100) : 0) + '%'
    document.getElementById('count-fix').textContent = fix
    document.getElementById('label-fix').textContent = fix + ' page' + (fix !== 1 ? 's' : '') + ' \u00B7 ' + (TOTAL_PAGES > 0 ? Math.round(fix / TOTAL_PAGES * 100) : 0) + '%'
    document.getElementById('count-rewrite').textContent = rewrite
    document.getElementById('label-rewrite').textContent = rewrite + ' page' + (rewrite !== 1 ? 's' : '') + ' \u00B7 ' + (TOTAL_PAGES > 0 ? Math.round(rewrite / TOTAL_PAGES * 100) : 0) + '%'
    document.getElementById('count-unaudited').textContent = unaudited
    document.getElementById('label-unaudited').textContent = unaudited + ' page' + (unaudited !== 1 ? 's' : '') + ' \u00B7 ' + (TOTAL_PAGES > 0 ? Math.round(unaudited / TOTAL_PAGES * 100) : 0) + '%'

    var done = approved + skipped
    var pct = TOTAL_PAGES > 0 ? Math.round(done / TOTAL_PAGES * 100) : 0
    document.getElementById('progress-text').textContent = approved + '/' + TOTAL_PAGES + ' approved'
    document.getElementById('progress-fill').style.width = pct + '%'
  }

  function applyFilters() {
    var critOnly = document.getElementById('critical-only').checked
    var critCount = 0
    document.querySelectorAll('.page-row').forEach(function(row) {
      var verdict = row.dataset.verdict
      var priority = row.dataset.priority
      var show = true
      if (activeFilter) {
        if (activeFilter === 'unaudited') show = !verdict
        else show = verdict === activeFilter
      }
      if (show && critOnly) show = priority === 'critical'
      if (critOnly && priority === 'critical') critCount++
      row.style.display = show ? '' : 'none'
    })
    // Highlight active card
    document.querySelectorAll('.scard').forEach(function(c) {
      c.classList.toggle('active', c.dataset.filter === activeFilter)
    })
    // Update critical label
    var critLabel = document.getElementById('critical-label')
    if (critLabel) critLabel.textContent = critOnly ? 'Critical only \u00B7 ' + critCount + ' pages' : 'Critical only'
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // TABLE ROW BADGES
  // ═══════════════════════════════════════════════════════════════════════════
  function updateRowBadges(path, state) {
    var ps = getPage(state, path)
    var row = document.querySelector('tr.page-row[data-path="' + path + '"]')
    if (!row) return

    if (ps.status) row.dataset.status = ps.status

    var gradeEl = document.getElementById('g-' + path)
    var verdictEl = document.getElementById('v-' + path)

    if (ps.audit && !ps.audit.error) {
      row.dataset.verdict = ps.audit.verdict
      row.title = ps.audit.verdict.toUpperCase() + ' \u2014 ' + ps.audit.overallGrade + ' \u2014 Click to view details'
      if (gradeEl) { gradeEl.textContent = ps.audit.overallGrade; gradeEl.className = 'grade-slot grade-' + ps.audit.overallGrade }
      if (verdictEl) { verdictEl.textContent = ps.audit.verdict.toUpperCase(); verdictEl.className = 'verdict-slot verdict-' + ps.audit.verdict }
    }

    // Deep scan columns
    var origEl = document.getElementById('o-' + path)
    var vdEl = document.getElementById('vd-' + path)
    if (ps.deepScan) {
      if (origEl && ps.deepScan.originality) { origEl.textContent = ps.deepScan.originality.grade; origEl.className = 'grade-slot grade-' + ps.deepScan.originality.grade }
      if (vdEl && ps.deepScan.voiceDeep) { vdEl.textContent = ps.deepScan.voiceDeep.grade; vdEl.className = 'grade-slot grade-' + ps.deepScan.voiceDeep.grade }
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // AUDIT API
  // ═══════════════════════════════════════════════════════════════════════════
  async function auditPage(path, archetype, persona, ref) {
    var res = await fetch('/api/go-live/audit', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path: path, archetype: archetype, persona: persona, referencePage: ref }),
    })
    if (!res.ok) throw new Error('Audit API returned ' + res.status)
    return await res.json()
  }

  async function checkPage(path) {
    var res = await fetch(path, { redirect: 'follow' })
    var html = await res.text()
    var titleMatch = html.match(/<title[^>]*>([\s\S]*?)<\/title>/i)
    var bodyText = html.replace(/<script[\s\S]*?<\/script>/gi,'').replace(/<style[\s\S]*?<\/style>/gi,'').replace(/<[^>]+>/g,' ').replace(/\s+/g,' ').trim()
    return { ok: res.ok, status: res.status, title: titleMatch ? titleMatch[1].trim() : '(no title)', wordCount: bodyText.split(/\s+/).filter(Boolean).length }
  }

  async function runCheck(path, state, forceRefresh) {
    var row = document.querySelector('tr.page-row[data-path="' + path + '"]')
    if (!row) return
    var ps = getPage(state, path)
    var pageType = row.dataset.pageType

    if (!forceRefresh && ps.cached) {
      openDrawer(path, state)
      return
    }

    openDrawer(path, state, true) // show loading in drawer

    try {
      var result
      if (pageType === 'audit') {
        result = await auditPage(path, row.dataset.archetype, row.dataset.persona, row.dataset.reference || null)
        ps.audit = result
      } else {
        result = await checkPage(path)
      }
      ps.cached = { response: result, fetchedAt: new Date().toISOString() }
      saveState(state)
      updateRowBadges(path, state)
      updateSummary(state)
      applyFilters()
      openDrawer(path, state)
    } catch (err) {
      document.getElementById('drawer-body').innerHTML = '<div style="color:#991b1b;padding:12px">Error: ' + esc(err.message) + '</div>'
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // DRAWER
  // ═══════════════════════════════════════════════════════════════════════════
  var currentDrawerPath = null

  function openDrawer(path, state, loading) {
    currentDrawerPath = path
    var row = document.querySelector('tr.page-row[data-path="' + path + '"]')
    var ps = getPage(state, path)
    var drawer = document.getElementById('audit-drawer')
    var backdrop = document.getElementById('drawer-backdrop')

    // Highlight row
    document.querySelectorAll('.page-row.selected').forEach(function(r) { r.classList.remove('selected') })
    if (row) row.classList.add('selected')

    // Header
    document.getElementById('drawer-title').textContent = row ? row.querySelector('.page-name').textContent : path
    document.getElementById('drawer-path').textContent = path
    var metaParts = []
    if (row) metaParts.push(row.dataset.archetype, row.dataset.persona !== 'general' ? row.dataset.persona : null, row.dataset.priority)
    if (ps.cached) metaParts.push('Audited ' + timeAgo(ps.cached.fetchedAt))
    document.getElementById('drawer-meta').textContent = metaParts.filter(Boolean).join(' \u00B7 ')

    // Body
    var body = document.getElementById('drawer-body')
    if (loading) {
      body.innerHTML = '<div style="padding:20px;color:var(--text-tertiary)">Auditing\u2026</div>'
    } else if (ps.audit && !ps.audit.error) {
      body.innerHTML = renderDrawerContent(ps.audit, path, state)
      wireDrawerSections()
    } else if (ps.cached && ps.cached.response && ps.cached.response.ok !== undefined) {
      // Simple check result
      var r = ps.cached.response
      body.innerHTML = '<div class="dsection"><div class="dsection-title">HTTP Check</div>' +
        '<div style="font-size:13px">' + (r.ok ? '<span style="color:#166534">' + r.status + ' OK</span>' : '<span style="color:#991b1b">' + r.status + ' Error</span>') +
        ' &mdash; ' + esc(r.title) + ' &mdash; ' + (r.wordCount || 0).toLocaleString() + ' words</div></div>'
    } else {
      body.innerHTML = '<div style="padding:20px;color:var(--text-tertiary)">No audit data yet. Click Audit to scan.</div>'
    }

    // Footer
    renderFooter(path, state)

    drawer.classList.add('open')
    backdrop.style.display = ''
  }

  function closeDrawer() {
    currentDrawerPath = null
    document.getElementById('audit-drawer').classList.remove('open')
    document.getElementById('drawer-backdrop').style.display = 'none'
    document.querySelectorAll('.page-row.selected').forEach(function(r) { r.classList.remove('selected') })
  }

  function renderFooter(path, state) {
    var ps = getPage(state, path)
    var f = document.getElementById('drawer-footer')
    var h = '<div class="review-bar">'
    h += '<button class="btn btn-sm btn-approve' + (ps.status === 'approved' ? ' active' : '') + '" data-set-status="approved">Approve</button>'
    h += '<button class="btn btn-sm btn-flag' + (ps.status === 'flagged' ? ' active' : '') + '" data-set-status="flagged">Flag</button>'
    h += '<button class="btn btn-sm btn-skip' + (ps.status === 'skipped' ? ' active' : '') + '" data-set-status="skipped">Skip</button>'
    h += '<span style="flex:1"></span>'
    h += '<button class="btn btn-sm btn-secondary" id="drawer-reaudit">Re-Audit</button>'
    h += '</div>'
    h += '<textarea class="note-input" id="drawer-note" placeholder="Notes...">' + esc(ps.note || '') + '</textarea>'
    f.innerHTML = h

    // Wire
    f.querySelectorAll('[data-set-status]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var ps2 = getPage(state, path)
        ps2.status = btn.dataset.setStatus
        ps2.reviewedAt = new Date().toISOString()
        saveState(state)
        updateRowBadges(path, state)
        updateSummary(state)
        applyFilters()
        f.querySelectorAll('[data-set-status]').forEach(function(b) { b.classList.remove('active') })
        btn.classList.add('active')
      })
    })
    var noteEl = document.getElementById('drawer-note')
    noteEl.addEventListener('input', function() { var ps2 = getPage(state, path); ps2.note = noteEl.value; saveState(state) })
    document.getElementById('drawer-reaudit').addEventListener('click', function() { runCheck(path, state, true) })
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // DRAWER CONTENT RENDERING
  // ═══════════════════════════════════════════════════════════════════════════
  function renderDrawerContent(audit, path, state) {
    var h = ''

    // Grades
    h += '<div class="dsection"><div class="dsection-title">Grades</div><div class="dgrades">'
    var cats = audit.categories
    if (cats.architecture) h += 'Arch: <strong class="grade-' + cats.architecture.grade + '">' + cats.architecture.grade + '</strong>'
    h += 'Design: <strong class="grade-' + cats.design.grade + '">' + cats.design.grade + '</strong>'
    h += 'SEO: <strong class="grade-' + cats.seo.grade + '">' + cats.seo.grade + '</strong>'
    if (cats.products) h += 'Products: <strong class="grade-' + cats.products.grade + '">' + cats.products.grade + '</strong>'
    if (cats.voice) h += 'Voice: <strong class="grade-' + cats.voice.grade + '">' + cats.voice.grade + '</strong>'
    h += '<span style="margin-left:auto;font-weight:700" class="grade-' + audit.overallGrade + '">' + audit.overallGrade + '</span>'
    h += '<span class="verdict-' + audit.verdict + '" style="font-size:11px;font-weight:600;text-transform:uppercase">' + audit.verdict + '</span>'
    h += '</div></div>'

    // Audit sections
    h += '<div class="dsection"><div class="dsection-title">Audit Details</div>'
    if (cats.architecture) h += renderCat(cats.architecture)
    h += renderCat(cats.design)
    h += renderCat(cats.seo)
    if (cats.products) h += renderCat(cats.products)
    if (cats.voice) h += renderCat(cats.voice)
    h += '</div>'

    // Deep scan
    var ps = getPage(state, path)
    var ds = ps.deepScan
    var deepTime = ds ? timeAgo(ds.scannedAt) : 'never'
    var isStale = ds && ds.scannedAt && (Date.now() - new Date(ds.scannedAt).getTime() > 7 * 24 * 60 * 60 * 1000)
    var btnLabel = ds ? 'Re-Run Deep Scan' : 'Run Deep Scan'

    h += '<div class="deep-section" id="deep-section">'
    h += '<div class="dsection-title">Deep Scan</div>'
    h += '<div id="deep-results">'
    // Restore saved results
    if (ds) {
      if (ds.originality) h += renderCat(ds.originality)
      if (ds.voiceDeep) h += renderCat(ds.voiceDeep)
    }
    h += '</div>'
    h += '<button class="btn btn-sm btn-secondary deep-btn" id="deep-scan-btn">' + btnLabel + '</button>'
    h += '<div class="deep-hint" id="deep-hint">~5\u201310s \u00B7 Originality + persona vectors + voice alignment \u00B7 Last: ' + deepTime
    if (isStale) h += ' <span style="color:#92400e">(consider re-running)</span>'
    h += '</div>'
    h += '</div>'

    // Actions
    if (audit.actions && audit.actions.length > 0) {
      h += '<div class="dactions"><div class="dsection-title">Priority Actions (' + audit.actions.length + ')</div>'
      audit.actions.forEach(function(a) {
        h += '<div class="daction-row">'
        h += '<span class="daction-num">' + a.index + '</span>'
        h += '<span class="daction-type dtype-' + a.type + '">' + a.type + '</span>'
        h += '<span class="daction-text">' + esc(a.action) + '</span>'
        h += '</div>'
      })
      h += '</div>'
    }

    return h
  }

  function renderCat(cat) {
    var passCount = cat.checks.filter(function(c) { return c.status === 'pass' }).length
    var h = '<div class="dcat">'
    h += '<div class="dcat-header" onclick="this.parentElement.classList.toggle(\'open\')">'
    h += '<span class="dcat-toggle">\u25B6</span>'
    h += '<span>' + esc(cat.name) + '</span>'
    h += '<span style="font-size:11px;color:var(--text-tertiary)">' + passCount + '/' + cat.checks.length + '</span>'
    h += '<span class="dcat-grade grade-' + cat.grade + '">' + cat.grade + '</span>'
    h += '</div><div class="dcat-body">'
    cat.checks.forEach(function(c) {
      var icon = c.status === 'pass' ? '\u2713' : c.status === 'fail' ? '\u2717' : '\u26A0'
      var cls = 'chk-' + c.status
      h += '<div class="dcheck"><span class="dcheck-icon ' + cls + '">' + icon + '</span><div>'
      h += '<div class="dcheck-label ' + cls + '">' + esc(c.label) + '</div>'
      if (c.detail) h += '<div class="dcheck-detail">' + esc(c.detail) + '</div>'
      h += '</div></div>'
    })
    h += '</div></div>'
    return h
  }

  function wireDrawerSections() {
    var btn = document.getElementById('deep-scan-btn')
    if (btn) {
      btn.addEventListener('click', function() {
        var path = currentDrawerPath
        var ps = getPage(state, path)

        // Confirm if recent scan exists (saves Originality credits)
        if (ps.deepScan && ps.deepScan.scannedAt) {
          var ageMs = Date.now() - new Date(ps.deepScan.scannedAt).getTime()
          if (ageMs < 10 * 60 * 1000) {
            if (!confirm('Last deep scan was ' + timeAgo(ps.deepScan.scannedAt) + '. Re-run? This uses Originality.ai credits.')) return
          }
        }

        btn.disabled = true
        btn.textContent = 'Running\u2026'
        var row = document.querySelector('tr.page-row[data-path="' + path + '"]')
        fetch('/api/go-live/deep-audit', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ path: path, persona: row ? row.dataset.persona : 'general' }),
        }).then(function(res) { return res.json() })
        .then(function(data) {
          if (data.error) throw new Error(data.message)

          // Persist to state
          ps.deepScan = {
            version: 1,
            originality: data.originality || null,
            voiceDeep: data.voiceDeep || null,
            scannedAt: new Date().toISOString(),
            duration: data.duration || null,
          }
          saveState(state)

          // Update table columns
          updateRowBadges(path, state)

          // Render results in drawer
          var results = document.getElementById('deep-results')
          var h = ''
          if (data.originality) h += renderCat(data.originality)
          if (data.voiceDeep) h += renderCat(data.voiceDeep)
          results.innerHTML = h

          btn.textContent = 'Re-Run Deep Scan'
          btn.disabled = false
          var hint = document.getElementById('deep-hint')
          if (hint) hint.innerHTML = '~5\u201310s \u00B7 Originality + persona vectors + voice alignment \u00B7 Last: just now'
        }).catch(function(err) {
          // Don't overwrite good deepScan on failure
          btn.textContent = ps.deepScan ? 'Re-Run Deep Scan' : 'Run Deep Scan'
          btn.disabled = false
          var results = document.getElementById('deep-results')
          // Prepend error but keep existing results
          var errHtml = '<div style="color:#991b1b;font-size:12px;margin-bottom:6px;padding:6px;border:1px solid #fee2e2;border-radius:4px">' + esc(err.message) + '</div>'
          results.insertAdjacentHTML('afterbegin', errHtml)
        })
      })
    }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // AUDIT ALL
  // ═══════════════════════════════════════════════════════════════════════════
  async function auditAll(state) {
    var rows = document.querySelectorAll('tr.page-row[data-page-type="audit"]')
    var btn = document.getElementById('audit-all-btn')
    btn.disabled = true
    var total = rows.length
    for (var i = 0; i < rows.length; i++) {
      btn.textContent = (i + 1) + '/' + total + '\u2026'
      var path = rows[i].dataset.path
      try { await runCheck(path, state, true) } catch (e) {}
    }
    btn.disabled = false
    btn.textContent = 'Audit All (' + total + ')'
    closeDrawer()
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // KEYBOARD
  // ═══════════════════════════════════════════════════════════════════════════
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeDrawer(); return }
    if (e.key !== 'ArrowUp' && e.key !== 'ArrowDown') return
    if (!currentDrawerPath) return
    e.preventDefault()
    var rows = Array.from(document.querySelectorAll('tr.page-row'))
    var visibleRows = rows.filter(function(r) { return r.style.display !== 'none' })
    var idx = visibleRows.findIndex(function(r) { return r.dataset.path === currentDrawerPath })
    if (idx === -1) return
    var next = e.key === 'ArrowDown' ? idx + 1 : idx - 1
    if (next < 0 || next >= visibleRows.length) return
    openDrawer(visibleRows[next].dataset.path, state)
    visibleRows[next].scrollIntoView({ block: 'nearest' })
  })

  // ═══════════════════════════════════════════════════════════════════════════
  // INIT
  // ═══════════════════════════════════════════════════════════════════════════
  var state = emptyState()

  ;(async function init() {
    var fileState = await loadStateFromFile()
    var localState = loadStateLocal()
    state = mergeStates(fileState, localState)
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state))
    if (fileState === null && localState !== null) {
      fetch('/api/go-live/state', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(state) }).catch(function() {})
    }

    // Restore row badges
    document.querySelectorAll('.page-row').forEach(function(row) {
      updateRowBadges(row.dataset.path, state)
    })

    // Restore filter
    var savedFilter = localStorage.getItem(FILTER_KEY)
    if (savedFilter) activeFilter = savedFilter

    updateSummary(state)
    applyFilters()
  })()

  // Wire row clicks (exclude link icons and action buttons)
  document.querySelectorAll('.page-row').forEach(function(row) {
    row.addEventListener('click', function(e) {
      if (e.target.closest('.icon-link') || e.target.closest('.action-btn')) return
      openDrawer(row.dataset.path, state)
    })
  })

  // Wire audit buttons
  document.querySelectorAll('.action-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation()
      var row = btn.closest('.page-row')
      runCheck(row.dataset.path, state, false)
    })
  })

  // Wire link icons to not propagate
  document.querySelectorAll('.icon-link').forEach(function(link) {
    link.addEventListener('click', function(e) { e.stopPropagation() })
  })

  // Wire summary cards
  document.querySelectorAll('.scard').forEach(function(card) {
    card.addEventListener('click', function() {
      var f = card.dataset.filter
      activeFilter = activeFilter === f ? null : f
      localStorage.setItem(FILTER_KEY, activeFilter || '')
      applyFilters()
    })
  })

  // Wire critical toggle
  document.getElementById('critical-only').addEventListener('change', applyFilters)

  // Wire backdrop
  document.getElementById('drawer-backdrop').addEventListener('click', closeDrawer)
  document.getElementById('drawer-close').addEventListener('click', closeDrawer)

  // Wire audit all
  document.getElementById('audit-all-btn').addEventListener('click', function() { auditAll(state) })

  // Wire reset
  document.getElementById('reset-btn').addEventListener('click', function() {
    if (confirm('Reset all progress?')) {
      localStorage.removeItem(STORAGE_KEY)
      localStorage.removeItem(FILTER_KEY)
      fetch('/api/go-live/state', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(emptyState()) })
        .then(function() { location.reload() }).catch(function() { location.reload() })
    }
  })
</script>
</AdminLayout>
