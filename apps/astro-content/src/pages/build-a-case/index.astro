---
/**
 * /build-a-case/ — Mix & Match Gallon Case Builder
 *
 * React island (CaseBuilder) handles the interactive picker.
 * Static content around it provides SEO value, internal links,
 * and context for the audit pipeline.
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import CaseBuilder from '../../components/bundle/CaseBuilder'
import { buildCloudinaryUrl } from '../../lib/cloudinary'

const title = 'Mix & Match Gallon Case Builder | Southland Organics'
const description =
  'Pick any 4 gallon products and save on price and shipping. Mix and match organic poultry, lawn, and garden products into one case.'

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/build-a-case/`
const ogImage = buildCloudinaryUrl('Southland Website/heroes/Farm_Athens_GA_4_qaishv', {
  width: 1200,
  height: 630,
  crop: 'fill',
})

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Build Your Own Gallon Case',
  description,
  url: canonicalUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: 'Southland Organics',
    url: siteUrl,
  },
}
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
>
  <!-- Hero -->
  <section class="bg-[#2C5234] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <span
        class="mb-4 inline-block rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-green-200"
      >
        Save on Every Case
      </span>
      <h1 class="mb-4 font-heading text-3xl uppercase text-white md:text-4xl lg:text-5xl">
        Build Your Own Case
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-green-100">
        4 individual gallons = 4 separate packages and 4 shipping charges. Build a case and they
        ship together — you save on every gallon and pay for one shipment, not four.
      </p>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h2
        class="mb-8 text-center font-heading text-2xl uppercase md:text-3xl"
        style="color: var(--color-title);"
      >
        How It Works
      </h2>
      <div class="space-y-6">
        <div class="flex gap-5">
          <div
            class="flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234] text-sm font-bold text-white"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            1
          </div>
          <div>
            <h3 class="font-semibold" style="color: var(--color-title);">Choose your products</h3>
            <p class="mt-1 text-sm text-gray-600">
              Browse our full line of gallon-sized products — <a
                href="/poultry/commercial/"
                class="font-medium text-[#44883E] hover:underline">poultry probiotics</a
              >,
              <a href="/lawn/turf-pros/" class="font-medium text-[#44883E] hover:underline"
                >soil conditioners</a
              >,
              <a href="/lawn/homeowners/" class="font-medium text-[#44883E] hover:underline"
                >lawn treatments</a
              >, and more.
            </p>
          </div>
        </div>
        <div class="flex gap-5">
          <div
            class="flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#44883E] text-sm font-bold text-white"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            2
          </div>
          <div>
            <h3 class="font-semibold" style="color: var(--color-title);">Fill your case</h3>
            <p class="mt-1 text-sm text-gray-600">
              Select any 4 gallon products. Pick 4 different products or multiples of the same one —
              it's your call. Popular picks include
              <a
                href="/products/poultry-probiotic/"
                class="font-medium text-[#44883E] hover:underline">Big Ole Bird</a
              > and
              <a href="/products/genesis/" class="font-medium text-[#44883E] hover:underline"
                >Genesis</a
              >.
            </p>
          </div>
        </div>
        <div class="flex gap-5">
          <div
            class="flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234] text-sm font-bold text-white"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            3
          </div>
          <div>
            <h3 class="font-semibold" style="color: var(--color-title);">
              Save on every gallon + shipping
            </h3>
            <p class="mt-1 text-sm text-gray-600">
              Case pricing applies automatically at checkout. 4 gallons ship as a single case
              instead of 4 individual packages — one shipping charge, not four.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular combinations -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h2
        class="mb-4 text-center font-heading text-2xl uppercase md:text-3xl"
        style="color: var(--color-title);"
      >
        Popular Case Combos
      </h2>
      <p class="mx-auto mb-10 max-w-2xl text-center text-gray-600">
        Not sure what to pick? Here's what other growers and turf pros build.
      </p>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Poultry case -->
        <div class="rounded-xl border border-gray-200 bg-[#F8FAF8] p-6">
          <div class="mb-3 flex items-center gap-2">
            <div
              class="flex h-8 w-8 flex-shrink-0 items-center justify-center bg-[#2C5234]"
              style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
            >
              <svg
                class="h-3.5 w-3.5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <h3 class="font-bold" style="color: #2C5234;">The Broiler Grower</h3>
          </div>
          <p class="mb-3 text-sm text-gray-600">For contract growers running 2-8 houses.</p>
          <ul class="space-y-1.5 text-sm text-gray-700">
            <li class="flex items-center gap-2">
              <svg
                class="h-3.5 w-3.5 shrink-0 text-[#44883E]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              2× <a
                href="/products/poultry-probiotic/"
                class="font-medium text-[#44883E] hover:underline">Big Ole Bird</a
              >
            </li>
            <li class="flex items-center gap-2">
              <svg
                class="h-3.5 w-3.5 shrink-0 text-[#44883E]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              1× <a
                href="/products/poultry-litter-amendment/"
                class="font-medium text-[#44883E] hover:underline">Litter Life</a
              >
            </li>
            <li class="flex items-center gap-2">
              <svg
                class="h-3.5 w-3.5 shrink-0 text-[#44883E]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              1× <a
                href="/products/catalyst-poultry-vitamin/"
                class="font-medium text-[#44883E] hover:underline">Catalyst</a
              >
            </li>
          </ul>
        </div>
        <!-- Turf case -->
        <div class="rounded-xl border border-gray-200 bg-[#F8FAF8] p-6">
          <div class="mb-3 flex items-center gap-2">
            <div
              class="flex h-8 w-8 flex-shrink-0 items-center justify-center bg-[#44883E]"
              style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
            >
              <svg
                class="h-3.5 w-3.5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
                ></path>
              </svg>
            </div>
            <h3 class="font-bold" style="color: #2C5234;">The Turf Pro</h3>
          </div>
          <p class="mb-3 text-sm text-gray-600">
            For superintendents and landscapers building soil biology.
          </p>
          <ul class="space-y-1.5 text-sm text-gray-700">
            <li class="flex items-center gap-2">
              <svg
                class="h-3.5 w-3.5 shrink-0 text-[#44883E]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              2× <a href="/products/genesis/" class="font-medium text-[#44883E] hover:underline"
                >Genesis</a
              >
            </li>
            <li class="flex items-center gap-2">
              <svg
                class="h-3.5 w-3.5 shrink-0 text-[#44883E]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              1× <a
                href="/products/turf-revival/"
                class="font-medium text-[#44883E] hover:underline">Turf Revival</a
              >
            </li>
            <li class="flex items-center gap-2">
              <svg
                class="h-3.5 w-3.5 shrink-0 text-[#44883E]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              1× <a href="/products/fertalive/" class="font-medium text-[#44883E] hover:underline"
                >FertAlive</a
              >
            </li>
          </ul>
        </div>
      </div>
      <p class="mt-6 text-center text-sm text-gray-500">
        Questions about what to include? <a
          href="/contact/"
          class="font-medium text-[#44883E] hover:underline">Talk to our team</a
        > — we'll help you build the right case for your operation. Read more on our
        <a href="/blog/" class="font-medium text-[#44883E] hover:underline">blog</a>.
      </p>
    </div>
  </section>

  <!-- Case Builder (React island) -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <CaseBuilder client:load />
    </div>
  </section>

  <!-- Proof Band -->
  <section class="bg-[#2C5234] py-12 md:py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">4</div>
          <div class="mt-1 text-sm font-medium text-white">Gallons per case</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">Mix</div>
          <div class="mt-1 text-sm font-medium text-white">Any combination</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">1</div>
          <div class="mt-1 text-sm font-medium text-white">Shipment, not 4</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">2009</div>
          <div class="mt-1 text-sm font-medium text-white">Family-owned since</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2
        class="mb-4 font-heading text-3xl uppercase md:text-4xl"
        style="color: var(--color-title);"
      >
        Ready to build your case?
      </h2>
      <p class="mx-auto mb-8 max-w-xl text-lg text-gray-600">
        Mix and match any of our gallon products. Pick four, we ship one case. Not sure what to
        include?
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="tel:800-608-3755"
          class="inline-flex items-center gap-3 rounded-xl bg-[#2C5234] px-8 py-4 text-xl font-bold text-white transition-colors hover:bg-[#2C5234]/90"
        >
          <svg class="h-6 w-6 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          800-608-3755
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-[#2C5234]/30 px-8 py-4 text-lg font-bold transition-colors hover:border-[#2C5234]/60 hover:bg-[#2C5234]/5"
          style="color: #2C5234;"
        >
          Contact Us
        </a>
      </div>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-sm text-gray-400">
        <span>Family-owned since 2009</span>
        <span class="hidden md:inline">·</span>
        <span>A+ BBB Rating</span>
      </div>
    </div>
  </section>
</BaseLayout>
