---
/**
 * Team Listing Page - /team/
 * Shows all team members in a grid layout
 */

export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import TeamGrid from '../../components/team/TeamGrid.astro'
import { getCollection } from 'astro:content'
import { getLogoUrl, buildSouthlandUrl } from '../../lib/cloudinary'

// Get all active team members
const allMembers = await getCollection('team', ({ data }) => {
  return data.active !== false
})

// Sort by order
const members = allMembers.sort((a, b) => (a.data.order || 99) - (b.data.order || 99))

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'

// Schema markup for team page
const teamSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Our Team | Southland Organics',
  description:
    'Meet the team behind Southland Organics. Experts in sustainable agriculture, soil biology, and organic solutions for poultry, turf, and farming.',
  url: `${siteUrl}/team/`,
  mainEntity: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: siteUrl,
    employee: members.map((member) => ({
      '@type': 'Person',
      name: member.data.name,
      jobTitle: member.data.role,
      description: member.data.bio,
      url: `${siteUrl}/team/${member.id.replace(/\.mdx?$/, '')}/`,
    })),
  },
}
---

<BaseLayout
  title="Our Team | Southland Organics"
  description="Meet the team behind Southland Organics. Experts in sustainable agriculture, soil biology, and organic solutions for poultry, turf, and farming."
  ogImage={buildSouthlandUrl('team/MIKE_Usry', {
    width: 1200,
    height: 630,
    crop: 'fill',
    gravity: 'face',
    quality: 'auto',
    format: 'auto',
  })}
  schema={teamSchema}
>
  <!-- Hero Section -->
  <section
    class="bg-gradient-to-br from-southland-green-dark via-southland-green-dark to-[#1f3d24] py-16 md:py-24"
  >
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm font-medium uppercase tracking-wide text-southland-green">
        Southland Organics
      </p>
      <h1 class="mb-6 font-heading text-4xl text-white md:text-5xl lg:text-6xl">Meet Our Team</h1>
      <p class="mx-auto max-w-2xl text-lg text-white/70 md:text-xl">
        When ammonia spikes, soil goes dead, or a turf program stalls, you need advice from people
        who've been in the field — not a call center. Every person on this page has hands-on
        experience in agriculture, soil biology, or poultry management.
      </p>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="bg-brand-gray py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-center font-heading text-2xl text-shopify-title md:text-3xl">
        The People Behind the Products
      </h2>
      <p class="mx-auto mb-10 max-w-2xl text-center text-shopify-secondary-text">
        Family-owned since 2009, with products developed alongside UGA researchers and tested on
        thousands of commercial operations. When you call, one of these people answers.
      </p>
      {
        members.length > 0 ? (
          <TeamGrid members={members} variant="grid" columns={3} />
        ) : (
          <div class="rounded-2xl bg-white py-16 text-center shadow-sm">
            <div class="mx-auto mb-6 h-20 w-20 text-shopify-secondary-text">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                />
              </svg>
            </div>
            <h3 class="mb-3 text-2xl font-bold text-shopify-title">Coming Soon</h3>
            <p class="mx-auto max-w-md text-shopify-secondary-text">
              Team profiles are being added. Check back soon!
            </p>
          </div>
        )
      }
    </div>
  </section>

  <!-- Testimonial -->
  <section class="bg-white py-12 md:py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <blockquote class="mx-auto max-w-3xl">
        <svg
          class="mx-auto mb-4 h-8 w-8 text-southland-green/30"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
          ></path>
        </svg>
        <p class="text-lg italic text-shopify-title md:text-xl">
          I called expecting a sales pitch and ended up talking to a guy who'd managed poultry
          houses himself. He knew exactly what I was dealing with. That's the difference.
        </p>
        <footer class="mt-4 text-sm text-shopify-secondary-text">
          — Commercial grower, North Georgia
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- Cross-links -->
  <section class="bg-brand-gray py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4 sm:grid-cols-3">
        <a
          href="/podcast/"
          class="group flex items-center gap-4 rounded-xl border border-gray-100 bg-white p-5 transition-shadow hover:shadow-md"
        >
          <div
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-southland-green/10"
          >
            <svg
              class="h-5 w-5 text-southland-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-shopify-title group-hover:text-southland-green">
              Ag & Culture Podcast
            </p>
            <p class="text-xs text-shopify-secondary-text">Hosted by Mike & Joseph</p>
          </div>
        </a>
        <a
          href="/blog/"
          class="group flex items-center gap-4 rounded-xl border border-gray-100 bg-white p-5 transition-shadow hover:shadow-md"
        >
          <div
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-southland-green/10"
          >
            <svg
              class="h-5 w-5 text-southland-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-shopify-title group-hover:text-southland-green">
              Our Blog
            </p>
            <p class="text-xs text-shopify-secondary-text">Insights from the field</p>
          </div>
        </a>
        <a
          href="/about/"
          class="group flex items-center gap-4 rounded-xl border border-gray-100 bg-white p-5 transition-shadow hover:shadow-md"
        >
          <div
            class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-southland-green/10"
          >
            <svg
              class="h-5 w-5 text-southland-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-shopify-title group-hover:text-southland-green">
              About Southland
            </p>
            <p class="text-xs text-shopify-secondary-text">Our story & mission</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Proof Band -->
  <section class="bg-[#2C5234] py-12 md:py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">15+</div>
          <div class="mt-1 text-sm font-medium text-white">Years in business</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">50+</div>
          <div class="mt-1 text-sm font-medium text-white">Products developed</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">1000s</div>
          <div class="mt-1 text-sm font-medium text-white">Operations served</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">A+</div>
          <div class="mt-1 text-sm font-medium text-white">BBB Rating</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-southland-green-dark py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="mb-4 font-heading text-3xl text-white">
        Stuck on a Problem? Talk to Someone Who Gets It.
      </h2>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-white/70">
        Ammonia levels, soil biology, turf recovery — our team has seen it. Tell us what you're
        dealing with and we'll point you to the right product and protocol.
      </p>
      <a
        href="/contact/"
        class="inline-flex items-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-bold text-southland-green-dark shadow-sm transition-all hover:bg-gray-50 hover:shadow-md active:scale-[0.98]"
      >
        Describe Your Situation
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </a>
      <p class="mt-4 text-sm text-white/50">
        Or call us at
        <a href="tel:+18006083755" class="font-medium text-white/70 hover:text-white"
          >800-608-3755</a
        >
        — Mon-Fri, 8am-5pm EST
      </p>
    </div>
  </section>
</BaseLayout>
