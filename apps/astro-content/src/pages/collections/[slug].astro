---
/**
 * /collections/[slug] — Collection detail page (SSR)
 *
 * Combines TinaCMS SEO content with Shopify product data.
 * Persona-aware: reads sl_persona cookie for product sorting,
 * CTA adaptation, and (Phase 2) full themed layouts.
 */
import { getCollection } from 'astro:content'
import { createClient, getCollectionProducts } from '@southland/shopify-storefront'
import BaseLayout from '../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../components/CloudinaryHero.astro'
import CollectionGrid from '../../components/shop/CollectionGrid.astro'
import AccordionFaq from '../../components/shop/AccordionFaq.astro'
import ProofPoints from '../../components/cdp/ProofPoints.astro'
import Breadcrumbs from '../../components/shared/Breadcrumbs.astro'
import type { PersonaId } from '../../lib/persona'

// SSR — do not prerender
const { slug } = Astro.params

if (!slug) {
  return Astro.redirect('/collections/')
}

// ── Redirect collection slugs that now have dedicated hub pages ──────────
const collectionRedirects: Record<string, string> = {
  'backyard-birds': '/poultry/backyard/',
  'poultry-broilers': '/poultry/commercial/',
  poultry: '/poultry/',
  'poultry-breeders': '/poultry/breeders/',
  turkey: '/poultry/turkey/',
  'game-birds': '/poultry/game-birds/',
  hydroseeders: '/hydroseeders/',
  // Lawn & Garden
  'golf-courses': '/lawn/golf-courses/',
  homeowners: '/lawn/homeowners/',
  landscapers: '/lawn/landscapers/',
  turf: '/lawn/turf-pros/',
  // Agriculture
  crops: '/agriculture/crops/',
  produce: '/agriculture/produce/',
  // Livestock
  'pig-and-swine-supplements': '/livestock/swine/',
  // Products
  sanitizers: '/products/sanitizers/',
  waste: '/products/waste-treatment/',
  // Other → homepage
  other: '/',
}
if (slug in collectionRedirects) {
  return Astro.redirect(collectionRedirects[slug]!, 301)
}

// ── Read persona from cookie (server-side) ──────────────────────────────────
const personaCookie = Astro.cookies.get('sl_persona')?.value ?? null
const { isValidPersonaId, PERSONA_TO_SEGMENT } = await import('../../lib/persona')
const LEGACY_MAP: Record<string, string> = { backyard: 'betty', commercial: 'bill', lawn: 'taylor' }
const resolvedCookie = personaCookie ? (LEGACY_MAP[personaCookie] ?? personaCookie) : null
const persona: PersonaId =
  resolvedCookie && isValidPersonaId(resolvedCookie) ? (resolvedCookie as PersonaId) : null

// ── Fetch TinaCMS content ───────────────────────────────────────────────────
const allCollections = await getCollection('shopCollections')
const tinaDoc =
  allCollections.find((c) => c.data.handle === slug || c.id.replace(/\.mdx?$/, '') === slug) ?? null

// ── Fetch Shopify collection ────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const shopifyCollection = await getCollectionProducts(client, slug)

if (!shopifyCollection) {
  return Astro.redirect('/collections/')
}

// ── Merge data ──────────────────────────────────────────────────────────────
const title = tinaDoc?.data.title || shopifyCollection.title
const seoDescription =
  tinaDoc?.data.seoDescription ||
  shopifyCollection.description ||
  `Shop ${title} from Southland Organics.`
const heroHeadline = tinaDoc?.data.heroHeadline || undefined
const heroSubheadline = tinaDoc?.data.heroSubheadline || undefined
const rawCollectionPersona = tinaDoc?.data.persona ?? null
const collectionPersona: PersonaId = rawCollectionPersona
  ? ((LEGACY_MAP[rawCollectionPersona] ?? rawCollectionPersona) as PersonaId)
  : null
const faq = tinaDoc?.data.faq ?? []

// Render MDX body content if present
const Content = tinaDoc ? (await tinaDoc.render()).Content : null

// Use the collection's persona tag if set, otherwise fall back to visitor cookie
const activePersona: PersonaId = collectionPersona || persona

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/collections/${slug}/`

// ── JSON-LD Schema ──────────────────────────────────────────────────────────
const schema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: seoDescription,
  url: canonicalUrl,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: shopifyCollection.products.length,
    itemListElement: shopifyCollection.products.map((product, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${siteUrl}/products/${product.handle}/`,
      name: product.title,
    })),
  },
}

// Add FAQ schema if present
const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }
    : null

const fullSchema = faqSchema ? [schema, faqSchema] : schema

// ── Hero image (Cloudinary public ID) ────────────────────────────────────────
const heroImage = tinaDoc?.data.heroImage ?? null

// ── Persona theme config ─────────────────────────────────────────────────────
const personaConfig = {
  backyard: {
    badge: 'For Backyard Flocks',
    heroGradient: 'from-amber-500 to-amber-700',
    proofBg: 'bg-amber-50',
    ctaGradient: 'from-amber-500 to-amber-700',
    ctaHeadline: 'Give your backyard flock a healthier coop',
    ctaSubtext: 'Start with proven supplements that keep your birds thriving.',
    ctaPrimary: { text: 'Explore Products', href: `/collections/${slug}/` },
    ctaSecondary: { text: 'Talk to Our Team', href: '/contact/' },
  },
  commercial: {
    badge: 'Commercial Poultry',
    heroGradient: 'from-slate-800 to-slate-900',
    proofBg: 'bg-slate-50',
    ctaGradient: 'from-slate-800 to-slate-900',
    ctaHeadline: 'Turn small performance gains into serious ROI',
    ctaSubtext: 'Improve feed conversion, mortality, and scores with proven tools.',
    ctaPrimary: { text: 'Explore Products', href: `/collections/${slug}/` },
    ctaSecondary: { text: 'Request Volume Quote', href: '/contact/commercial/' },
  },
  lawn: {
    badge: 'Lawn & Turf',
    heroGradient: 'from-emerald-500 to-emerald-700',
    proofBg: 'bg-emerald-50',
    ctaGradient: 'from-emerald-500 to-emerald-700',
    ctaHeadline: 'Build healthier soil for greener turf',
    ctaSubtext: 'Organic programs that work for homeowners and pros.',
    ctaPrimary: { text: 'Explore Products', href: `/collections/${slug}/` },
    ctaSecondary: { text: 'Talk to Our Team', href: '/contact/' },
  },
} as const

const defaultTheme = {
  badge: null as string | null,
  heroGradient: 'from-green-700 to-green-900',
  proofBg: 'bg-green-50',
  ctaGradient: 'from-green-700 to-green-900',
  ctaHeadline: 'Natural solutions to natural problems',
  ctaSubtext: 'Explore products that restore biology in soil, flocks, and facilities.',
  ctaPrimary: { text: 'Explore Products', href: '/collections/' },
  ctaSecondary: { text: 'Talk to Our Team', href: '/contact/' },
}

const theme =
  activePersona && activePersona !== 'general' && activePersona in personaConfig
    ? personaConfig[activePersona as keyof typeof personaConfig]
    : defaultTheme

const displayTitle = heroHeadline || title
const displaySubheadline = heroSubheadline || seoDescription
---

<BaseLayout
  title={`${title} | Southland Organics`}
  description={seoDescription}
  canonicalUrl={canonicalUrl}
  schema={fullSchema}
>
  {/* ── 1. Breadcrumbs ──────────────────────────────────────────────────────── */}
  <div class="bg-white/80 px-4 py-3 backdrop-blur-sm">
    <div class="mx-auto max-w-6xl">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Collections', href: '/collections/' },
          { label: title, href: `/collections/${slug}/` },
        ]}
      />
    </div>
  </div>

  {/* ── 2. Hero ─────────────────────────────────────────────────────────────── */}
  {
    heroImage ? (
      <CloudinaryHero
        publicId={heroImage}
        alt={title}
        height={500}
        minHeight="300px"
        maxHeight="500px"
        overlay="gradient"
        overlayOpacity={60}
        contentAlign="center"
        contentJustify="center"
        priority={true}
      >
        <div class="mx-auto max-w-3xl text-center">
          {theme.badge && (
            <span class="mb-4 inline-block rounded-full bg-white/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-wide text-white backdrop-blur-sm">
              {theme.badge}
            </span>
          )}
          <h1 class="font-heading text-3xl text-white sm:text-4xl lg:text-5xl">{displayTitle}</h1>
          {displaySubheadline && (
            <p class="mx-auto mt-4 max-w-2xl text-base text-white/90 sm:text-lg">
              {displaySubheadline}
            </p>
          )}
          <p class="mt-3 text-sm text-white/60">
            {shopifyCollection.products.length}{' '}
            {shopifyCollection.products.length === 1 ? 'product' : 'products'}
          </p>
        </div>
      </CloudinaryHero>
    ) : (
      <section class={`bg-gradient-to-br ${theme.heroGradient} px-4 py-16 sm:py-20`}>
        <div class="mx-auto max-w-3xl text-center">
          {theme.badge && (
            <span class="mb-4 inline-block rounded-full bg-white/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-wide text-white backdrop-blur-sm">
              {theme.badge}
            </span>
          )}
          <h1 class="font-heading text-3xl text-white sm:text-4xl lg:text-5xl">{displayTitle}</h1>
          {displaySubheadline && (
            <p class="mx-auto mt-4 max-w-2xl text-base text-white/80 sm:text-lg">
              {displaySubheadline}
            </p>
          )}
          <p class="mt-3 text-sm text-white/50">
            {shopifyCollection.products.length}{' '}
            {shopifyCollection.products.length === 1 ? 'product' : 'products'}
          </p>
        </div>
      </section>
    )
  }

  {/* ── 3. Product Grid ─────────────────────────────────────────────────────── */}
  <section class="bg-white px-4 py-12 sm:py-16">
    <div class="mx-auto max-w-6xl">
      <CollectionGrid products={shopifyCollection.products} persona={activePersona} />
    </div>
  </section>

  {/* ── 4. ProofPoints (persona collections only) ───────────────────────────── */}
  {
    activePersona && activePersona !== 'general' && (
      <section class={`px-4 py-12 sm:py-16 ${theme.proofBg}`}>
        <div class="mx-auto max-w-4xl">
          <ProofPoints persona={activePersona} variant="cards" />
        </div>
      </section>
    )
  }

  {/* ── 5. MDX Content ──────────────────────────────────────────────────────── */}
  {
    Content && (
      <section class="bg-gray-50 px-4 py-12 sm:py-16">
        <div class="mx-auto max-w-3xl">
          <div class="prose prose-lg prose-green max-w-none prose-headings:font-heading prose-headings:text-brand-green-dark prose-a:text-brand-green-light prose-a:no-underline hover:prose-a:underline">
            <Content />
          </div>
        </div>
      </section>
    )
  }

  {/* ── 6. CTA Section ──────────────────────────────────────────────────────── */}
  <section class={`bg-gradient-to-r ${theme.ctaGradient} px-4 py-12 sm:py-16`}>
    <div class="mx-auto max-w-3xl text-center text-white">
      <h2 class="font-heading text-2xl md:text-3xl">{theme.ctaHeadline}</h2>
      <p class="mt-3 text-base text-white/90">{theme.ctaSubtext}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href={theme.ctaPrimary.href}
          class="inline-flex items-center justify-center rounded-full bg-white px-6 py-2.5 text-sm font-semibold text-slate-900 transition hover:-translate-y-0.5 hover:shadow-lg"
        >
          {theme.ctaPrimary.text}
        </a>
        <a
          href={theme.ctaSecondary.href}
          class="inline-flex items-center justify-center rounded-full border-2 border-white/50 px-6 py-2.5 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:border-white hover:bg-white/10"
        >
          {theme.ctaSecondary.text}
        </a>
      </div>
    </div>
  </section>

  {/* ── 7. FAQ Accordion ────────────────────────────────────────────────────── */}
  {
    faq.length > 0 && (
      <section class="bg-white px-4 py-12 sm:py-16">
        <div class="mx-auto max-w-3xl">
          <h2 class="mb-8 text-center font-heading text-2xl text-brand-green-dark">
            Frequently Asked Questions
          </h2>
          <AccordionFaq items={faq} persona={activePersona} />
        </div>
      </section>
    )
  }
</BaseLayout>

<script is:inline define:vars={{
  ga4List: {
    item_list_id: slug,
    item_list_name: title,
    items: shopifyCollection.products.map((p, i) => ({
      item_id: p.handle,
      item_name: p.title,
      item_brand: 'Southland Organics',
      price: parseFloat(p.priceRange.minVariantPrice.amount),
      currency: p.priceRange.minVariantPrice.currencyCode || 'USD',
      index: i,
      item_list_id: slug,
      item_list_name: title,
    })),
  },
}}>
  // GA4: view_item_list on collection page load
  window.dataLayer = window.dataLayer || []
  window.dataLayer.push({ ecommerce: null })
  window.dataLayer.push({
    event: 'view_item_list',
    ecommerce: {
      item_list_id: ga4List.item_list_id,
      item_list_name: ga4List.item_list_name,
      items: ga4List.items,
    },
  })
</script>
