            <a
              href="/products/"
              class="bg-brand-green-dark inline-flex items-center gap-2 rounded-lg px-8 py-3.5 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-green-800"
            >
              View All Products
            </a>
          </div>
        </div>
