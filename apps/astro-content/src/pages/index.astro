                  <a
                    href={cta.href}
                    class="border-brand-green-dark hover:bg-brand-green-dark inline-flex items-center rounded-lg border-2 px-6 py-3.5 text-base font-semibold transition hover:text-white"
                    style="color: var(--color-title);"
