---
/**
 * Homepage — Full e-commerce homepage with persona-aware Reality Tunnels.
 *
 * Architecture:
 * - SSR: Fetches products from Shopify Storefront API on every request
 * - Copy: All text pulled from content/homepage/index.mdx
 * - Default: 10-section arc (hero, persona strip, science, benefits band,
 *   trust stats, products, trust & proof, human help, content hub, final CTA)
 * - Persona tunnels: Filtered product grids for Betty/Bill/Taylor
 * - Decision Engine: In-page persona selection (no redirects)
 */
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
// DecisionEngine + RealityTunnel disabled for launch — enable post-launch for persona tunnels
// import DecisionEngine from '../components/cdp/DecisionEngine.astro'
import RealityTunnel from '../components/tunnels/RealityTunnel.astro'
import CollectionProductCard from '../components/shop/CollectionProductCard.astro'
import EmailCapture from '../components/shared/EmailCapture.astro'
import { createClient, getAllProducts, getAllCollections } from '@southland/shopify-storefront'
import type { Product, CollectionSummary } from '@southland/shopify-storefront'
import { buildSouthlandUrl } from '../lib/cloudinary'

// ── Load homepage copy from content collection ──────────────────────────────
const homepageEntries = await getCollection('homepage')
const homepageDoc = homepageEntries[0]
const hp = homepageDoc.data

const betty = hp.backyard
const bill = hp.commercial
const taylor = hp.lawn
const def = hp.default

const title = hp.seoTitle
const description = hp.seoDescription

// ── Fetch Shopify data ──────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

let allProducts: Product[] = []
let collections: CollectionSummary[] = []

try {
  ;[allProducts, collections] = await Promise.all([
    getAllProducts(client),
    getAllCollections(client),
  ])
} catch (err) {
  console.error('[homepage] Failed to fetch Shopify data:', err)
}

// ── Filter products by persona/category ─────────────────────────────────────
const tagIncludes = (product: Product, terms: string[]) =>
  terms.some(
    (term) =>
      product.tags.some((t) => t.toLowerCase().includes(term)) ||
      product.title.toLowerCase().includes(term)
  )

const poultryProducts = allProducts.filter((p) =>
  tagIncludes(p, ['poultry', 'chicken', 'hen', 'bird', 'flock', 'big ole bird', 'hen helper'])
)
const lawnProducts = allProducts.filter((p) =>
  tagIncludes(p, ['lawn', 'turf', 'grass', 'soil', 'garden'])
)

// Featured: 8 curated SKUs weighted by segment revenue (5 poultry, 2 turf, 1 waste)
const CURATED_HANDLES = [
  'poultry-probiotic',                          // Big Ole Bird (Bill) — $21K Shopify
  'catalyst-poultry-vitamin',                   // Catalyst Vitamins (Betty) — $12K
  'torched-all-natural-weed-killer',            // Torched (Taylor) — $8K
  'poultry-litter-amendment',                   // Litter Life (Bill) — $4K
  'hen-helper',                                  // Hen Helper (Betty) — $5K
  'apple-cider-vinegar-for-chickens',           // Mother Load ACV (Bill) — $4K
  'natural-mite-control-livestock-poultry',     // Desecticide (Betty) — $3K
  'pour-the-port-septic-tank-treatment',        // PORT (Sam) — $3K, 88% margin
]
const featuredProducts = CURATED_HANDLES
  .map((handle) => allProducts.find((p) => p.handle === handle))
  .filter(Boolean) as Product[]

// Category collections to display (persona tunnels still use these)
const skipHandles = new Set(['frontpage', 'all', 'flowers', 'lavender-and-eucalyptus-bundles'])
const categoryCollections = collections.filter((c) => !skipHandles.has(c.handle)).slice(0, 6)

// ── Content Hub images (Cloudinary) ─────────────────────────────────────────
const contentHubImages = {
  podcast: buildSouthlandUrl('podcast/episodes/ep-001-invisible-economy', { width: 600, height: 340, crop: 'fill', gravity: 'auto' }),
  blog: buildSouthlandUrl('heroes/Farm_Athens_GA_7_jbdjik', { width: 600 }),
}

// ── SEO Schema ──────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Southland Organics',
  description,
  url: siteUrl,
  logo: 'https://res.cloudinary.com/southland-organics/image/upload/v1/Southland%20Website/Southland%20Branding/logos/southland-logo-primary.png',
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-800-608-3755',
    contactType: 'customer service',
    areaServed: 'US',
    availableLanguage: 'English',
  },
  sameAs: [
    'https://www.facebook.com/southlandorganics',
    'https://www.instagram.com/southlandorganics',
    'https://www.youtube.com/southlandorganics',
  ],
}

// ── Helper: resolve product list by filter ──────────────────────────────────
function getProducts(filter: string) {
  if (filter === 'poultry') return poultryProducts.length > 0 ? poultryProducts : featuredProducts
  if (filter === 'lawn') return lawnProducts.length > 0 ? lawnProducts : featuredProducts
  return featuredProducts
}
