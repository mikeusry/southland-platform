                >
              ) : (
                <a
                  href={cta.href}
                  class="rounded-lg border-2 border-white/40 px-7 py-3.5 font-semibold text-white transition hover:border-white hover:bg-white/10"
                  >{cta.label}</a
                >
              )
            )}
          </div>
        </div>
      </section>
    </Fragment>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- DEFAULT: 7-section homepage for new/unknown visitors                   -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <Fragment slot="default">

      <!-- ─── Section 1: Hero — 55/45 Credibility + Product Preview ──────── -->
      <section class="bg-gradient-to-br from-[#2C5234] to-[#44883E] px-5 py-16 md:py-24">
        <div class="mx-auto grid max-w-6xl items-center gap-10 md:grid-cols-[55fr_45fr]" id="hero-section">
          <!-- LEFT (55%): Credibility -->
          <div>
            <h1 class="font-heading text-4xl leading-tight text-white md:text-5xl lg:text-6xl">
              {def.heroHeadline}
            </h1>
            <p class="mt-5 max-w-xl font-serif text-lg italic leading-relaxed text-white/80 md:text-xl">
              {def.heroSubheadline}
            </p>

            <!-- Phone -->
            <div class="mt-5">
              <a
                href="tel:1-800-608-3755"
                aria-label="Call Southland Organics at 800-608-3755"
                class="inline-flex items-center gap-2 text-lg font-semibold text-white/90 transition hover:text-white"
              >
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                800-608-3755
              </a>
            </div>

            <!-- Proof credential chips (text-only — A+ BBB lives in Proof Band below) -->
            <div class="mt-6 flex flex-wrap gap-3">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1.5 text-sm font-medium text-white/90">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                USDA Organic Certified
              </span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-1.5 text-sm font-medium text-white/90">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                Family-Owned Since 2009
              </span>
            </div>

            <!-- CTAs — primary scrolls to persona selector, secondary to products -->
            <div class="mt-8 flex flex-wrap gap-4">
              <a
                href="#persona-selector"
                class="inline-flex items-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-semibold transition hover:-translate-y-0.5 hover:shadow-lg"
                style="color: var(--color-title);"
              >
                What are you growing?
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                </svg>
              </a>
              <a
                href="/products/"
                class="inline-flex items-center rounded-lg border-2 border-white/50 px-8 py-4 text-base font-semibold text-white transition hover:border-white hover:bg-white/10"
              >
                Explore Products
              </a>
            </div>
          </div>

          <!-- RIGHT (45%): Featured product preview (desktop only) -->
          <div class="hidden md:grid md:grid-cols-2 md:gap-4">
            {featuredProducts.slice(0, 4).map((product) => (
              <a
                href={`/products/${product.handle}/`}
                class="group overflow-hidden rounded-xl bg-white/10 backdrop-blur-sm transition hover:bg-white/20"
              >
                {product.images[0] ? (
                  <img
                    src={product.images[0].url}
                    alt={product.images[0].altText || product.title}
                    class="aspect-square w-full object-cover transition group-hover:scale-105"
                    width="300"
                    height="300"
                    loading="eager"
                  />
                ) : (
                  <div class="flex aspect-square w-full items-center justify-center bg-white/5">
                    <svg class="h-12 w-12 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                  </div>
                )}
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ─── Section 2: Persona Strip — "What Are You Growing?" ───────────── -->
      <section class="bg-[#f8f5ef] px-5 py-16" id="persona-selector" style="scroll-margin-top: 120px;">
        <DecisionEngine
          headline="What Are You Growing?"
          subheadline="Select your focus area and we'll show you the right products"
          source="decision_engine"
        />
      </section>

      <!-- ─── Section 3: Proof Band — Stats ────────────────────────────────── -->
      <section class="bg-[#2C5234] px-5 py-12">
        <div class="mx-auto grid max-w-4xl grid-cols-2 gap-8 text-center md:grid-cols-4">
          {def.trustStats.map((stat) => (
            <div>
              <div class="mb-1 text-3xl font-bold text-white">{stat.value}</div>
              <div class="text-sm uppercase tracking-wide text-white/70">{stat.label}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- ─── Section 4: Featured Products ─────────────────────────────────── -->
      {featuredProducts.length > 0 && (
        <section id="featured-products" class="bg-white px-5 py-16" style="scroll-margin-top: 120px;">
          <div class="mx-auto max-w-6xl">
            <div class="mb-10 text-center">
              <!-- NOTE: Use font-sans here to override global font-heading -->
              <h2 class="font-sans text-3xl font-bold" style="color: var(--color-title);">
                {def.productsHeadline}
              </h2>
              <p class="mt-3 text-gray-500">
                {def.productsSubheadline}
              </p>
            </div>
            <div class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3">
              {featuredProducts.map((product) => (
                <CollectionProductCard product={product} />
              ))}
            </div>
            <div class="mt-10 text-center">
              <a
                href="/products/"
                class="bg-brand-green-dark inline-flex items-center gap-2 rounded-lg px-8 py-3.5 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-green-800"
              >
                Browse All Products
              </a>
            </div>
          </div>
        </section>
      )}

      <!-- ─── Section 5: Content Hub Teaser (Podcast + Blog only) ────────── -->
      {hp.resources && hp.resources.length >= 2 && (
        <section class="bg-[#f8f5ef] px-5 py-16">
          <div class="mx-auto max-w-4xl">
            <div class="mb-10 text-center">
              <!-- NOTE: Use font-sans here to override global font-heading -->
              <h2 class="font-sans text-3xl font-bold" style="color: var(--color-title);">
                {hp.resourcesHeadline}
              </h2>
            </div>
            <div class="grid gap-6 md:grid-cols-2">
              {[
                { resource: hp.resources[0], image: contentHubImages.podcast, fallbackIcon: 'mic' },
                { resource: hp.resources[1], image: contentHubImages.blog, fallbackIcon: 'book' },
              ].map(({ resource, image, fallbackIcon }) => resource && (
                <a
                  href={resource.href}
                  class="group overflow-hidden rounded-xl bg-white shadow-sm transition-shadow hover:shadow-md"
                >
                  <!-- Image with fallback -->
                  <div class="relative h-48 overflow-hidden bg-green-50">
                    <img
                      src={image}
                      alt=""
                      loading="lazy"
                      class="h-full w-full object-cover transition group-hover:scale-105"
                      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                    />
                    <div class="hidden h-full w-full items-center justify-center bg-green-50">
                      {fallbackIcon === 'mic' && (
                        <svg class="h-12 w-12 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m-4 0h8m-8-8a3 3 0 016 0v1a3 3 0 01-6 0v-1z" />
                        </svg>
                      )}
                      {fallbackIcon === 'book' && (
                        <svg class="h-12 w-12 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                        </svg>
                      )}
                    </div>
                  </div>
                  <div class="p-5">
                    <!-- NOTE: Use font-sans here to override global font-heading -->
                    <h3 class="font-sans font-semibold text-gray-900 group-hover:text-[#2C5234]">
                      {resource.title}
                    </h3>
                    <p class="mt-2 text-sm text-gray-500">
                      {resource.description}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}

      <!-- ─── Section 6: Persona Mini Section (conditional, client-only) ───── -->
      <section id="persona-mini" class="bg-white px-5 py-16" style="display: none;">
        <div class="mx-auto max-w-2xl text-center">
          <!-- Backyard mini -->
          <div data-persona-mini="backyard" style="display: none;">
            {betty.ctaHeadline && (
              <Fragment>
                <h2 class="font-sans text-2xl font-bold" style="color: var(--color-title);">{betty.ctaHeadline}</h2>
                <p class="mt-3 text-gray-600">{betty.ctaBody}</p>
                {betty.ctaCTAs[0] && (
                  <a href={betty.ctaCTAs[0].href} class="bg-brand-green-dark mt-6 inline-flex rounded-lg px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-green-800">
                    {betty.ctaCTAs[0].label}
                  </a>
                )}
              </Fragment>
            )}
          </div>
          <!-- Commercial mini -->
          <div data-persona-mini="commercial" style="display: none;">
            {bill.ctaHeadline && (
              <Fragment>
                <h2 class="font-sans text-2xl font-bold" style="color: var(--color-title);">{bill.ctaHeadline}</h2>
                <p class="mt-3 text-gray-600">{bill.ctaBody}</p>
                {bill.ctaCTAs[0] && (
                  <a href={bill.ctaCTAs[0].href} class="bg-brand-green-dark mt-6 inline-flex rounded-lg px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-green-800">
                    {bill.ctaCTAs[0].label}
                  </a>
                )}
              </Fragment>
            )}
          </div>
          <!-- Lawn mini -->
          <div data-persona-mini="lawn" style="display: none;">
            {taylor.ctaHeadline && (
              <Fragment>
                <h2 class="font-sans text-2xl font-bold" style="color: var(--color-title);">{taylor.ctaHeadline}</h2>
                <p class="mt-3 text-gray-600">{taylor.ctaBody}</p>
                {taylor.ctaCTAs[0] && (
                  <a href={taylor.ctaCTAs[0].href} class="bg-brand-green-dark mt-6 inline-flex rounded-lg px-6 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-green-800">
                    {taylor.ctaCTAs[0].label}
                  </a>
                )}
              </Fragment>
            )}
          </div>
        </div>
      </section>

      <!-- ─── Section 7: Final CTA — Service-Oriented ─────────────────────── -->
      <section class="bg-gradient-to-br from-[#44883E] to-[#2C5234] px-5 py-16 text-center md:py-20">
        <div class="mx-auto max-w-2xl">
          <h2 class="font-heading text-3xl text-white md:text-4xl">{def.ctaHeadline}</h2>
          <p class="mt-4 font-serif text-lg italic text-white/90">
            {def.ctaBody}
          </p>

          <!-- Phone — prominent display -->
          {def.ctaPhone && (
            <div class="mt-6">
              <a
                href={`tel:${def.ctaPhone}`}
                aria-label="Call Southland Organics at 800-608-3755"
                class="inline-flex items-center gap-3 text-3xl font-bold text-white transition hover:text-white/80 md:text-4xl"
              >
                <svg class="h-8 w-8 md:h-9 md:w-9" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                {def.ctaPhone}
              </a>
            </div>
          )}

          <!-- Action buttons — Find a Dealer + Contact -->
          <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
            <a
              href="/store-locator/"
              class="inline-flex items-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-semibold transition hover:-translate-y-0.5 hover:shadow-lg"
              style="color: var(--color-title);"
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
              </svg>
              Find a Dealer Near You
            </a>
            <a
              href="/contact/"
              class="inline-flex items-center rounded-lg border-2 border-white/50 px-8 py-4 text-base font-semibold text-white transition hover:border-white hover:bg-white/10"
            >
              Send a Message
            </a>
          </div>

          <!-- Email Capture — single instance on homepage -->
          <div class="mt-10 border-t border-white/20 pt-8">
            <EmailCapture
              variant="banner"
              source="website"
              headline="Stay in the loop"
              description="Get tips, deals, and product updates."
              buttonText="Sign Up"
            />
          </div>
        </div>
      </section>

    </Fragment>
  </RealityTunnel>
</BaseLayout>

<script>
  import { getPersonaId, getJourneyStage } from '../lib/persona'

  function initHomepage() {
    const personaId = getPersonaId()
    const stage = getJourneyStage()

    // Track homepage view
    if ((window as any).pdPixel) {
      ;(window as any).pdPixel.track('homepage_view', {
        persona: personaId || 'unknown',
        stage: stage || 'unaware',
        has_persona: Boolean(personaId),
        is_personalized: Boolean(personaId && personaId !== 'general'),
      })
    }

    // Reveal persona mini section for returning visitors
    const miniSection = document.getElementById('persona-mini')
    if (miniSection && personaId && personaId !== 'general') {
      const miniBlock = miniSection.querySelector(`[data-persona-mini="${personaId}"]`) as HTMLElement
      if (miniBlock && miniBlock.innerHTML.trim()) {
        miniBlock.style.display = 'block'
        miniSection.style.display = 'block'
      }
    }
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomepage)
  } else {
    initHomepage()
  }

  // Run on Astro page transitions
  document.addEventListener('astro:page-load', initHomepage as any)
</script>
