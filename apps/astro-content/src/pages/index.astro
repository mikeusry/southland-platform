        </div>
      </section>

  {/* </Fragment> */}
  {/* </RealityTunnel> */}
</BaseLayout>

<style>
  /* ── Section 3: Science Credibility ──────────────────────────────────────── */
  .hp-science-col {
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .hp-science-col:hover {
    box-shadow: 0 4px 20px rgba(44, 82, 52, 0.12);
    transform: translateY(-2px);
  }

  /* ── Section 4: Benefits Band ────────────────────────────────────────────── */
  .hp-benefit-card {
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .hp-benefit-card:hover {
    background-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  /* ── Section 7: Trust Logos ──────────────────────────────────────────────── */
  .hp-trust-logo {
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .hp-trust-logo:hover {
    border-color: #44883E;
    box-shadow: 0 2px 8px rgba(68, 136, 62, 0.15);
  }

  /* ── Section 8: Human — placeholder height ──────────────────────────────── */
  .hp-human-placeholder {
    min-height: 320px;
  }
</style>

<script>
  import { getPersonaId, getJourneyStage } from '../lib/persona'

  function initHomepage() {
    const personaId = getPersonaId()
    const stage = getJourneyStage()

    // Track homepage view
    if ((window as any).pdPixel) {
      ;(window as any).pdPixel.track('homepage_view', {
        persona: personaId || 'unknown',
        stage: stage || 'unaware',
        has_persona: Boolean(personaId),
        is_personalized: Boolean(personaId && personaId !== 'general'),
      })
    }
  }

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomepage)
  } else {
    initHomepage()
  }

  // Run on Astro page transitions
  document.addEventListener('astro:page-load', initHomepage as any)
</script>
