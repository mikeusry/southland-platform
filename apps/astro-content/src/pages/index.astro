        <div class="mx-auto max-w-6xl">
          <div class="mb-10 text-center">
            <h2 class="font-heading text-3xl" style="color: var(--color-title);">
              {bill.productsHeadline}
            </h2>
            <p class="mt-3 text-gray-500">
              {bill.productsSubheadline}
