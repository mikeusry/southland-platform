---
/**
 * /referral/ — Referral program landing page
 *
 * Dedicated page for the referral program (previously a 302 to /rewards/).
 * BettyHero evangelist stage links here with "Get Your Referral Link" CTA.
 */

export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import { buildSouthlandUrl } from '../../lib/cloudinary'

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const lookupUrl = 'https://nexus.southlandorganics.com/api/loyalty/lookup'

const referralSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Refer a Friend | Southland Organics',
  description:
    'Give your friends $10 off their first order and earn 500 bonus loyalty points for every successful referral.',
  url: `${siteUrl}/referral/`,
  mainEntity: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: siteUrl,
  },
}
---

<BaseLayout
  title="Refer a Friend — Give $10, Get 500 Points | Southland Organics"
  description="Share Southland Organics with a friend. They get $10 off their first order, you earn 500 bonus loyalty points. No limit on referrals."
  ogImage={buildSouthlandUrl('heroes/Farm_Athens_GA_7_jbdjik', {
    width: 1200,
    height: 630,
    crop: 'fill',
    quality: 'auto',
    format: 'auto',
  })}
  canonicalUrl={`${siteUrl}/referral/`}
  schema={referralSchema}
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="bg-southland-green-dark py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm font-medium uppercase tracking-widest text-southland-green">
        Referral Program
      </p>
      <h1 class="mb-6 font-heading text-4xl text-white md:text-5xl lg:text-6xl">
        Give $10, Get 500 Points
      </h1>
      <p class="mx-auto max-w-3xl text-lg text-white/80 md:text-xl">
        Share Southland Organics with friends and family. They get $10 off their first order, and you earn 500 bonus loyalty points for every successful referral.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="#get-link"
          class="btn-primary inline-flex items-center gap-2 px-8 py-3 text-lg"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
            ></path>
          </svg>
          Get My Referral Link
        </a>
        <a
          href="/rewards/"
          class="btn-secondary inline-flex items-center gap-2 border-white/40 px-8 py-3 text-lg text-white hover:bg-white hover:text-southland-green-dark"
        >
          Learn About Rewards
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. HOW IT WORKS (3-step strip)
       ============================================================ -->
  <section class="relative -mt-8 pb-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-6 text-center shadow-lg">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10">
            <span class="text-2xl font-bold text-southland-green">1</span>
          </div>
          <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-southland-green">
            Step 1
          </p>
          <h3 class="mb-2 text-xl text-shopify-title">Get Your Link</h3>
          <p class="text-sm text-shopify-secondary-text">
            Enter your email below to receive your unique referral link.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-6 text-center shadow-lg">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10">
            <span class="text-2xl font-bold text-southland-green">2</span>
          </div>
          <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-southland-green">
            Step 2
          </p>
          <h3 class="mb-2 text-xl text-shopify-title">Share It</h3>
          <p class="text-sm text-shopify-secondary-text">
            Send your link to friends, family, or neighbors. Text, email, social — whatever works.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-6 text-center shadow-lg">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10">
            <span class="text-2xl font-bold text-southland-green">3</span>
          </div>
          <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-southland-green">
            Step 3
          </p>
          <h3 class="mb-2 text-xl text-shopify-title">Earn Points</h3>
          <p class="text-sm text-shopify-secondary-text">
            When they buy, they get $10 off and you earn 500 bonus points. No limit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. THE DEAL — Side by side
       ============================================================ -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-southland-green">
          Everybody Wins
        </p>
        <h2 class="mb-12 font-heading text-3xl md:text-4xl">Here's the Deal</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Your friend gets -->
        <div class="rounded-xl border-2 border-southland-green/20 bg-southland-green/5 p-8 text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-southland-green/10">
            <svg class="h-8 w-8 text-southland-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="mb-2 font-heading text-2xl">Your Friend Gets</h3>
          <div class="mb-4 text-4xl font-bold text-southland-green-dark">$10 Off</div>
          <p class="text-shopify-secondary-text">
            Their first order, automatically applied at checkout. No minimum purchase required.
          </p>
        </div>

        <!-- You get -->
        <div class="rounded-xl border-2 border-yellow-400/40 bg-yellow-50 p-8 text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-yellow-100">
            <svg class="h-8 w-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
          </div>
          <h3 class="mb-2 font-heading text-2xl">You Get</h3>
          <div class="mb-4 text-4xl font-bold text-southland-green-dark">500 Points</div>
          <p class="text-shopify-secondary-text">
            Bonus loyalty points added to your account when they make their first purchase. Redeem for discounts, free shipping, and more.
          </p>
        </div>
      </div>

      <!-- No limit callout -->
      <div class="mt-8 rounded-lg bg-gray-50 p-5 text-center">
        <p class="text-sm text-shopify-secondary-text">
          <span class="font-semibold text-shopify-title">No limit on referrals.</span> Refer 10 friends and earn 5,000 bonus points — that's $25+ in rewards.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. WHAT TO SHARE — Product suggestions
       ============================================================ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-southland-green">
          What to Share
        </p>
        <h2 class="mb-4 font-heading text-3xl md:text-4xl">Products Your Friends Will Love</h2>
        <p class="mx-auto mb-12 max-w-2xl text-shopify-secondary-text">
          Not sure what to recommend? Here are our most-referred products.
        </p>
      </div>

      <div class="mx-auto grid max-w-4xl gap-6 sm:grid-cols-3">
        <a href="/products/pour-the-port-septic-tank-treatment/" class="group rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm transition-shadow hover:shadow-md">
          <div class="mb-4 text-3xl">🏠</div>
          <h3 class="mb-2 text-base font-semibold text-shopify-title group-hover:text-southland-green">Pour the PORT</h3>
          <p class="text-sm text-shopify-secondary-text">Monthly septic treatment. Perfect for any homeowner with a septic system.</p>
        </a>
        <a href="/poultry/" class="group rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm transition-shadow hover:shadow-md">
          <div class="mb-4 text-3xl">🐔</div>
          <h3 class="mb-2 text-base font-semibold text-shopify-title group-hover:text-southland-green">Poultry Products</h3>
          <p class="text-sm text-shopify-secondary-text">Backyard flock health. Great for friends who keep chickens.</p>
        </a>
        <a href="/lawn/" class="group rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm transition-shadow hover:shadow-md">
          <div class="mb-4 text-3xl">🌱</div>
          <h3 class="mb-2 text-base font-semibold text-shopify-title group-hover:text-southland-green">Lawn & Garden</h3>
          <p class="text-sm text-shopify-secondary-text">Organic lawn care. For the neighbor who's always working on their yard.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. FAQ
       ============================================================ -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-southland-green">
          Questions
        </p>
        <h2 class="mb-10 font-heading text-3xl md:text-4xl">Frequently Asked Questions</h2>
      </div>

      <div class="divide-y divide-gray-200">
        <details class="group py-5">
          <summary class="flex cursor-pointer items-center justify-between text-left font-semibold text-shopify-title transition-colors hover:text-southland-green">
            <span>How do I get my referral link?</span>
            <svg class="ml-4 h-5 w-5 shrink-0 text-shopify-secondary-text transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 leading-relaxed text-shopify-secondary-text">
            Enter your email in the form below. We'll send a link to your rewards portal, which includes your unique referral code and shareable link.
          </p>
        </details>
        <details class="group py-5">
          <summary class="flex cursor-pointer items-center justify-between text-left font-semibold text-shopify-title transition-colors hover:text-southland-green">
            <span>Is there a limit on how many people I can refer?</span>
            <svg class="ml-4 h-5 w-5 shrink-0 text-shopify-secondary-text transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 leading-relaxed text-shopify-secondary-text">
            No limit. Refer as many friends as you want and earn 500 points for each successful referral.
          </p>
        </details>
        <details class="group py-5">
          <summary class="flex cursor-pointer items-center justify-between text-left font-semibold text-shopify-title transition-colors hover:text-southland-green">
            <span>When do I receive my points?</span>
            <svg class="ml-4 h-5 w-5 shrink-0 text-shopify-secondary-text transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 leading-relaxed text-shopify-secondary-text">
            Points are credited to your account after your friend's first order is fulfilled. This typically happens within a few business days of their purchase.
          </p>
        </details>
        <details class="group py-5">
          <summary class="flex cursor-pointer items-center justify-between text-left font-semibold text-shopify-title transition-colors hover:text-southland-green">
            <span>Does my friend need to use a specific link?</span>
            <svg class="ml-4 h-5 w-5 shrink-0 text-shopify-secondary-text transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 leading-relaxed text-shopify-secondary-text">
            Yes, they need to use your unique referral link so we can track the referral and apply their $10 discount automatically. You'll find the link in your rewards portal.
          </p>
        </details>
        <details class="group py-5">
          <summary class="flex cursor-pointer items-center justify-between text-left font-semibold text-shopify-title transition-colors hover:text-southland-green">
            <span>What can I do with 500 points?</span>
            <svg class="ml-4 h-5 w-5 shrink-0 text-shopify-secondary-text transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 leading-relaxed text-shopify-secondary-text">
            500 points redeems for $5 off your next order. Refer two friends and you've earned enough for free shipping (750 points). See all rewards at <a href="/rewards/" class="text-southland-green underline hover:no-underline">southlandorganics.com/rewards</a>.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. GET YOUR LINK — Bottom CTA
       ============================================================ -->
  <section id="get-link" class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-xl px-4 text-center sm:px-6 lg:px-8">
      <div
        class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10"
      >
        <svg
          class="h-7 w-7 text-southland-green"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
          ></path>
        </svg>
      </div>
      <h2 class="mb-2 font-heading text-3xl md:text-4xl">Get Your Referral Link</h2>
      <p class="mb-8 text-shopify-secondary-text">
        Enter your email and we'll send a link to your rewards portal where you can find your unique referral code.
      </p>
      <form id="referral-lookup-form" class="flex flex-col gap-3 sm:flex-row">
        <input
          type="email"
          id="referral-email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-1 rounded-lg border border-gray-200 bg-white px-4 py-3 text-base focus:border-southland-green focus:outline-none focus:ring-2 focus:ring-southland-green/20"
        />
        <button
          type="submit"
          id="referral-submit"
          class="btn-primary whitespace-nowrap px-6 py-3"
        >
          Send My Referral Link
        </button>
      </form>
      <p id="referral-message" class="mt-4 text-xs text-shopify-secondary-text">
        We'll only use your email to send your rewards portal link. No spam.
      </p>

      <script define:vars={{ lookupUrl }}>
        document
          .getElementById('referral-lookup-form')
          .addEventListener('submit', async (e) => {
            e.preventDefault()
            const email = document.getElementById('referral-email').value.trim()
            const btn = document.getElementById('referral-submit')
            const msg = document.getElementById('referral-message')
            if (!email) return

            btn.disabled = true
            btn.textContent = 'Sending...'
            msg.className = 'mt-4 text-xs text-shopify-secondary-text'
            msg.textContent = ''

            try {
              const res = await fetch(lookupUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email }),
              })
              if (res.status === 429) {
                msg.textContent = 'Too many requests. Please try again in a few minutes.'
                msg.className = 'mt-4 text-sm font-medium text-amber-600'
              } else {
                msg.textContent =
                  "If you have a rewards account, we've sent your portal link with your referral code. Check your email!"
                msg.className = 'mt-4 text-sm font-medium text-southland-green'
              }
            } catch {
              msg.textContent = 'Something went wrong. Please try again.'
              msg.className = 'mt-4 text-sm font-medium text-red-600'
            } finally {
              btn.disabled = false
              btn.textContent = 'Send My Referral Link'
            }
          })
      </script>
    </div>
  </section>
</BaseLayout>
