---
/**
 * /lawn/turf-pros/ — Turf Pro Taylor StoryBrand Landing Page
 *
 * StoryBrand framework: Hero (Taylor) → Problem (the treadmill) → JTBD (3 jobs
 * with real products) → Shop Grid → Proof → SEO Content → FAQ → CTA
 *
 * Products fetched dynamically from Shopify Storefront API.
 * SEO content + FAQ pulled from TinaCMS shopCollections entry.
 */
import { getCollection } from 'astro:content'
import { createClient, getProductByHandle, getCollectionProducts } from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../../components/CloudinaryHero.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro'
import { buildSouthlandUrl, buildCloudinaryUrl } from '../../../lib/cloudinary'

// ── Brad Broxton photo ──────────────────────────────────────────────────────
const bradPhoto = buildSouthlandUrl('team/BRAD_Broxton', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

const HANDLE = 'turf'

// ── TinaCMS content ─────────────────────────────────────────────────────────
const allCollections = await getCollection('shopCollections')
const tinaDoc =
  allCollections.find(
    (c) => c.data.handle === HANDLE || c.id.replace(/\.mdx?$/, '') === HANDLE,
  ) ?? null

const title = tinaDoc?.data.title || 'Organic Turf Management Products for Pros'
const seoTitle = 'Organic Lawn Care for Turf Pros | Southland Organics'
const seoDescription =
  tinaDoc?.data.seoDescription ||
  'Organic turf management products that restore soil biology, deepen roots, and build resilient playing surfaces. Humic acid and microbial solutions for pros.'
const faq = tinaDoc?.data.faq ?? []
const heroImage = tinaDoc?.data.heroImage ?? 'Southland Website/heroes/lawn_result_ait3ra'
const Content = tinaDoc ? (await tinaDoc.render()).Content : null

// ── Shopify client ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

// ── Fetch JTBD-featured products individually (need full detail) ────────────
const jtbdHandles = [
  'genesis',
  'jump-start-soil-conditioner',
  'turf-revival',
  'omega-soil-activator',
  'fertalive',
  'veridian-humate-liquid-iron-for-lawns',
] as const

const jtbdProducts = await Promise.all(
  jtbdHandles.map((h) => getProductByHandle(client, h))
)
const productMap = new Map(
  jtbdProducts.filter(Boolean).map((p) => [p!.handle, p!])
)

// ── Fetch ALL products in the turf collection for the shop grid ─────────────
const turfCollection = await getCollectionProducts(client, HANDLE)

// Filter out homeowner / non-pro products
const EXCLUDED_HANDLES = new Set([
  'dog-spot-for-lawns',
  'perfect-pot',
  'chicken-manure-fertilizer',
  'natural-lawn-care-subscription',
])
const allTurfProducts: Product[] = (turfCollection?.products ?? []).filter(
  (p) => !EXCLUDED_HANDLES.has(p.handle)
)

/** Helper: get product or null */
function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

/** Helper: format price from Shopify Money */
function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── JTBD data ───────────────────────────────────────────────────────────────
const jobs = [
  {
    title: 'Rebuild soil structure from the ground up.',
    struggle:
      'Compacted rootzones, poor infiltration, shallow roots that can\'t handle stress.',
    bestFor: 'Fields and courses with heavy traffic or compaction issues',
    products: [getProduct('genesis'), getProduct('jump-start-soil-conditioner')].filter(Boolean),
    proof: '15-30% infiltration improvement',
    proofSource: 'Superintendent field data',
    recommended: true,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  },
  {
    title: 'Feed the biology that feeds your turf.',
    struggle:
      'Dead soil, thatch buildup, disease pressure, slow recovery between events.',
    bestFor: 'Turf transitioning to biological programs or fighting chronic disease',
    products: [getProduct('turf-revival'), getProduct('omega-soil-activator')].filter(Boolean),
    proof: '20-40% CEC increase in treated rootzones',
    proofSource: 'Sand-based rootzone trials',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: 'Build sustainable fertility that compounds.',
    struggle:
      'Nutrient lockup, iron deficiency, escalating fertilizer costs that never seem to end.',
    bestFor: 'Programs looking to reduce synthetic dependency while improving results',
    products: [getProduct('fertalive'), getProduct('veridian-humate-liquid-iron-for-lawns')].filter(Boolean),
    proof: 'Input costs equalize by Year 2-3',
    proofSource: 'Program cost analysis',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
]

// ── Schema.org ──────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/lawn/turf-pros/`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: seoDescription,
  url: canonicalUrl,
}
const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
      }
    : null
const fullSchema = faqSchema ? [schema, faqSchema] : schema
const ogImage = heroImage
  ? buildCloudinaryUrl(heroImage, { width: 1200, height: 630, crop: 'fill' })
  : undefined
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  schema={fullSchema}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — "Your turf takes a beating"                        -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId={heroImage}
    alt="Lush athletic turf field maintained with organic soil biology programs"
    height={600}
    minHeight="500px"
    overlay="gradient"
    overlayOpacity={90}
    contentAlign="center"
    contentJustify="start"
    priority={true}
  >
    <div class="mx-auto w-full max-w-6xl pb-12 pt-12 md:pt-20">
      <Breadcrumbs
        items={[
          { label: 'Home', href: '/' },
          { label: 'Lawn & Turf', href: '/lawn/' },
          { label: 'Turf Professionals' },
        ]}
        class="mb-4 [&_a]:text-white/80 [&_span]:text-white/60 [&_*]:text-sm"
      />
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-block rounded-full bg-white/15 px-4 py-1 text-sm font-medium text-green-300">
            For Superintendents & Turf Managers
          </span>
          <span class="inline-block rounded-full bg-green-400/20 px-3 py-1 text-sm font-semibold text-green-300">
            20-40% CEC Increase in Treated Rootzones
          </span>
        </div>
        <h1 class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl lg:text-6xl">
          Your turf takes a beating. Your soil shouldn't.
        </h1>
        <p class="mb-5 text-lg text-white/70 md:text-xl">
          You can't control weather or event schedules. But you can control:
        </p>
        <!-- Three levers — scannable -->
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-2">
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Soil Structure
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Biology
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Nutrition
          </span>
        </div>
        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3.5 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Talk to Brad
          </a>
          <a
            href="#turf-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Shop Turf Products
          </a>
          <a
            href="#proof"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/5"
          >
            See the Proof
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
        <p class="mt-2 text-sm text-white/50">No sales script — just a conversation about your program</p>
        <!-- Trust bar -->
        <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/80">
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            No Residue
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Soil-First Approach
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Programs from ~$0.02/sq ft
          </span>
        </div>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM — "The conventional approach is a treadmill."     -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
        The conventional approach is a treadmill.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        You already know it. Your budget knows it. But the schedule never stops long enough to fix it.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What the schedule demands</h3>
          <p class="leading-relaxed text-gray-600">
            Constant play, heavy traffic, compaction — surfaces that need to look perfect while getting destroyed. Every event resets the clock on your recovery window.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#44883E]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What you already know</h3>
          <p class="leading-relaxed text-gray-600">
            Synthetic inputs mask problems while degrading the soil biology that creates real resilience. Every season, you need more product to get less result. The math only goes one direction.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What shouldn't be true</h3>
          <p class="leading-relaxed text-gray-600">
            Turf professionals shouldn't have to choose between championship surfaces today and healthy soil tomorrow. The best programs should build on themselves, not tear themselves down.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: GUIDE — Brad Broxton                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
        <div class="order-2 md:order-1">
          <span class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-green-700">
            Your guide
          </span>
          <h2 class="mb-6 font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
            We've walked the fields. We know the soil.
          </h2>
          <p class="mb-4 text-lg leading-relaxed text-gray-700">
            Brad Broxton works directly with turf professionals — superintendents, sports turf managers, and lawn care operators who need results they can measure. He understands the pressure of maintaining playing surfaces that perform under heavy traffic and extreme weather.
          </p>
          <p class="mb-4 text-lg leading-relaxed text-gray-600">
            When you call Southland, Brad can help you build a soil biology program that reduces your synthetic dependency, deepens root systems, and builds turf that recovers faster. This isn't theory — it's what's working on courses and fields right now.
          </p>
          <p class="mb-8 leading-relaxed text-gray-600">
            One conversation. That's all it takes to find out if organic soil management makes sense for your operation.
          </p>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Turf & soil specialist
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Works with pros daily
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              USDA Organic certified products
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Actually answers the phone
            </span>
          </div>

          <!-- Quick contact -->
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[#44883E]/85"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Brad
            </a>
            <a
              href="mailto:brad@southlandorganics.com"
              class="text-sm font-medium text-green-700 underline decoration-green-300 underline-offset-2 hover:text-green-600"
            >
              brad@southlandorganics.com
            </a>
          </div>
        </div>

        <!-- Brad's photo -->
        <div class="order-1 md:order-2">
          <div class="relative mx-auto w-64 md:w-72 lg:w-80">
            <img
              src={bradPhoto}
              alt="Brad Broxton, Turf & Soil Specialist at Southland Organics"
              width="600"
              height="750"
              class="rounded-2xl object-cover shadow-lg"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 right-0 rounded-b-2xl bg-gradient-to-t from-black/70 to-transparent px-5 pb-4 pt-10">
              <p class="text-lg font-bold text-white">Brad Broxton</p>
              <p class="text-sm text-green-300">Turf & Soil Specialist</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: JTBD — "Three jobs. Real solutions."                      -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-4xl uppercase md:text-5xl" style="color: var(--color-title);">
        Three jobs. Real solutions.
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-gray-600">
        Every product here exists to do one of three jobs on your turf. Pick the job you need help with — we'll show you the right tools.
      </p>
      <p class="mb-12 text-center">
        <a href="#turf-products" class="inline-flex items-center gap-1 text-sm font-medium text-green-700 hover:text-green-600 hover:underline">
          Skip to all turf products
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        {jobs.map((job) => (
          <div class:list={[
            'relative flex flex-col rounded-xl border bg-white p-8 shadow-sm',
            job.recommended ? 'border-green-300 ring-1 ring-green-200' : 'border-gray-200',
          ]}>
            {job.recommended && (
              <span class="absolute -top-3 left-6 rounded-full bg-green-600 px-3 py-0.5 text-xs font-bold uppercase tracking-wide text-white">
                Recommended starting point
              </span>
            )}

            <!-- Job icon (hex) -->
            <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
              <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={job.icon} />
              </svg>
            </div>

            <!-- Job title + struggle -->
            <h3 class="mb-2 text-xl font-bold" style="color: var(--color-title);">
              {job.title}
            </h3>
            <p class="mb-3 text-sm text-gray-600">{job.struggle}</p>

            <!-- Best for -->
            <p class="mb-6 text-xs font-medium uppercase tracking-wide text-green-700">
