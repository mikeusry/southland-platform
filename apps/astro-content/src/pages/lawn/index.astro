---
/**
 * /lawn/ — Lawn & Garden Hub (Routing Page)
 *
 * Routes visitors to the right lawn page by audience type.
 * Establishes Southland's turf authority in 6 sections:
 * Hero → Four Paths → Product Grid → Proof Band → Blog Posts → Final CTA
 *
 * Modeled after /poultry/ hub page structure.
 */
import { createClient, getProductByHandle } from '@southland/shopify-storefront'
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogCard from '../../components/blog/BlogCard.astro'
import CloudinaryHero from '../../components/CloudinaryHero.astro'
import { buildCloudinaryUrl } from '../../lib/cloudinary'

// ── Fetch products ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const handles = [
  'genesis',
  'jump-start-soil-conditioner',
  'turf-revival',
  'omega-soil-activator',
  'fertalive',
  'veridian-humate-liquid-iron-for-lawns',
  'c-fix-biochar-soil-amendment',
  'dog-spot-for-lawns',
] as const

const products = (
  await Promise.all(handles.map((h) => getProductByHandle(client, h)))
).filter(Boolean) as NonNullable<Awaited<ReturnType<typeof getProductByHandle>>>[]

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// Product → segment mapping for "Best for" badges
const productSegments: Record<string, string[]> = {
  genesis: ['Turf Pros', 'Landscapers', 'Golf'],
  'jump-start-soil-conditioner': ['All Lawns', 'New Installs'],
  'turf-revival': ['Turf Pros', 'Golf'],
  'omega-soil-activator': ['Turf Pros', 'Golf'],
  fertalive: ['All Lawns', 'Landscapers'],
  'veridian-humate-liquid-iron-for-lawns': ['All Lawns', 'Homeowners'],
  'c-fix-biochar-soil-amendment': ['Landscapers', 'New Installs'],
  'dog-spot-for-lawns': ['Homeowners'],
}

// Latest lawn blog posts
const placeholderImg = 'DSC_0137_dco2wk'
const lawnPosts = (await getCollection('blog', ({ data }) =>
  data.draft !== true && data.segment === 'turf'
))
  .filter((p) => p.data.featuredImage && !p.data.featuredImage.includes(placeholderImg))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3)

const title = 'Organic Lawn Fertilizer & Soil Care | Southland'
const description =
  'Natural lawn fertilizer and humic acid soil conditioners that build real soil biology. Safe for kids, pets, and pollinators. Since 2009.'
const canonicalUrl = 'https://southlandorganics.com/lawn/'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Organic Lawn Fertilizer & Soil Conditioner',
  description: description,
  url: canonicalUrl,
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: 'https://southlandorganics.com',
    foundingDate: '2009',
  },
}

const ogImage = buildCloudinaryUrl('Southland Website/heroes/lawn_result_ait3ra', {
  width: 1200,
  height: 630,
  crop: 'fill',
})

const stats = [
  { number: '20-40%', label: 'CEC increase with humic acid programs', source: 'Soil Science Society of America' },
  { number: '15-30%', label: 'Water infiltration improvement', source: 'Superintendent field data' },
  { number: 'Year 2-3', label: 'Cost equalization vs. conventional', source: 'Program cost analysis' },
  { number: '2009', label: 'Formulating organic turf products', source: '' },
]
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 1: HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/heroes/lawn_result_ait3ra"
    alt="Healthy green lawn — organic lawn and turf care by Southland Organics"
    overlay="gradient"
    overlayOpacity={88}
    priority={true}
  >
    <div class="mx-auto max-w-6xl px-4 py-14 text-center md:py-20">
      <span
        class="mb-5 inline-block rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-green-200"
      >
        Organic Lawn Fertilizer &amp; Soil Conditioner
      </span>

      <h1 class="font-heading mb-5 text-3xl uppercase text-white md:text-4xl lg:text-5xl">
        The key to a beautiful lawn is healthy soil.
      </h1>

      <p class="mx-auto mb-7 max-w-2xl text-base leading-relaxed text-green-100 md:text-lg">
        Our natural lawn fertilizers are made from a unique deposit of humic acid material found in coastal Georgia — organic acids, activated carbon, and beneficial microbes that build the biology your turf needs to thrive. Kids and pets can play on the lawn even right after you spray it.
      </p>

      <div
        class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs font-medium uppercase tracking-wider text-green-200/80"
      >
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Safe for Kids &amp; Pets
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Humic Acid from Coastal Georgia
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          20-40% CEC Increase
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Family-Owned Since 2009
        </span>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 2: FOUR PATHS (The Fork)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="font-heading mb-3 text-center text-3xl uppercase md:text-4xl"
        style="color: #2C5234;"
      >
        What kind of turf do you manage?
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-base leading-relaxed text-gray-500">
        Same activated carbon, organic acids, and beneficial microbes — different programs. Whether you're a superintendent managing fairways or a homeowner who wants the yard your neighbors ask about, pick your path below.
      </p>

      <!-- Primary cards: Turf Pros + Homeowners -->
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Card A: Turf Pros -->
        <div class="overflow-hidden rounded-xl border border-[#2C5234]/15 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/30 hover:shadow-md">
          <img
            src="https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_600,h_220,g_auto,f_auto,q_auto/v1774914801/Southland%20Website/heroes/lawn_result_ait3ra"
            alt="Professional turf field with deep green grass"
            class="h-36 w-full object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="mb-2 text-xl font-bold" style="color: #2C5234;">Turf Professionals</h3>

            <p class="mb-4 text-sm font-medium text-gray-700">
              Organic turf management that builds resilience from the rootzone up.
            </p>

            <p class="mb-5 text-sm leading-relaxed text-gray-600">
              Your surfaces take a beating from traffic, heat, and inconsistent rain. Conventional programs mask the problem — our humic acid soil conditioners counteract stress by energizing soil with organic acids, carbon, and beneficial microbes. Deeper roots, faster recovery, lower input costs over time.
            </p>

            <div
              class="mb-6 inline-flex items-center gap-1.5 rounded-md bg-[#2C5234]/8 px-2.5 py-1 text-xs font-medium text-[#2C5234]"
            >
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              20-40% CEC increase — Soil Science Society of America
            </div>

            <div>
              <a
                href="/lawn/turf-pros/"
                class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:opacity-90"
                style="background: #44883E;"
              >
                See the Turf Pro System
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <p class="mt-4 text-xs text-gray-400">
              Programs from ~$0.02/sq ft. No contracts — just results.
            </p>
          </div>
        </div>

        <!-- Card B: Homeowners -->
        <div class="overflow-hidden rounded-xl border border-[#44883E]/15 bg-[#F8FAF8] transition-all hover:border-[#44883E]/30 hover:shadow-md">
          <img
            src="https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_600,h_220,g_auto,f_auto,q_auto/v1774912156/Southland%20Website/heroes/grass_kvxy54"
            alt="Lush green residential lawn — organic lawn care"
            class="h-36 w-full object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="mb-2 text-xl font-bold" style="color: #2C5234;">Homeowners</h3>

            <p class="mb-4 text-sm font-medium text-gray-700">
              A beautiful lawn without the chemicals. Seriously.
            </p>

            <p class="mb-5 text-sm leading-relaxed text-gray-600">
              Other programs may seem to work quickly, but they strip your soil of vital organic matter. Our natural lawn fertilizer does the opposite — humic acid adds nutrient value, improves water-holding capacity, and stimulates root growth. Your grass gets stronger every season, not weaker. And your kids and pets can be on it right after you spray.
            </p>

            <div
              class="mb-6 inline-flex items-center gap-1.5 rounded-md bg-[#44883E]/8 px-2.5 py-1 text-xs font-medium text-[#44883E]"
            >
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Safe for kids, pets, and pollinators — apply and play
            </div>

            <div>
              <a
                href="/lawn/homeowners/"
                class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:opacity-90"
                style="background: #44883E;"
              >
                Shop Homeowner Products
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <p class="mt-4 text-xs text-gray-400">
              Free shipping over $50. Most homeowners start with Jump Start.
            </p>
          </div>
        </div>
      </div>

      <!-- Secondary cards: Landscapers + Golf Courses -->
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <!-- Card C: Landscapers -->
        <div class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/25 hover:shadow-md">
          <div class="p-6">
            <div class="mb-3 flex h-10 w-10 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
              <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Landscapers</h3>
            <p class="mb-3 text-sm text-gray-700">Fewer callbacks. Healthier properties. Better margins.</p>
            <p class="mb-4 text-xs leading-relaxed text-gray-500">
              Organic soil programs that build results across multiple properties — so your work speaks for itself.
            </p>
            <a
              href="/lawn/landscapers/"
              class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
              style="border-color: #2C5234; color: #2C5234;"
            >
              Landscaper Solutions
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Card D: Golf Courses -->
        <div class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/25 hover:shadow-md">
          <div class="p-6">
            <div class="mb-3 flex h-10 w-10 flex-shrink-0 items-center justify-center bg-[#44883E]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
              <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path>
              </svg>
            </div>
            <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Golf Courses</h3>
            <p class="mb-3 text-sm text-gray-700">Championship surfaces with sustainable biology.</p>
            <p class="mb-4 text-xs leading-relaxed text-gray-500">
              Humic acid and biochar programs built for sand-based rootzones, fairways, and greens complexes.
            </p>
            <a
              href="/lawn/golf-courses/"
              class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
              style="border-color: #2C5234; color: #2C5234;"
            >
              Golf Course Solutions
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 3: PRODUCT GRID
       ═══════════════════════════════════════════════════════════════════════ -->
  <section id="products" class="border-t border-gray-100 bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="font-heading mb-3 text-center text-3xl uppercase md:text-4xl"
        style="color: #2C5234;"
      >
        Organic lawn care products
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-base leading-relaxed text-gray-500">
        Every product below is made from humic acid sourced in coastal Georgia — a natural deposit of organic matter laid down hundreds of thousands of years ago. We turn it into soil conditioners, organic fertilizers, and microbial treatments that rebuild what conventional programs take away.
      </p>
      <p class="mx-auto mb-12 max-w-2xl text-center text-sm text-gray-400">
        No residue. Safe for kids, pets, and pollinators. Ships same-day from Athens, GA.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {products.map((product) => (
          <a
            href={`/products/${product.handle}/`}
            class="group flex flex-col rounded-xl border border-gray-200 bg-white p-4 transition-all hover:border-[#44883E]/30 hover:shadow-md"
          >
            {product.images?.[0] && (
              <div class="relative mb-4 aspect-square overflow-hidden rounded-lg bg-gray-50">
                <img
                  src={product.images[0].url}
                  alt={product.images[0].altText || product.title}
                  width="300"
                  height="300"
                  class="h-full w-full object-contain transition-transform group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex flex-1 flex-col">
              <h3 class="mb-1 text-sm font-bold text-gray-900 group-hover:text-[#2C5234]">
                {product.title.includes('|') ? product.title.split('|')[0].trim() : product.title}
              </h3>
              {productSegments[product.handle] && (
                <div class="mb-2 flex flex-wrap gap-1">
                  {productSegments[product.handle].map((seg) => (
                    <span class="rounded-full bg-[#2C5234]/8 px-2 py-0.5 text-[10px] font-medium text-[#2C5234]">
                      {seg}
                    </span>
                  ))}
                </div>
              )}
              <p class="mb-3 flex-1 text-xs leading-relaxed text-gray-500">
                {product.description?.slice(0, 100)}{product.description && product.description.length > 100 ? '…' : ''}
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm font-semibold" style="color: #2C5234;">
                  From {formatPrice(product.priceRange.minVariantPrice.amount)}
                </span>
                <span class="text-xs font-semibold text-[#44883E] group-hover:underline">
                  View &rarr;
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 4: PROOF BAND
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="py-12 md:py-16" style="background: #2C5234;">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="font-heading mb-10 text-center text-3xl uppercase text-white md:text-4xl"
      >
        The numbers behind the biology
      </h2>

      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="text-center">
              <div class="mb-1 text-3xl font-bold text-green-300 md:text-4xl">{stat.number}</div>
              <div class="text-sm leading-snug text-white">{stat.label}</div>
              {stat.source && (
                <div class="mt-1 text-xs text-green-200/60">{stat.source}</div>
              )}
            </div>
          ))
        }
      </div>

      <div class="mt-8 text-center text-xs text-green-200/50">
        Soil Science Society of America &middot; Superintendent field data &middot; Family-owned since 2009
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 5: LATEST LAWN & TURF INSIGHTS
       ═══════════════════════════════════════════════════════════════════════ -->
  {lawnPosts.length > 0 && (
    <section class="bg-white py-16 md:py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="mb-10 flex items-end justify-between">
          <div>
            <h2
              class="font-heading text-2xl uppercase md:text-3xl"
              style="color: #2C5234;"
            >
              Latest lawn & turf insights
            </h2>
            <p class="mt-2 max-w-lg text-sm text-gray-500">
              Guides, soil science, and field-tested advice from our team and the turf managers we work with.
            </p>
          </div>
          <a
            href="/blog/?tag=Turf"
            class="hidden items-center gap-1.5 text-sm font-semibold text-[#44883E] transition-colors hover:text-[#2C5234] md:inline-flex"
          >
            All turf articles
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {lawnPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              slug={post.id.replace(/\.mdx?$/, '')}
              description={post.data.description}
              publishDate={post.data.publishDate}
              featuredImage={post.data.featuredImage}
              segment={post.data.segment}
            />
          ))}
        </div>
        <div class="mt-8 text-center md:hidden">
          <a
            href="/blog/?tag=Turf"
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#44883E]"
          >
            All turf articles
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 6: FINAL CTA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#2C5234] py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2 class="font-heading mb-4 text-3xl uppercase text-white md:text-4xl">
        Not sure where to start?
      </h2>

      <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed text-green-100">
        Tell Brad about your turf and your goals. He'll recommend the right organic lawn treatment
        for your situation — no contracts, no pressure, just soil science that works.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="tel:800-608-3755"
          class="inline-flex items-center gap-2.5 rounded-lg bg-white px-8 py-4 text-lg font-semibold transition-colors hover:bg-green-50"
          style="color: #2C5234;"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
