---
/**
 * Rewards Page - /rewards/
 * Customer-facing loyalty rewards landing page
 * Earn points, redeem rewards, tier progression, referral program
 */

export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import { buildSouthlandUrl } from '../../lib/cloudinary'

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const shopUrl = '/products/'
const lookupUrl = 'https://nexus.southlandorganics.com/api/loyalty/lookup'

const rewardsSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Southland Rewards | Loyalty Program',
  description:
    'Earn points on every order. Redeem for discounts, free shipping, and VIP perks. Join Southland Rewards today.',
  url: `${siteUrl}/rewards/`,
  mainEntity: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: siteUrl,
  },
}

const rewards = [
  { name: '$5 Off', points: 500, minPurchase: '$25', tier: null },
  { name: 'Free Shipping', points: 750, minPurchase: 'None', tier: null },
  { name: '$10 Off', points: 1000, minPurchase: '$50', tier: null },
  { name: '10% Off', points: 1500, minPurchase: '$50', tier: 'Silver+' },
  { name: '15% Off', points: 2000, minPurchase: '$75', tier: 'Gold only' },
  { name: '$25 Off', points: 2500, minPurchase: '$100', tier: 'Silver+' },
]

const faqs = [
  {
    q: 'How do I earn points?',
    a: 'You earn points automatically on every purchase. 1 point per $1 spent, multiplied by your tier level.',
  },
  {
    q: 'How do I redeem points?',
    a: 'Visit your rewards portal (link sent via email) to browse available rewards and generate a discount code.',
  },
  {
    q: 'Do points expire?',
    a: 'Points are valid as long as your account is active with at least one purchase per year.',
  },
  {
    q: 'What are the tiers?',
    a: 'Bronze (free), Silver ($500+ spent), Gold ($1,500+ spent). Higher tiers earn points faster and unlock exclusive rewards.',
  },
  {
    q: 'How does the referral program work?',
    a: 'Share your unique referral code. New customers get $10 off, and you earn 500 bonus points per referral.',
  },
  {
    q: 'Can I use rewards with other discounts?',
    a: 'One discount code per order. Rewards codes cannot be combined with other promotions.',
  },
  {
    q: 'How do I check my points balance?',
    a: "Enter your email in the form below and we'll send you a link to your personal rewards portal.",
  },
]
---

<BaseLayout
  title="Southland Rewards | Earn Points on Every Order"
  description="Earn points on every order. Redeem for discounts, free shipping, and VIP perks. Join the Southland Rewards loyalty program today."
  ogImage={buildSouthlandUrl('heroes/Farm_Athens_GA_7_jbdjik', {
    width: 1200,
    height: 630,
    crop: 'fill',
    quality: 'auto',
    format: 'auto',
  })}
  canonicalUrl={`${siteUrl}/rewards/`}
  schema={rewardsSchema}
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <section class="bg-southland-green-dark py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <p class="mb-3 text-sm font-medium uppercase tracking-widest text-southland-green">
        Loyalty Program
      </p>
      <h1 class="mb-6 font-heading text-4xl text-white md:text-5xl lg:text-6xl">
        Southland Rewards
      </h1>
      <p class="mx-auto max-w-3xl text-lg text-white/80 md:text-xl">
        Earn points on every order. Redeem for discounts, free shipping, and VIP perks.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={shopUrl} class="btn-primary inline-flex items-center gap-2 px-8 py-3 text-lg">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          Start Earning Rewards
        </a>
        <a
          href="#check-points"
          class="btn-secondary inline-flex items-center gap-2 border-white/40 px-8 py-3 text-lg text-white hover:bg-white hover:text-southland-green-dark"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Check My Points
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. HOW IT WORKS (3-step strip)
       ============================================================ -->
  <section class="relative -mt-8 pb-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4 sm:grid-cols-3">
        <!-- Step 1: Shop -->
        <div class="rounded-2xl bg-white p-6 text-center shadow-lg">
          <div
            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10"
          >
            <svg
              class="h-7 w-7 text-southland-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
          </div>
          <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-southland-green">
            Step 1
          </p>
          <h3 class="mb-2 text-xl text-shopify-title">Shop</h3>
          <p class="text-sm text-shopify-secondary-text">
            Earn 1 point for every $1 spent. Gold members earn 1.5x.
          </p>
        </div>
        <!-- Step 2: Earn -->
        <div class="rounded-2xl bg-white p-6 text-center shadow-lg">
          <div
            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10"
          >
            <svg
              class="h-7 w-7 text-southland-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-southland-green">
            Step 2
          </p>
          <h3 class="mb-2 text-xl text-shopify-title">Earn</h3>
          <p class="text-sm text-shopify-secondary-text">
            Points add up automatically with every purchase.
          </p>
        </div>
        <!-- Step 3: Redeem -->
        <div class="rounded-2xl bg-white p-6 text-center shadow-lg">
          <div
            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10"
          >
            <svg
              class="h-7 w-7 text-southland-green"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"
              ></path>
            </svg>
          </div>
          <p class="mb-1 text-xs font-semibold uppercase tracking-wider text-southland-green">
            Step 3
          </p>
          <h3 class="mb-2 text-xl text-shopify-title">Redeem</h3>
          <p class="text-sm text-shopify-secondary-text">
            Cash in points for discounts, free shipping, and exclusive perks.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. EARN SECTION
       ============================================================ -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-southland-green">
          Earning Points
        </p>
        <h2 class="mb-4 font-heading text-3xl md:text-4xl">Every Dollar Counts</h2>
        <p class="mx-auto mb-12 max-w-2xl text-shopify-secondary-text">
          Points are earned automatically at checkout. The more you spend, the faster your tier
          upgrades and the more you earn per dollar.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Base Rate -->
        <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
          <div class="mb-3 text-3xl font-bold text-southland-green-dark">1 pt</div>
          <p class="mb-1 font-semibold text-shopify-title">Per $1 Spent</p>
          <p class="text-sm text-shopify-secondary-text">Base earning rate for all members</p>
        </div>
        <!-- Bronze -->
        <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
          <div class="mb-3 text-3xl font-bold text-amber-700">1x</div>
          <p class="mb-1 font-semibold text-shopify-title">Bronze Rate</p>
          <p class="text-sm text-shopify-secondary-text">Standard earning for all customers</p>
        </div>
        <!-- Silver -->
        <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
          <div class="mb-3 text-3xl font-bold text-gray-500">1.25x</div>
          <p class="mb-1 font-semibold text-shopify-title">Silver Rate</p>
          <p class="text-sm text-shopify-secondary-text">After $500+ in qualifying purchases</p>
        </div>
        <!-- Gold -->
        <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
          <div class="mb-3 text-3xl font-bold text-yellow-600">1.5x</div>
          <p class="mb-1 font-semibold text-shopify-title">Gold Rate</p>
          <p class="text-sm text-shopify-secondary-text">After $1,500+ in qualifying purchases</p>
        </div>
      </div>

      <!-- Referral callout -->
      <div
        class="mt-8 rounded-xl border border-southland-green/20 bg-southland-green/5 p-6 text-center"
      >
        <p class="text-lg font-semibold text-shopify-title">
          Referral Bonus: Earn <span class="text-southland-green">500 points</span> when you refer a friend
        </p>
        <p class="mt-1 text-sm text-shopify-secondary-text">
          They get $10 off their first order, too.
        </p>
      </div>

      <!-- Example -->
      <div class="mt-6 rounded-lg bg-gray-50 p-5 text-center">
        <p class="text-sm text-shopify-secondary-text">
          <span class="font-semibold text-shopify-title">Example:</span> A $75 order earns
          <span class="font-semibold">75 points</span> at Bronze,
          <span class="font-semibold">94 points</span> at Silver, or
          <span class="font-semibold">113 points</span> at Gold.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. REWARDS MENU
       ============================================================ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-southland-green">
          Rewards Menu
        </p>
        <h2 class="mb-4 font-heading text-3xl md:text-4xl">Redeem Your Points</h2>
        <p class="mx-auto mb-12 max-w-2xl text-shopify-secondary-text">
          Choose from discounts, free shipping, and tier-exclusive perks. Unlock more rewards as you
          level up.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          rewards.map((reward) => (
            <div class="flex items-center gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-southland-green/10">
                <svg
                  class="h-6 w-6 text-southland-green"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"
                  />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-baseline justify-between">
                  <h3 class="text-base font-semibold text-shopify-title">{reward.name}</h3>
                  <span class="text-sm font-bold text-southland-green">
                    {reward.points.toLocaleString()} pts
                  </span>
                </div>
                <div class="mt-0.5 flex items-center gap-2 text-xs text-shopify-secondary-text">
                  <span>Min. purchase: {reward.minPurchase}</span>
                  {reward.tier && (
                    <span class="rounded bg-southland-green/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-southland-green">
                      {reward.tier}
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. TIER SECTION
       ============================================================ -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-southland-green">
          VIP Tiers
        </p>
        <h2 class="mb-4 font-heading text-3xl md:text-4xl">Level Up Your Rewards</h2>
        <p class="mx-auto mb-12 max-w-2xl text-shopify-secondary-text">
          Every qualifying purchase moves you closer to the next tier. Higher tiers mean faster
          earning and exclusive perks.
        </p>
      </div>

      <!-- Tier Ladder (visual) -->
      <div class="mx-auto mb-12 grid max-w-3xl gap-4 sm:grid-cols-3">
        <!-- Bronze -->
        <div
          class="relative rounded-xl border-2 border-amber-200 bg-gradient-to-b from-amber-50 to-white p-6 text-center"
        >
          <div
            class="mx-auto mb-3 flex h-16 w-16 items-center justify-center rounded-full bg-amber-100"
          >
            <svg
              class="h-8 w-8 text-amber-700"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-amber-800">Bronze</h3>
          <p class="mt-1 text-sm font-semibold text-amber-700">$0+ spent</p>
          <p class="mt-2 text-sm text-shopify-secondary-text">1x earn rate</p>
        </div>
        <!-- Silver -->
        <div
          class="relative rounded-xl border-2 border-gray-300 bg-gradient-to-b from-gray-100 to-white p-6 text-center"
        >
          <div
            class="mx-auto mb-3 flex h-16 w-16 items-center justify-center rounded-full bg-gray-200"
          >
            <svg
              class="h-8 w-8 text-gray-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-700">Silver</h3>
          <p class="mt-1 text-sm font-semibold text-gray-600">$500+ spent</p>
          <p class="mt-2 text-sm text-shopify-secondary-text">1.25x earn rate</p>
          <p class="mt-1 text-xs font-semibold text-southland-green">+100 pts upgrade bonus</p>
        </div>
        <!-- Gold -->
        <div
          class="relative rounded-xl border-2 border-yellow-400 bg-gradient-to-b from-yellow-50 to-white p-6 text-center"
        >
          <div
            class="mx-auto mb-3 flex h-16 w-16 items-center justify-center rounded-full bg-yellow-100"
          >
            <svg
              class="h-8 w-8 text-yellow-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
              ></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-yellow-700">Gold</h3>
          <p class="mt-1 text-sm font-semibold text-yellow-600">$1,500+ spent</p>
          <p class="mt-2 text-sm text-shopify-secondary-text">1.5x earn rate</p>
          <p class="mt-1 text-xs font-semibold text-southland-green">+250 pts upgrade bonus</p>
        </div>
      </div>

      <!-- Comparison Table -->
      <div class="mx-auto max-w-3xl overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b-2 border-southland-green-dark">
              <th
                class="py-3 pr-4 text-xs font-semibold uppercase tracking-wider text-shopify-secondary-text"
              ></th>
              <th
                class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-amber-700"
                >Bronze</th
              >
              <th
                class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-gray-600"
                >Silver</th
              >
              <th
                class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wider text-yellow-600"
                >Gold</th
              >
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr>
              <td class="py-3 pr-4 font-medium text-shopify-title">Qualifying Spend</td>
              <td class="px-4 py-3 text-center">$0</td>
              <td class="px-4 py-3 text-center">$500+</td>
              <td class="px-4 py-3 text-center">$1,500+</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-medium text-shopify-title">Earn Rate</td>
              <td class="px-4 py-3 text-center">1x</td>
              <td class="px-4 py-3 text-center">1.25x</td>
              <td class="px-4 py-3 text-center">1.5x</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-medium text-shopify-title">Upgrade Bonus</td>
              <td class="px-4 py-3 text-center text-shopify-secondary-text">&mdash;</td>
              <td class="px-4 py-3 text-center">100 pts</td>
              <td class="px-4 py-3 text-center">250 pts</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-medium text-shopify-title">Exclusive Rewards</td>
              <td class="px-4 py-3 text-center text-shopify-secondary-text">&mdash;</td>
              <td class="px-4 py-3 text-center">10% Off, $25 Off</td>
              <td class="px-4 py-3 text-center">15% Off</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ============================================================
       6. REFERRAL BLOCK
       ============================================================ -->
  <section class="bg-southland-green-dark py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl">
        <div
          class="mb-6 inline-flex h-16 w-16 items-center justify-center rounded-full bg-white/10"
        >
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
            ></path>
          </svg>
        </div>
        <h2 class="mb-4 font-heading text-3xl text-white md:text-4xl">Give $10, Get 500 Points</h2>
        <p class="text-lg text-white/80">
          Share your referral code with friends. They get $10 off their first order, you get 500
          points when they buy.
        </p>
        <a
          href={shopUrl}
          class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-8 py-3 font-semibold text-southland-green-dark transition-colors hover:bg-gray-100"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
            ></path>
          </svg>
          Start Referring
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       7. FAQ SECTION
       ============================================================ -->
  <section class="py-16 md:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-southland-green">
          Questions
        </p>
        <h2 class="mb-10 font-heading text-3xl md:text-4xl">Frequently Asked Questions</h2>
      </div>

      <div class="divide-y divide-gray-200">
        {
          faqs.map((faq) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between text-left font-semibold text-shopify-title transition-colors hover:text-southland-green">
                <span>{faq.q}</span>
                <svg
                  class="ml-4 h-5 w-5 shrink-0 text-shopify-secondary-text transition-transform group-open:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </summary>
              <p class="mt-3 leading-relaxed text-shopify-secondary-text">{faq.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================================
       8. BOTTOM CTA — Check My Points
       ============================================================ -->
  <section id="check-points" class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-xl px-4 text-center sm:px-6 lg:px-8">
      <div
        class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-full bg-southland-green/10"
      >
        <svg
          class="h-7 w-7 text-southland-green"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
          ></path>
        </svg>
      </div>
      <h2 class="mb-2 font-heading text-3xl md:text-4xl">Check My Points</h2>
      <p class="mb-8 text-shopify-secondary-text">
        Enter your email and we'll send you a link to your personal rewards portal.
      </p>
      <form id="rewards-lookup-form" class="flex flex-col gap-3 sm:flex-row">
        <input
          type="email"
          id="rewards-email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-1 rounded-lg border border-gray-200 bg-white px-4 py-3 text-base focus:border-southland-green focus:outline-none focus:ring-2 focus:ring-southland-green/20"
        />
        <button type="submit" id="rewards-submit" class="btn-primary whitespace-nowrap px-6 py-3">
          Send My Rewards Link
        </button>
      </form>
      <p id="rewards-message" class="mt-4 text-xs text-shopify-secondary-text">
        We'll only use your email to send your rewards portal link. No spam.
      </p>

      <script define:vars={{ lookupUrl }}>
        document.getElementById('rewards-lookup-form').addEventListener('submit', async (e) => {
          e.preventDefault()
          const email = document.getElementById('rewards-email').value.trim()
          const btn = document.getElementById('rewards-submit')
          const msg = document.getElementById('rewards-message')
          if (!email) return

          btn.disabled = true
          btn.textContent = 'Sending...'
          msg.className = 'mt-4 text-xs text-shopify-secondary-text'
          msg.textContent = ''

          try {
            const res = await fetch(lookupUrl, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            })
            if (res.status === 429) {
              msg.textContent = 'Too many requests. Please try again in a few minutes.'
              msg.className = 'mt-4 text-sm font-medium text-amber-600'
            } else {
              msg.textContent =
                "If you have a rewards account, we've sent your portal link. Check your email!"
              msg.className = 'mt-4 text-sm font-medium text-southland-green'
            }
          } catch {
            msg.textContent = 'Something went wrong. Please try again.'
            msg.className = 'mt-4 text-sm font-medium text-red-600'
          } finally {
            btn.disabled = false
            btn.textContent = 'Send My Rewards Link'
          }
        })
      </script>
    </div>
  </section>
</BaseLayout>
