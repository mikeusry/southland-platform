</BaseLayout>

<script
  is:inline
  define:vars={{
    ga4Product: {
      item_id: product.handle,
      item_name: product.title,
      item_brand: product.vendor || 'Southland Organics',
      item_category: resolvedProductType || undefined,
      price: parseFloat(product.priceRange.minVariantPrice.amount),
      currency: product.priceRange.minVariantPrice.currencyCode || 'USD',
    },
  }}
>
  // GA4: view_item on PDP load
  window.dataLayer = window.dataLayer || []
  window.dataLayer.push({ ecommerce: null })
  window.dataLayer.push({
    event: 'view_item',
    ecommerce: {
      currency: ga4Product.currency,
      value: ga4Product.price,
      items: [ga4Product],
    },
  })
</script>

<script>
  // ── Sticky mobile ATC ────────────────────────────────────────────────────
  const hero = document.getElementById('pdp-hero')
  const stickyBar = document.getElementById('sticky-atc')
  const stickyBtn = document.getElementById('sticky-atc-btn')
  const atcSection = document.getElementById('pdp-atc')

  if (hero && stickyBar) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          stickyBar.classList.add('translate-y-full')
          stickyBar.classList.remove('translate-y-0')
        } else {
          stickyBar.classList.remove('translate-y-full')
          stickyBar.classList.add('translate-y-0')
        }
      },
      { threshold: 0 }
    )
    observer.observe(hero)
  }

  if (stickyBtn && atcSection) {
    stickyBtn.addEventListener('click', () => {
      atcSection.scrollIntoView({ behavior: 'smooth', block: 'center' })
    })
  }

  // ── Persona CTA client-side swap ─────────────────────────────────────────
  // Swaps CTA text in S8 based on persona cookie. HTML source stays default.
  const PERSONA_CTA: Record<string, { headline: string; shopLabel: string }> = {
    betty: { headline: 'Your Flock Deserves the Best', shopLabel: 'Shop Backyard Products' },
    bill: { headline: 'Talk to a Poultry Specialist', shopLabel: 'See Commercial Solutions' },
    taylor: { headline: 'Build Your Turf Program', shopLabel: 'Shop Turf Products' },
  }

  function getPersonaCookie(): string | null {
    const match = document.cookie.match(/(?:^|;\s*)sl_persona=([^;]+)/)
    return match ? decodeURIComponent(match[1]) : null
  }

  function swapPersonaCTA() {
    const raw = getPersonaCookie()
    if (!raw) return
    const LEGACY: Record<string, string> = { backyard: 'betty', commercial: 'bill', lawn: 'taylor' }
    const persona = LEGACY[raw] ?? raw
    const config = PERSONA_CTA[persona]
    if (!config) return

    const ctaSection = document.getElementById('pdp-final-cta')
    if (!ctaSection) return

    const h2 = ctaSection.querySelector('h2')
    if (h2) h2.textContent = config.headline

    const shopBtn = ctaSection.querySelector('[data-cta-type="shop"]')
    if (shopBtn) {
      const svg = shopBtn.querySelector('svg')
      shopBtn.textContent = ''
      if (svg) shopBtn.prepend(svg)
      shopBtn.append(document.createTextNode(` ${config.shopLabel}`))
    }
  }
  swapPersonaCTA()

  // ── Section-level analytics ──────────────────────────────────────────────
  function trackEvent(name: string, data: Record<string, unknown> = {}) {
    const handle = window.location.pathname.split('/products/')[1]?.replace(/\/$/, '') ?? ''
    const tier = document.querySelector('main')?.dataset.pdpTier ?? 'unknown'
    const persona = getPersonaCookie() ?? 'none'
    const payload = { handle, tier, persona, ...data }

    // Fire to point.dog pixel if available
    if (typeof (window as any).pdPixel?.track === 'function') {
      ;(window as any).pdPixel.track(name, payload)
    }
    // Also fire as CustomEvent for any listeners
    window.dispatchEvent(new CustomEvent(name, { detail: payload }))
  }

  // Intersection-based impressions
  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return
        const section = entry.target as HTMLElement
        const sectionName = section.dataset.section
        if (!sectionName) return

        // Fire impression once per section
        if (section.dataset.tracked) return
        section.dataset.tracked = '1'

        if (sectionName === 'pdp-video') trackEvent('pdp_video_impression')
        if (sectionName === 'pdp-hero') trackEvent('pdp_hero_atc_view')
        if (sectionName === 'pdp-reviews') trackEvent('pdp_reviews_impression')
      })
    },
    { threshold: 0.3 }
  )

  document.querySelectorAll('[data-section]').forEach((el) => sectionObserver.observe(el))

  // Scroll depth tracking
  let maxDepth = 0
  const depthThresholds = [25, 50, 75, 100]
  function checkScrollDepth() {
    const scrollTop = window.scrollY
    const docHeight = document.documentElement.scrollHeight - window.innerHeight
    if (docHeight <= 0) return
    const pct = Math.round((scrollTop / docHeight) * 100)
    for (const threshold of depthThresholds) {
      if (pct >= threshold && maxDepth < threshold) {
        maxDepth = threshold
        trackEvent('pdp_scroll_depth', { percent: threshold })
      }
    }
  }
  window.addEventListener('scroll', checkScrollDepth, { passive: true })

  // FAQ open tracking
  document.querySelectorAll('[data-section="pdp-faq"] details').forEach((el, i) => {
    el.addEventListener('toggle', () => {
      if ((el as HTMLDetailsElement).open) {
        trackEvent('pdp_faq_open', { question_index: i })
      }
    })
  })

  // Related product click tracking
  document.querySelectorAll('[data-section="pdp-related"] a[href*="/products/"]').forEach((el) => {
    el.addEventListener('click', () => {
      const href = (el as HTMLAnchorElement).getAttribute('href') ?? ''
      const relatedHandle = href.split('/products/')[1]?.replace(/\/$/, '') ?? ''
      trackEvent('pdp_related_product_click', { related_handle: relatedHandle })
    })
  })

  // Related blog click tracking
  document.querySelectorAll('[data-section="pdp-related"] a[href*="/blog/"]').forEach((el) => {
    el.addEventListener('click', () => {
      const href = (el as HTMLAnchorElement).getAttribute('href') ?? ''
      const blogSlug = href.split('/blog/')[1]?.replace(/\/$/, '') ?? ''
      trackEvent('pdp_related_blog_click', { blog_slug: blogSlug })
    })
  })

  // Final CTA click tracking
  document.querySelectorAll('[data-section="pdp-cta"] a[data-cta-type]').forEach((el) => {
    el.addEventListener('click', () => {
      trackEvent('pdp_final_cta_click', { cta_type: (el as HTMLElement).dataset.ctaType })
    })
  })
</script>
