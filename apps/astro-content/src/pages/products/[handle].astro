                    {bp.title}
                  </h3>
                  <p class="mt-auto pt-2 text-xs text-gray-500">
                    Step {idx + 2} — {idx === 0 ? 'Flush 24 hr, then ACV' : 'Repopulate gut biology'}
                  </p>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    {/* S5c: ORP/pH calculator — conditional */}
    {
      tina?.calculatorType === 'orp-ph' && (
        <section class="border-t border-gray-100 bg-brand-green-dark/5 py-10 md:py-14" data-section="pdp-calculator">
          <div class="mx-auto max-w-3xl px-4">
            <h2 class="text-center font-heading text-2xl text-gray-900 sm:text-3xl">
              ORP at the bird, not ppm at the bucket
            </h2>
            <p class="mx-auto mt-3 max-w-2xl text-center text-base leading-relaxed text-gray-600">
              ORP (oxidation-reduction potential) is what proves your water is still sanitized when
              the bird drinks it. Adjust your dosed-water pH and see how it changes the working
              chemistry.
            </p>
            <div class="mx-auto mt-8 max-w-2xl rounded-xl bg-white p-6 shadow-sm ring-1 ring-gray-200">
              <div class="grid grid-cols-1 items-end gap-4 sm:grid-cols-3">
                <div class="sm:col-span-2">
                  <label
                    for="orp-ph-input"
                    class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-600"
                  >
                    Dosed-water pH
                  </label>
                  <input
                    id="orp-ph-input"
                    type="range"
                    min="5.0"
                    max="9.0"
                    step="0.1"
                    value="6.0"
                    class="h-2 w-full cursor-pointer appearance-none rounded-full bg-gray-200 accent-brand-green-dark"
                  />
                  <div class="mt-1 flex justify-between text-xs text-gray-500">
                    <span>5.0</span>
                    <span>6.0</span>
                    <span>7.0</span>
                    <span>8.0</span>
                    <span>9.0</span>
                  </div>
                </div>
                <div class="text-center sm:text-right">
                  <div class="text-xs font-semibold uppercase tracking-wider text-gray-500">
                    Current pH
                  </div>
                  <div id="orp-ph-value" class="font-heading text-3xl text-gray-900">6.0</div>
                </div>
              </div>

              <div class="mt-6 grid grid-cols-2 gap-4 border-t border-gray-200 pt-6">
                <div>
                  <div class="text-xs font-semibold uppercase tracking-wider text-gray-500">
                    HOCl share (active)
                  </div>
                  <div id="orp-hocl-pct" class="mt-1 font-heading text-2xl text-brand-green-dark">
                    97%
                  </div>
                </div>
                <div>
                  <div class="text-xs font-semibold uppercase tracking-wider text-gray-500">
                    Approx. ORP at 2 ppm
                  </div>
                  <div id="orp-mv-value" class="mt-1 font-heading text-2xl text-gray-900">
                    ~750 mV
                  </div>
                </div>
              </div>

              <div id="orp-status" class="mt-4 rounded-md bg-green-50 p-3 text-sm text-brand-green-dark">
                <strong>Excellent.</strong> HOCl-dominant — your far-end nipple should test in the
                700+ mV range.
              </div>

              <p class="mt-4 text-xs leading-relaxed text-gray-500">
                Reference values from published HOCl/OCl⁻ equilibrium curves. ORP also depends on
                organic load and biofilm — verify with a meter at the far-end nipple. The ZeroPoint
                Water Sanitation Protocol covers the full 3-point procedure.
              </p>
            </div>
          </div>
        </section>
      )
    }
    <script is:inline>
      ;(function () {
        var slider = document.getElementById('orp-ph-input')
        if (!slider) return
        var pHEl = document.getElementById('orp-ph-value')
        var pctEl = document.getElementById('orp-hocl-pct')
        var mvEl = document.getElementById('orp-mv-value')
        var statusEl = document.getElementById('orp-status')
        // HOCl % at 2 ppm vs pH (pKa ~7.5). Lookup table at 0.5 increments, interp linearly.
        // [pH, HOCl%, approx mV at 2 ppm]
        var TABLE = [
          [5.0, 99, 760],
          [5.5, 99, 760],
          [6.0, 97, 750],
          [6.5, 91, 730],
          [7.0, 76, 700],
          [7.5, 50, 660],
          [8.0, 24, 600],
          [8.5, 9, 540],
          [9.0, 3, 480],
        ]
        function lookup(pH) {
          if (pH <= TABLE[0][0]) return TABLE[0]
          if (pH >= TABLE[TABLE.length - 1][0]) return TABLE[TABLE.length - 1]
          for (var i = 0; i < TABLE.length - 1; i++) {
            if (pH >= TABLE[i][0] && pH <= TABLE[i + 1][0]) {
              var t = (pH - TABLE[i][0]) / (TABLE[i + 1][0] - TABLE[i][0])
              return [pH, Math.round(TABLE[i][1] + t * (TABLE[i + 1][1] - TABLE[i][1])), Math.round(TABLE[i][2] + t * (TABLE[i + 1][2] - TABLE[i][2]))]
            }
          }
          return TABLE[0]
        }
        function statusFor(mv) {
          if (mv >= 700) return ['bg-green-50', 'text-brand-green-dark', '<strong>Excellent.</strong> HOCl-dominant — your far-end nipple should test in the 700+ mV range.']
          if (mv >= 650) return ['bg-yellow-50', 'text-yellow-800', '<strong>Acceptable.</strong> ≥650 mV is the bacteriological-safety floor. Monitor and consider line cleaning if trending down.']
          if (mv >= 550) return ['bg-orange-50', 'text-orange-800', '<strong>Marginal.</strong> Increase injection rate or schedule line cleaning. Acidify source water if pH > 7.0.']
          return ['bg-red-50', 'text-red-800', '<strong>Fail.</strong> HOCl losing to OCl⁻ — drop pH to 5.5–6.5 or use ZeroPoint pH-buffer additive.']
        }
        function update() {
          var pH = parseFloat(slider.value)
          var row = lookup(pH)
          if (pHEl) pHEl.textContent = pH.toFixed(1)
          if (pctEl) pctEl.textContent = row[1] + '%'
          if (mvEl) mvEl.textContent = '~' + row[2] + ' mV'
          if (statusEl) {
            var s = statusFor(row[2])
            statusEl.className = 'mt-4 rounded-md p-3 text-sm ' + s[0] + ' ' + s[1]
            statusEl.innerHTML = s[2]
          }
        }
        slider.addEventListener('input', update)
        update()
      })()
    </script>

    {/* S6: FAQ — conditional */}
    {
      faqItems.length > 0 && (
        <section class="border-t border-gray-100 bg-gray-50 py-8 md:py-12" data-section="pdp-faq">
          <div class="mx-auto max-w-3xl px-4">
            <h2 class="mb-6 font-heading text-2xl text-gray-900">Frequently Asked Questions</h2>
            <AccordionFaq items={faqItems} persona={segment ?? inferredSegment} />
          </div>
        </section>
      )
    }

    {/* S7: RELATED PRODUCTS + CROSS-LINKS — always */}
    {
      (relatedProducts.length > 0 || relatedBlogPosts.length > 0 || hubLink) && (
        <section class="border-t border-gray-100" data-section="pdp-related">
          <div class="mx-auto max-w-6xl px-4 py-8 sm:py-12">
            {/* Related products */}
            {relatedProducts.length > 0 && (
              <div>
                <h2 class="font-heading text-2xl text-gray-900">Related Products</h2>
                <div class="mt-6 grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-4">
                  {relatedProducts.map((related) => (
                    <CollectionProductCard
                      product={related}
                      persona={persona}
                      reviewAggregate={allAggregates.get(related.id) ?? null}
                    />
                  ))}
                </div>
              </div>
            )}

            {/* Cross-links: blog posts + hub link */}
            {(relatedBlogPosts.length > 0 || hubLink) && (
              <div class={relatedProducts.length > 0 ? 'mt-10 border-t border-gray-100 pt-8' : ''}>
                <h3 class="font-heading text-lg text-gray-900">Learn More</h3>
                <div class="mt-4 flex flex-wrap gap-3">
                  {relatedBlogPosts.map((post) => (
                    <a
                      href={`/blog/${post.slug}/`}
                      class="inline-flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm text-gray-700 transition hover:border-brand-green-light hover:text-brand-green-dark"
                    >
                      <svg
                        class="h-4 w-4 text-brand-green-light"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
                        />
                      </svg>
                      {post.title}
                    </a>
                  ))}
                  {hubLink && (
                    <a
                      href={hubLink.href}
                      class="inline-flex items-center gap-2 rounded-lg border border-brand-green-light bg-green-50 px-4 py-2.5 text-sm font-medium text-brand-green-dark transition hover:bg-green-100"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 7l5 5m0 0l-5 5m5-5H6"
                        />
                      </svg>
                      {hubLink.label}
                    </a>
                  )}
                </div>
              </div>
            )}
          </div>
        </section>
      )
    }

    {/* S8: FINAL CTA — always, server-rendered default, persona-swapped client-side */}
    <section
      id="pdp-final-cta"
      class="border-t border-gray-100 bg-brand-green-dark py-12 md:py-16"
      data-section="pdp-cta"
    >
      <div class="mx-auto max-w-3xl px-4 text-center">
        {
          tina?.guideName && tina?.guidePhoto && (
            <img
              src={`https://res.cloudinary.com/southland-organics/image/upload/w_80,h_80,c_fill,g_face,q_auto,f_auto/${tina.guidePhoto}`}
              alt={tina.guideName}
              width="80"
              height="80"
              class="mx-auto mb-4 rounded-full border-2 border-green-300"
              loading="lazy"
            />
          )
        }
        <h2 class="font-heading text-2xl text-white sm:text-3xl">
          {tina?.guideName ? `Talk to ${tina.guideName}` : 'Ready to Get Started?'}
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-green-200">
          Have questions about {displayTitle}? Our team has helped over 1,000 farms find the right
          solution. Call us or shop now.
        </p>
        <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-brand-green-dark transition hover:bg-green-50"
            data-cta-type="phone"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
            Call 800-608-3755
          </a>
          <a
            href={`/products/${handle}/`}
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
            data-cta-type="shop"
            onclick="document.getElementById('pdp-atc')?.scrollIntoView({behavior:'smooth'});return false;"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"
              ></path></svg
            >
            Add to Cart
          </a>
        </div>
      </div>
    </section>

    {/* Sticky mobile ATC — fixed bottom bar, shows after hero scrolls away */}
    <div
      id="sticky-atc"
      class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-gray-200 bg-white px-4 py-3 shadow-lg transition-transform duration-300 md:hidden"
    >
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0 flex-1">
          <p class="truncate text-sm font-semibold text-gray-900">{displayTitle}</p>
          <p class="text-sm font-bold text-brand-green-dark">{priceFormatted}</p>
