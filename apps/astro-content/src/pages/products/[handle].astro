                      {post.title}
                    </a>
                  ))}
                  {hubLink && (
                    <a
                      href={hubLink.href}
                      class="inline-flex items-center gap-2 rounded-lg border border-brand-green-light bg-green-50 px-4 py-2.5 text-sm font-medium text-brand-green-dark transition hover:bg-green-100"
                    >
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 7l5 5m0 0l-5 5m5-5H6"
                        />
                      </svg>
                      {hubLink.label}
                    </a>
                  )}
                </div>
              </div>
            )}
          </div>
        </section>
      )
    }

    {/* S8: FINAL CTA — always, server-rendered default, persona-swapped client-side */}
    <section
      id="pdp-final-cta"
      class="border-t border-gray-100 bg-brand-green-dark py-12 md:py-16"
      data-section="pdp-cta"
    >
      <div class="mx-auto max-w-3xl px-4 text-center">
        {
          tina?.guideName && tina?.guidePhoto && (
            <img
              src={`https://res.cloudinary.com/southland-organics/image/upload/w_80,h_80,c_fill,g_face,q_auto,f_auto/${tina.guidePhoto}`}
              alt={tina.guideName}
              width="80"
              height="80"
              class="mx-auto mb-4 rounded-full border-2 border-green-300"
              loading="lazy"
            />
          )
        }
        <h2 class="font-heading text-2xl text-white sm:text-3xl">
          {tina?.guideName ? `Talk to ${tina.guideName}` : 'Ready to Get Started?'}
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-green-200">
          Have questions about {displayTitle}? Our team has helped over 1,000 farms find the right
          solution. Call us or shop now.
        </p>
        <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-brand-green-dark transition hover:bg-green-50"
            data-cta-type="phone"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
            Call 800-608-3755
          </a>
          <a
            href={`/products/${handle}/`}
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
            data-cta-type="shop"
            onclick="document.getElementById('pdp-atc')?.scrollIntoView({behavior:'smooth'});return false;"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"
              ></path></svg
            >
            Add to Cart
          </a>
        </div>
      </div>
    </section>

    {/* Sticky mobile ATC — fixed bottom bar, shows after hero scrolls away */}
    <div
      id="sticky-atc"
      class="fixed inset-x-0 bottom-0 z-40 translate-y-full border-t border-gray-200 bg-white px-4 py-3 shadow-lg transition-transform duration-300 md:hidden"
    >
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0 flex-1">
          <p class="truncate text-sm font-semibold text-gray-900">{displayTitle}</p>
          <p class="text-sm font-bold text-brand-green-dark">{priceFormatted}</p>
        </div>
        <button
          id="sticky-atc-btn"
          class="flex-shrink-0 rounded-lg bg-brand-green-light px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-green-dark"
