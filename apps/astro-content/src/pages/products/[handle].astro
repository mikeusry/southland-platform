        {/* Testimonials (full mode only) */}
        {
          tina?.testimonials && tina.testimonials.length > 0 && (
            <div class="mt-10 border-t border-green-700 pt-10">
              <div
                class={`grid gap-6 ${tina.testimonials.length === 1 ? 'mx-auto max-w-2xl' : 'sm:grid-cols-2 lg:grid-cols-3'}`}
              >
