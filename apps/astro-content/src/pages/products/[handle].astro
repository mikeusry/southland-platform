    {/* S7: RELATED PRODUCTS + CROSS-LINKS — always */}
    {
      (relatedProducts.length > 0 || relatedBlogPosts.length > 0 || hubLink) && (
        <section class="border-t border-gray-100" data-section="pdp-related">
          <div class="mx-auto max-w-6xl px-4 py-8 sm:py-12">
            {/* Related products */}
            {relatedProducts.length > 0 && (
              <div>
                <h2 class="font-heading text-2xl text-gray-900">Related Products</h2>
                <div class="mt-6 grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-4">
                  {relatedProducts.map((related) => (
                    <CollectionProductCard
