            {/* Cross-links: blog posts + hub link */}
            {(relatedBlogPosts.length > 0 || hubLink) && (
              <div class={relatedProducts.length > 0 ? 'mt-10 border-t border-gray-100 pt-8' : ''}>
                <h3 class="font-heading text-lg text-gray-900">Learn More</h3>
                <div class="mt-4 flex flex-wrap gap-3">
