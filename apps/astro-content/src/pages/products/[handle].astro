---
/**
 * /products/[handle] — Product Detail Page (SSR)
 *
 * Fetches product from Shopify Storefront API by handle.
 * Renders full PDP with image gallery, variant selector, add-to-cart,
 * and HTML description. Persona-aware for CTA adaptation.
 */
import {
  createClient,
  getProductByHandle,
  getCollectionProducts,
} from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import { getCollection, getEntry, render } from 'astro:content'
import { buildSouthlandUrl } from '../../lib/cloudinary'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumbs from '../../components/shared/Breadcrumbs.astro'
import ImageGallery from '../../components/product/ImageGallery'
import AddToCartButton from '../../components/product/AddToCartButton'
import CollectionProductCard from '../../components/shop/CollectionProductCard.astro'
import AccordionFaq from '../../components/shop/AccordionFaq.astro'
import { isValidPersonaId, type PersonaId } from '../../lib/persona'
import TalkToRep from '../../components/product/TalkToRep'
import { fetchProductReviews, fetchAllAggregates } from '../../lib/klaviyo-reviews'
import StarRating from '../../components/product/StarRating.astro'
import ReviewsSection from '../../components/product/ReviewsSection.astro'

// SSR — do not prerender
const { handle } = Astro.params

if (!handle) {
  return Astro.redirect('/products/')
}

// ── Read persona from cookie (server-side) ──────────────────────────────────
const personaCookie = Astro.cookies.get('sl_persona')?.value ?? null
const LEGACY_MAP: Record<string, string> = { backyard: 'betty', commercial: 'bill', lawn: 'taylor' }
const resolvedCookie = personaCookie ? (LEGACY_MAP[personaCookie] ?? personaCookie) : null
const persona: PersonaId =
  resolvedCookie && isValidPersonaId(resolvedCookie) ? (resolvedCookie as PersonaId) : null

// ── Load TinaCMS editorial content (resolves friendly slugs → Shopify handles)
const allProducts = await getCollection('products')
const tinaProduct =
  allProducts.find(
    (p) => p.data.shopifyHandle === handle || p.id.replace(/\.mdx?$/, '') === handle
  ) ?? null

// Resolve the Shopify handle: TinaCMS shopifyHandle takes priority, then URL handle
const shopifyHandle = tinaProduct?.data.shopifyHandle ?? handle

// ── Fetch product from Shopify ──────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const product = await getProductByHandle(client, shopifyHandle)

if (!product) {
  return new Response(null, { status: 404, statusText: 'Product not found' })
}

// ── Fetch Klaviyo reviews (graceful — returns null on failure) ──────────────
const reviewData = await fetchProductReviews(product.id)

// ── Related products (same productType collection) ──────────────────────────
let relatedProducts: Product[] = []
if (product.productType) {
  const typeHandle = product.productType.toLowerCase().replace(/\s+/g, '-')
  const collection = await getCollectionProducts(client, typeHandle, 8)
  if (collection) {
    relatedProducts = collection.products.filter((p) => p.handle !== shopifyHandle).slice(0, 4)
  }
}

// ── Batch review aggregates for related product cards ───────────────────────
const allAggregates = relatedProducts.length > 0 ? await fetchAllAggregates() : new Map()

// ── Bundle products (annihilate-and-repopulate kit etc.) ────────────────────
type BundleEntry = Awaited<ReturnType<typeof getProductByHandle>>
let bundleProducts: NonNullable<BundleEntry>[] = []
const tinaBundleHandles: string[] = tinaProduct?.data.bundleHandles ?? []
if (tinaBundleHandles.length > 0) {
  const fetched = await Promise.all(
    tinaBundleHandles.map((h: string) => getProductByHandle(client, h).catch(() => null))
  )
  bundleProducts = fetched.filter((p): p is NonNullable<BundleEntry> => p !== null)
}

const hasTinaContent = !!tinaProduct
// TinaContent rendered for Phase 3 (full StoryBrand mode)
// eslint-disable-next-line @typescript-eslint/no-unused-vars
let TinaContent: Awaited<ReturnType<typeof render>>['Content'] | null = null
if (tinaProduct) {
  const rendered = await render(tinaProduct)
  TinaContent = rendered.Content
}
const tina = tinaProduct?.data ?? null

// ── Reviewer (E-E-A-T attribution) ─────────────────────────────────────────
let reviewer: {
  name: string
  slug: string
  role?: string
  photoUrl?: string | null
} | null = null
if (tina?.reviewerSlug) {
  try {
    const teamMember = await getEntry('team', tina.reviewerSlug)
    if (teamMember) {
      reviewer = {
        name: teamMember.data.name,
        slug: tina.reviewerSlug,
        role: teamMember.data.role,
        photoUrl: teamMember.data.photo
          ? buildSouthlandUrl(teamMember.data.photo, {
              width: 64,
              height: 64,
              crop: 'fill',
              gravity: 'face',
              quality: 'auto',
              format: 'auto',
            })
          : null,
      }
    }
  } catch {
    // Reviewer slug points to a non-existent team entry — skip silently
  }
}

// ── Collection FAQ fallback (with dedup guardrail) ─────────────────────────
// Load FAQ from TinaCMS product first, then fall back to collection-level FAQ
// Only use collection FAQ if ≤2 products share that collection (prevents near-dupes)
let faqItems: Array<{ question: string; answer: string }> = tina?.faq ?? []
let faqFromCollection = false
if (faqItems.length === 0 && product.productType) {
  const typeHandle = product.productType.toLowerCase().replace(/\s+/g, '-')
  const allCollectionDocs = await getCollection('shopCollections')
  const collectionDoc = allCollectionDocs.find(
    (c) => c.data.handle === typeHandle || c.id.replace(/\.mdx?$/, '') === typeHandle
  )
  if (collectionDoc?.data.faq?.length) {
    // Dedup guardrail: count how many products share this collection
    const collectionProducts = await getCollectionProducts(client, typeHandle, 20)
    const productCount = collectionProducts?.products.length ?? 0
    if (productCount <= 2) {
      faqItems = collectionDoc.data.faq
      faqFromCollection = true
    }
  }
}

// ── Trust badges (TinaCMS override → segment defaults → system defaults) ───
const SEGMENT_BADGES: Record<string, string[]> = {
  poultry: ['USDA Organic Compliant', 'A+ BBB Rating', 'Free Shipping on Cases'],
  turf: ['Safe for Kids & Pets', 'A+ BBB Rating', 'Free Shipping'],
  agriculture: ['Soil Health Focused', 'A+ BBB Rating', 'Free Shipping'],
}
const DEFAULT_BADGES = ['A+ BBB Rating', 'Since 2009', 'Free Shipping']
const segment = tina?.segment ?? null
const inferredSegment = product.productType?.toLowerCase().includes('poultry')
  ? 'poultry'
  : product.productType?.toLowerCase().includes('turf') ||
      product.productType?.toLowerCase().includes('lawn')
    ? 'turf'
    : product.productType?.toLowerCase().includes('agri') ||
        product.productType?.toLowerCase().includes('soil')
      ? 'agriculture'
      : null
const trustBadges = tina?.trustBadges?.length
  ? tina.trustBadges
  : (SEGMENT_BADGES[segment ?? inferredSegment ?? ''] ?? DEFAULT_BADGES)

// ── Resolved product type (Shopify → TinaCMS segment fallback) ─────────────
const SEGMENT_TO_TYPE: Record<string, string> = {
  poultry: 'Poultry',
  turf: 'Turf',
  agriculture: 'Crops',
}
const resolvedProductType =
  product.productType || (tina?.segment ? SEGMENT_TO_TYPE[tina.segment] : '') || ''

// ── Gallon variant detection (for case builder upsell) ─────────────────────
const gallonVariant = product.variants.find((v) =>
  v.selectedOptions.some((o) => o.name === 'Size' && o.value === '1 Gallon')
)
const hasGallonVariant = !!gallonVariant
const caseSavings = gallonVariant ? Math.round(parseFloat(gallonVariant.price.amount) * 4 * 0.1) : 0

// ── Display title (strip pipe-delimited SEO keywords) ──────────────────────
const displayTitle =
  tina?.headline ||
  (product.title.includes('|') ? product.title.split('|')[0].trim() : product.title)

// ── SEO metadata ────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/products/${handle}/`

const pageTitle = tina?.seoTitle || product.seo.title || `${product.title} | Southland Organics`
const pageDescription =
  tina?.seoDescription ||
  product.seo.description ||
  product.description.slice(0, 160).replace(/\s+/g, ' ').trim()

const ogImage = product.images[0]?.url ?? '/images/podcast/og-default.jpg'

// ── Schema.org Product ──────────────────────────────────────────────────────
const hasMultipleVariants = product.variants.length > 1

// Shared shipping details for all offers
const shippingDetails = {
  '@type': 'OfferShippingDetails' as const,
  shippingDestination: {
    '@type': 'DefinedRegion' as const,
    addressCountry: 'US',
  },
  deliveryTime: {
    '@type': 'ShippingDeliveryTime' as const,
    handlingTime: {
      '@type': 'QuantitativeValue' as const,
      minValue: 1,
      maxValue: 2,
      unitCode: 'DAY',
    },
    transitTime: {
      '@type': 'QuantitativeValue' as const,
      minValue: 2,
      maxValue: 7,
      unitCode: 'DAY',
    },
  },
}
const seller = { '@type': 'Organization' as const, name: 'Southland Organics' }
const returnPolicy = {
  '@type': 'MerchantReturnPolicy' as const,
  applicableCountry: 'US',
  returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
  merchantReturnDays: 30,
  returnMethod: 'https://schema.org/ReturnByMail',
  returnFees: 'https://schema.org/ReturnShippingFees',
}

// Build per-variant offers
const variantOffers = product.variants.map((variant) => ({
  '@type': 'Offer' as const,
  name: variant.title !== 'Default Title' ? variant.title : product.title,
  price: variant.price.amount,
  priceCurrency: variant.price.currencyCode || 'USD',
  availability: variant.availableForSale
    ? 'https://schema.org/InStock'
    : 'https://schema.org/OutOfStock',
  url: canonicalUrl,
  seller,
  shippingDetails,
  hasMerchantReturnPolicy: returnPolicy,
}))

// Determine if variants represent a true ProductGroup (size/type options)
const hasNamedVariants =
  hasMultipleVariants && product.variants.some((v) => v.title !== 'Default Title')

// ── Schema.org AggregateRating + Review[] (from Klaviyo) ───────────────────
const reviewSchemaProps =
  reviewData?.aggregate && reviewData.aggregate.reviewCount > 0
    ? {
        aggregateRating: {
          '@type': 'AggregateRating',
          ratingValue: reviewData.aggregate.averageRating.toFixed(1),
          reviewCount: reviewData.aggregate.reviewCount,
          bestRating: 5,
          worstRating: 1,
        },
        review: reviewData.reviews.slice(0, 5).map((r) => ({
          '@type': 'Review',
          author: { '@type': 'Person', name: r.author },
          datePublished: r.createdAt.split('T')[0],
          reviewBody: r.content,
          ...(r.title ? { name: r.title } : {}),
          reviewRating: {
            '@type': 'Rating',
            ratingValue: r.rating,
            bestRating: 5,
            worstRating: 1,
          },
        })),
      }
    : {}

// ProductGroup + hasVariant for multi-variant products with named options
const productSchema = hasNamedVariants
  ? {
      '@context': 'https://schema.org',
      '@type': 'ProductGroup',
      name: product.title,
      description: product.description,
      url: canonicalUrl,
      image: product.images.map((img) => img.url),
      brand: {
        '@type': 'Brand',
        name: product.vendor || 'Southland Organics',
      },
      category: resolvedProductType || undefined,
      productGroupID: product.id,
      hasVariant: product.variants.map((variant) => ({
        '@type': 'Product',
        name:
          variant.title !== 'Default Title' ? `${product.title} — ${variant.title}` : product.title,
        image: variant.image?.url || product.images[0]?.url,
        offers: {
          '@type': 'Offer',
          price: variant.price.amount,
          priceCurrency: variant.price.currencyCode || 'USD',
          availability: variant.availableForSale
            ? 'https://schema.org/InStock'
            : 'https://schema.org/OutOfStock',
          url: canonicalUrl,
          seller,
          shippingDetails,
          hasMerchantReturnPolicy: returnPolicy,
        },
      })),
      offers: {
        '@type': 'AggregateOffer',
        lowPrice: product.priceRange.minVariantPrice.amount,
        highPrice: Math.max(...product.variants.map((v) => parseFloat(v.price.amount))).toFixed(2),
        priceCurrency: product.priceRange.minVariantPrice.currencyCode || 'USD',
        offerCount: product.variants.length,
      },
      ...reviewSchemaProps,
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'Product',
      name: product.title,
      description: product.description,
      url: canonicalUrl,
      image: product.images.map((img) => img.url),
      brand: {
        '@type': 'Brand',
        name: product.vendor || 'Southland Organics',
      },
      category: resolvedProductType || undefined,
      offers: hasMultipleVariants
        ? {
            '@type': 'AggregateOffer',
            lowPrice: product.priceRange.minVariantPrice.amount,
            highPrice: Math.max(...product.variants.map((v) => parseFloat(v.price.amount))).toFixed(
              2
            ),
            priceCurrency: product.priceRange.minVariantPrice.currencyCode || 'USD',
            offerCount: product.variants.length,
            offers: variantOffers,
          }
        : variantOffers[0],
      ...reviewSchemaProps,
    }

// ── Schema.org BreadcrumbList ──────────────────────────────────────────────
const collectionHandle = resolvedProductType
  ? resolvedProductType.toLowerCase().replace(/\s+/g, '-')
  : ''

// Map Shopify collection handles → hub page URLs
const COLLECTION_TO_HUB: Record<string, string> = {
  poultry: '/poultry/',
  'poultry-broilers': '/poultry/commercial/',
  'backyard-birds': '/poultry/backyard/',
  'poultry-breeders': '/poultry/breeders/',
  turkey: '/poultry/turkey/',
  'game-birds': '/poultry/game-birds/',
  turf: '/lawn/turf-pros/',
  homeowners: '/lawn/homeowners/',
  landscapers: '/lawn/landscapers/',
  'golf-courses': '/lawn/golf-courses/',
  crops: '/agriculture/crops/',
  produce: '/agriculture/produce/',
  'pig-and-swine-supplements': '/livestock/swine/',
  hydroseeders: '/hydroseeders/',
  sanitizers: '/products/sanitizers/',
  waste: '/products/waste-treatment/',
}
const hubUrl = COLLECTION_TO_HUB[collectionHandle] || `/products/`

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    ...(collectionHandle
      ? [
          {
            '@type': 'ListItem',
            position: 2,
            name: resolvedProductType,
            item: `${siteUrl}${hubUrl}`,
          },
        ]
      : []),
    {
      '@type': 'ListItem',
      position: collectionHandle ? 3 : 2,
      name: displayTitle,
      item: canonicalUrl,
    },
  ],
}

// ── Breadcrumb items ────────────────────────────────────────────────────────
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  ...(collectionHandle
    ? [{ label: resolvedProductType, href: hubUrl }]
    : [{ label: 'Products', href: '/products/' }]),
  { label: displayTitle, href: `/products/${handle}/` },
]

// ── Price display for static rendering ──────────────────────────────────────
const minPrice = product.priceRange.minVariantPrice
const priceFormatted = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: minPrice.currencyCode || 'USD',
}).format(Number(minPrice.amount))

// ── Product video (TinaCMS override → hardcoded map) ───────────────────────
const PRODUCT_VIDEOS: Record<string, string> = {
  // Enriched products (also in MDX)
  'poultry-probiotic': 'kisHZ3H00cgwwtbYpNFTuJvpX3aQjYktRPognZMCkl8A',
  'hen-helper': 'lhqXJEfCsnDBe2EFT1tXmF8p3yus2Hlr3uVY4LrxPKo',
  'catalyst-poultry-vitamin': 'xbWo4DayyMYxp9qOFQFZX800n2T00GpiZjCKfJufAIabc',
  'poultry-litter-amendment': '3mUEyNwpZJEOGfANXLYqzPgnYyx4HWgaQHEAozTAMqM',
  'natural-mite-control-livestock-poultry': '602A01013ey02O5fulCavm3sTKucUhv02fBMGiitIZafJ7rM',
  'veridian-humate-liquid-iron-for-lawns': '3nN6ccBWE00s00iYw6501y00XjZs2HCGoS4gRyOL3pHDxDE',
  genesis: 'ESZbDKvLaZ9mCwsVr3TJ01yf14ga62xt6DdKVcD0000SVw',
  'torched-all-natural-weed-killer': 'qrxyFtXf6q4fAzJw3wdww00LDdYeXVPaP3YCU15qLKxg',
  // Baseline products (video from Supabase voice_videos)
  'apple-cider-vinegar-for-chickens': 'g7O7CYd00ZTSYrsvFNB5D1sW01CROAWLBNDBN01bT9ptuk',
  'dog-spot-for-lawns': 'ZqoNlN5xEDBDz01qw8h4yseQShdw6gZSPxPk5VzRvnVc',
  'omega-soil-activator': 'ASnZzDrBC6tnDdCH5LWdaIMXm1CaB9c8KusLGO84vNg',
  'zeropoint-industrial': 'J01c01V5t8P9w02edLkbxA3jGQarZ00Pp1z2Pizr01uiMGuQ',
  'chicken-manure-fertilizer': 'bB3FPoLyDNCqBWCu01xDq7kPbS24siLsp02UL3ZaMhHv00',
  'defender-natural-insecticide': 'LwP00wsXzr8uzr3QT02UAse7egL7jscCuuFX6Ey01okXMQ',
  'turf-revival': 'X4efuotTtKPAd8ExF2VVClXLgFuHSxKWk95wYP6TD7Q',
  'pour-the-port-septic-tank-treatment': '5tBUcLSXF7Q02TDgWlBvAy00IAv3IIdYrDfw00grJxbxOY',
  'holding-tank-treatment': 'B01iD3jNMqomjYsIThINQJytKN2YSrQ4GBHKB4Dh900yM',
  fertalive: 'd7GcWLervUFQEFiUKfduYVer4k012h2NVJGY6pnEHQ01c',
  'backyard-poultry-bundle-chicken-supplements': 'GFSWvTO1uKSB6YCIvC02UMg9wlZTe00PBev1ZF021CDbhA',
  'liquid-catalyst-poultry-vitamin': 'kZFIUpw5g6pJEEiuctE465h21cYEb9xyXOCONJyKAQA',
  'jump-start-soil-conditioner': 'YdqBB002OcYb7d8EircHqXXvOxoEuSlq6D93kkiN01P4k',
}
const muxPlaybackId = tina?.muxPlaybackId || PRODUCT_VIDEOS[shopifyHandle] || null
const videoTitle = tina?.videoTitle || displayTitle
const youtubeId = tina?.youtubeId || null
const youtubeTitle = tina?.youtubeTitle || displayTitle
const hasTwoVideos = Boolean(muxPlaybackId && youtubeId)

// ── Strip Gumlet/Wistia iframes from Shopify description HTML ───────────────
const cleanDescriptionHtml = product.descriptionHtml
  ?.replace(/<iframe[^>]*(?:gumlet|wistia)[^>]*>[\s\S]*?<\/iframe>/gi, '')
  ?.replace(/<div[^>]*(?:gumlet|wistia)[^>]*>[\s\S]*?<\/div>/gi, '')
  ?.replace(/<script[^>]*(?:gumlet|wistia)[^>]*>[\s\S]*?<\/script>/gi, '')
  ?.trim()

// ── FAQ schema (conditional) ───────────────────────────────────────────────
const shouldEmitFaqSchema =
  faqItems.length > 0 && !faqFromCollection && tina?.allowFaqSchema !== false
const faqSchema = shouldEmitFaqSchema
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null

// ── Aggregate all schemas ──────────────────────────────────────────────────
const schemas = [productSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])]

// ── Proof stats (TinaCMS → generic defaults) ───────────────────────────────
const proofStats = tina?.proofStats?.length
  ? tina.proofStats
  : [
      { value: '2009', label: 'Founded', source: undefined },
      { value: 'A+', label: 'BBB Rating', source: undefined },
      { value: '1,000+', label: 'Farms Helped', source: undefined },
      { value: '17+', label: 'Years Experience', source: undefined },
    ]

// ── Related blog posts (TinaCMS curated) ───────────────────────────────────
const relatedBlogSlugs = tina?.relatedBlogSlugs ?? []
let relatedBlogPosts: Array<{ slug: string; title: string; description: string }> = []
if (relatedBlogSlugs.length > 0) {
  const allBlog = await getCollection('blog')
  relatedBlogPosts = relatedBlogSlugs
    .map((slug) => {
      const post = allBlog.find((p) => p.id.replace(/\.mdx?$/, '') === slug)
      return post
        ? {
            slug: post.id.replace(/\.mdx?$/, ''),
            title: post.data.title,
            description: post.data.description,
          }
        : null
    })
    .filter((p): p is NonNullable<typeof p> => p !== null)
}

// ── Hub link for cross-linking ─────────────────────────────────────────────
const SEGMENT_HUBS: Record<string, { label: string; href: string }> = {
  poultry: { label: 'Poultry Health Hub', href: '/poultry/' },
  turf: { label: 'Lawn & Turf Hub', href: '/lawn/' },
  agriculture: { label: 'Agriculture Hub', href: '/agriculture/crops/' },
}
const hubLink = SEGMENT_HUBS[segment ?? inferredSegment ?? ''] ?? null

// ── PDP tier (for analytics) ───────────────────────────────────────────────
const pdpTier = hasTinaContent ? 'enriched' : 'baseline'

// ── Cache: anonymous PDP HTML cacheable at edge (persona swap is client-side) ─
Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400')
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  schema={schemas}
>
  <main data-pdp-tier={pdpTier}>
    {/* S0: Breadcrumbs */}
    <div class="bg-gray-50 px-4 py-3">
      <div class="mx-auto max-w-6xl">
        <Breadcrumbs items={breadcrumbItems} />
      </div>
    </div>

    {/* S1: HERO — two-column, always */}
    <section id="pdp-hero" class="mx-auto max-w-6xl px-4 py-8 sm:py-12" data-section="pdp-hero">
      <div class="grid gap-8 md:grid-cols-2 md:gap-12">
        {/* Left: Image gallery */}
        <div>
          <ImageGallery
            client:load
            images={product.images}
            productTitle={product.title}
            productHandle={product.handle}
          />
        </div>

        {/* Right: Product info + add to cart */}
        <div class="flex flex-col">
          {/* Vendor badge */}
          {
            product.vendor && product.vendor !== 'Southland Organics' && (
              <span class="mb-2 text-sm font-medium uppercase tracking-wider text-gray-500">
                {product.vendor}
              </span>
            )
          }

          <h1 class="font-heading text-3xl text-gray-900 sm:text-4xl">
            {displayTitle}
          </h1>
          {
            product.title.includes('|') && !tina?.headline && (
              <p class="mt-1 text-base text-gray-500">
                {product.title.split('|').slice(1).join('|').trim()}
              </p>
            )
          }

          {/* Hero bullets (TinaCMS enriched only) */}
          {
            tina?.heroBullets && tina.heroBullets.length > 0 && (
              <ul class="mt-3 space-y-1">
                {tina.heroBullets.map((bullet) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600">
                    <svg
                      class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-green-light"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            )
          }

