    {/* S4: FEATURES / PRODUCT DETAILS */}
    {/* Full mode: TinaCMS features→benefits table + optional dosing + MDX body */}
    {/* Baseline mode: cleaned Shopify descriptionHtml */}
    {
      hasTinaContent && (tina?.features?.length || tina?.dosingInstructions || TinaContent) ? (
        <section class="border-t border-gray-100 py-8 sm:py-12" data-section="pdp-features">
          <div class="mx-auto max-w-6xl px-4">
            <h2 class="font-heading text-2xl text-gray-900">How It Works</h2>

            {/* Features → Benefits two-column table */}
            {tina?.features && tina.features.length > 0 && (
              <div class="mt-6 overflow-hidden overflow-x-auto rounded-xl border border-gray-200">
                <table class="w-full text-left text-sm">
                  <thead>
