          </div>
          <div>
            <p class="text-sm font-semibold text-[#2C5234] group-hover:text-[#44883E]">
              Contact Us
            </p>
            <p class="text-xs text-gray-500">Bulk pricing & custom orders</p>
          </div>
        </a>
