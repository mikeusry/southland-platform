---
/**
 * /products/sanitizers/ — Commercial Sanitizer Landing Page
 *
 * StoryBrand-style page for Alpet D2 sanitizer line.
 * Hero → Problem → Guide (Lisa) → Products → Proof → FAQ → CTA
 */
import { getCollection } from 'astro:content'
import { createClient, getCollectionProducts } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../../components/CloudinaryHero.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro'
import { buildSouthlandUrl } from '../../../lib/cloudinary'

const HANDLE = 'sanitizers'

// ── Lisa Davis photo ────────────────────────────────────────────────────────
const lisaPhoto = buildSouthlandUrl('team/Lisa_Davis', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

// ── TinaCMS content ─────────────────────────────────────────────────────────
const allCollections = await getCollection('shopCollections')
const tinaDoc =
  allCollections.find((c) => c.data.handle === HANDLE || c.id.replace(/\.mdx?$/, '') === HANDLE) ??
  null

const faq = tinaDoc?.data.faq ?? []

// ── Shopify products ────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})
const shopifyCollection = await getCollectionProducts(client, HANDLE)

if (!shopifyCollection) {
  return Astro.redirect('/')
}

// ── SEO ─────────────────────────────────────────────────────────────────────
const seoTitle = 'Commercial Sanitizers | EPA Registered | Southland'
const seoDescription =
  'EPA-registered surface sanitizers for poultry farms, food processing, and agriculture. Hypochlorous acid and peracetic acid — no rinse required. Food safe.'
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/products/sanitizers/`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Commercial Sanitizers',
  description: seoDescription,
  url: canonicalUrl,
}
const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
      }
    : null
const fullSchema = faqSchema ? [schema, faqSchema] : schema
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  schema={fullSchema}
  canonicalUrl={canonicalUrl}
  ogImage={buildSouthlandUrl('products/alpet-d2-spray', {
    width: 1200,
    height: 630,
    crop: 'fill',
    quality: 'auto',
    format: 'auto',
  })}
>
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO                                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gradient-to-br from-[#1a3a22] via-[#2C5234] to-[#1e4a2a] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <Breadcrumbs items={[{ label: 'Products', href: '/products/' }, { label: 'Sanitizers' }]} />
      <div class="mt-6 max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span
            class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1 text-sm font-medium text-green-300"
          >
            ZeroPoint Industrial &bull; EPA Registered &bull; No Rinse
          </span>
        </div>
        <h1 class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl">
          Zero pathogens. Zero evacuation. Zero compromise.
        </h1>
        <p class="mb-5 text-lg text-white/80 md:text-xl">
          When 50,000+ birds depend on your biosecurity decision, there's no room for products that
          "might" work. <strong class="text-white">ZeroPoint Industrial</strong> is our EPA-registered
          hypochlorous acid (HOCl) sanitizer — hospital-grade disinfection that eliminates pathogens in
          60 seconds, requires no evacuation, and degrades to salt and water. No rinse, no residue, no
          resistance development.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            Talk to Lisa
          </a>
          <a
            href="#sanitizer-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3 font-semibold text-white transition-colors hover:bg-white/20"
          >
            Shop Sanitizers
          </a>
        </div>
        <div
          class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/70"
        >
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path></svg
            >
            EPA Registered
          </span>
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path></svg
            >
            Food Contact Safe
          </span>
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path></svg
            >
            No Rinse Required
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM — "The cost of cutting corners on sanitation"      -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-3 text-center font-heading text-2xl uppercase text-[#2C5234] md:text-3xl">
        The cost of cutting corners on sanitation
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        You already know that contamination kills margins. But most sanitizers force you to choose
        between effectiveness and safety. Here's what that trade-off actually costs.
      </p>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center bg-[#2C5234]"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"
              ></path></svg
            >
          </div>
          <h3 class="mb-2 font-semibold text-[#2C5234]">Residue risk</h3>
          <p class="text-sm text-gray-600">
            Harsh chemical sanitizers leave residue on surfaces that come into contact with food or
            animals. That residue creates compliance headaches and health concerns downstream.
          </p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center bg-[#2C5234]"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path></svg
            >
          </div>
          <h3 class="mb-2 font-semibold text-[#2C5234]">Audit exposure</h3>
          <p class="text-sm text-gray-600">
            When inspectors or integrators show up, your sanitation protocol is on the table.
            Non-EPA-registered products or rinse-required chemicals add unnecessary risk to every
            audit.
          </p>
        </div>
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div
            class="mb-4 flex h-12 w-12 items-center justify-center bg-[#44883E]"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path></svg
            >
          </div>
          <h3 class="mb-2 font-semibold text-[#2C5234]">Labor waste</h3>
          <p class="text-sm text-gray-600">
            Rinse-required sanitizers double your labor time. Your crew spends hours rinsing
            surfaces that could be productive — or worse, skips the rinse when they're short on
            time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: GUIDE — Lisa Davis                                         -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
        <div class="order-2 md:order-1">
          <span
            class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-green-700"
          >
            Your guide
          </span>
          <h2 class="mb-6 font-heading text-3xl uppercase md:text-4xl" style="color: #2C5234;">
            We know what's at stake.
          </h2>
          <p class="mb-4 text-lg leading-relaxed text-gray-700">
            Lisa Davis works directly with farm operations and food processing facilities to find
            the right sanitation protocol — not just the right product. She understands the
            difference between a sanitizer that looks good on a spec sheet and one that actually
            holds up under USDA inspection.
          </p>
          <p class="mb-4 text-lg leading-relaxed text-gray-600">
            For large-scale livestock biosecurity, ZeroPoint Industrial is the go-to — hypochlorous
            acid that eliminates pathogens in 60 seconds, safe to use with animals present, and
            degrades to nothing but salt and water. For surface sanitizing, the Alpet D2 line covers
            everything from spray bottles to bulk containers, all EPA-registered and no-rinse.
          </p>
          <p class="mb-8 leading-relaxed text-gray-600">
            Call Lisa and tell her about your operation. She'll help you match ZeroPoint, Alpet D2,
            or both to your specific environment — and make sure your protocol is audit-ready.
          </p>

          <div class="mb-8 flex flex-wrap gap-2">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              Sanitation & food safety specialist
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              Works with farms & processors
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              EPA-registered product expertise
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]"
            >
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4"></path></svg
              >
              Actually answers the phone
            </span>
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[#44883E]/85"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path></svg
              >
              Call Lisa
            </a>
            <a
              href="mailto:lisa@southlandorganics.com"
              class="text-sm font-medium text-green-700 underline decoration-green-300 underline-offset-2 hover:text-green-600"
            >
              lisa@southlandorganics.com
            </a>
          </div>
        </div>

        <div class="order-1 md:order-2">
          <div class="relative mx-auto w-64 md:w-72 lg:w-80">
            <img
              src={lisaPhoto}
              alt="Lisa Davis, Sanitizer & Food Safety Specialist at Southland Organics"
              width="600"
              height="750"
              class="rounded-2xl object-cover shadow-lg"
              loading="lazy"
            />
            <div
              class="absolute bottom-0 left-0 right-0 rounded-b-2xl bg-gradient-to-t from-black/70 to-transparent px-5 pb-4 pt-10"
            >
              <p class="text-lg font-bold text-white">Lisa Davis</p>
              <p class="text-sm text-green-300">Sanitizer & Food Safety</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: PRODUCTS                                                   -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section id="sanitizer-products" class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-3 text-center font-heading text-2xl uppercase text-[#2C5234] md:text-3xl">
        ZeroPoint + Alpet D2 Sanitizer System
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        ZeroPoint Industrial leads the line — hypochlorous acid biosecurity for commercial
        operations. The full Alpet D2 system covers surface sanitizing in spray, wipe, and bulk
        formats. Everything is EPA-registered, food contact safe, and no rinse required.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {shopifyCollection.products.map((product) => <CollectionProductCard product={product} />)}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 5: PROOF BAND                                                 -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#2C5234] py-12 md:py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">EPA</div>
          <div class="mt-1 text-sm font-medium text-white">Registered</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">No Rinse</div>
          <div class="mt-1 text-sm font-medium text-white">Required</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">Food Safe</div>
          <div class="mt-1 text-sm font-medium text-white">Contact surfaces</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-green-300 md:text-4xl">2009</div>
          <div class="mt-1 text-sm font-medium text-white">Family-owned since</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 6: FAQ                                                        -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  {
    faq.length > 0 && (
      <section class="bg-[#F8FAF8] py-16 md:py-20">
        <div class="mx-auto max-w-4xl px-4">
          <h2 class="mb-8 text-center font-heading text-2xl uppercase text-[#2C5234] md:text-3xl">
            Frequently Asked Questions
          </h2>
          <AccordionFaq items={faq} />
        </div>
      </section>
    )
  }

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 7: CROSS-LINKS                                                -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-12">
    <div class="mx-auto max-w-5xl px-4">
      <p class="mb-6 text-center text-sm font-medium uppercase tracking-wider text-gray-400">
        Related programs
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <a
          href="/poultry/commercial/"
          class="group flex items-center gap-3 rounded-xl border border-[#44883E]/15 bg-[#F8FAF8] p-4 transition-all hover:border-[#44883E]/30 hover:shadow-md"
        >
          <div
            class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-[#2C5234]"
          >
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path></svg
            >
          </div>
          <div>
            <p class="text-sm font-semibold text-[#2C5234] group-hover:text-[#44883E]">
              Commercial Poultry
            </p>
            <p class="text-xs text-gray-500">Biosecurity programs</p>
          </div>
        </a>
        <a
          href="/products/waste-treatment/"
          class="group flex items-center gap-3 rounded-xl border border-[#44883E]/15 bg-[#F8FAF8] p-4 transition-all hover:border-[#44883E]/30 hover:shadow-md"
        >
          <div
            class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-[#2C5234]"
          >
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
              ></path></svg
            >
          </div>
          <div>
            <p class="text-sm font-semibold text-[#2C5234] group-hover:text-[#44883E]">
              Waste Treatment
            </p>
            <p class="text-xs text-gray-500">Septic & lagoon solutions</p>
          </div>
        </a>
        <a
          href="/contact/"
          class="group flex items-center gap-3 rounded-xl border border-[#44883E]/15 bg-[#F8FAF8] p-4 transition-all hover:border-[#44883E]/30 hover:shadow-md"
        >
          <div
            class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-[#2C5234]"
          >
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
