---
/**
 * /products/waste-treatment/ — Septic & Waste Treatment StoryBrand Landing
 *
 * StoryBrand: Hero → Problem → Guide (Allen, Brad, Mike) → JTBD → Shop Grid
 * → Proof → FAQ → CTA
 *
 * Three use cases: septic homeowners, commercial holding/vault, lagoons.
 * Products fetched from Shopify 'waste' collection.
 */
import { getCollection } from 'astro:content'
import { createClient, getCollectionProducts, getProductByHandle } from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro'
import { buildSouthlandUrl } from '../../../lib/cloudinary'

const HANDLE = 'waste'

// ── Guide photos ────────────────────────────────────────────────────────────
const allenPhoto = buildSouthlandUrl('team/ALLEN_Reynolds', {
  width: 600, height: 750, crop: 'fill', gravity: 'face', quality: 'auto', format: 'auto',
})
const bradPhoto = buildSouthlandUrl('team/BRAD_Broxton', {
  width: 600, height: 750, crop: 'fill', gravity: 'face', quality: 'auto', format: 'auto',
})
const mikePhoto = buildSouthlandUrl('team/MIKE_Usry', {
  width: 600, height: 750, crop: 'fill', gravity: 'face', quality: 'auto', format: 'auto',
})

// ── TinaCMS content ─────────────────────────────────────────────────────────
const allCollections = await getCollection('shopCollections')
const tinaDoc =
  allCollections.find(
    (c) => c.data.handle === HANDLE || c.id.replace(/\.mdx?$/, '') === HANDLE,
  ) ?? null

const faq = tinaDoc?.data.faq ?? []

// ── Shopify products ────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})
const shopifyCollection = await getCollectionProducts(client, HANDLE)

if (!shopifyCollection) {
  return Astro.redirect('/')
}

// Fetch JTBD-featured products individually
const jtbdHandles = [
  'pour-the-port-septic-tank-treatment',
  'holding-tank-treatment',
  'pure-b-s-bio-surfactant',
  'compost-starter',
] as const

const jtbdProducts = await Promise.all(
  jtbdHandles.map((h) => getProductByHandle(client, h))
)
const productMap = new Map(
  jtbdProducts.filter(Boolean).map((p) => [p!.handle, p!])
)

function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

const allProducts: Product[] = shopifyCollection?.products ?? []

// ── SEO ─────────────────────────────────────────────────────────────────────
const seoTitle = 'Septic & Waste Treatment | Southland Organics'
const seoDescription =
  'Natural septic tank treatment using beneficial bacteria. For septic systems, holding tanks, lagoons, and drains. No harsh chemicals. Ships same day.'
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/products/waste-treatment/`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Septic & Waste Treatment',
  description: seoDescription,
  url: canonicalUrl,
}
const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null
const fullSchema = faqSchema ? [schema, faqSchema] : schema

// ── JTBD data ───────────────────────────────────────────────────────────────
const jobs = [
  {
    title: 'Keep your septic system working without pumping it every year.',
    struggle:
      'Antibacterial soaps, bleach, and household chemicals kill the bacteria your septic tank needs to break down solids. The system backs up, odors creep in, and you end up pumping more often than you should.',
    bestFor: 'Homeowners with septic systems, rural properties, or vacation homes',
    products: [getProduct('pour-the-port-septic-tank-treatment')].filter(Boolean),
    proof: 'Billions of beneficial bacteria per dose',
    proofSource: 'Product formulation',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>`,
  },
  {
    title: 'Manage holding tanks and vault toilets without chemical burns.',
    struggle:
      'Commercial holding tanks at campgrounds, parks, and job sites build up fast. Chemical treatments mask the smell temporarily but destroy the biology you need for breakdown. The result: more frequent pump-outs, higher costs, and complaints.',
    bestFor: 'Campgrounds, parks, portable toilet operators, job sites',
    products: [getProduct('holding-tank-treatment'), getProduct('pure-b-s-bio-surfactant')].filter(Boolean),
    proof: 'Reduces pump-out frequency',
    proofSource: 'Field reports from park systems',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.079-.481 1.079-1.09a7.74 7.74 0 00-1.525-4.66A8.25 8.25 0 0016.5 6H4.5m0 0v7.5"/>`,
  },
  {
    title: 'Turn waste into compost instead of a liability.',
    struggle:
      'Whether it is farm waste, food scraps, or organic material piling up — raw organics attract pests, create odors, and take forever to break down on their own. Chemical accelerants introduce compounds you do not want in your soil.',
    bestFor: 'Farms, gardens, municipal composting, food waste operations',
    products: [getProduct('compost-starter'), getProduct('pure-b-s-bio-surfactant')].filter(Boolean),
    proof: 'Accelerates natural decomposition',
    proofSource: 'Microbial inoculant science',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>`,
  },
]

// ── Objections (FAQ) ────────────────────────────────────────────────────────
const objections = [
  {
    question: 'How do beneficial bacteria actually break down septic waste?',
    answer:
      'Your septic tank already runs on bacteria — billions of microorganisms digest solids around the clock. The problem is that antibacterial soaps, bleach, and cleaning products kill those bacteria faster than they can recover. Our septic treatment replenishes those populations with concentrated beneficial microbes that get the system back to work. It is the same biology your tank was designed to use.',
  },
  {
    question: 'How often should I treat my septic system?',
    answer:
      'Monthly is the standard for most residential systems. If you have heavy use, use a lot of antibacterial products, or recently had the tank pumped, start with a dose every two weeks for the first month. After that, monthly keeps the bacterial population strong enough to handle normal household load.',
  },
  {
    question: 'Will this work on commercial holding tanks and vault toilets?',
    answer:
      'Yes. Holding Tank Treatment is formulated for the high-volume, high-abuse environments at campgrounds, parks, and portable units. The bacterial strains are selected to handle the organic load and the chemical residue that comes with commercial use. Several state park systems use it.',
  },
  {
    question: 'Can natural products actually clear drain clogs?',
    answer:
      'Pure B.S. Bio-Surfactant uses enzymes and beneficial bacteria to break down grease, hair, and food buildup over time. It works slower than chemical drain cleaner — you will not see instant results — but it is safer for your pipes, safer for your septic system, and the effect is cumulative. Use it weekly as prevention, not as a plunger replacement.',
  },
  {
    question: 'What makes this different from the septic products at the hardware store?',
    answer:
      'Most hardware store septic treatments use enzymes only. Enzymes break bonds but do not reproduce — they are a one-time reaction. Our products contain live bacterial cultures that multiply in your tank, colonize the surfaces, and keep working between doses. That is the difference between a chemical reaction and a living system.',
  },
]
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  schema={fullSchema}
  canonicalUrl={canonicalUrl}
  ogImage={buildSouthlandUrl('heroes/Farm_Athens_GA_7_jbdjik', { width: 1200, height: 630, crop: 'fill', quality: 'auto', format: 'auto' })}
>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO                                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden py-16 md:py-20">
    <img
      src="https://res.cloudinary.com/southland-organics/image/upload/w_1920,h_700,c_fill,g_auto,q_auto,f_auto/pour-the-port/nature-mountains"
      alt="Natural landscape — Southland Organics waste treatment products work with nature"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a3a22]/85 via-[#2C5234]/80 to-[#1e4a2a]/90" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-4">
      <Breadcrumbs
        items={[
          { label: 'Products', href: '/products/' },
          { label: 'Waste Treatment' },
        ]}
      />
      <div class="mt-6 max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1 text-sm font-medium text-green-300">
            Beneficial Bacteria &bull; No Harsh Chemicals
          </span>
        </div>
        <h1 class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl">
          Your system runs on biology. Feed it right.
        </h1>
        <p class="mb-5 text-lg text-white/80 md:text-xl">
          Natural septic tank treatment, holding tank products, and drain care that work with your system's biology instead of killing it. Beneficial bacteria that digest waste, reduce odors, and cut pump-out frequency &mdash; no formaldehyde, no bleach, no chlorine.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Talk to Our Team
          </a>
          <a
            href="#waste-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3 font-semibold text-white transition-colors hover:bg-white/20"
          >
            Shop Waste Treatment
          </a>
        </div>
        <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/70">
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
            Live Bacterial Cultures
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
            No Harsh Chemicals
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" /></svg>
            Ships Same Day
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM                                                    -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-3 text-center font-heading text-2xl uppercase text-[#2C5234] md:text-3xl">
        Chemicals kill the biology your system needs
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        Every septic system, holding tank, and drain line depends on living bacteria to break down waste. Most treatments destroy those bacteria. Then you wonder why the system backs up.
      </p>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">The backup cycle</h3>
          <p class="leading-relaxed text-gray-600">
            Bleach and antibacterial products wipe out the microbes your tank needs. Solids stop breaking down. You pump more often, spend more money, and the cycle starts again the day you pour the next bottle of cleaner down the drain.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#44883E]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">The cost you do not see</h3>
          <p class="leading-relaxed text-gray-600">
            Emergency pump-outs run $300&ndash;$500. A drain field replacement can cost $10,000 or more. The slow decline of your system's biology does not announce itself until you have a real problem &mdash; and by then, the cheap fix is off the table.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">Chemicals solve one problem, create three more</h3>
          <p class="leading-relaxed text-gray-600">
            Formaldehyde and bleach-based additives mask odors temporarily while destroying the microbial ecosystem your system depends on. You are treating the symptom and killing the cure at the same time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: GUIDE — Allen, Brad, Mike                                  -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-3 text-center font-heading text-2xl uppercase text-[#2C5234] md:text-3xl">
        We have been solving waste problems since 2009
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        From farm lagoons to national park vault toilets to your backyard septic tank &mdash; our team formulates and supports every product we sell.
      </p>

      <div class="grid gap-8 md:grid-cols-3">
        <!-- Allen -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 text-center">
          <img
            src={allenPhoto}
            alt="Allen Reynolds — Southland Organics VP of Operations"
            class="mx-auto mb-4 h-28 w-28 rounded-full object-cover"
            loading="lazy"
          />
          <h3 class="mb-1 text-lg font-bold" style="color: var(--color-title);">Allen Reynolds</h3>
          <p class="mb-3 text-sm font-medium text-[#44883E]">VP &amp; Director of Operations</p>
          <p class="text-sm leading-relaxed text-gray-600">
            Allen has spent years in the field working with farmers on lagoon odor, waste breakdown, and biosecurity. If you have a commercial waste problem, Allen has probably seen it firsthand.
          </p>
        </div>
        <!-- Brad -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 text-center">
          <img
            src={bradPhoto}
            alt="Brad Broxton — Southland Organics"
            class="mx-auto mb-4 h-28 w-28 rounded-full object-cover"
            loading="lazy"
          />
          <h3 class="mb-1 text-lg font-bold" style="color: var(--color-title);">Brad Broxton</h3>
          <p class="mb-3 text-sm font-medium text-[#44883E]">Sales &amp; Field Support</p>
          <p class="text-sm leading-relaxed text-gray-600">
            Brad works directly with campgrounds, municipalities, and commercial operators to match the right product to the right system. He will walk you through dosing and scheduling for your specific setup.
          </p>
        </div>
        <!-- Mike -->
        <div class="rounded-xl border border-gray-200 bg-white p-6 text-center">
          <img
            src={mikePhoto}
            alt="Mike Usry — Southland Organics Founder"
            class="mx-auto mb-4 h-28 w-28 rounded-full object-cover"
            loading="lazy"
          />
          <h3 class="mb-1 text-lg font-bold" style="color: var(--color-title);">Mike Usry</h3>
          <p class="mb-3 text-sm font-medium text-[#44883E]">Founder &amp; Formulator</p>
          <p class="text-sm leading-relaxed text-gray-600">
            Mike formulates every product Southland sells. The bacterial strains, concentrations, and delivery systems behind these waste treatments come from his work in microbiology and organic chemistry.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: JTBD — Three jobs                                          -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-3 text-center font-heading text-2xl uppercase text-[#2C5234] md:text-3xl">
        Three jobs. Real products.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        Different systems, same principle: feed the biology, and the biology does the work.
      </p>

      <div class="grid gap-8 md:grid-cols-3">
        {jobs.map((job) => (
          <div class="flex flex-col rounded-xl border border-gray-200 bg-[#F8FAF8] p-8 shadow-sm">
            <!-- Job icon (hex) -->
            <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
              <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <Fragment set:html={job.icon} />
              </svg>
            </div>

            <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">{job.title}</h3>
            <p class="mb-4 text-sm leading-relaxed text-gray-600">{job.struggle}</p>

            <!-- Best for badge -->
            <p class="mb-4 text-xs font-medium text-[#44883E]">
              Best for: {job.bestFor}
            </p>

            <!-- Products for this job -->
            <div class="mt-auto space-y-3 border-t border-gray-200 pt-4">
              {job.products.map((product) => product && (
                <a
                  href={`/products/${product.handle}/`}
                  class="flex items-center gap-3 rounded-lg bg-white p-3 transition-colors hover:bg-green-50"
                >
                  {product.images?.[0] && (
                    <img
                      src={product.images[0].url}
                      alt={product.title}
                      class="h-12 w-12 rounded-md object-contain"
                      loading="lazy"
                    />
                  )}
                  <div class="min-w-0 flex-1">
                    <p class="truncate text-sm font-semibold text-gray-900">{product.title.includes('|') ? product.title.split('|')[0].trim() : product.title}</p>
                    <p class="text-xs text-[#44883E]">
                      From {formatPrice(product.priceRange.minVariantPrice.amount)}
                    </p>
                  </div>
                  <svg class="h-4 w-4 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>

            <!-- Proof micro-badge -->
            <div class="mt-4 flex items-center gap-2">
              <svg class="h-4 w-4 text-[#44883E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              <span class="text-xs text-gray-500">{job.proof}</span>
            </div>
          </div>
        ))}
      </div>
