---
/**
 * /agriculture/produce/ — Produce StoryBrand Landing Page
 *
 * StoryBrand framework: Hero (Commercial Grower) → Problem (depleting soil) → JTBD (3 jobs
 * with real products) → Shop Grid → Proof → SEO Content → FAQ → CTA
 *
 * Products fetched dynamically from Shopify Storefront API.
 * SEO content + FAQ pulled from TinaCMS shopCollections entry.
 */
import { getCollection } from 'astro:content'
import { createClient, getProductByHandle, getCollectionProducts } from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../../components/CloudinaryHero.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import { buildSouthlandUrl, buildCloudinaryUrl } from '../../../lib/cloudinary'

const HANDLE = 'produce'

// ── TinaCMS content ─────────────────────────────────────────────────────────
const allCollections = await getCollection('shopCollections')
const tinaDoc =
  allCollections.find(
    (c) => c.data.handle === HANDLE || c.id.replace(/\.mdx?$/, '') === HANDLE,
  ) ?? null

const title = tinaDoc?.data.title || 'Organic Soil Amendments for Produce Farms'
const seoDescription =
  tinaDoc?.data.seoDescription ||
  'Organic soil amendments that boost vegetable quality, flavor, shelf life, and soil health for commercial produce growers. OMRI Listed inputs safe for organic operations.'
const faq = tinaDoc?.data.faq ?? []
const heroImage = tinaDoc?.data.heroImage ?? 'Southland Website/heroes/DSC_0137_dco2wk'
const Content = tinaDoc ? (await tinaDoc.render()).Content : null

// ── Shopify client ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

// ── Fetch JTBD-featured products individually (need full detail) ────────────
const jtbdHandles = [
  'jump-start-soil-conditioner',
  'compost-tea',
  'fertalive',
  'chicken-manure-fertilizer',
  'c-fix-biochar-soil-amendment',
  'zeropoint-industrial',
] as const

const jtbdProducts = await Promise.all(
  jtbdHandles.map((h) => getProductByHandle(client, h))
)
const productMap = new Map(
  jtbdProducts.filter(Boolean).map((p) => [p!.handle, p!])
)

// ── Fetch ALL products in the produce collection for the shop grid ──────────
const produceCollection = await getCollectionProducts(client, HANDLE)
const allProduceProducts: Product[] = produceCollection?.products ?? []

/** Helper: get product or null */
function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

/** Helper: format price from Shopify Money */
function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── JTBD data ───────────────────────────────────────────────────────────────
const jobs = [
  {
    title: 'Build soil that grows flavorful, nutrient-dense produce.',
    struggle:
      'Depleted organic matter, poor CEC, crops that lack the flavor and density buyers pay a premium for.',
    bestFor: 'Farms rebuilding soil structure or transitioning to organic',
    products: [getProduct('jump-start-soil-conditioner'), getProduct('c-fix-biochar-soil-amendment')].filter(Boolean),
    proof: '20-40% CEC increase in amended soils',
    proofSource: 'Humic acid research, Soil Science Society of America',
    recommended: true,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  },
  {
    title: 'Feed the microbiome that feeds your crops.',
    struggle:
      'Dead soil biology, nutrient lockup, increasing fertilizer rates that deliver diminishing returns.',
    bestFor: 'Growers fighting yield plateaus or declining soil test results',
    products: [getProduct('compost-tea'), getProduct('fertalive')].filter(Boolean),
    proof: 'Higher Brix readings in treated produce',
    proofSource: 'Grower field data, refractometer testing',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: 'Protect quality from field to shelf.',
    struggle:
      'Post-harvest losses, food safety concerns, short shelf life cutting into margins and buyer confidence.',
    bestFor: 'Operations focused on food safety, shelf life, and premium market positioning',
    products: [getProduct('chicken-manure-fertilizer'), getProduct('zeropoint-industrial')].filter(Boolean),
    proof: 'Year 2-3 cost equalization',
    proofSource: 'Program cost analysis vs. conventional inputs',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
]

// ── Schema.org ──────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/agriculture/produce/`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description: seoDescription,
  url: canonicalUrl,
}
const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: { '@type': 'Answer', text: item.answer },
        })),
      }
    : null
const fullSchema = faqSchema ? [schema, faqSchema] : schema
const ogImage = heroImage
  ? buildCloudinaryUrl(heroImage, { width: 1200, height: 630, crop: 'fill' })
  : undefined
---

<BaseLayout
  title={title}
  description={seoDescription}
  schema={fullSchema}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — "Flavor starts in the soil"                        -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId={heroImage}
    alt="Fresh produce growing in organic soil — Southland Organics"
    height={600}
    minHeight="500px"
    overlay="gradient"
    overlayOpacity={90}
    gravity="center"
    contentAlign="center"
    contentJustify="start"
    priority={true}
  >
    <div class="mx-auto w-full max-w-6xl pb-12 pt-12 md:pt-20">
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-block rounded-full bg-white/15 px-4 py-1 text-sm font-medium text-green-300">
            For Commercial Vegetable Growers
          </span>
          <span class="inline-block rounded-full bg-green-400/20 px-3 py-1 text-sm font-semibold text-green-300">
            Flavor Starts in the Soil
          </span>
        </div>
        <h1 class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl lg:text-6xl">
          Flavor, shelf life, and yield all start in the same place.
        </h1>
        <p class="mb-5 text-lg text-white/70 md:text-xl">
          You can't control weather or market prices. But you can control:
        </p>
        <!-- Three levers — scannable -->
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-2">
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Soil Biology
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Nutrient Density
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Food Safety
          </span>
        </div>
        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3.5 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Talk to Mike
          </a>
          <a
            href="#produce-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Shop Products
          </a>
          <a
            href="#proof"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/5"
          >
            See the Proof
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
        <p class="mt-2 text-sm text-white/50">No sales script — just a conversation about your soil and your goals</p>
        <!-- Trust bar -->
        <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/80">
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            OMRI Listed
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Soil-First Approach
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Safe for Organic Ops
          </span>
        </div>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM — "The soil is the crop."                         -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
        The soil is the crop.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        Flavor, nutrition, shelf life — they don't come from the seed packet. They come from what's happening underground.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What the market demands</h3>
          <p class="leading-relaxed text-gray-600">
            Consistent quality, longer shelf life, higher brix, year after year — from soil that's been asked to give more than it gets back. Buyers expect premium produce from depleting ground.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#44883E]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What every grower sees</h3>
          <p class="leading-relaxed text-gray-600">
            Yields plateau, flavor fades, soil tests show declining organic matter despite more inputs every season. You're spending more to get less, and the trend line isn't turning around.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
            <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What shouldn't be true</h3>
          <p class="leading-relaxed text-gray-600">
            Growing food that nourishes people shouldn't require practices that destroy the soil it grows in. The best farming should build fertility, not mine it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: JTBD — "Three jobs. Real solutions."                      -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-4xl uppercase md:text-5xl" style="color: var(--color-title);">
        Three jobs. Real solutions.
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-gray-600">
        Every product here exists to do one of three jobs on your farm. Pick the job you need help with — we'll show you the right tools.
      </p>
      <p class="mb-12 text-center">
        <a href="#produce-products" class="inline-flex items-center gap-1 text-sm font-medium text-green-700 hover:text-green-600 hover:underline">
          Skip to all produce products
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        {jobs.map((job) => (
          <div class:list={[
            'relative flex flex-col rounded-xl border bg-white p-8 shadow-sm',
            job.recommended ? 'border-green-300 ring-1 ring-green-200' : 'border-gray-200',
          ]}>
            {job.recommended && (
              <span class="absolute -top-3 left-6 rounded-full bg-green-600 px-3 py-0.5 text-xs font-bold uppercase tracking-wide text-white">
                Recommended starting point
              </span>
            )}

            <!-- Job icon (hex) -->
            <div class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);">
              <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={job.icon} />
              </svg>
            </div>

            <!-- Job title + struggle -->
            <h3 class="mb-2 text-xl font-bold" style="color: var(--color-title);">
              {job.title}
            </h3>
            <p class="mb-3 text-sm text-gray-600">{job.struggle}</p>

            <!-- Best for -->
            <p class="mb-6 text-xs font-medium uppercase tracking-wide text-green-700">
              Best for: {job.bestFor}
            </p>

            <!-- Products -->
            <div class="mb-6 flex-1 space-y-4">
              {job.products.map((product) => (
                <a
                  href={`/products/${product!.handle}/`}
                  class="flex items-center gap-3 rounded-lg border border-gray-100 bg-gray-50 p-3 transition-colors hover:border-green-200 hover:bg-green-50"
                >
                  {product!.images?.[0] && (
                    <img
                      src={product!.images[0].url}
                      alt={product!.images[0].altText || product!.title}
                      width="56"
                      height="56"
                      class="h-14 w-14 rounded-md object-cover"
                      loading="lazy"
                    />
                  )}
                  <div class="min-w-0 flex-1">
                    <div class="truncate text-sm font-semibold text-gray-900">
                      {product!.title.includes('|') ? product!.title.split('|')[0].trim() : product!.title}
                    </div>
                    <div class="text-sm text-green-700">
                      From {formatPrice(product!.priceRange.minVariantPrice.amount)}
                    </div>
                  </div>
                  <svg class="h-4 w-4 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>

            <!-- Proof line -->
            <div class="border-t border-gray-100 pt-4">
              <div class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                </svg>
                <div>
                  <span class="text-sm font-semibold text-green-700">{job.proof}</span>
                  <span class="block text-xs text-gray-500">{job.proofSource}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: SHOP THE PRODUCE SYSTEM — Full product grid               -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section id="produce-products" class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
        Shop the Produce System
      </h2>
      <p class="mx-auto mb-6 max-w-2xl text-center text-gray-600">
        Everything on this shelf exists to do one of the three jobs above. Start with one product or run the full program.
      </p>

      <!-- System vs Individual callout -->
      <div class="mx-auto mb-10 max-w-3xl rounded-xl border border-green-200 bg-green-50 p-5 md:p-6">
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <div class="mb-1 flex items-center gap-2">
              <svg class="h-5 w-5 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <span class="font-bold text-[#2C5234]">Full Program</span>
            </div>
            <p class="text-sm text-gray-600">
              Jump Start + Compost Tea + FertAlive covers structure, biology, and nutrition. Most growers see measurable change within one growing season.
            </p>
          </div>
          <div>
            <div class="mb-1 flex items-center gap-2">
              <svg class="h-5 w-5 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              <span class="font-bold text-[#2C5234]">Start with One</span>
            </div>
            <p class="text-sm text-gray-600">
              Not ready for a full program? Pick one product, test it on one field. Track Brix and yield for a season. If the soil doesn't respond, don't reorder.
            </p>
          </div>
        </div>
      </div>

      {allProduceProducts.length > 0 ? (
        <div class="grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-4">
          {allProduceProducts.map((product) => (
            <CollectionProductCard product={product} />
          ))}
        </div>
      ) : (
        <div class="text-center">
          <a
            href="/collections/produce/"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            Browse All Produce Products
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      )}

      <div class="mt-8 text-center">
        <a
          href="tel:800-608-3755"
          class="inline-flex items-center gap-2 text-sm font-medium text-green-700 hover:text-green-600"
        >
