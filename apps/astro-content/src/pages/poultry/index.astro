---
/**
 * /poultry/ — Poultry Hub (Routing Page)
 *
 * Routes visitors to the right poultry page by operation type.
 * Establishes Southland's poultry authority in 5 sections:
 * Hero → Four Paths → Product Grid → Proof Band → Final CTA
 *
 * Copy source: BB-Persona/poultry-hub-copy.md
 */
import { createClient, getProductByHandle } from '@southland/shopify-storefront'
import BaseLayout from '../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../components/CloudinaryHero.astro'

// ── Fetch products ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const handles = [
  'poultry-probiotic',                              // Big Ole Bird
  'hen-helper',                                     // Hen Helper
  'poultry-litter-amendment',                       // Litter Life
  'catalyst-poultry-vitamin',                       // Catalyst
  'natural-mite-control-livestock-poultry',         // Desecticide
  'backyard-poultry-bundle-chicken-supplements',    // Backyard Bundle
  'apple-cider-vinegar-for-chickens',                // Mother Load ACV
] as const

const products = (
  await Promise.all(handles.map((h) => getProductByHandle(client, h)))
).filter(Boolean) as NonNullable<Awaited<ReturnType<typeof getProductByHandle>>>[]

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

const title = 'Organic Poultry Solutions | Southland Organics'
const description =
  'Probiotics, litter treatments, and gut health products for broiler growers, turkey producers, game bird operations, and backyard flock owners. USDA Organic certified. Zero withdrawal. Since 2009.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Organic Poultry Solutions',
  description: description,
  url: 'https://southlandorganics.com/poultry/',
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: 'https://southlandorganics.com',
    foundingDate: '2009',
  },
}

const stats = [
  { number: '2009', label: 'Formulating organic poultry products', source: '' },
  {
    number: '6.2%',
    label: 'Mortality reduction in UGA-validated study',
    source: 'C. Stephen Roney DVM',
  },
  { number: '0', label: 'Withdrawal period on every product', source: 'USDA Organic' },
  { number: '500+', label: 'Farms using Southland products', source: '' },
]
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 1: HERO
       Background: CloudinaryHero (exterior poultry house photo)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/poultry/poultry_house_w1zen3_iecnpo"
    alt="Commercial poultry houses under open sky — Southland Organics serves broiler, turkey, game bird, and backyard operations"
    overlay="gradient"
    overlayOpacity={88}
    priority={true}
  >
    <div class="mx-auto max-w-6xl px-4 py-20 text-center md:py-28">
      <span
        class="mb-6 inline-block rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-green-200"
      >
        Organic Poultry Solutions Since 2009
      </span>

      <h1 class="font-heading mb-6 text-4xl uppercase text-white md:text-5xl lg:text-6xl">
        Organic poultry health products that work.
      </h1>

      <p class="mx-auto mb-8 max-w-3xl text-lg leading-relaxed text-green-100 md:text-xl">
        Probiotics, litter treatments, and gut health products for broilers, turkeys, game birds, and
        backyard flocks. Used on millions of birds. USDA Organic certified. Zero withdrawal. Results
        you can measure.
      </p>

      <div
        class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs font-medium uppercase tracking-wider text-green-200/80"
      >
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          USDA Organic
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          OMRI Listed
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          Zero Withdrawal
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          Family-Owned Since 2009
        </span>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 2: FOUR PATHS (The Fork)
       Background: white
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="font-heading mb-3 text-center text-3xl uppercase md:text-4xl"
        style="color: #2C5234;"
      >
        What kind of birds do you raise?
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-base leading-relaxed text-gray-500">
        Same biology, different operations. Pick your path for products, dosing, and support built
        for how you actually raise birds.
      </p>

      <!-- Primary cards: Commercial + Backyard (full-size, mini-hero treatment) -->
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Card A: Commercial Broilers -->
        <div class="overflow-hidden rounded-xl border border-[#2C5234]/15 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/30 hover:shadow-md">
          <div class="p-8">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-lg bg-[#2C5234]/10">
              <svg
                class="h-7 w-7 text-[#2C5234]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 21h18M4 21V10l8-6 8 6v11M9 21v-6h6v6"></path>
              </svg>
            </div>

            <h3 class="mb-2 text-xl font-bold" style="color: #2C5234;">Commercial Broilers</h3>

            <p class="mb-4 text-sm font-medium text-gray-700">
              Lower mortality, better FCR, stronger settlements.
            </p>

            <p class="mb-5 text-sm leading-relaxed text-gray-600">
              Contract growers running 2–8 houses. You're measured on every tenth of a point — our
              system is built for that math.
            </p>

            <div
              class="mb-6 inline-flex items-center gap-1.5 rounded-md bg-[#2C5234]/8 px-2.5 py-1 text-xs font-medium text-[#2C5234]"
            >
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              6.2% mortality reduction — UGA validated
            </div>

            <div>
              <a
                href="/poultry/commercial/"
                class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:opacity-90"
                style="background: #44883E;"
              >
                See the Broiler System
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <p class="mt-4 text-xs text-gray-400">
              Talk to Allen Reynolds — 10+ years in the houses.
            </p>
          </div>
        </div>

        <!-- Card B: Backyard -->
        <div class="overflow-hidden rounded-xl border border-[#44883E]/15 bg-[#F8FAF8] transition-all hover:border-[#44883E]/30 hover:shadow-md">
          <div class="p-8">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-lg bg-[#44883E]/10">
              <svg
                class="h-7 w-7 text-[#44883E]"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M12 19c-4 0-7-2.5-7-6 0-2 1-3.5 2-4.5-.5-1-.5-2.5 0-3.5 1 0 2 .5 2.5 1 .5-1 1.5-2 3-2s2.5 1 3 2c.5-.5 1.5-1 2.5-1 .5 1 .5 2.5 0 3.5 1 1 2 2.5 2 4.5 0 3.5-3 6-7 6z"
                ></path>
              </svg>
            </div>

            <h3 class="mb-2 text-xl font-bold" style="color: #2C5234;">Backyard Flocks</h3>

            <p class="mb-4 text-sm font-medium text-gray-700">
              Healthier birds, more eggs, less guesswork.
            </p>

            <p class="mb-5 text-sm leading-relaxed text-gray-600">
              5–50 birds in the yard. You want happy chickens and consistent eggs — without a
              chemistry degree or a cabinet full of supplements.
            </p>

            <div
              class="mb-6 inline-flex items-center gap-1.5 rounded-md bg-[#44883E]/8 px-2.5 py-1 text-xs font-medium text-[#44883E]"
            >
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              Same biology used on millions of commercial birds — sized for your flock
            </div>

            <div>
              <a
                href="/poultry/backyard/"
                class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:opacity-90"
                style="background: #44883E;"
              >
                Shop the Backyard Line
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <p class="mt-4 text-xs text-gray-400">
              Free shipping over $50. Most keepers start with the Backyard Bundle.
            </p>
          </div>
        </div>
      </div>

      <!-- Secondary cards: Breeders, Turkey, Game Birds (upgraded with outcome lines + CTA buttons) -->
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <!-- Card C: Breeders -->
        <div class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] p-6 transition-all hover:border-[#2C5234]/25 hover:shadow-md">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#2C5234]/10">
            <svg
              class="h-6 w-6 text-[#2C5234]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
              ></path>
            </svg>
          </div>
          <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Breeders</h3>
          <p class="mb-3 text-sm text-gray-700">Better hatchability, stronger egg quality.</p>
          <p class="mb-4 text-xs leading-relaxed text-gray-500">
            Biosecurity and gut health products built for breeder operations.
          </p>
          <a
            href="/poultry/breeders/"
            class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
            style="border-color: #2C5234; color: #2C5234;"
          >
            Breeder Solutions
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Card D: Turkey -->
        <div class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] p-6 transition-all hover:border-[#2C5234]/25 hover:shadow-md">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#2C5234]/10">
            <svg
              class="h-6 w-6 text-[#2C5234]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M12 3c-1.5 0-3 1-3.5 2.5C7 6 5.5 7 5 8.5c-.5 2 0 4 1.5 5.5 1 1 2 2.5 2 4v3h7v-3c0-1.5 1-3 2-4 1.5-1.5 2-3.5 1.5-5.5-.5-1.5-2-2.5-3.5-3C14.5 4 13.5 3 12 3z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Turkey</h3>
          <p class="mb-3 text-sm text-gray-700">Lower mortality across longer grow-outs.</p>
          <p class="mb-4 text-xs leading-relaxed text-gray-500">
            Heavier birds, higher stakes per head. Products dosed for turkey-scale operations.
          </p>
          <a
            href="/poultry/turkey/"
            class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
            style="border-color: #2C5234; color: #2C5234;"
          >
            Turkey Solutions
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Card E: Game Birds -->
        <div class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] p-6 transition-all hover:border-[#2C5234]/25 hover:shadow-md">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#2C5234]/10">
            <svg
              class="h-6 w-6 text-[#2C5234]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Game Birds</h3>
          <p class="mb-3 text-sm text-gray-700">Healthier quail, pheasant, and chukar.</p>
          <p class="mb-4 text-xs leading-relaxed text-gray-500">
            Trusted by Tuck Farms. Same proven biology, adjusted for game bird operations.
          </p>
          <a
            href="/poultry/game-birds/"
            class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
            style="border-color: #2C5234; color: #2C5234;"
          >
            Game Bird Solutions
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 3: PRODUCT GRID
       Background: cream (#F8FAF8)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section id="products" class="border-t border-gray-100 bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="font-heading mb-3 text-center text-3xl uppercase md:text-4xl"
        style="color: #2C5234;"
      >
        Our poultry products
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-base leading-relaxed text-gray-500">
        Every product here is used across multiple bird types. The best starting point depends on
        your operation — pick your path above if you're not sure.
      </p>
      <p class="mx-auto mb-12 max-w-2xl text-center text-sm text-gray-400">
        USDA Organic certified. Zero withdrawal. All products ship same-day.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {products.map((product) => (
          <a
            href={`/products/${product.handle}/`}
            class="group flex flex-col rounded-xl border border-gray-200 bg-white p-4 transition-all hover:border-[#44883E]/30 hover:shadow-md"
          >
            {product.images?.[0] && (
              <div class="mb-4 aspect-square overflow-hidden rounded-lg bg-gray-50">
                <img
                  src={product.images[0].url}
                  alt={product.images[0].altText || product.title}
                  width="300"
                  height="300"
                  class="h-full w-full object-contain transition-transform group-hover:scale-105"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex flex-1 flex-col">
              <h3 class="mb-1 text-sm font-bold text-gray-900 group-hover:text-[#2C5234]">
                {product.title.includes('|') ? product.title.split('|')[0].trim() : product.title}
              </h3>
              <p class="mb-3 flex-1 text-xs leading-relaxed text-gray-500">
                {product.description?.slice(0, 100)}{product.description && product.description.length > 100 ? '…' : ''}
              </p>
              <div class="flex items-center justify-between">
                <span class="text-sm font-semibold" style="color: #2C5234;">
                  From {formatPrice(product.priceRange.minVariantPrice.amount)}
                </span>
                <span class="text-xs font-semibold text-[#44883E] group-hover:underline">
                  View &rarr;
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 4: PROOF BAND (renumbered from 3)
       Background: #2C5234 (dark green)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="py-12 md:py-16" style="background: #2C5234;">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="font-heading mb-10 text-center text-3xl uppercase text-white md:text-4xl"
      >
        Why poultry people trust us
      </h2>

      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="text-center">
              <div class="mb-1 text-3xl font-bold text-green-300 md:text-4xl">{stat.number}</div>
              <div class="text-sm leading-snug text-white">{stat.label}</div>
              {stat.source && (
                <div class="mt-1 text-xs text-green-200/60">{stat.source}</div>
              )}
            </div>
          ))
        }
      </div>

      <div class="mt-8 text-center text-xs text-green-200/50">
        UGA Study, C. Stephen Roney DVM &middot; USDA Organic Certified &middot; OMRI Listed
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 5: FINAL CTA
       Background: CloudinaryHero (interior poultry house photo)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/poultry/Poultry_Industry_dcsedd_wyrhru"
    alt="Inside a commercial poultry house — Southland Organics products at work"
    overlay="dark"
    overlayOpacity={88}
    effect="blur"
  >
    <div class="mx-auto max-w-4xl px-4 py-16 text-center md:py-20">
      <h2 class="font-heading mb-4 text-3xl uppercase text-white md:text-4xl">
        Not sure where to start?
      </h2>

      <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed text-green-100">
        If you're not sure which system fits, call and we'll match products to your birds and houses.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="tel:800-608-3755"
          class="inline-flex items-center gap-2.5 rounded-lg bg-white px-8 py-4 text-lg font-semibold transition-colors hover:bg-green-50"
          style="color: #2C5234;"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          Talk to a Poultry Expert
        </a>

        <a
          href="#products"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 text-base font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/10"
        >
          See All Poultry Products
        </a>
      </div>

      <p class="mt-6 text-xs text-green-200/50">
        Family-owned in Georgia since 2009. Real people answer the phone.
      </p>
    </div>
  </CloudinaryHero>
</BaseLayout>
