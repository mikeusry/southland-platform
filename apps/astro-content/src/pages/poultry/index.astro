---
/**
 * /poultry/ — Poultry Hub (Routing Page)
 *
 * Routes visitors to the right poultry page by operation type.
 * Establishes Southland's poultry authority in 5 sections:
 * Hero → Four Paths → Product Grid → Proof Band → Final CTA
 *
 * Copy source: BB-Persona/poultry-hub-copy.md
 */
import { createClient, getProductByHandle } from '@southland/shopify-storefront'
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogCard from '../../components/blog/BlogCard.astro'
import CloudinaryHero from '../../components/CloudinaryHero.astro'

// ── Fetch products ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const handles = [
  'poultry-probiotic', // Big Ole Bird
  'hen-helper', // Hen Helper
  'poultry-litter-amendment', // Litter Life
  'catalyst-poultry-vitamin', // Catalyst
  'natural-mite-control-livestock-poultry', // Desecticide
  'zeropoint-industrial', // ZeroPoint Industrial
  'backyard-poultry-bundle-chicken-supplements', // Backyard Bundle
  'apple-cider-vinegar-for-chickens', // Mother Load ACV
] as const

const products = (await Promise.all(handles.map((h) => getProductByHandle(client, h)))).filter(
  Boolean
) as NonNullable<Awaited<ReturnType<typeof getProductByHandle>>>[]

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// Product → segment mapping for "Best for" badges
const productSegments: Record<string, string[]> = {
  'poultry-probiotic': ['Commercial', 'Turkey', 'Breeders'],
  'hen-helper': ['Backyard'],
  'poultry-litter-amendment': ['Commercial', 'Turkey'],
  'catalyst-poultry-vitamin': ['Commercial', 'Backyard', 'Turkey'],
  'natural-mite-control-livestock-poultry': ['Backyard', 'Game Birds'],
  'zeropoint-industrial': ['Commercial', 'Breeders', 'Turkey'],
  'backyard-poultry-bundle-chicken-supplements': ['Backyard'],
  'apple-cider-vinegar-for-chickens': ['Commercial', 'Backyard'],
}

// Latest poultry blog posts — exclude placeholder images
const placeholderImg = 'DSC_0137_dco2wk'
const poultryPosts = (
  await getCollection('blog', ({ data }) => data.draft !== true && data.segment === 'poultry')
)
  .filter((p) => p.data.featuredImage && !p.data.featuredImage.includes(placeholderImg))
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3)

const title = 'Poultry Supplements & Probiotics | Southland Organics'
const description =
  'Poultry supplements and chicken probiotics built for real farms. Gut health, litter treatment, biosecurity. USDA Organic. Zero withdrawal. Ships same day.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Poultry Supplements & Probiotics',
  description: description,
  url: 'https://southlandorganics.com/poultry/',
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
    url: 'https://southlandorganics.com',
    foundingDate: '2009',
  },
}

const stats = [
  { number: '2009', label: 'Making poultry supplements in Georgia', source: '' },
  {
    number: '1,000+',
    label: 'Farms helped since day one',
    source: '',
  },
  { number: '0', label: 'Days withdrawal on every product we sell', source: '' },
  { number: '500+', label: 'Commercial farms running our program', source: '' },
]
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 1: HERO
       Background: CloudinaryHero (exterior poultry house photo)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/poultry/poultry_house_w1zen3_iecnpo"
    alt="Commercial poultry houses under open sky — Southland Organics serves broiler, turkey, game bird, and backyard operations"
    overlay="gradient"
    overlayOpacity={88}
    priority={true}
  >
    <div class="mx-auto max-w-6xl px-4 py-14 text-center md:py-20">
      <span
        class="mb-5 inline-block rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-green-200"
      >
        Helped 1,000+ farms since 2009
      </span>

      <h1 class="mb-5 font-heading text-3xl uppercase text-white md:text-4xl lg:text-5xl">
        Poultry supplements that actually move your numbers.
      </h1>

      <p class="mx-auto mb-7 max-w-2xl text-base leading-relaxed text-green-100 md:text-lg">
        Southland Organics manufactures poultry probiotics, poultry litter treatment products, and
        gut health supplements to help your birds stay healthy and grow. Our beneficial bacteria
        supports feed conversion and helps fight mortality &mdash; proven results, proven time and
        again. Zero withdrawal on every product.
      </p>

      <div
        class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs font-medium uppercase tracking-wider text-green-200/80"
      >
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          WSDA Approved
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          OMRI Listed
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          Zero Withdrawal
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
              clip-rule="evenodd"></path>
          </svg>
          1,000+ Farms Helped
        </span>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 2: FOUR PATHS (The Fork)
       Background: white
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="mb-3 text-center font-heading text-3xl uppercase md:text-4xl"
        style="color: #2C5234;"
      >
        What does your farm operation look like?
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-base leading-relaxed text-gray-500">
        The gut biology is the same across all poultry. The dosing, the timing, and the problems are
        not. Choose your operation and we'll guide you to the poultry supplements that fit your
        needs.
      </p>

      <!-- Primary cards: Commercial + Backyard (full-size, mini-hero treatment) -->
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Card A: Commercial Broilers -->
        <div
          class="overflow-hidden rounded-xl border border-[#2C5234]/15 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/30 hover:shadow-md"
        >
          <img
            src="https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_600,h_220,g_auto,f_auto,q_auto/v1772456410/Southland%20Website/poultry/Poultry_house_e515fc_jxbulv"
            alt="Commercial poultry houses"
            class="h-36 w-full object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="mb-2 text-xl font-bold" style="color: #2C5234;">Commercial Broilers</h3>

            <p class="mb-4 text-sm font-medium text-gray-700">
              Lower mortality. Tighter FCR. Settlements that make the math work.
            </p>

            <p class="mb-5 text-sm leading-relaxed text-gray-600">
              You are running commercial broiler houses and your integrator measures every little
              bit that counts toward your feed conversion ratio. A bad grow-out doesn't just cost
              birds &mdash; it really costs you on your settlement check. Our products are designed
              with you in mind, helping you alleviate stress and keep more money in your pocket.
            </p>

            <div
              class="bg-[#2C5234]/8 mb-6 inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-medium text-[#2C5234]"
            >
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              Case studies show results like 6.2% mortality reduction &mdash; UGA validated
            </div>

            <div>
              <a
                href="/poultry/commercial/"
                class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:opacity-90"
                style="background: #44883E;"
              >
                Commercial Poultry Program
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <p class="mt-4 text-xs text-gray-400">
              Allen Reynolds has walked hundreds of poultry houses. He'll walk yours too.
            </p>
          </div>
        </div>

        <!-- Card B: Backyard -->
        <div
          class="overflow-hidden rounded-xl border border-[#44883E]/15 bg-[#F8FAF8] transition-all hover:border-[#44883E]/30 hover:shadow-md"
        >
          <img
            src="https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_600,h_220,g_auto,f_auto,q_auto/v1772720860/Southland%20Website/poultry/backyard/Backyard_poultry_products"
            alt="Backyard chickens in a flock"
            class="h-36 w-full object-cover"
            loading="lazy"
          />
          <div class="p-6">
            <h3 class="mb-2 text-xl font-bold" style="color: #2C5234;">Backyard Flocks</h3>

            <p class="mb-4 text-sm font-medium text-gray-700">
              Stronger birds. More eggs. One simple routine.
            </p>

            <p class="mb-5 text-sm leading-relaxed text-gray-600">
              You've got a wonderful little flock that you love, and you want to care for them
              deeply. But you didn't sign up for a chemistry degree. Our chicken supplements use the
              same beneficial bacteria that commercial operations depend on &mdash; just sized for
              your backyard coop. Healthy gut flora means healthier, happier birds.
            </p>

            <div
              class="bg-[#44883E]/8 mb-6 inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-medium text-[#44883E]"
            >
              <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"></path>
              </svg>
              Same probiotics used on millions of commercial birds &mdash; dosed for your flock
            </div>

            <div>
              <a
                href="/poultry/backyard/"
                class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:opacity-90"
                style="background: #44883E;"
              >
                Shop the Backyard Line
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"></path>
                </svg>
              </a>
            </div>

            <p class="mt-4 text-xs text-gray-400">Most keepers start with the Backyard Bundle.</p>
          </div>
        </div>
      </div>

      <!-- Secondary cards: Breeders, Turkey, Game Birds (upgraded with outcome lines + CTA buttons) -->
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <!-- Card C: Breeders -->
        <div
          class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/25 hover:shadow-md"
        >
          <img
            src="https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_400,h_160,g_auto,f_auto,q_auto/v1772721454/Southland%20Website/poultry/breeders-layers/Breeders_Header"
            alt="Breeder flock"
            class="h-28 w-full object-cover"
            loading="lazy"
          />
          <div class="p-5">
            <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Breeders</h3>
            <p class="mb-3 text-sm text-gray-700">
              As a poultry breeder, egg quality means everything.
            </p>
            <p class="mb-4 text-xs leading-relaxed text-gray-500">
              We focus on poultry biosecurity and gut health supplements to make your breeder
              operation stand out and become more profitable. Stronger beneficial bacteria helps you
              gain optimal production.
            </p>
            <a
              href="/poultry/breeders/"
              class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
              style="border-color: #2C5234; color: #2C5234;"
            >
              Breeder Solutions
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Card D: Turkey -->
        <div
          class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/25 hover:shadow-md"
        >
          <img
            src="https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_400,h_140,g_auto,f_auto,q_auto/Southland Website/poultry/turkey/Turkey_Header"
            alt="Turkey flock"
            class="h-28 w-full object-cover"
            loading="lazy"
          />
          <div class="p-5">
            <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Turkey</h3>
            <p class="mb-3 text-sm text-gray-700">16 weeks of grow-out. No room for a bad week.</p>
            <p class="mb-4 text-xs leading-relaxed text-gray-500">
              As a turkey operator you want bigger, heavier, healthier birds. You need better
              tolerance for ammonia, heat stress, and disease suppression. Our poultry supplements
              are geared for your turkey operation.
            </p>
            <a
              href="/poultry/turkey/"
              class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
              style="border-color: #2C5234; color: #2C5234;"
            >
              Turkey Solutions
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Card E: Game Birds -->
        <div
          class="overflow-hidden rounded-xl border border-[#2C5234]/10 bg-[#F8FAF8] transition-all hover:border-[#2C5234]/25 hover:shadow-md"
        >
          <img
            src="https://res.cloudinary.com/southland-organics/image/upload/c_fill,w_400,h_140,g_auto,f_auto,q_auto/Southland Website/poultry/game-birds/Quail_Header"
            alt="Quail game birds"
            class="h-28 w-full object-cover"
            loading="lazy"
          />
          <div class="p-5">
            <h3 class="mb-1 text-base font-bold" style="color: #2C5234;">Game Birds</h3>
            <p class="mb-3 text-sm text-gray-700">Quail, pheasant &mdash; same gut biology.</p>
            <p class="mb-4 text-xs leading-relaxed text-gray-500">
              Game bird operations run tighter margins and have more sensitive birds. Our probiotics
              and vitamins that work on broilers work here as well. Just ask Tuck Farms in Alabama.
            </p>
            <a
              href="/poultry/game-birds/"
              class="inline-flex items-center gap-1.5 rounded-md border-2 px-4 py-2 text-xs font-semibold transition-colors hover:bg-[#2C5234] hover:text-white"
              style="border-color: #2C5234; color: #2C5234;"
            >
              Game Bird Solutions
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 3: PRODUCT GRID
       Background: cream (#F8FAF8)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section id="products" class="border-t border-gray-100 bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="mb-3 text-center font-heading text-3xl uppercase md:text-4xl"
        style="color: #2C5234;"
      >
        Poultry supplements &amp; chicken probiotics
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-base leading-relaxed text-gray-500">
        Probiotics for poultry gut health, litter amendments that knock down ammonia fast, and
        poultry vitamins that fill the gap antibiotics used to cover. Our products work across all
        bird types &mdash; the difference is dosing. Not sure where to start? Pick your operation
        above.
      </p>
      <p class="mx-auto mb-12 max-w-2xl text-center text-sm text-gray-400">
        USDA Organic certified. OMRI Listed. Zero withdrawal period. Ships same day.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {
          products.map((product) => (
            <a
              href={`/products/${product.handle}/`}
              class="group flex flex-col rounded-xl border border-gray-200 bg-white p-4 transition-all hover:border-[#44883E]/30 hover:shadow-md"
            >
              {product.images?.[0] && (
                <div class="relative mb-4 aspect-square overflow-hidden rounded-lg bg-gray-50">
                  <img
                    src={product.images[0].url}
                    alt={product.images[0].altText || product.title}
                    width="300"
                    height="300"
                    class="h-full w-full object-contain transition-transform group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col">
                <h3 class="mb-1 text-sm font-bold text-gray-900 group-hover:text-[#2C5234]">
                  {product.title.includes('|') ? product.title.split('|')[0].trim() : product.title}
                </h3>
                {productSegments[product.handle] && (
                  <div class="mb-2 flex flex-wrap gap-1">
                    {productSegments[product.handle].map((seg) => (
                      <span class="bg-[#2C5234]/8 rounded-full px-2 py-0.5 text-[10px] font-medium text-[#2C5234]">
                        {seg}
                      </span>
                    ))}
                  </div>
                )}
                <p class="mb-3 flex-1 text-xs leading-relaxed text-gray-500">
                  {product.description?.slice(0, 100)}
                  {product.description && product.description.length > 100 ? '…' : ''}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-sm font-semibold" style="color: #2C5234;">
                    From {formatPrice(product.priceRange.minVariantPrice.amount)}
                  </span>
                  <span class="text-xs font-semibold text-[#44883E] group-hover:underline">
                    View &rarr;
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 4: PROOF BAND (renumbered from 3)
       Background: #2C5234 (dark green)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="py-12 md:py-16" style="background: #2C5234;">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-10 text-center font-heading text-3xl uppercase text-white md:text-4xl">
        Numbers, not promises
      </h2>

      <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="text-center">
              <div class="mb-1 text-3xl font-bold text-green-300 md:text-4xl">{stat.number}</div>
              <div class="text-sm leading-snug text-white">{stat.label}</div>
              {stat.source && <div class="mt-1 text-xs text-green-200/60">{stat.source}</div>}
            </div>
          ))
        }
      </div>

      <div class="mt-8 text-center text-xs text-green-200/50">
        UGA Study, C. Stephen Roney DVM &middot; USDA Organic Certified &middot; OMRI Listed
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SECTION 5: LATEST POULTRY INSIGHTS
       Background: white
       ═══════════════════════════════════════════════════════════════════════ -->
  {
    poultryPosts.length > 0 && (
      <section class="bg-white py-16 md:py-20">
        <div class="mx-auto max-w-6xl px-4">
          <div class="mb-10 flex items-end justify-between">
            <div>
              <h2 class="font-heading text-2xl uppercase md:text-3xl" style="color: #2C5234;">
                From the field
              </h2>
              <p class="mt-2 max-w-lg text-sm text-gray-500">
                We have poultry health guides covering ammonia control research, biosecurity
                walkthroughs, and real grower stories. These articles are written by people who've
                been in the houses.
              </p>
            </div>
            <a
              href="/blog/?tag=Poultry"
              class="hidden items-center gap-1.5 text-sm font-semibold text-[#44883E] transition-colors hover:text-[#2C5234] md:inline-flex"
            >
              All poultry articles
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>
          <div class="grid gap-6 md:grid-cols-3">
            {poultryPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                slug={post.id.replace(/\.mdx?$/, '')}
                description={post.data.description}
                publishDate={post.data.publishDate}
                featuredImage={post.data.featuredImage}
                segment={post.data.segment}
              />
            ))}
          </div>
          <div class="mt-8 text-center md:hidden">
            <a
              href="/blog/?tag=Poultry"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#44883E]"
            >
              All poultry articles
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>
        </div>
      </section>
    )
  }

