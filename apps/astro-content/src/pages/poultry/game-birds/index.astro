---
/**
 * /poultry/game-birds/ — Game Bird Operations Landing Page
 *
 * StoryBrand framework: Hero → Problem → Guide → JTBD → Shop Grid → Proof → Plan → Objections → CTA
 *
 * Same products as broilers, copy tailored for quail/pheasant/chukar operators.
 * Persona: commercial (same as Broiler Bill — these are production operations).
 * Canonical destination for /collections/game-birds (301 redirect).
 */
import {
  createClient,
  getProductByHandle,
  getCollectionProducts,
} from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../../components/CloudinaryHero.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import { buildSouthlandUrl } from '../../../lib/cloudinary'

// ── Allen Reynolds photo ────────────────────────────────────────────────────
const allenPhoto = buildSouthlandUrl('team/ALLEN_Reynolds', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

const title = 'Game Bird Supplements | Southland Organics'
const description =
  'Natural probiotics, litter treatments & vitamins for game bird operations. USDA Organic, zero withdrawal. Trusted by Tuck Farms.'

// OG image from hero
const ogImage = buildSouthlandUrl('Southland Website/poultry/game-birds/Quail_Header', {
  width: 1200,
  height: 630,
  crop: 'fill',
  gravity: 'south',
  quality: 'auto',
  format: 'auto',
})

// ── Fetch products ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const handles = [
  'poultry-probiotic', // Big Ole Bird
  'hen-helper',
  'poultry-litter-amendment', // Litter Life
  'catalyst-poultry-vitamin', // Catalyst
  'natural-mite-control-livestock-poultry', // Desecticide
] as const

const products = await Promise.all(handles.map((h) => getProductByHandle(client, h)))
const productMap = new Map(products.filter(Boolean).map((p) => [p!.handle, p!]))

// Fetch ALL products in the game-birds collection for the shop grid
const gameBirdCollection = await getCollectionProducts(client, 'game-birds')
// Filter out non-game-bird products that ops mis-assigned to this collection
const EXCLUDED_HANDLES = new Set([
  'apple-cider-vinegar-for-pigs',
  'torched-all-natural-weed-killer',
])
const allGameBirdProducts: Product[] = (gameBirdCollection?.products ?? []).filter(
  (p) => !EXCLUDED_HANDLES.has(p.handle)
)

function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── JTBD data ───────────────────────────────────────────────────────────────
const jobs = [
  {
    title: 'Keep mortality low from hatch to release.',
    struggle:
      "Ulcerative enteritis can wipe a pen in 48 hours. Respiratory issues hit young chicks before you see signs. In flight pens and large ranges, you can't catch problems bird by bird — you need biology working before disease gets a foothold.",
    products: [getProduct('poultry-probiotic'), getProduct('hen-helper')].filter(Boolean),
    proof: 'Used on 1.4M+ quail chicks/year at Tuck Farms',
    proofSource: "World's largest bobwhite quail hatchery",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  },
  {
    title: 'Control ammonia in flight pens and brood houses.',
    struggle:
      "Game bird houses run tight and flight pens hold litter longer. Ammonia builds fast, disinfectants nuke beneficial biology along with the bad, and you're back to square one every cleanout.",
    products: [
      getProduct('poultry-litter-amendment'),
      getProduct('natural-mite-control-livestock-poultry'),
    ].filter(Boolean),
    proof: 'Biological ammonia reduction within 48 hours',
    proofSource: 'Grower field reports',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: 'Survive moves, shipment, and high-stress events.',
    struggle:
      "Pen moves, transport to preserves, weather swings, and housing transitions — game birds are more stress-sensitive than broilers. By the time you see symptoms, you've already lost days and birds.",
    products: [getProduct('catalyst-poultry-vitamin'), getProduct('poultry-probiotic')].filter(
      Boolean
    ),
    proof: 'Targeted nutrition during stress reduces immune suppression',
    proofSource: 'Southland Organics product research',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
]

// ── Objections (FAQ) ────────────────────────────────────────────────────────
const objections = [
  {
    question: 'These products are made for chickens. Do they work on quail and pheasant?',
    answer:
      "Yes. The biology is the same — Bacillus-based probiotics colonize avian gut lining regardless of species. Big Ole Bird was developed for poultry gut health broadly, not just broilers. Game bird operations including Tuck Farms (the world's largest bobwhite quail hatchery) use our products on quail and pheasant. The dosing scales down naturally for smaller birds.",
  },
  {
    question:
      "I can't be in the house constantly — will these products work with minimal interaction?",
    answer:
      "That's actually the point. Game bird operations need preventive systems that work without daily intervention. Big Ole Bird goes in the water line — dose it at water change and the probiotics do the work. Litter Life treats the litter biology once and keeps working between visits. These are set-and-forget systems designed for operations where less human contact means better birds.",
  },
  {
    question: 'My operation is smaller than a commercial broiler farm. Is this cost-effective?',
    answer:
      'Big Ole Bird costs roughly $0.02-0.05 per bird. Even on a small game bird operation, the math works if it prevents one disease event per grow-out cycle. Tuck Farms runs 1.4 million chicks a year and uses our products because the ROI scales — but it works at any size. Start with one barn, one cycle.',
  },
  {
    question: "Will this affect the birds' flight ability or wildness?",
    answer:
      'No. These are probiotics, vitamins, and litter biology — not drugs or hormones. They support gut health and immune function. They have zero effect on behavior, flight instinct, or wildness. USDA Organic certified, zero withdrawal, zero residue.',
  },
  {
    question: "What about ulcerative enteritis? That's our biggest killer.",
    answer:
      "UE is a gut-flora problem — Clostridium colinum exploits weak or disrupted gut biology. Big Ole Bird works by establishing strong Bacillus colonies that compete against Clostridium and other pathogens for gut real estate. It's not a treatment for active UE, but preventive probiotic support from day one is your best defense against it taking hold. As John Tuck says: be prepared and stay in front of it.",
  },
]

// ── Schema.org ──────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Game Bird Supplements',
  description,
  url: `${siteUrl}/poultry/game-birds/`,
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: objections.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  schema={[pageSchema, faqSchema]}
>
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO                                                       -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/poultry/game-birds/Quail_Header"
    alt="Bobwhite quail in flight pens — game bird operation"
    height={600}
    minHeight="500px"
    overlay="gradient"
    overlayOpacity={85}
    contentAlign="center"
    contentJustify="start"
    priority={true}
    gravity="south"
  >
    <div class="mx-auto w-full max-w-6xl pb-12 pt-12 md:pt-20">
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span
            class="inline-block rounded-full bg-white/15 px-4 py-1 text-sm font-medium text-green-300"
          >
            For Game Bird Operations
          </span>
          <span
            class="inline-block rounded-full bg-green-400/20 px-3 py-1 text-sm font-semibold text-green-300"
          >
            USDA Organic · Zero Withdrawal · Zero Residue
          </span>
        </div>
        <h1
          class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl lg:text-6xl"
        >
          Your birds can't tell you what's wrong. Your biology can.
        </h1>
        <p class="mb-5 text-lg text-white/70 md:text-xl">
          Game birds are sensitive, fast-growing, and unforgiving when something goes wrong.
          Preventive gut health and litter biology are cheaper than treating your way out of a
          crisis.
        </p>
        <!-- Three levers -->
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-2">
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Gut Health
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Litter Biology
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Stress Support
          </span>
        </div>
        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3.5 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            Talk to Allen
          </a>
          <a
            href="#game-bird-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            Shop Game Bird Products
          </a>
          <a
            href="#proof"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/5"
          >
            See the Proof
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </a>
        </div>
        <p class="mt-2 text-sm text-white/50">
          No sales script — just a conversation about your operation
        </p>
        <!-- Trust bar -->
        <div
          class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/80"
        >
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path>
            </svg>
            USDA Organic
          </span>
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path>
            </svg>
            Zero Withdrawal
          </span>
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path>
            </svg>
            Trusted by Tuck Farms
          </span>
        </div>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM                                                    -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-3xl uppercase text-shopify-title md:text-4xl">
        Game birds don't give you second chances.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        Quail, pheasant, and chukar are faster, more sensitive, and less forgiving than broilers.
        Three problems define game bird production.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="hex-icon mb-4 bg-[#2C5234]/10">
            <svg
              class="h-6 w-6 text-[#2C5234]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-shopify-title">
            Disease moves faster than you can
          </h3>
          <p class="leading-relaxed text-gray-600">
            Ulcerative enteritis, respiratory issues in young chicks, coccidiosis — by the time you
            see symptoms, you've already lost birds. Game bird production demands prevention, not
            reaction.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="hex-icon mb-4 bg-[#44883E]/10">
            <svg
              class="h-6 w-6 text-[#44883E]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-shopify-title">
            You can't be in the house every day
          </h3>
          <p class="leading-relaxed text-gray-600">
            Game birds need minimal human interaction — imprinting kills flight instinct and market
            value. You need systems that work without constant presence. Walk in twice a week, not
            twice a day.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="hex-icon mb-4 bg-[#2C5234]/10">
            <svg
              class="h-6 w-6 text-[#2C5234]"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-shopify-title">
            Disinfectants are making it worse
          </h3>
          <p class="leading-relaxed text-gray-600">
            Nuking everything — good bacteria and bad — just creates a vacuum for pathogens to fill.
            Game bird houses need biological balance, not chemical scorched earth.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: GUIDE — Allen + Tuck Farms                                -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
        <div class="order-2 md:order-1">
          <span
            class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-[#44883E]"
          >
            Your guide
          </span>
          <h2 class="mb-6 font-heading text-3xl uppercase text-shopify-title md:text-4xl">
            We've worked with the biggest names in game birds.
          </h2>
          <p class="mb-4 text-lg leading-relaxed text-gray-700">
            Allen Reynolds has spent 10+ years inside poultry houses — commercial broilers, turkeys,
            and game bird operations. When John Tuck at Tuck Farms needed a probiotic system that
            worked for quail, he called us.
          </p>
          <p class="mb-4 text-lg leading-relaxed text-gray-600">
            Game birds aren't just small chickens. They have different gut biology, different stress
            responses, and different management constraints. We understand the differences because
            we've been in the barns.
          </p>
          <!-- Scope proof -->
          <div class="mb-6 rounded-lg border border-green-200 bg-green-50 px-5 py-3">
            <p class="text-sm font-semibold text-[#2C5234]">
              Used across 1.4 million+ quail chicks per year at Tuck Farms — the world's largest
              bobwhite quail hatchery — plus pheasant and chukar operations nationwide.
            </p>
          </div>
          <p class="mb-8 leading-relaxed text-gray-600">
            Every product is USDA Organic certified with zero withdrawal period. Same biology that
            works on millions of commercial broilers, adapted for game bird operations.
          </p>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            {
              [
                '10+ years on farms',
                'Trusted by Tuck Farms',
                'USDA Organic Certified',
                'Zero Withdrawal',
                'Family-owned since 2009',
              ].map((cred) => (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4"
                    />
                  </svg>
                  {cred}
                </span>
              ))
            }
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[#44883E]/85"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              Call Allen
            </a>
            <a
              href="mailto:allen@southlandorganics.com"
              class="text-sm font-medium text-[#44883E] underline decoration-[#44883E]/40 underline-offset-2 hover:text-[#2C5234]"
            >
              allen@southlandorganics.com
            </a>
          </div>
        </div>

        <!-- Allen's photo -->
        <div class="order-1 md:order-2">
          <div class="relative mx-auto w-64 md:w-72 lg:w-80">
            <img
              src={allenPhoto}
              alt="Allen Reynolds, VP & Director of Operations at Southland Organics — 10+ years helping poultry and game bird growers"
              width="600"
              height="750"
              class="aspect-[4/5] rounded-2xl object-cover shadow-lg"
              loading="lazy"
            />
            <!-- Name badge overlay -->
            <div
              class="absolute bottom-0 left-0 right-0 rounded-b-2xl bg-gradient-to-t from-black/70 to-transparent px-5 pb-4 pt-10"
            >
              <p class="text-lg font-bold text-white">Allen Reynolds</p>
              <p class="text-sm text-green-300">VP & Director of Operations</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: JTBD GRID                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section id="jobs" class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-4xl uppercase text-shopify-title md:text-5xl">
        Three jobs. Real solutions.
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-gray-600">
        Same biology proven on millions of commercial birds. Adapted for quail, pheasant, and chukar
        operations.
      </p>
      <p class="mb-12 text-center">
        <a
          href="#game-bird-products"
          class="inline-flex items-center gap-1 text-sm font-medium text-[#44883E] hover:text-[#2C5234] hover:underline"
        >
          Skip to all game bird products
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        {
          jobs.map((job) => (
            <div class="flex flex-col rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
