---
/**
 * /poultry/turkey/ — Turkey Grower StoryBrand Landing Page
 *
 * StoryBrand framework: Hero (turkey grower) → Problem (longer grow-out risk)
 * → Guide (Allen/Southland) → JTBD (3 jobs with real products) → Shop Grid
 * → Proof → Plan → Objections → CTA
 *
 * Products fetched dynamically from Shopify Storefront API.
 * Same product lineup as broilers — different copy, different stress points.
 */
import { createClient, getProductByHandle, getCollectionProducts } from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../../components/CloudinaryHero.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import { buildSouthlandUrl } from '../../../lib/cloudinary'

// ── Allen Reynolds photo ────────────────────────────────────────────────────
const turkeyIcon = buildSouthlandUrl('poultry/turkey/Turkey_icon', {
  width: 40,
  height: 40,
  crop: 'fit',
  quality: 'auto',
  format: 'auto',
})

const allenPhoto = buildSouthlandUrl('team/ALLEN_Reynolds', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

const title = 'Turkey Production Solutions | Southland Organics'
const description =
  'Natural probiotics, litter treatments, and vitamins for commercial turkey growers. USDA Organic, zero withdrawal. Heavier birds, better conversion, cleaner houses.'

// ── Fetch products ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

// Fetch JTBD-featured products individually (need full detail)
const jtbdHandles = [
  'poultry-probiotic',           // Big Ole Bird
  'hen-helper',
  'poultry-litter-amendment',    // Litter Life
  'natural-mite-control-livestock-poultry', // Desecticide
  'catalyst-poultry-vitamin',
] as const

const jtbdProducts = await Promise.all(
  jtbdHandles.map((h) => getProductByHandle(client, h))
)
const productMap = new Map(
  jtbdProducts.filter(Boolean).map((p) => [p!.handle, p!])
)

// Fetch ALL products in the turkey collection for the shop grid
const turkeyCollection = await getCollectionProducts(client, 'turkey')

// Filter out non-poultry products that ops mis-assigned to this collection
const EXCLUDED_HANDLES = new Set([
  'apple-cider-vinegar-for-pigs',
  'torched-all-natural-weed-killer',
])
const allTurkeyProducts: Product[] = (turkeyCollection?.products ?? []).filter(
  (p) => !EXCLUDED_HANDLES.has(p.handle)
)

/** Helper: get product or null */
function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

/** Helper: format price from Shopify Money */
function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── JTBD data ───────────────────────────────────────────────────────────────
const jobs = [
  {
    title: 'Keep poults alive and standing through week 16.',
    struggle:
      'Turkey poults are fragile — and the ones that survive still need to carry 40+ lbs on two legs. Bad gut health in week 2 becomes leg problems in week 14. Every week of poor conversion compounds.',
    bestFor: 'Early mortality, inconsistent conversion, or leg issues in finishing',
    products: [getProduct('poultry-probiotic'), getProduct('hen-helper')].filter(Boolean),
    proof: '6.2% mortality reduction in poultry',
    proofSource: 'UGA Study, C. Stephen Roney DVM',
    recommended: true,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  },
  {
    title: 'Keep litter working for 16 weeks, not 6.',
    struggle:
      'Broiler litter gets 42 days of abuse. Turkey litter gets 4 months. By week 10, ammonia is compounding, paw quality is dropping, and beetle pressure is out of control — all while birds are at their heaviest.',
    bestFor: 'Ammonia buildup, paw downgrades, reused litter, or beetle pressure late in grow-out',
    products: [getProduct('poultry-litter-amendment'), getProduct('natural-mite-control-livestock-poultry')].filter(Boolean),
    proof: 'Ammonia reduction within 48 hours',
    proofSource: 'Grower field reports',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: "Hit target weight before Thanksgiving — no second chance.",
    struggle:
      "Turkey flocks run into holidays. A summer heat event in week 8 or a vaccine reaction in week 12 doesn't just cost you a few points — it can mean missing your window entirely. There's no next flock to make it up.",
    bestFor: 'Summer heat stress, vaccine weeks, or finishing-phase weight targets',
    products: [getProduct('catalyst-poultry-vitamin'), getProduct('poultry-probiotic')].filter(Boolean),
    proof: '7-point FCR improvement, +0.4 lb in 38 days',
    proofSource: 'UGA Study, 2018',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
]

// ── Objections (FAQ) ────────────────────────────────────────────────────────
const objections = [
  {
    question: "These products say 'poultry' — do they actually work on turkeys?",
    answer:
      "Yes. Big Ole Bird, Litter Life, Catalyst, and Desecticide are formulated for all commercial poultry, not just chickens. The gut biology, litter chemistry, and stress physiology are the same across species. Turkey growers have been using these products for years — the UGA study was conducted on broilers, but the mechanisms apply directly to turkey production.",
  },
  {
    question: "Turkey grow-outs are longer. Do I need to dose differently?",
    answer:
      "Dosing schedules may differ slightly for turkeys because of the longer grow-out cycle. Allen can walk you through the recommended protocol for your operation — how many houses, what stage of production, what problems you're seeing. Call and we'll build a program that fits your cycle, not a one-size-fits-all sheet.",
  },
  {
    question: "My integrator might not approve this.",
    answer:
      "Everything we sell is USDA Organic certified with zero withdrawal period and zero residue. There's nothing in our products that would cause a compliance issue at the plant. Turkey growers under major integrators use Big Ole Bird and Litter Life every flock. We're happy to provide documentation for your field tech.",
  },
  {
    question: "I can't afford to experiment on a 16-week grow-out.",
    answer:
      "We understand — the stakes are higher with turkeys because the grow-out is longer and the per-bird investment is bigger. That's exactly why we say: test on one house, one flock. Big Ole Bird costs pennies per bird. If it doesn't move your numbers, don't reorder. The math works or it doesn't.",
  },
  {
    question: "How is this different from what I'm already doing?",
    answer:
      "Most turkey growers are running some kind of vitamin or acidifier program. The difference is targeted probiotics — not generic supplements. Big Ole Bird was developed specifically for poultry gut biology and validated in peer-reviewed research. If your current program is working, keep it. If your numbers have plateaued, one product on one house will tell you whether this is the missing piece.",
  },
]

// ── Schema.org ──────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Turkey Production Solutions',
  description,
  url: `${siteUrl}/poultry/turkey/`,
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: objections.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}
---

<BaseLayout title={title} description={description} schema={[pageSchema, faqSchema]}>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — "Your turkeys grow for months, not weeks"           -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/poultry/turkey/Turkey_Header"
    alt="Commercial turkey house — healthy turkeys in production environment"
    height={600}
    minHeight="500px"
    overlay="gradient"
    overlayOpacity={85}
    contentAlign="center"
    contentJustify="start"
    priority={true}
  >
    <div class="mx-auto w-full max-w-6xl pb-12 pt-12 md:pt-20">
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1 text-sm font-medium text-green-300">
            <img src={turkeyIcon} alt="" width="20" height="20" class="h-5 w-5" />
            For Turkey Growers
          </span>
          <span class="inline-block rounded-full bg-green-400/20 px-3 py-1 text-sm font-semibold text-green-300">
            USDA Organic &bull; Zero Withdrawal
          </span>
        </div>
        <h1 class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl lg:text-6xl">
          Your turkeys grow for months, not weeks. Every week matters.
        </h1>
        <p class="mb-5 text-lg text-white/70 md:text-xl">
          Longer grow-outs mean more time for things to go wrong — and more time for the right tools to compound results.
        </p>
        <!-- Three levers — scannable -->
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-2">
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Gut Health
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Litter Quality
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Stress Management
          </span>
        </div>
        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3.5 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Talk to Allen
          </a>
          <a
            href="#turkey-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Shop Turkey Products
          </a>
          <a
            href="#proof"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/5"
          >
            See the Proof
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
        <p class="mt-2 text-sm text-white/50">Allen knows turkey production — call and talk specifics</p>
        <!-- Trust bar -->
        <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/80">
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            USDA Organic
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Zero Withdrawal
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Integrator-Friendly
          </span>
        </div>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM — "Turkey production is a longer bet"              -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
        Turkey production is a longer bet.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        14 to 20 weeks of grow-out. Every problem has more time to compound — and more money riding on the outcome.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#2C5234]/10">
            <svg class="h-6 w-6 text-[#2C5234]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">The longer timeline</h3>
          <p class="leading-relaxed text-gray-600">
            Broiler growers have 6 weeks to get it right. You have 14-20. That means more exposure to heat, disease, and ammonia — with a bigger per-bird investment on the line.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#44883E]/10">
            <svg class="h-6 w-6 text-[#44883E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">The compounding worry</h3>
          <p class="leading-relaxed text-gray-600">
            Week 4 looks fine. Week 8 looks fine. But by week 12 you're watching the numbers and wondering if this flock is going to finish where it needs to — or fall short.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#2C5234]/10">
            <svg class="h-6 w-6 text-[#2C5234]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What's not right about it</h3>
          <p class="leading-relaxed text-gray-600">
            You're putting in the work and the hours. A grower who manages birds for 4-5 months at a time deserves tools that match the scale of that commitment.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: GUIDE — "We've been in the houses"                         -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
        <div class="order-2 md:order-1">
          <span class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-green-700">
            Your guide
          </span>
          <h2 class="mb-6 font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
            Same products. Turkey-specific guidance.
          </h2>
          <p class="mb-4 text-lg leading-relaxed text-gray-700">
            Allen Reynolds works with turkey growers the same way he works with broiler growers — by understanding your specific operation, your integrator's expectations, and what's actually happening in your houses.
          </p>
          <p class="mb-4 text-lg leading-relaxed text-gray-600">
            The products are the same ones commercial broiler growers use. The difference is the dosing schedule and timing. Turkey grow-outs have different critical windows, and Allen will help you build a program that matches your cycle.
          </p>
          <p class="mb-8 leading-relaxed text-gray-600">
            Since 2014, he's traveled thousands of miles visiting poultry farms, troubleshooting problems, and helping growers find solutions that hold up in the house.
          </p>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              10+ years on farms
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Turkey + broiler experience
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              ABF specialist since 2017
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Actually answers the phone
            </span>
          </div>

          <!-- Quick contact -->
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[#44883E]/85"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Allen
            </a>
            <a
              href="mailto:allen@southlandorganics.com"
              class="text-sm font-medium text-green-700 underline decoration-green-300 underline-offset-2 hover:text-green-600"
            >
              allen@southlandorganics.com
            </a>
          </div>
        </div>

        <!-- Allen's photo -->
        <div class="order-1 md:order-2">
          <div class="relative mx-auto w-64 md:w-72 lg:w-80">
            <img
              src={allenPhoto}
              alt="Allen Reynolds, VP & Director of Operations at Southland Organics"
              width="600"
              height="750"
              class="rounded-2xl object-cover shadow-lg"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 right-0 rounded-b-2xl bg-gradient-to-t from-black/70 to-transparent px-5 pb-4 pt-10">
              <p class="text-lg font-bold text-white">Allen Reynolds</p>
              <p class="text-sm text-green-300">VP & Director of Operations</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: JTBD GRID — "Three jobs. Real solutions."                  -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-4xl uppercase md:text-5xl" style="color: var(--color-title);">
        Three jobs. Real solutions.
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-gray-600">
        Every product here exists to do one of three jobs in your turkey houses. Pick the job you need help with — we'll show you the right tools.
      </p>
      <p class="mb-12 text-center">
        <a href="#turkey-products" class="inline-flex items-center gap-1 text-sm font-medium text-green-700 hover:text-green-600 hover:underline">
          Skip to all turkey products
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        {jobs.map((job) => (
          <div class:list={[
            'relative flex flex-col rounded-xl border bg-white p-8 shadow-sm',
            job.recommended ? 'border-green-300 ring-1 ring-green-200' : 'border-gray-200',
          ]}>
            {job.recommended && (
              <span class="absolute -top-3 left-6 rounded-full bg-[#44883E] px-3 py-0.5 text-xs font-bold uppercase tracking-wide text-white">
                Recommended starting point
              </span>
            )}

            <!-- Job icon -->
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-green-100">
              <svg class="h-6 w-6 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={job.icon} />
              </svg>
            </div>

            <!-- Job title + struggle -->
            <h3 class="mb-2 text-xl font-bold" style="color: var(--color-title);">
              {job.title}
            </h3>
            <p class="mb-3 text-sm text-gray-600">{job.struggle}</p>

            <!-- Best for -->
            <p class="mb-6 text-xs font-medium uppercase tracking-wide text-green-700">
              Best for: {job.bestFor}
            </p>

            <!-- Products -->
            <div class="mb-6 flex-1 space-y-4">
              {job.products.map((product) => (
                <a
                  href={`/products/${product!.handle}/`}
                  class="flex items-center gap-3 rounded-lg border border-gray-100 bg-gray-50 p-3 transition-colors hover:border-green-200 hover:bg-green-50"
                >
                  {product!.images?.[0] && (
                    <img
                      src={product!.images[0].url}
                      alt={product!.images[0].altText || product!.title}
                      width="56"
                      height="56"
                      class="h-14 w-14 rounded-md object-cover"
                      loading="lazy"
                    />
                  )}
                  <div class="min-w-0 flex-1">
                    <div class="truncate text-sm font-semibold text-gray-900">
                      {product!.title.includes('|') ? product!.title.split('|')[0].trim() : product!.title}
                    </div>
                    <div class="text-sm text-green-700">
                      From {formatPrice(product!.priceRange.minVariantPrice.amount)}
                    </div>
                  </div>
                  <svg class="h-4 w-4 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>

            <!-- Proof line -->
            <div class="border-t border-gray-100 pt-4">
              <div class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
