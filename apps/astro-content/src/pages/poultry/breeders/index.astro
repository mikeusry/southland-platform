---
/**
 * /poultry/breeders/ — Poultry Breeder StoryBrand Landing Page
 *
 * StoryBrand framework: Hero (breeder grower) → Problem (hatchability + egg quality)
 * → Guide (Allen/Southland) → JTBD (3 jobs with real products) → Shop Grid
 * → Proof → Plan → Objections → CTA
 *
 * Products fetched dynamically from Shopify Storefront API.
 * Breeder-specific framing: hatchability, egg quality, biosecurity, longer production cycles.
 */
import { createClient, getProductByHandle, getCollectionProducts } from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../../components/CloudinaryHero.astro'
import AccordionFaq from '../../../components/shop/AccordionFaq.astro'
import CollectionProductCard from '../../../components/shop/CollectionProductCard.astro'
import { buildSouthlandUrl } from '../../../lib/cloudinary'

// ── Allen Reynolds photo ────────────────────────────────────────────────────
const allenPhoto = buildSouthlandUrl('team/ALLEN_Reynolds', {
  width: 600,
  height: 750,
  crop: 'fill',
  gravity: 'face',
  quality: 'auto',
  format: 'auto',
})

const title = 'Poultry Breeder Supplements | Southland Organics'
const description =
  'Natural probiotics, vitamins, litter treatments, and biosecurity solutions for commercial poultry breeders. Improve hatchability, egg quality, and flock health. USDA Organic, zero withdrawal.'

// ── Fetch products ──────────────────────────────────────────────────────────
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

// Fetch JTBD-featured products individually (need full detail)
const jtbdHandles = [
  'poultry-probiotic',                      // Big Ole Bird
  'hen-helper',
  'apple-cider-vinegar-for-chickens',       // Mother Load ACV
  'catalyst-poultry-vitamin',
  'poultry-litter-amendment',               // Litter Life
  'natural-mite-control-livestock-poultry', // Desecticide
  'zeropoint-industrial',                   // ZeroPoint
] as const

const jtbdProducts = await Promise.all(
  jtbdHandles.map((h) => getProductByHandle(client, h))
)
const productMap = new Map(
  jtbdProducts.filter(Boolean).map((p) => [p!.handle, p!])
)

// Fetch ALL products in the breeder collection for the shop grid
const breederCollection = await getCollectionProducts(client, 'poultry-breeders')

// Filter out non-poultry products that ops mis-assigned to this collection
const EXCLUDED_HANDLES = new Set([
  'apple-cider-vinegar-for-pigs',
  'torched-all-natural-weed-killer',
])
const allBreederProducts: Product[] = (breederCollection?.products ?? []).filter(
  (p) => !EXCLUDED_HANDLES.has(p.handle)
)

/** Helper: get product or null */
function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

/** Helper: format price from Shopify Money */
function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// ── JTBD data ───────────────────────────────────────────────────────────────
const jobs = [
  {
    title: 'Maximize hatchability and egg quality through the lay cycle.',
    struggle:
      'Every percentage point of hatchability is revenue. When breeder hens have poor gut health, nutrient absorption drops — and so do fertility rates, shell strength, and embryo viability. The numbers show up at the hatchery.',
    bestFor: 'Declining hatch rates, thin shells, or inconsistent fertility',
    products: [getProduct('poultry-probiotic'), getProduct('apple-cider-vinegar-for-chickens'), getProduct('hen-helper')].filter(Boolean),
    proof: '6.2% mortality reduction in poultry',
    proofSource: 'UGA Study, C. Stephen Roney DVM',
    recommended: true,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  },
  {
    title: 'Keep breeder houses clean for 40+ weeks of production.',
    struggle:
      'Breeder flocks stay in the house for months. Litter degrades, ammonia builds, and mite pressure climbs — all while you need pristine conditions for egg quality and bird health. One biosecurity lapse can cost the entire flock.',
    bestFor: 'Ammonia issues, mite pressure, litter degradation, or biosecurity concerns',
    products: [getProduct('poultry-litter-amendment'), getProduct('natural-mite-control-livestock-poultry'), getProduct('zeropoint-industrial')].filter(Boolean),
    proof: 'Ammonia reduction within 48 hours',
    proofSource: 'Grower field reports',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: 'Support hens through peak production and stress periods.',
    struggle:
      'Peak lay puts enormous physiological demand on breeder hens. Heat stress, lighting changes, and vaccination schedules can all tank production just when you need every egg. Recovery time costs hatchery throughput.',
    bestFor: 'Peak production dips, heat stress, post-vaccination recovery',
    products: [getProduct('catalyst-poultry-vitamin'), getProduct('poultry-probiotic')].filter(Boolean),
    proof: '7-point FCR improvement, +0.4 lb in 38 days',
    proofSource: 'UGA Study, 2018',
    recommended: false,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
]

// ── Objections (FAQ) ────────────────────────────────────────────────────────
const objections = [
  {
    question: 'Will these products affect egg quality or hatchability negatively?',
    answer:
      "No. Everything we sell is USDA Organic certified with zero withdrawal period and zero residue. These products are designed to improve egg quality, not compromise it. Breeder operations under major integrators use Big Ole Bird and Litter Life every flock. We're happy to provide documentation for your hatchery or integrator.",
  },
  {
    question: 'How do probiotics help breeder hens specifically?',
    answer:
      "Breeder hens have higher nutritional demands than broilers — they're not just growing, they're building embryos. Probiotics optimize gut health so hens absorb more from their feed. Better absorption means stronger shells, higher fertility rates, and more consistent production through the lay cycle. The biology is the same, but the stakes are higher.",
  },
  {
    question: 'Our biosecurity protocols are strict. Are these products compatible?',
    answer:
      'Yes. ZeroPoint Industrial is specifically designed for commercial poultry biosecurity — it eliminates pathogens without leaving residues that could affect breeding stock or egg quality. Desecticide handles mite and beetle pressure naturally. Both are used in breeder operations with strict integrator requirements.',
  },
  {
    question: 'Breeder flocks are expensive. How do I justify the cost?',
    answer:
      "Breeder birds represent a significant per-bird investment, which is exactly why the math works in your favor. A few pennies per bird in probiotic support can mean percentage points of hatchability improvement — and that translates directly to hatchery throughput and revenue. Test on one house, one cycle. The settlement numbers will tell you whether it's worth continuing.",
  },
  {
    question: "We're already running a vitamin program. Why add this?",
    answer:
      "Most breeder operations run some form of vitamin supplementation. The difference is targeted probiotics — they don't replace your vitamin program, they make it work better. When gut health is optimized, hens absorb more of what you're already giving them. Think of it as unlocking the nutrition that's already in your feed budget.",
  },
]

// ── Schema.org ──────────────────────────────────────────────────────────────
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Poultry Breeder Supplements',
  description,
  url: `${siteUrl}/poultry/breeders/`,
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: objections.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}
---

<BaseLayout title={title} description={description} schema={[pageSchema, faqSchema]}>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: HERO — "Every egg is a bet on your operation"             -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <CloudinaryHero
    publicId="Southland Website/poultry/Caged_housing_gyiynj_vawvom"
    alt="Commercial poultry breeder house — healthy breeding flock"
    height={600}
    minHeight="500px"
    overlay="gradient"
    overlayOpacity={88}
    contentAlign="center"
    contentJustify="start"
    priority={true}
    effect="blur"
  >
    <div class="mx-auto w-full max-w-6xl pb-12 pt-12 md:pt-20">
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span class="inline-block rounded-full bg-white/15 px-4 py-1 text-sm font-medium text-green-300">
            For Poultry Breeders
          </span>
          <span class="inline-block rounded-full bg-green-400/20 px-3 py-1 text-sm font-semibold text-green-300">
            USDA Organic &bull; Zero Withdrawal
          </span>
        </div>
        <h1 class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl lg:text-6xl">
          Every egg is a bet on your operation. Make it count.
        </h1>
        <p class="mb-5 text-lg text-white/70 md:text-xl">
          Hatchability, fertility, shell strength — when breeder hens are healthy from the gut up, every metric improves.
        </p>
        <!-- Three levers — scannable -->
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-2">
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Hatchability
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Egg Quality
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Biosecurity
          </span>
        </div>
        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="tel:800-608-3755"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3.5 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Talk to Allen
          </a>
          <a
            href="#breeder-products"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            Shop Breeder Products
          </a>
          <a
            href="#proof"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/5"
          >
            See the Proof
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
        <p class="mt-2 text-sm text-white/50">Allen works with breeder operations — call and talk specifics</p>
        <!-- Trust bar -->
        <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/80">
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            USDA Organic
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Zero Withdrawal
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-3.5 w-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
            </svg>
            Hatchery-Safe
          </span>
        </div>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: PROBLEM — "Breeder operations can't afford guesswork"     -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
        Breeder operations can't afford guesswork.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        Your birds aren't just growing — they're building the next generation. Every gap in nutrition, every biosecurity lapse, every week of poor litter shows up at the hatchery.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#2C5234]/10">
            <svg class="h-6 w-6 text-[#2C5234]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">The hatchability pressure</h3>
          <p class="leading-relaxed text-gray-600">
            Every point of hatchability is revenue. When fertility dips or shell quality drops, the hatchery feels it immediately — and so does your settlement. The margin between a profitable cycle and a break-even one is measured in percentages.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#44883E]/10">
            <svg class="h-6 w-6 text-[#44883E]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">The long-cycle anxiety</h3>
          <p class="leading-relaxed text-gray-600">
            Breeder flocks produce for 40+ weeks. A problem at week 20 compounds for the next 20. You're watching production curves and wondering if the decline is normal aging or something you could be fixing right now.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-[#2C5234]/10">
            <svg class="h-6 w-6 text-[#2C5234]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">What's at stake</h3>
          <p class="leading-relaxed text-gray-600">
            Breeder birds are the most valuable birds in the chain. They deserve tools that match that value — not generic supplements designed for a 6-week broiler cycle.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 3: GUIDE — "We understand breeder operations"                -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
        <div class="order-2 md:order-1">
          <span class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-green-700">
            Your guide
          </span>
          <h2 class="mb-6 font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
            Breeder-specific programs, not generic advice.
          </h2>
          <p class="mb-4 text-lg leading-relaxed text-gray-700">
            Allen Reynolds works with breeder operations that can't afford to experiment blindly. He understands that your birds are the most valuable in the chain and your biosecurity requirements are non-negotiable.
          </p>
          <p class="mb-4 text-lg leading-relaxed text-gray-600">
            The products are the same ones commercial broiler and turkey growers use — proven biology. The difference is the protocol. Breeder flocks have different critical windows, different nutritional demands during lay cycle, and stricter requirements for anything that touches the house.
          </p>
          <p class="mb-8 leading-relaxed text-gray-600">
            Allen will help you build a program around your production schedule, your integrator's requirements, and the specific challenges in your houses.
          </p>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              10+ years on farms
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Breeder + broiler + turkey experience
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              ABF specialist since 2017
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
              </svg>
              Actually answers the phone
            </span>
          </div>

          <!-- Quick contact -->
          <div class="flex flex-wrap items-center gap-4">
            <a
              href="tel:800-608-3755"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[#44883E]/85"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Allen
            </a>
            <a
              href="mailto:allen@southlandorganics.com"
              class="text-sm font-medium text-green-700 underline decoration-green-300 underline-offset-2 hover:text-green-600"
            >
              allen@southlandorganics.com
            </a>
          </div>
        </div>

        <!-- Allen's photo -->
        <div class="order-1 md:order-2">
          <div class="relative mx-auto w-64 md:w-72 lg:w-80">
            <img
              src={allenPhoto}
              alt="Allen Reynolds, VP & Director of Operations at Southland Organics"
              width="600"
              height="750"
              class="rounded-2xl object-cover shadow-lg"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 right-0 rounded-b-2xl bg-gradient-to-t from-black/70 to-transparent px-5 pb-4 pt-10">
              <p class="text-lg font-bold text-white">Allen Reynolds</p>
              <p class="text-sm text-green-300">VP & Director of Operations</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 4: JTBD GRID — "Three jobs in every breeder house"           -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="mb-4 text-center font-heading text-4xl uppercase md:text-5xl" style="color: var(--color-title);">
        Three jobs in every breeder house.
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-gray-600">
        Every product here exists to do one of three jobs for your breeding flock. Pick the job you need help with — we'll show you the right tools.
      </p>
      <p class="mb-12 text-center">
        <a href="#breeder-products" class="inline-flex items-center gap-1 text-sm font-medium text-green-700 hover:text-green-600 hover:underline">
          Skip to all breeder products
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        {jobs.map((job) => (
          <div class:list={[
            'relative flex flex-col rounded-xl border bg-white p-8 shadow-sm',
            job.recommended ? 'border-green-300 ring-1 ring-green-200' : 'border-gray-200',
          ]}>
