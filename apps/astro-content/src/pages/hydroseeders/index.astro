---
/**
 * /hydroseeders/ — Hydroseeding Professionals Landing Page
 *
 * StoryBrand framework: Hero -> Problem -> Guide -> JTBD -> Shop Grid -> Proof -> Plan -> Objections -> CTA
 *
 * Persona: lawn (Turf Pro Taylor). Guide = Southland Organics (company).
 * Primary CTA: Shop / Build Your Program. Phone secondary.
 * Canonical destination for /collections/hydroseeders (301 redirect).
 */
import {
  createClient,
  getProductByHandle,
  getCollectionProducts,
} from '@southland/shopify-storefront'
import type { Product } from '@southland/shopify-storefront'
import BaseLayout from '../../layouts/BaseLayout.astro'
import CloudinaryHero from '../../components/CloudinaryHero.astro'
import AccordionFaq from '../../components/shop/AccordionFaq.astro'
import CollectionProductCard from '../../components/shop/CollectionProductCard.astro'
import Breadcrumbs from '../../components/shared/Breadcrumbs.astro'
import { buildSouthlandUrl } from '../../lib/cloudinary'

const bradPhoto = buildSouthlandUrl('team/BRAD_Broxton', { width: 600 })
const germinationChart = buildSouthlandUrl('hydroseeders/germination', { width: 800 })
const hydroProductsChart = buildSouthlandUrl('hydroseeders/hydroseeding_products', { width: 800 })

const title = 'Hydroseeding Soil Amendments | Southland Organics'
const description =
  'Humic acid, biochar, and organic fertilizers for hydroseeding. 155% faster germination (third-party tested). Fewer callbacks.'

// -- Fetch products --------------------------------------------------------
const client = createClient({
  storeDomain: import.meta.env.PUBLIC_SHOPIFY_STORE_DOMAIN,
  publicAccessToken: import.meta.env.PUBLIC_SHOPIFY_STOREFRONT_TOKEN,
})

const handles = [
  'genesis',
  'omega-soil-activator',
  'c-fix-biochar-soil-amendment',
  'chicken-manure-fertilizer',
  'turf-revival',
  'torched-all-natural-weed-killer',
] as const

const products = await Promise.all(handles.map((h) => getProductByHandle(client, h)))
const productMap = new Map(products.filter(Boolean).map((p) => [p!.handle, p!]))

// Fetch full collection for shop grid
const hydroCollection = await getCollectionProducts(client, 'hydroseeders')
const allHydroProducts: Product[] = hydroCollection?.products ?? []

function getProduct(handle: string) {
  return productMap.get(handle) ?? null
}

function formatPrice(amount: string) {
  const num = parseFloat(amount)
  return num % 1 === 0 ? `$${num}` : `$${num.toFixed(2)}`
}

// -- JTBD data -------------------------------------------------------------
const jobs = [
  {
    title: 'Get ugly sites to green up fast.',
    struggle:
      "Stripped, compacted soil has no carbon or biology. Seeds sit on dead ground. You spray, you wait, you hope. Half the time you're back in 3 weeks re-spraying at your own cost.",
    products: [getProduct('genesis'), getProduct('omega-soil-activator')].filter(Boolean),
    proof: '155% greater germination rate vs. control',
    proofSource: 'TRI Environmental third-party study',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
  },
  {
    title: 'Hold seed through the first big rain.',
    struggle:
      "You need roots in the ground before the next rain event. Mulch alone doesn't cut it on steep grades. When the job washes out, you eat the cost and the client calls someone else.",
    products: [getProduct('c-fix-biochar-soil-amendment'), getProduct('genesis')].filter(Boolean),
    proof: 'Permanent carbon foundation improves water retention',
    proofSource: 'Biochar soil science',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: 'Stop eating callbacks on thin stands.',
    struggle:
      'Thin, patchy results after 30 days mean callbacks, re-seeding, and lost margin. Synthetic fertilizer burns tender seedlings. You need sustained nutrition without the risk.',
    products: [getProduct('chicken-manure-fertilizer'), getProduct('turf-revival')].filter(Boolean),
    proof: 'Slow-release nitrogen without burn risk',
    proofSource: 'Organic matter + beneficial microbes',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
]

// -- Objections (FAQ) ------------------------------------------------------
const objections = [
  {
    question: 'I already have a slurry recipe that works. Why change?',
    answer:
      "You're not changing your recipe — you're adding to it. Genesis and Omega go into your existing tank with your existing mulch and fertilizer. Same equipment, same process. The difference is what happens in the soil after you spray. If your current recipe delivers consistent day-6 breakthrough and zero callbacks, don't change a thing. If not, test it on one job.",
  },
  {
    question: 'How does this mix with my existing mulch and fertilizer?',
    answer:
      'Add it before water so it coats seeds and mulch in the agitator. 1 gallon of Omega per 500 gallons of slurry. Genesis at 10-12 oz per 1,000 sq ft. Compatible with all standard hydroseeding mulches and fertilizer programs. No pH issues, no clumping, no equipment modifications.',
  },
  {
    question: '155% germination improvement sounds too good. Is that real?',
    answer:
      "That's from a third-party study by TRI Environmental — not our marketing department. They tested Genesis-treated seeds against untreated control. The mechanism is straightforward: humic acid chelates nutrients, adds carbon, and feeds beneficial microbes that accelerate root development. It's soil biology, not magic.",
  },
  {
    question: "I can't afford to experiment on a paying job.",
    answer:
      "You can't afford to keep re-spraying failed jobs either. Start with a $19 jug of Genesis on your next small project. At 10-12 oz per 1,000 sq ft, one jug covers a meaningful test area. If it doesn't outperform your current results, you're out $19. If it does, you've found your competitive edge.",
  },
  {
    question: 'Can I get this from my normal supplier?',
    answer:
      "Order direct at southlandorganics.com — ships same day, arrives in 2-5 business days. No minimum order. If you want to stock it through your distributor, call us at 800-608-3755 and we'll set that up.",
  },
]

// -- Schema.org ------------------------------------------------------------
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Hydroseeding Soil Amendments',
  description,
  url: `${siteUrl}/hydroseeders/`,
  provider: {
    '@type': 'Organization',
    name: 'Southland Organics',
  },
}

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: objections.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}
---

<BaseLayout title={title} description={description} schema={[pageSchema, faqSchema]}>
  <!-- ======================================================================= -->
  <!-- SECTION 1: HERO                                                         -->
  <!-- ======================================================================= -->
  <CloudinaryHero
    publicId="Southland Website/hydroseeders/header"
    alt="Freshly hydroseeded slope with green mulch establishing"
    height={700}
    minHeight="600px"
    overlay="gradient"
    overlayOpacity={82}
    gravity="south"
    contentAlign="center"
    contentJustify="start"
    priority={true}
  >
    <div class="mx-auto w-full max-w-6xl pb-16 pt-12 md:pb-24 md:pt-20">
      <Breadcrumbs
        items={[{ label: 'Home', href: '/' }, { label: 'Hydroseeders' }]}
        class="mb-4 [&_*]:text-sm [&_a]:text-white/80 [&_span]:text-white/60"
      />
      <div class="max-w-3xl">
        <div class="mb-3 flex flex-wrap items-center gap-2">
          <span
            class="inline-block rounded-full bg-white/15 px-4 py-1 text-sm font-medium text-green-300"
          >
            For Professional Hydroseeders
          </span>
          <span
            class="inline-block rounded-full bg-green-400/20 px-3 py-1 text-sm font-semibold text-green-300"
          >
            Third-Party Tested · Ships Same Day
          </span>
        </div>
        <h1
          class="mb-4 font-heading text-4xl uppercase leading-tight text-white md:text-5xl lg:text-6xl"
        >
          Your slurry is only as good as the soil beneath it.
        </h1>
        <p class="mb-5 text-lg text-white/70 md:text-xl">
          Dead soil starves seeds. Our hydroseeding soil amendments add the carbon, microbes, and
          organic acids that turn your mix into a biological engine — faster germination, stronger
          roots, fewer callbacks.
        </p>
        <!-- Three levers -->
        <div class="mb-6 flex flex-wrap gap-x-6 gap-y-2">
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Faster Germination
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Erosion Control
          </span>
          <span class="flex items-center gap-2 text-lg font-semibold text-white">
            <span class="inline-block h-2 w-2 rounded-full bg-green-400"></span>
            Fewer Callbacks
          </span>
        </div>
        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <a
            href="#hydroseed-products"
            class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-6 py-3.5 font-semibold text-white transition-colors hover:bg-[#44883E]/85"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            Shop Hydroseeding Products
          </a>
          <a
            href="/blog/hydroseeding-products-for-faster-seed-germination-and-erosion-control/"
            class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-6 py-3.5 font-semibold text-white transition-colors hover:bg-white/20"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            See the Germination Study
          </a>
        </div>
        <p class="mt-2 text-sm text-white/50">No minimum order — test it on your next job</p>
        <!-- Trust bar -->
        <div
          class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 border-t border-white/10 pt-4 text-sm text-white/80"
        >
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path>
            </svg>
            155% Germination Improvement
          </span>
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path>
            </svg>
            Third-Party Tested
          </span>
          <span class="flex items-center gap-1.5">
            <svg
              class="h-3.5 w-3.5 text-green-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4"></path>
            </svg>
            Family-Owned Since 2009
          </span>
        </div>
      </div>
    </div>
  </CloudinaryHero>

  <!-- ======================================================================= -->
  <!-- SECTION 2: PROBLEM                                                      -->
  <!-- ======================================================================= -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="mb-4 text-center font-heading text-3xl uppercase md:text-4xl"
        style="color: var(--color-title);"
      >
        Your reputation rides on every job.
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-gray-600">
        Hydroseeding is competitive. The contractors who win repeat business aren't just cheaper —
        they deliver faster green-up and fewer callbacks. Three problems define the gap.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <!-- External Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div
            class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            <svg
              class="h-5 w-5 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">
            Dead soil kills germination
          </h3>
          <p class="leading-relaxed text-gray-600">
            Stripped, compacted ground has no carbon and no biology. You're spraying seeds onto a
            surface that can't support life. No amount of mulch fixes what's missing underneath.
          </p>
        </div>
        <!-- Internal Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div
            class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#44883E]"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            <svg
              class="h-5 w-5 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">
            Callbacks eat your margin
          </h3>
          <p class="leading-relaxed text-gray-600">
            Every re-spray costs labor, materials, and the job you could have been running instead.
            Failed establishment doesn't just cost money — it costs your reputation and your next
            bid.
          </p>
        </div>
        <!-- Philosophical Problem -->
        <div class="rounded-xl border border-gray-200 bg-gray-50 p-8">
          <div
            class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
          >
            <svg
              class="h-5 w-5 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"
              ></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold" style="color: var(--color-title);">
            Synthetic fertilizer burns seedlings
          </h3>
          <p class="leading-relaxed text-gray-600">
            Hot fertilizer in your slurry risks burning tender seedlings during the most critical
            establishment window. You need sustained nutrition without the risk — especially on
            high-visibility jobs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================= -->
  <!-- SECTION 3: GUIDE — Southland Organics (company)                         -->
  <!-- ======================================================================= -->
  <section class="bg-gray-50 py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <span
            class="mb-2 inline-block text-sm font-semibold uppercase tracking-wider text-[#44883E]"
          >
            Your guide
          </span>
          <h2
            class="mb-6 font-heading text-3xl uppercase md:text-4xl"
            style="color: var(--color-title);"
          >
            Soil biology products built with contractors, not just for them.
          </h2>
          <p class="mb-4 text-lg leading-relaxed text-gray-700">
            Since 2009, Southland Organics has developed soil biology products used by professional
            contractors, golf course superintendents, and erosion control specialists. Our
            hydroseeding line was built with input from contractors like Sandy Creek Hydroseeding,
            who tested our products on real municipal projects.
          </p>
          <p class="mb-4 leading-relaxed text-gray-600">
            Genesis and Omega aren't lab experiments. They're field-proven formulations that go into
            your existing tank, mix with your existing mulch, and deliver measurable results —
            backed by a third-party germination study from TRI Environmental.
          </p>

          <!-- Proof callout -->
          <div class="mb-6 rounded-lg border border-green-200 bg-green-50 px-5 py-3">
            <p class="text-sm font-semibold text-[#2C5234]">
              "On my first hydroseed job with the product I started noticing breakthrough at day
              six. It certainly produces better results in the first few critical weeks after
              spraying."
              <span class="mt-1 block font-normal text-gray-600">— Bill, South Carolina</span>
            </p>
          </div>

          <!-- Credential chips -->
          <div class="mb-8 flex flex-wrap gap-2">
            {
              [
                'Third-party tested (TRI Environmental)',
                'Contractor-proven',
                'Family-owned since 2009',
                'A+ BBB Rating',
                'Ships same day',
              ].map((cred) => (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-[#44883E]/10 px-3 py-1 text-sm font-medium text-[#2C5234]">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4"
                    />
                  </svg>
                  {cred}
                </span>
              ))
            }
          </div>

          <div class="flex flex-wrap items-center gap-4">
            <a
              href="#hydroseed-products"
              class="inline-flex items-center gap-2 rounded-lg bg-[#44883E] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[#44883E]/85"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
              Shop Products
            </a>
            <a
              href="tel:800-608-3755"
              class="text-sm font-medium text-[#44883E] underline decoration-[#44883E]/40 underline-offset-2 hover:text-[#2C5234]"
            >
              Questions? Call 800-608-3755
            </a>
          </div>
        </div>

        <!-- Visual — Brad photo + how it works -->
        <div class="space-y-6">
          <a href="/team/brad-broxton/" class="group block overflow-hidden rounded-2xl shadow-sm">
            <img
              src={bradPhoto}
              alt="Brad Broxton — Southland Organics"
              width="600"
              height="750"
              class="w-full rounded-2xl object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
            <div class="mt-2 text-center text-sm font-medium text-[#44883E] group-hover:underline">
              Meet Brad Broxton →
            </div>
          </a>
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
            <h3 class="mb-4 text-lg font-bold" style="color: var(--color-title);">
              How it works in your tank
            </h3>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#2C5234]/10 text-sm font-bold text-[#2C5234]"
                >
                  1
                </div>
                <p class="text-sm text-gray-600">
                  <span class="font-semibold text-gray-900">Add before water</span> — coats seeds and
                  mulch in the agitator.
                </p>
              </div>
              <div class="flex items-start gap-3">
                <div
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#2C5234]/10 text-sm font-bold text-[#2C5234]"
                >
                  2
                </div>
                <p class="text-sm text-gray-600">
                  <span class="font-semibold text-gray-900">Simple ratio</span> — 1 gal Omega per 500
                  gal slurry. Genesis at 10-12 oz / 1,000 sq ft.
                </p>
              </div>
              <div class="flex items-start gap-3">
                <div
                  class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#2C5234]/10 text-sm font-bold text-[#2C5234]"
                >
                  3
                </div>
                <p class="text-sm text-gray-600">
                  <span class="font-semibold text-gray-900">Same equipment</span> — compatible with all
                  standard mulches and fertilizers.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================= -->
  <!-- SECTION 4: JTBD GRID                                                    -->
  <!-- ======================================================================= -->
  <section id="jobs" class="bg-[#F8FAF8] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-4">
      <h2
        class="mb-4 text-center font-heading text-4xl uppercase md:text-5xl"
        style="color: var(--color-title);"
      >
        Three jobs. Real solutions.
      </h2>
      <p class="mx-auto mb-4 max-w-2xl text-center text-gray-600">
        Soil biology products that go into your existing slurry and deliver measurable results on
        your next job.
      </p>
      <p class="mb-12 text-center">
        <a
          href="#hydroseed-products"
          class="inline-flex items-center gap-1 text-sm font-medium text-[#44883E] hover:text-[#2C5234] hover:underline"
        >
          Skip to all hydroseeding products
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        {
          jobs.map((job) => (
            <div class="flex flex-col rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
              <div
                class="mb-4 flex h-12 w-12 flex-shrink-0 items-center justify-center bg-[#2C5234]"
                style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
              >
                <svg
                  class="h-5 w-5 text-white"
                  fill="none"
                  stroke="currentColor"
