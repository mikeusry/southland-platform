---
/**
 * Topic Browser Page - /podcast/topics/
 * Browse Ag & Culture Podcast episodes by topic, organized by segment.
 */

import PodcastLayout from '../../../layouts/PodcastLayout.astro'
import { getCollection } from 'astro:content'
import { buildCloudinaryUrl } from '../../../lib/cloudinary'

// Get all topics
const allTopics = await getCollection('topics')

// Get all episodes to count topic usage
const allEpisodes = await getCollection('episodes', ({ data }) => {
  return data.draft !== true
})

// Build topic episode counts
const topicCounts: Record<string, number> = {}
allEpisodes.forEach((episode) => {
  episode.data.topics?.forEach((topic) => {
    topicCounts[topic] = (topicCounts[topic] || 0) + 1
  })
})

// Sort topics by episode count
const sortedTopics = [...allTopics].sort((a, b) => {
  const aCount = topicCounts[a.id] || 0
  const bCount = topicCounts[b.id] || 0
  return bCount - aCount
})

// Group by segment
const segmentGroups: Record<string, typeof sortedTopics> = {
  poultry: [],
  turf: [],
  agriculture: [],
  general: [],
}

sortedTopics.forEach((topic) => {
  const segment = topic.data.segment || 'general'
  segmentGroups[segment].push(topic)
})

const totalTopics = sortedTopics.length
const totalEpisodes = allEpisodes.length

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://southlandorganics.com'
const canonicalUrl = `${siteUrl}/podcast/topics/`
const ogImage = buildCloudinaryUrl('Southland Website/heroes/Farm_Athens_GA_4_qaishv', {
  width: 1200, height: 630, crop: 'fill',
})

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Ag & Culture Podcast Topics',
  description: `Browse ${totalTopics} topics across ${totalEpisodes} episodes of the Ag & Culture Podcast.`,
  url: canonicalUrl,
}

// Segment config: icon SVG paths + colors (replaces emoji)
const segments = [
  {
    key: 'poultry',
    label: 'Poultry',
    color: '#2C5234',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    key: 'turf',
    label: 'Turf & Lawn Care',
    color: '#44883E',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  },
  {
    key: 'agriculture',
    label: 'Agriculture',
    color: '#2C5234',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
  {
    key: 'general',
    label: 'General Topics',
    color: '#44883E',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
  },
]
---

<PodcastLayout
  title="Topics"
  description="Browse Ag & Culture Podcast episodes by topic — poultry gut health, organic turf management, soil biology, sustainable farming, and more."
  breadcrumbs={[{ label: 'Topics', href: '/podcast/topics/' }]}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  schema={schema}
>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-20 lg:px-8">
    <!-- Header -->
    <header class="mb-12 text-center">
      <h1 class="mb-4 font-heading text-3xl uppercase md:text-4xl" style="color: var(--color-title);">
        Browse by Topic
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-gray-600">
        {totalTopics} topics across {totalEpisodes} episodes — from poultry gut health
        and mortality reduction to soil biology and organic turf management.
      </p>
    </header>

    <!-- Topic Segments -->
    {sortedTopics.length > 0 ? (
      <div class="space-y-16">
        {segments.map((seg) => {
          const topics = segmentGroups[seg.key] || []
          if (topics.length === 0) return null
          return (
            <section>
              <div class="mb-6 flex items-center gap-3">
                <div
                  class="flex h-10 w-10 flex-shrink-0 items-center justify-center"
                  style={`background: ${seg.color}; clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);`}
                >
                  <svg class="h-4 w-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <Fragment set:html={seg.icon} />
                  </svg>
                </div>
                <h2 class="font-heading text-xl uppercase" style="color: var(--color-title);">
                  {seg.label}
                </h2>
                <span class="rounded-full bg-[#2C5234]/8 px-2.5 py-0.5 text-xs font-medium text-[#2C5234]">
                  {topics.length} topic{topics.length !== 1 ? 's' : ''}
                </span>
              </div>
              <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {topics.map((topic) => (
                  <a
                    href={`/podcast/topics/${topic.id}/`}
                    class="group block rounded-xl border border-gray-200 bg-white p-6 transition-all hover:border-[#44883E]/30 hover:shadow-md"
                  >
                    <div class="flex items-start justify-between">
                      <div>
                        <h3 class="mb-1 font-semibold text-gray-900 group-hover:text-[#2C5234]">
                          {topic.data.name}
                        </h3>
                        <p class="line-clamp-2 text-sm text-gray-600">{topic.data.description}</p>
                      </div>
                    </div>
                    <div class="mt-4 flex items-center justify-between">
                      <span class="text-sm font-medium" style="color: #44883E;">
                        {topicCounts[topic.id] || 0} episode{(topicCounts[topic.id] || 0) !== 1 ? 's' : ''}
                      </span>
                      <span class="text-xs font-semibold text-[#44883E] opacity-0 transition-opacity group-hover:opacity-100">
                        Browse &rarr;
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        })}
      </div>
    ) : (
      <div class="py-12 text-center">
        <p class="text-gray-500">Topic directory coming soon.</p>
      </div>
    )}
  </div>

  <!-- CTA -->
  <section class="bg-[#2C5234] py-16 md:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2 class="mb-4 font-heading text-3xl uppercase text-white md:text-4xl">
        Listen to the Ag & Culture Podcast
      </h2>
      <p class="mx-auto mb-8 max-w-xl text-lg text-green-100">
        Real conversations with farmers, growers, and soil scientists about
        what actually works — no sales pitch, just field-tested knowledge.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/podcast/"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3.5 font-semibold transition-colors hover:bg-green-50"
          style="color: #2C5234;"
        >
          All Episodes
        </a>
        <a
          href="/podcast/guests/"
          class="inline-flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3.5 font-semibold text-white transition-colors hover:border-white/60 hover:bg-white/5"
        >
          Browse Guests
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-green-200/80">
        <a href="/blog/" class="underline decoration-green-300/40 underline-offset-2 hover:text-white">Read the Blog</a>
        <span class="hidden md:inline">·</span>
        <a href="/products/big-ole-bird" class="underline decoration-green-300/40 underline-offset-2 hover:text-white">Shop Products</a>
        <span class="hidden md:inline">·</span>
        <a href="/about/" class="underline decoration-green-300/40 underline-offset-2 hover:text-white">About Southland</a>
      </div>
    </div>
  </section>
</PodcastLayout>
